// valid_for_each_array_continue — continue inside for-each over an array handle.
//
// continue skips the rest of the body and advances to the next element, exactly
// as in the slice for-each. Over [10,20,30,40,50]: 10 + 30 + 50 = 90 (skips 20
// and 40).
//
// expect: 90
fn main() -> i64 {
    let a: i64 = array_new(8, 5);
    array_set_i64(a, 0, 10);
    array_set_i64(a, 1, 20);
    array_set_i64(a, 2, 30);
    array_set_i64(a, 3, 40);
    array_set_i64(a, 4, 50);
    let mut sum: i64 = 0;
    for (x in a) {
        if (x == 20) { continue; }
        if (x == 40) { continue; }
        sum = sum + x;
    }
    return sum;
}
