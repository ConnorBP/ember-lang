// valid_for_each_array_u8 — for-each over a u8 array handle.
//
// iterable() hook, array case with elem_size=1 -> the loop variable x is u8
// (the element type inferred from array_new(1, n)). codegen dispatches to
// array_get_u8 for each element. x is u8, so it is cast to i64 to accumulate
// into an i64 sum (mixed-width arithmetic is not implicit).
//
// expect: 60 (10+20+30)
fn main() -> i64 {
    let a: i64 = array_new(1, 3);
    array_set_u8(a, 0, 10);
    array_set_u8(a, 1, 20);
    array_set_u8(a, 2, 30);
    let mut sum: i64 = 0;
    for (x in a) {
        sum = sum + (x as i64);
    }
    return sum;
}
