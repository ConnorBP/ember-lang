// valid for parser: deeply nested blocks (8 levels) with shadowing at each
// level - the recursive-descent parser must track its block-recursion depth
// without stack overflow, and each nested block must close its own braces.
fn main() -> i64 {
    let x: i64 = 1;
    {
        let x: i64 = 2;
        {
            let x: i64 = 3;
            {
                let x: i64 = 4;
                {
                    let x: i64 = 5;
                    {
                        let x: i64 = 6;
                        {
                            let x: i64 = 7;
                            {
                                let x: i64 = 8;
                                assert_eq_i64(x, 8);
                            }
                            assert_eq_i64(x, 7);
                        }
                        assert_eq_i64(x, 6);
                    }
                    assert_eq_i64(x, 5);
                }
                assert_eq_i64(x, 4);
            }
            assert_eq_i64(x, 3);
        }
        assert_eq_i64(x, 2);
    }
    assert_eq_i64(x, 1);
    return 0;
}
