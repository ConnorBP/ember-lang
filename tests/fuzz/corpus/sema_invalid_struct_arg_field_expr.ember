struct Point { x: i64; y: i64; }
struct Pair { a: Point; b: Point; }

fn sum_point(p: Point) -> i64 { return p.x + p.y; }

// Same restriction as sema_invalid_struct_arg_not_ident.ember, but for a
// field-access expression (`pr.a`) rather than a literal - still not a
// bare Ident, still rejected.
fn main() -> i64 {
    let pr: Pair = Pair { a: Point { x: 1, y: 2 }, b: Point { x: 3, y: 4 } };
    let r: i64 = sum_point(pr.a);
    return r;
}
