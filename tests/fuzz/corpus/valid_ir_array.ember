// expect: 80
// Thin-IR regression: fixed-array address generation must target r11, not rbx.
fn main() -> i64 {
    let mut a: i64[4];

    // Constant-index store and read.
    a[0] = 10;

    // Variable-index store and read.
    let mut index: i64 = 1;
    a[index] = 20;

    // Repeated variable-index stores through a loop.
    let mut i: i64 = 2;
    while (i < 4) {
        a[i] = i * 10;
        i = i + 1;
    }

    return a[0] + a[index] + a[2] + a[3];
}
