// valid_array_push_pop_i64 — push/pop lifecycle for i64 elements.
// Three pushes build [100, 200, 300]; pops return LIFO order (300, 100) and
// shrink the length each time. A pop on an empty array returns 0. Each
// intermediate length and value is asserted.
// expect: 1
fn main() -> i64 {
    let a: i64 = array_new(8, 0);
    array_push_i64(a, 100);
    array_push_i64(a, 200);
    array_push_i64(a, 300);
    if (array_length(a) != 3) { return 0; }
    let v1: i64 = array_pop_i64(a);
    if (v1 != 300) { return 0; }
    if (array_length(a) != 2) { return 0; }
    let v2: i64 = array_pop_i64(a);
    if (v2 != 200) { return 0; }
    if (array_length(a) != 1) { return 0; }
    let v3: i64 = array_pop_i64(a);
    if (v3 != 100) { return 0; }
    if (array_length(a) != 0) { return 0; }
    let v4: i64 = array_pop_i64(a);
    if (v4 != 0) { return 0; }
    return 1;
}
