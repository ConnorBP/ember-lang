// sema_invalid_local_slice_scriptfn_return_field_store.ember — C5 reject
// (slice-escape safety Stage 2). A stack-backed slice is passed to a script fn
// that BORROWS its arg into the return (return_it returns s). The call result
// is a propagated localview slice, so when the CALLER stores it into a FIELD
// of a global struct, the existing C2b FieldExpr-target guard fires (the
// root-chase finds the global root). This proves the propagated localview bit
// reaches the C2b guard too.
struct S { data: u8[]; }
global gs : S = S { data: "" };
fn return_it(s: u8[]) -> u8[] { return s; }
fn bad() -> i64 {
    let a: u8[2];
    a[0] = 1; a[1] = 2;
    gs.data = return_it(a[..]);
    return 0;
}
