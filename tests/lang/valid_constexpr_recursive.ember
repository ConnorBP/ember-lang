// constexpr recursive fn (Tier 1): a recursive constexpr fn is const-evaluated
// at sema time when called with a constant arg. The interpreter handles
// bounded recursion (max 256 depth). fib(10) = 55.
//
// sema_valid: must parse OK and sema OK. The ctest asserts fib(10) == 55.
constexpr fn fib(n: i64) -> i64 {
    if (n <= 1) {
        return n;
    }
    return fib(n - 1) + fib(n - 2);
}

fn main() -> i64 {
    return fib(10);
}
