// valid for sema: a switch with a default clause and multiple terminated
// case bodies. Implicit fallthrough is rejected; each nonempty body ends in
// break or return.
fn classify(x: i64) -> i64 {
    let mut r: i64 = 0;
    switch (x) {
    case 1:
        r = 10;
        break;
    case 2:
        r = r + 20;
        break;
    default:
        r = -1;
        break;
    }
    return r;
}

fn entry() -> i64 {
    return classify(1) + classify(2) + classify(99);
}
