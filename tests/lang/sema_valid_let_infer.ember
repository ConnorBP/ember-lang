// valid for sema: `let`/`const` with no ':TYPE' infer from the initializer
// via the same path (Item A - Rust-style optional annotation). `auto x = e;`
// is a deprecated redundant spelling of `let x = e;` (kept working, warns).
fn entry() -> i64 {
    let x = 5;
    let s = "hi";
    const c = 10;
    let a = 20;
    let f = 1.5f;
    let b = true;
    return x + c + a + (f > 1.0f ? 1 : 0) + (b ? 1 : 0);
}
