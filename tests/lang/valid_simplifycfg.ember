// valid_simplifycfg.ember — constant if/else CFG simplification.
// Run with: ember_cli run ../tests/lang/valid_simplifycfg.ember
//                         --passes simplifycfg
// expect: 42

fn main() -> i64 {
    let mut result: i64 = 0;

    if (true) {
        result = 40;
    } else {
        result = 99;
    }

    if (false) {
        result = 1;
    } else {
        result = result + 2;
    }

    return result;
}
