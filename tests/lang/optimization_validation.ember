// optimization_validation.ember — comprehensive IR optimization pass validation.
//
// Value-preservation methodology: this script exercises MOST ember language
// features in a single file — structs, enums, for-each, match, while/for/do-while
// loops, if/else, switch, recursion, native calls (string, array, math), slices,
// operator overloads, casts, defer, compound assignment, pre/post inc/dec. It
// produces a DETERMINISTIC i64 return value. Running with
//   --passes constprop,cse,dce,licm
// MUST produce the SAME return value as running with no passes. Any difference
// is a PASS-BROKEN-CORRECTNESS bug in the IR optimization pipeline.
//
// Design: the script is a sequence of feature-gated blocks. Each block computes
// a result, asserts it against the expected value (returning a distinctive
// early-exit code on mismatch), and folds a small contribution into a running
// accumulator. The final return is the accumulator, kept < 256 so the CLI's
// 8-bit exit-code reading is exact (no truncation masking). If a pass breaks
// any block's computation, the early-exit fires OR the accumulator changes,
// making the break observable.
//
// expect: 177
//
// Build/run:
//   ./buildt/ember_cli.exe run tests/lang/optimization_validation.ember
//   ./buildt/ember_cli.exe run tests/lang/optimization_validation.ember --passes constprop,cse,dce,licm
// Both MUST exit 177.

// ── enums (untyped i64 constants, auto-increment + explicit values) ──
enum Tag { A, B, C = 100, D }

// ── structs (value types, packed layout) ──
struct Vec2 { x: i64; y: i64; }
struct Point { tag: i64; pos: Vec2; }

// ── globals (mutable, initialized) ──
global g_counter: i64 = 0;

// ── recursion (factorial) ──
fn fact(n: i64) -> i64 {
    if (n <= 1) { return 1; }
    return n * fact(n - 1);
}

// ── recursion (fibonacci) ──
fn fib(n: i64) -> i64 {
    if (n < 2) { return n; }
    return fib(n - 1) + fib(n - 2);
}

// ── struct by value (parameter + return) ──
fn add_vec(v: Vec2) -> i64 {
    return v.x + v.y;
}

fn make_vec(x: i64, y: i64) -> Vec2 {
    return Vec2 { x: x, y: y };
}

// ── operator overload: string + string (concatenation via string extension) ──
fn build_label(prefix: string, n: i64) -> string {
    return prefix + string_from_i64(n);
}

// ── a function with a dead store (DCE target) + redundant compute (CSE target) ──
fn opt_target(n: i64) -> i64 {
    let dead: i64 = n * 13;       // dead store — DCE should remove
    let a: i64 = n * 7;            // redundant compute (see below)
    let b: i64 = n * 7;            // CSE should coalesce with a
    return a + b;                  // dead is never used
}

// ── a function with a loop-invariant (LICM target) + const-foldable expr ──
fn invariant_loop(n: i64) -> i64 {
    let mut s: i64 = 0;
    let mut i: i64 = 0;
    while (i < n) {
        let k: i64 = 100 * 200;    // loop-invariant — LICM should hoist
        let c: i64 = 3 + 4;        // const-foldable — constprop should fold to 7
        s = s + k + c + i;
        i = i + 1;
    }
    return s;
}

// ── defer (lexical-block-exit LIFO) ──
fn defer_probe() -> i64 {
    let mut acc: i64 = 0;
    {
        defer acc = acc + 1;
        {
            defer acc = acc + 2;
        }
    }
    return acc;  // LIFO: inner 2 fires before outer 1 → acc = 3
}

fn main() -> i64 {
    let mut acc: i64 = 0;

    // ── block 1: enums ──
    if (Tag::A != 0) { return 200; }
    if (Tag::B != 1) { return 201; }
    if (Tag::C != 100) { return 202; }
    if (Tag::D != 101) { return 203; }
    let ev: i64 = Tag::C + Tag::D;  // 201
    if (ev != 201) { return 204; }
    acc = acc + 1;

    // ── block 2: structs — literal, field access, by-value param/return ──
    let v: Vec2 = Vec2 { x: 3, y: 4 };
    if (v.x != 3 || v.y != 4) { return 210; }
    let sum: i64 = add_vec(v);
    if (sum != 7) { return 211; }
    let v2: Vec2 = make_vec(10, 20);
    if (v2.x + v2.y != 30) { return 212; }
    // nested struct (layout exercised; field-of-field read is a known
    // codegen gap — structs are ir_safe=false — so we only test the top-
    // level field here. The nested Vec2 is verified via make_vec above.)
    let p: Point = Point { tag: Tag::B, pos: Vec2 { x: 5, y: 6 } };
    if (p.tag != 1) { return 213; }
    acc = acc + 2;

    // ── block 3: recursion (factorial + fibonacci) ──
    if (fact(5) != 120) { return 220; }
    if (fact(10) != 3628800) { return 221; }
    if (fib(10) != 55) { return 222; }
    if (fib(15) != 610) { return 223; }
    acc = acc + 3;

    // ── block 4: for-each over a slice (fixed array → slice view) ──
    let arr: i64[5] = [10, 20, 30, 40, 50];
    let sl: i64[] = arr[..];
    let mut fe_sum: i64 = 0;
    for (x in sl) {
        fe_sum = fe_sum + x;
    }
    if (fe_sum != 150) { return 230; }
    // for-each with break + continue
    let mut fe_bc: i64 = 0;
    for (x in sl) {
        if (x == 20) { continue; }
        if (x == 40) { break; }
        fe_bc = fe_bc + x;
    }
    // 10 (20 skipped) 30 (40 breaks) → 10 + 30 = 40
    if (fe_bc != 40) { return 231; }
    acc = acc + 4;

    // ── block 5: match (int + bool subject, with wildcard) ──
    let mut m_val: i64 = 0;
    match (2) {
        1 => { m_val = 10; },
        2 => { m_val = 20; },
        3 => { m_val = 30; },
        _ => { m_val = 99; }
    }
    if (m_val != 20) { return 240; }
    match (99) {
        1 => { m_val = 10; },
        _ => { m_val = 77; }
    }
    if (m_val != 77) { return 241; }
    // bool subject match
    let mut mb: i64 = 0;
    match (true) {
        true => { mb = 100; },
        false => { mb = 200; }
    }
    if (mb != 100) { return 242; }
    // match with enum variant
    let mut me: i64 = 0;
    match (Tag::C) {
        Tag::A => { me = 1; },
        Tag::B => { me = 2; },
        Tag::C => { me = 3; },
        _ => { me = 9; }
    }
    if (me != 3) { return 243; }
    acc = acc + 5;

    // ── block 6: switch (with case + default + break) ──
    let mut sw: i64 = 0;
    switch (2) {
    case 1:
        sw = 11;
        break;
    case 2:
        sw = 22;
        break;
    default:
        sw = 33;
        break;
    }
    if (sw != 22) { return 250; }
    switch (999) {
    case 1:
        sw = 11;
        break;
    default:
        sw = 44;
        break;
    }
    if (sw != 44) { return 251; }
    acc = acc + 6;

    // ── block 7: while / for / do-while loops ──
    let mut w_sum: i64 = 0;
    let mut w_i: i64 = 0;
    while (w_i < 10) {
        w_sum = w_sum + w_i;
        w_i = w_i + 1;
    }
    if (w_sum != 45) { return 260; }
    // for loop (C-style)
    let mut f_sum: i64 = 0;
    for (let mut f_i: i64 = 0; f_i < 10; f_i = f_i + 1) {
        f_sum = f_sum + f_i;
    }
    if (f_sum != 45) { return 261; }
    // do-while
    let mut d_sum: i64 = 0;
    let mut d_i: i64 = 0;
    do {
        d_sum = d_sum + d_i;
        d_i = d_i + 1;
    } while (d_i < 10);
    if (d_sum != 45) { return 262; }
    acc = acc + 7;

    // ── block 8: if/else chains ──
    let mut branch: i64 = 0;
    let test: i64 = 5;
    if (test < 0) {
        branch = 1;
    } else if (test < 3) {
        branch = 2;
    } else if (test < 7) {
        branch = 3;
    } else {
        branch = 4;
    }
    if (branch != 3) { return 270; }
    acc = acc + 8;

    // ── block 9: native calls — string ──
    let s: string = string_from_i64(12345);
    if (string_length(s) != 5) { return 280; }
    let label: string = build_label("n=", 42);
    if (string_length(label) != 4) { return 281; }  // "n=42" = 4 chars
    let s2: string = string_from_i64(-7);
    if (string_length(s2) != 2) { return 282; }     // "-7" = 2 chars
    acc = acc + 9;

    // ── block 10: native calls — array (push/pop/length) ──
    let a: i64 = array_new(8, 0);
    array_push_i64(a, 7);
    array_push_i64(a, 14);
    array_push_i64(a, 21);
    if (array_length(a) != 3) { return 290; }
    let ap: i64 = array_pop_i64(a);
    if (ap != 21) { return 291; }
    if (array_length(a) != 2) { return 292; }
    array_clear(a);
    if (array_length(a) != 0) { return 293; }
    acc = acc + 10;

    // ── block 11: native calls — math ──
    let sq: f64 = sqrt_f64(144.0);
    if (sq != 12.0) { return 300; }
    let pw: f64 = pow_f64(3.0, 4.0);
    if (pw != 81.0) { return 301; }
    let ab: i64 = abs_i64(-99);
    if (ab != 99) { return 302; }
    acc = acc + 11;

    // ── block 12: casts (i64↔f64, integer narrowing, array same-type) ──
    let ci: i64 = 2147483647;
    let cf: f64 = ci as f64;
    if ((cf as i64) != ci) { return 310; }
    let narrow: i8 = 200 as i8;       // 200 → -56 (i8 wrap)
    if ((narrow as i64) != -56) { return 311; }
    let widen: i64 = (42 as i8) as i64;
    if (widen != 42) { return 312; }
    let arr2: i64[3] = [1, 2, 3];
    let arr3: i64[3] = arr2 as i64[3];
    if (arr3[0] + arr3[1] + arr3[2] != 6) { return 313; }
    acc = acc + 12;

    // ── block 13: operator overloads (string concat + equality) ──
    let cat: string = string_from_slice("ab") + string_from_slice("cd");
    if (string_length(cat) != 4) { return 320; }
    let eq: bool = string_from_slice("hi") == string_from_slice("hi");
    if (!eq) { return 321; }
    acc = acc + 13;

    // ── block 14: compound assignment + pre/post inc/dec ──
    let mut ca: i64 = 10;
    ca += 5;
    if (ca != 15) { return 330; }
    ca -= 3;
    if (ca != 12) { return 331; }
    ca *= 2;
    if (ca != 24) { return 332; }
    ca /= 4;
    if (ca != 6) { return 333; }
    ca %= 4;
    if (ca != 2) { return 334; }
    let mut inc: i64 = 5;
    let post: i64 = inc++;
    let pre: i64 = ++inc;
    if (inc != 7 || post != 5 || pre != 7) { return 335; }
    let mut dec: i64 = 5;
    let pd: i64 = dec--;
    let pd2: i64 = --dec;
    if (dec != 3 || pd != 5 || pd2 != 3) { return 336; }
    acc = acc + 14;

    // ── block 15: integer arithmetic edges (div, mod, overflow wrap) ──
    if ((7 / 2) != 3) { return 340; }
    if ((7 % 3) != 1) { return 341; }
    if ((-7 / 2) != -3) { return 342; }
    if ((-7 % 3) != -1) { return 343; }
    let wrap_u8: u8 = (255 as u8) + (1 as u8);
    if (wrap_u8 != 0 as u8) { return 344; }
    let shl: i64 = 1 << 8;
    if (shl != 256) { return 345; }
    let shr: i64 = 256 >> 2;
    if (shr != 64) { return 346; }
    let bx: i64 = 0x0F | 0xF0;
    if (bx != 255) { return 347; }
    let band: i64 = 0xFF & 0x0F;
    if (band != 15) { return 348; }
    let bxor: i64 = 0xFF ^ 0x0F;
    if (bxor != 240) { return 349; }
    acc = acc + 15;

    // ── block 16: defer (LIFO block-exit) ──
    let dp: i64 = defer_probe();
    if (dp != 3) { return 350; }
    acc = acc + 16;

    // ── block 17: globals (mutable, read/write across calls) ──
    g_counter = 100;
    g_counter = g_counter + 23;
    if (g_counter != 123) { return 360; }
    acc = acc + 17;

    // ── block 18: IR-optimization-target functions (must stay correct under passes) ──
    // opt_target: dead store + redundant compute — DCE/CSE must not change result.
    if (opt_target(5) != 70) { return 370; }    // 5*7 + 5*7 = 70
    if (opt_target(10) != 140) { return 371; }  // 10*7 + 10*7 = 140
    // invariant_loop: LICM + constprop must not change result.
    // n=3: iterations 0,1,2; k=20000, c=7 each; s += 20000+7+i
    //   i=0: s=20007, i=1: s=40015, i=2: s=60024 → 60024
    if (invariant_loop(3) != 60024) { return 372; }
    if (invariant_loop(5) != 100045) { return 373; }
    // n=5: i=0..4: each adds (20000+7+i):
    //   i=0: 20007, i=1: 20008, i=2: 20009, i=3: 20010, i=4: 20011
    //   sum = 20007+20008+20009+20010+20011 = 100045
    acc = acc + 18;

    // ── block 19: nested loops + early return inside loop ──
    let mut nest: i64 = 0;
    let mut ni: i64 = 0;
    while (ni < 3) {
        let mut nj: i64 = 0;
        while (nj < 3) {
            nest = nest + ni * 3 + nj;
            nj = nj + 1;
        }
        ni = ni + 1;
    }
    // ni=0: 0+1+2=3; ni=1: 3+4+5=12; ni=2: 6+7+8=21; total=36
    if (nest != 36) { return 380; }
    acc = acc + 19;

    // ── block 20: ternary-style if-expression via if/else yielding into a var ──
    let mut tern: i64 = 0;
    if (7 > 3) { tern = 111; } else { tern = 222; }
    if (tern != 111) { return 390; }
    if (3 > 7) { tern = 111; } else { tern = 222; }
    if (tern != 222) { return 391; }
    // logical and/or/not
    if (!(true && false) != true) { return 392; }
    if ((true || false) != true) { return 393; }
    if (!false != true) { return 394; }
    acc = acc + 20;

    // ── block 21: fixed-array indexing with bounds ──
    let mut fa: i64[4];
    let mut fi: i64 = 0;
    while (fi < 4) {
        fa[fi] = fi * fi;
        fi = fi + 1;
    }
    let mut fa_sum: i64 = 0;
    let mut fj: i64 = 0;
    while (fj < 4) {
        fa_sum = fa_sum + fa[fj];
        fj = fj + 1;
    }
    // 0 + 1 + 4 + 9 = 14
    if (fa_sum != 14) { return 400; }
    acc = acc + 21;

    // ── accumulator check ──
    // acc = 1+2+3+...+21 = sum of 1..21 = 21*22/2 = 231
    // But we want a final value < 256 and distinctive. 231 is fine but let's
    // fold in the opt-target correctness to make it a tighter checksum.
    // Final: acc (231) — 54 = 177 (a distinctive sentinel < 256).
    // The -54 is a checksum adjustment: if any block's early-exit fired we'd
    // never reach here; if a pass silently changed an intermediate without
    // triggering the guard, acc itself would differ. The -54 keeps the final
    // value in a distinctive range and exercises a final const-foldable Sub.
    if (acc != 231) { return 250; }
    return acc - 54;  // 231 - 54 = 177
}
