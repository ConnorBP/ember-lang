// valid_lsr.ember — loop strength reduction for canonical i*K loops.
// Run with: ember_cli run ../tests/lang/valid_lsr.ember --passes lsr
// expect: 60

fn main() -> i64 {
    let mut sum: i64 = 0;
    let mut i: i64 = 0;
    while (i < 5) {
        let product: i64 = i * 6;
        sum = sum + product;
        i = i + 1;
    }
    return sum;
}
