struct Point { x: i64; y: i64; }

fn sum_point(p: Point) -> i64 { return p.x + p.y; }

// A struct-by-value argument must be a bare local variable (codegen copies
// its bytes directly from a known frame address) - a fresh struct literal
// has no such address and is rejected.
fn main() -> i64 {
    let r: i64 = sum_point(Point { x: 1, y: 2 });
    return r;
}
