// valid_array_clear — array_clear empties the array.
// Three pushes produce length 3; clear resets the length to 0. The array
// handle remains valid (a subsequent push still works), confirming clear
// only empties storage rather than destroying the slot.
// expect: 1
fn main() -> i64 {
    let a: i64 = array_new(8, 0);
    array_push_i64(a, 10);
    array_push_i64(a, 20);
    array_push_i64(a, 30);
    if (array_length(a) != 3) { return 0; }
    array_clear(a);
    if (array_length(a) != 0) { return 0; }
    array_push_i64(a, 99);
    if (array_length(a) != 1) { return 0; }
    if (array_get_i64(a, 0) != 99) { return 0; }
    return 1;
}
