// valid_match_nested_in_for_each — match nested inside a for-each loop.
// Each element of the slice is classified by a match into one of three
// counters. Over [1,2,2,3]: ones=1, twos=2, threes=1.
// expect: 1
fn main() -> i64 {
    let a: i64[4] = [1, 2, 2, 3];
    let s: i64[] = a[..];
    let mut ones: i64 = 0;
    let mut twos: i64 = 0;
    let mut threes: i64 = 0;
    for (x in s) {
        match (x) {
            1 => { ones = ones + 1; },
            2 => { twos = twos + 1; },
            3 => { threes = threes + 1; }
        }
    }
    if (ones != 1) { return 0; }
    if (twos != 2) { return 0; }
    if (threes != 1) { return 0; }
    return 1;
}
