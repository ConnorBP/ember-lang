// Positive execution coverage for audit D6/D7/M5: control flow, compile-time
// layout constants, lexical-scope LIFO defer, return ABI preservation, f64,
// integer boundaries, and f-string lowering through the string extension.
struct Inner { a: i16; b: u8; }
struct Outer { tag: u8; inner: Inner; words: i32[2]; }
struct DoublePair { left: f64; right: f64; }
enum Constants { Folded = 6 * 7 }

global defer_trace: i64 = 0;
fn mark(v: i64) -> i64 { defer_trace = defer_trace * 10 + v; return 0; }
fn mark_via_native(v: i64) -> i64 {
    // The native sqrt call makes return-value preservation exercise the real
    // Win64 cleanup-call alignment path rather than only leaf script calls.
    let root: f32 = sqrt(4.0f);
    if (root != 2.0f) { defer_trace = -1; return 0; }
    defer_trace = defer_trace * 10 + v;
    return 0;
}

fn main() -> i64 {
    let mut i: i64 = 0;
    let mut sum: i64 = 0;
    do {
        i++;
        if (i == 2) { continue; }
        sum += i;
    } while (i < 3);
    if (sum != 4) { return 1; }
    do {
        sum += 10;
        break;
        sum += 100;
    } while (true);
    if (sum != 14) { return 1; }

    let mut n: i64 = 5;
    let post_inc = n++;
    let pre_inc = ++n;
    let post_dec = n--;
    let pre_dec = --n;
    if (n != 5 || post_inc != 5 || pre_inc != 7 || post_dec != 7 || pre_dec != 5) { return 2; }

    const primitive_size: u64 = sizeof(i64);
    const inner_offset: u64 = offsetof(Outer, inner);
    const words_offset: u64 = offsetof(Outer, words);
    // `const` plus an explicit enum value exercise v1's restricted constexpr
    // evaluator (integer literals/arithmetic and sizeof/offsetof constants).
    const folded: i64 = Constants::Folded;
    if (primitive_size != 8 || sizeof(Outer) != 12 || inner_offset != 1 || words_offset != 4 || folded != 42) { return 3; }

    // M5 defer checks are independent runtime assertions: lexical nested-block
    // fallthrough, per-iteration reset, cleanup before break/continue, LIFO,
    // local references, function falloff, return edges, and return ABI values.
    if (defer_probe() != 0 || defer_trace != 21) { return 4; }
    if (nested_fallthrough_probe() != 321) { return 9; }
    if (conditional_fallthrough_probe() != 3) { return 20; }
    if (iteration_probe() != 123) { return 10; }
    if (break_probe() != 4) { return 11; }
    if (continue_probe() != 12) { return 12; }
    if (switch_continue_probe() != 12) { return 19; }
    if (lifo_probe() != 65) { return 13; }
    defer_trace = 0;
    falloff_probe();
    if (defer_trace != 7) { return 14; }
    defer_trace = 0;
    let returned_scalar: i64 = return_scalar_defer();
    if (returned_scalar != 123456789 || defer_trace != 6) { return 21; }
    defer_trace = 0;
    let returned_f64: f64 = return_f64_defer();
    if (returned_f64 != 16777217.0 || defer_trace != 8) { return 15; }
    defer_trace = 0;
    let returned_f32: f32 = return_f32_defer();
    if (returned_f32 != 3.5f || defer_trace != 9) { return 16; }
    defer_trace = 0;
    let returned_pair: DoublePair = return_pair_defer();
    if (returned_pair.left != 16777217.0 || returned_pair.right != 4.0 || defer_trace != 1) { return 17; }
    defer_trace = 0;
    let mut return_values: i64[2];
    return_values[0] = 41;
    return_values[1] = 42;
    let returned_slice: i64[] = return_slice_defer(return_values[..]);
    if (returned_slice[0] != 41 || returned_slice[1] != 42 || defer_trace != 2) { return 18; }

    let precise: f64 = 16777217.0;
    if (!(precise > 16777216.0)) { return 5; }
    let mut values: f64[2];
    values[0] = 16777217.0;
    values[1] = values[0] + 1.0;
    if (!(values[0] > 16777216.0) || values[1] != 16777218.0) { return 5; }
    let mut pair: DoublePair = DoublePair { left: 16777217.0, right: 2.0 };
    if (!(pair.left > 16777216.0) || pair.right != 2.0) { return 5; }
    pair.right = pair.left + 1.0;
    if (pair.right != 16777218.0) { return 5; }

    let umax: u64 = (0 as u64) - (1 as u64);
    if (!(umax > 0 as u64) || (umax >> (63 as u64)) != 1 as u64) { return 6; }
    let wrap: u8 = (255 as u8) + (1 as u8);
    let signed_min: i8 = 128 as i8;
    if (wrap != 0 as u8 || signed_min != -128 as i8) { return 7; }

    let who: i64 = 42;
    let text: string = f"value={who}, ok={true}";
    if (string_length(text) != 17) { return 8; }
    return 93;
}

fn defer_probe() -> i64 {
    defer_trace = 0;
    defer mark(1);
    defer mark(2);
    return 0;
}

fn nested_fallthrough_probe() -> i64 {
    defer_trace = 0;
    {
        defer mark(1);
        {
            defer mark(2);
            defer mark(3);
        }
        if (defer_trace != 32) { return 0; }
    }
    return defer_trace;
}

fn conditional_fallthrough_probe() -> i64 {
    defer_trace = 0;
    if (true) {
        defer mark(3);
    }
    // The then-block cleanup has fired; function return must not run it again.
    return defer_trace;
}

fn iteration_probe() -> i64 {
    defer_trace = 0;
    for (let mut i: i64 = 0; i < 3; i++) {
        let local: i64 = i + 1;
        defer mark(local);
    }
    return defer_trace;
}

fn break_probe() -> i64 {
    defer_trace = 0;
    while (true) {
        defer mark(4);
        break;
    }
    return defer_trace;
}

fn continue_probe() -> i64 {
    defer_trace = 0;
    let mut i: i64 = 0;
    while (i < 2) {
        i++;
        defer mark(i);
        continue;
    }
    return defer_trace;
}

fn switch_continue_probe() -> i64 {
    defer_trace = 0;
    let mut i: i64 = 0;
    while (i < 2) {
        i++;
        defer mark(i);
        switch (i) {
            case 1: defer mark(8); continue;
            default: break;
        }
    }
    // First iteration: switch scope cleans 8, then loop body cleans 1;
    // second iteration cleans 2 before normal loop back-edge.
    if (defer_trace != 812) { return 0; }
    return 12;
}

fn lifo_probe() -> i64 {
    defer_trace = 0;
    {
        defer mark(5);
        defer mark(6);
    }
    return defer_trace;
}

fn falloff_probe() {
    defer mark(7);
}

fn return_scalar_defer() -> i64 {
    defer mark_via_native(6);
    return 123456789;
}

fn return_f64_defer() -> f64 {
    defer mark_via_native(8);
    return 16777217.0;
}

fn return_f32_defer() -> f32 {
    defer mark_via_native(9);
    return 3.5f;
}

fn return_pair_defer() -> DoublePair {
    let pair: DoublePair = DoublePair { left: 16777217.0, right: 4.0 };
    defer mark(1);
    return pair;
}

fn return_slice_defer(values: i64[]) -> i64[] {
    defer mark(2);
    return values;
}
