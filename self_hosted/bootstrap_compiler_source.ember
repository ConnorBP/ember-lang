// self_hosted/lex.ember — the ember lexer, written IN ember.
//
// Self-hosting Stage 1: prove ember can lex itself. This is a full port of
// src/lexer.cpp (the C++ reference lexer) to ember source. It handles ember's
// complete v1 token set — every keyword, operator, literal, and comment form —
// and emits a token stream the test (lex_test.ember) verifies against a known
// program.
//
// === Token storage design ===
//
// ember's type system has no growable array-of-struct-with-string-fields: the
// `array<T>` extension stores raw bytes by elem_size with strictly-typed
// `array_push_i64`/`array_get_i64` (i64 only — a `string` handle is a distinct
// type and is rejected), and `string[N]` fixed arrays can't be initialized
// (a string literal is a `u8[]` slice, not a `string`, and storing into a
// global array element is restricted). There is also no f64 slot in the array
// extension and no f64<->i64 bitcast.
//
// So a Token is stored as a fixed stride of i64s in a growable `array`-
// extension buffer (elem_size 8), with the string `text` reconstructed on
// demand by slicing the original source, and the f64 `fvalue` kept in a
// parallel global f64 array indexed by token index. This is the "flat i64
// array with a fixed Token stride" option the task endorses. The `Token`
// struct below is the typed read surface: `get_token(arr, i)` builds one from
// the flat store so callers see a real struct.
//
//   flat stride (6 i64s per token):  [ kind, src_start, src_len, line, col, ivalue ]
//   fvalue:                          decode_float(src_start, src_len) on demand
//                                    (f64, FloatLit only — re-derived from the
//                                    source span when read, since ember has no
//                                    working global f64 array and no f64 slot in
//                                    the array extension)
//   text:                            string_substr(g_src, src_start, src_len)
//
// `tok_text` returns the raw source span for every token. For identifiers,
// keywords, operators, and numbers this is exactly the token's text. For
// string/fstring/rawstring literals it is the raw source span (quotes and
// escapes included); the decoded character content is not materialized at lex
// time (a Stage 1 simplification — the lexer still correctly SCANS past
// escapes so it finds the real closing quote). Decoded numeric values for
// integer and float literals ARE carried: ivalue (i64) in the flat store and
// fvalue is decoded on demand from the source span (see tok_fvalue).
//
// === Tok enum ===
//
// Values match the declaration order of `enum class Tk` in src/lexer.hpp so a
// token kind from this lexer is directly comparable to the C++ lexer's kind.
// (Eof=0, IntLit=1, ... At=104 — 105 values, 0..104.)

// -----------------------------------------------------------------------------
// Token kinds. i64 constants usable in switch + comparisons (Tier 1 enum).
// -----------------------------------------------------------------------------
enum Tok {
    Eof          = 0,
    // literals
    IntLit       = 1,
    FloatLit     = 2,
    StringLit    = 3,
    FStringLit   = 4,
    RawStringLit = 5,
    BoolLit      = 6,
    Ident        = 7,
    // keywords
    Kw_fn            = 8,
    Kw_struct        = 9,
    Kw_global        = 10,
    Kw_let           = 11,
    Kw_mut           = 12,
    Kw_const         = 13,
    Kw_constexpr     = 14,
    Kw_defer         = 15,
    Kw_priv          = 16,
    Kw_if            = 17,
    Kw_else          = 18,
    Kw_while         = 19,
    Kw_do            = 20,
    Kw_for           = 21,
    Kw_switch        = 22,
    Kw_case          = 23,
    Kw_default       = 24,
    Kw_break         = 25,
    Kw_continue      = 26,
    Kw_return        = 27,
    Kw_as            = 28,
    Kw_auto          = 29,
    Kw_in            = 30,
    Kw_try           = 31,
    Kw_catch         = 32,
    Kw_throw         = 33,
    Kw_yield         = 34,
    Kw_true          = 35,
    Kw_false         = 36,
    Kw_sizeof        = 37,
    Kw_offsetof      = 38,
    Kw_link          = 39,
    Kw_enum          = 40,
    Kw_match         = 41,
    Kw_static_assert = 42,
    Kw_namespace     = 43,
    // primitive types
    Kw_bool = 44,
    Kw_i8   = 45,
    Kw_i16  = 46,
    Kw_i32  = 47,
    Kw_i64  = 48,
    Kw_u8   = 49,
    Kw_u16  = 50,
    Kw_u32  = 51,
    Kw_u64  = 52,
    Kw_f32  = 53,
    Kw_f64  = 54,
    Kw_void = 55,
    // punctuation
    LParen       = 56,
    RParen       = 57,
    LBrace       = 58,
    RBrace       = 59,
    LBracket     = 60,
    RBracket     = 61,
    Comma        = 62,
    Semicolon    = 63,
    Colon        = 64,
    DoubleColon  = 65,
    Arrow        = 66,
    FatArrow     = 67,
    Dot          = 68,
    DotDot       = 69,
    // operators
    Plus          = 70,
    Minus         = 71,
    Star          = 72,
    Slash         = 73,
    Percent       = 74,
    Assign        = 75,
    Eq            = 76,
    Neq           = 77,
    Lt            = 78,
    Le            = 79,
    Gt            = 80,
    Ge            = 81,
    AndAnd        = 82,
    OrOr          = 83,
    Not           = 84,
    Amp           = 85,
    Pipe          = 86,
    Caret         = 87,
    Tilde         = 88,
    Shl           = 89,
    Shr           = 90,
    Inc           = 91,
    Dec           = 92,
    Question      = 93,
    PlusAssign    = 94,
    MinusAssign   = 95,
    StarAssign    = 96,
    SlashAssign   = 97,
    PercentAssign = 98,
    AmpAssign     = 99,
    PipeAssign    = 100,
    CaretAssign   = 101,
    ShlAssign     = 102,
    ShrAssign     = 103,
    // annotation
    At = 104,
}

// A lexed token — the typed read surface over the flat store. `get_token`
// builds one of these from the flat array so callers handle a real
// struct. Fields mirror the C++ `Token` (kind/text/line/col/ivalue/fvalue).
struct Token {
    kind:   i64;
    text:   string;
    line:   i64;
    col:    i64;
    ivalue: i64;
    fvalue: f64;
}

// Flat-store stride: 6 i64s per token (kind, src_start, src_len, line, col, ivalue).
global LEX_STRIDE : i64 = 6;

// --- lexer cursor + state (scalar/string globals; the array handle is a
//     scalar i64 global too). The demo compiler uses the same scalar-globals
//     pattern for its lexer cursor. ---
global g_src  : string = "";   // the source being lexed (so tok_text can slice it)
global g_arr  : i64    = 0;    // flat token array handle (array extension, elem_size 8)
global g_pos  : i64    = 0;    // cursor into g_src
global g_len  : i64    = 0;    // string_length(g_src)
global g_line : i64    = 1;    // current line (1-based)
global g_col  : i64    = 1;    // current column (1-based)
global g_tok_line : i64 = 1;   // line at the start of the token being pushed
global g_tok_col  : i64 = 1;   // col  at the start of the token being pushed
global g_err  : i64    = 0;    // 1 once a lex error is flagged
global g_errline : i64 = 0;    // error position (1-based)
global g_errcol  : i64 = 0;

// --- keyword string cache (allocated ONCE at module load). ---
// The host string store has no string_free -- every string_from_slice(...) is
// a permanent slot until reset(). keyword_kind previously called
// string_from_slice("fn")/"if"/... on every identifier probe (~up to 11 per
// token), leaking a host string slot each call. Across the pipeline's repeated
// lex passes that accumulation crashed the host at scale. Caching the keyword
// texts as module globals allocates each exactly once.
global KW_fn   : string = "fn";
global KW_if   : string = "if";
global KW_do   : string = "do";
global KW_as   : string = "as";
global KW_in   : string = "in";
global KW_i8   : string = "i8";
global KW_u8   : string = "u8";
global KW_let  : string = "let";
global KW_mut  : string = "mut";
global KW_for  : string = "for";
global KW_try  : string = "try";
global KW_i16  : string = "i16";
global KW_i32  : string = "i32";
global KW_i64  : string = "i64";
global KW_u16  : string = "u16";
global KW_u32  : string = "u32";
global KW_u64  : string = "u64";
global KW_f32  : string = "f32";
global KW_f64  : string = "f64";
global KW_else  : string = "else";
global KW_case  : string = "case";
global KW_void  : string = "void";
global KW_enum  : string = "enum";
global KW_link  : string = "link";
global KW_bool  : string = "bool";
global KW_auto  : string = "auto";
global KW_priv  : string = "priv";
global KW_true  : string = "true";
global KW_while : string = "while";
global KW_break : string = "break";
global KW_catch : string = "catch";
global KW_const : string = "const";
global KW_defer : string = "defer";
global KW_match : string = "match";
global KW_yield : string = "yield";
global KW_throw : string = "throw";
global KW_false : string = "false";
global KW_return : string = "return";
global KW_struct : string = "struct";
global KW_switch : string = "switch";
global KW_global : string = "global";
global KW_sizeof : string = "sizeof";
global KW_default : string = "default";
global KW_continue : string = "continue";
global KW_offsetof : string = "offsetof";
global KW_namespace : string = "namespace";
global KW_constexpr : string = "constexpr";
global KW_static_assert : string = "static_assert";

// -----------------------------------------------------------------------------
// char classifiers (mirror the demo's is_digit/is_alpha; ASCII code ranges).
// -----------------------------------------------------------------------------

fn is_digit(ch: i64) -> i64 {
    if (ch >= 48 && ch <= 57) { return 1; }   // '0'..'9'
    return 0;
}

fn is_alpha(ch: i64) -> i64 {
    if ((ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || ch == 95) {
        return 1;   // 'A'..'Z' | 'a'..'z' | '_'
    }
    return 0;
}

fn is_alnum(ch: i64) -> i64 {
    if (is_alpha(ch) == 1) { return 1; }
    if (is_digit(ch) == 1) { return 1; }
    return 0;
}

fn is_xdigit(ch: i64) -> i64 {
    if (ch >= 48 && ch <= 57) { return 1; }    // '0'..'9'
    if (ch >= 65 && ch <= 70) { return 1; }    // 'A'..'F'
    if (ch >= 97 && ch <= 102) { return 1; }   // 'a'..'f'
    return 0;
}

// peek the byte at g_pos + off (0 if past end — string_char_at returns 0 OOB,
// which matches no operator char so it is a safe "no more input" sentinel).
fn peek(off: i64) -> i64 {
    return string_char_at(g_src, g_pos + off);
}

// advance the cursor by n bytes, updating column.
fn adv(n: i64) -> i64 {
    g_pos = g_pos + n;
    g_col = g_col + n;
    return 0;
}

// advance one byte; if it was a newline, bump line and reset column.
fn adv_nl(ch: i64) -> i64 {
    if (ch == 10) { g_line = g_line + 1; g_col = 1; g_pos = g_pos + 1; return 0; }
    g_pos = g_pos + 1;
    g_col = g_col + 1;
    return 0;
}

// -----------------------------------------------------------------------------
// push one token into the flat store. Reads g_tok_line/g_tok_col (set at the
// token's start by the caller) so the recorded position is the token's first
// byte, not its last. 4 args (direct call — well within the safe surface).
// -----------------------------------------------------------------------------
fn push_tok(kind: i64, start: i64, len: i64, ivalue: i64) -> i64 {
    array_push_i64(g_arr, kind);
    array_push_i64(g_arr, start);
    array_push_i64(g_arr, len);
    array_push_i64(g_arr, g_tok_line);
    array_push_i64(g_arr, g_tok_col);
    array_push_i64(g_arr, ivalue);
    return 0;
}

// flag a lex error at the current position (or a given one) and return -1.
// The main loop checks g_err after each step.
fn lex_error(line: i64, col: i64) -> i64 {
    g_err = 1;
    g_errline = line;
    g_errcol = col;
    return -1;
}

// -----------------------------------------------------------------------------
// keyword lookup. Compares the identifier text (a substring of g_src from
// [start, start+len)) against each keyword. Returns the matching Tok kind, or
// Tok::Ident if no keyword matches. true/false are mapped to BoolLit here too
// (matching the C++ lexer, which rewrites Kw_true/Kw_false to BoolLit).
//
// Builds the id into a `string` once, then string==string compares against
// each keyword's `string_from_slice`. The keyword fns are kept to one arg so
// the dispatch is all direct calls.
// -----------------------------------------------------------------------------

// Test whether the identifier at g_src[start..start+len) equals the literal
// text `kw`. Builds a string from the source span and compares to a string
// built from the keyword literal.
fn id_eq(start: i64, len: i64, kw: string) -> i64 {
    // Compare the source span [start, start+len) against `kw` character by
    // character. The previous form built a fresh substring with
    // string_substr(g_src, start, len) on EVERY keyword probe (and keyword_kind
    // calls id_eq up to ~11x per identifier), which leaked a host string slot
    // each call -- the host string store has no string_free, so every string
    // allocation is permanent until reset(). At scale (lex re-run across the
    // pipeline stages) the leaked strings accumulated and crashed the host.
    // Comparing via string_char_at allocates nothing.
    let klen: i64 = string_length(kw);
    if (klen != len) { return 0; }
    let mut i: i64 = 0;
    while (i < len) {
        if (string_char_at(g_src, start + i) != string_char_at(kw, i)) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn keyword_kind(start: i64, len: i64) -> i64 {
    // fast reject by length: only check keywords of this length. `import` is
    // NOT a keyword here (the C++ lexer's keyword map omits it — the import
    // resolver handles `import` lines pre-lex), so `import` lexes as Ident.
    // Keyword texts are cached module globals (KW_*) allocated once; id_eq
    // compares char-by-char so no substring is allocated per probe.
    if (len == 2) {
        if (id_eq(start, len, KW_fn) == 1) { return Tok::Kw_fn as i64; }
        if (id_eq(start, len, KW_if) == 1) { return Tok::Kw_if as i64; }
        if (id_eq(start, len, KW_do) == 1) { return Tok::Kw_do as i64; }
        if (id_eq(start, len, KW_as) == 1) { return Tok::Kw_as as i64; }
        if (id_eq(start, len, KW_in) == 1) { return Tok::Kw_in as i64; }
        if (id_eq(start, len, KW_i8) == 1) { return Tok::Kw_i8 as i64; }
        if (id_eq(start, len, KW_u8) == 1) { return Tok::Kw_u8 as i64; }
        return Tok::Ident as i64;
    }
    if (len == 3) {
        if (id_eq(start, len, KW_let) == 1) { return Tok::Kw_let as i64; }
        if (id_eq(start, len, KW_mut) == 1) { return Tok::Kw_mut as i64; }
        if (id_eq(start, len, KW_for) == 1) { return Tok::Kw_for as i64; }
        if (id_eq(start, len, KW_try) == 1) { return Tok::Kw_try as i64; }
        if (id_eq(start, len, KW_i16) == 1) { return Tok::Kw_i16 as i64; }
        if (id_eq(start, len, KW_i32) == 1) { return Tok::Kw_i32 as i64; }
        if (id_eq(start, len, KW_i64) == 1) { return Tok::Kw_i64 as i64; }
        if (id_eq(start, len, KW_u16) == 1) { return Tok::Kw_u16 as i64; }
        if (id_eq(start, len, KW_u32) == 1) { return Tok::Kw_u32 as i64; }
        if (id_eq(start, len, KW_u64) == 1) { return Tok::Kw_u64 as i64; }
        if (id_eq(start, len, KW_f32) == 1) { return Tok::Kw_f32 as i64; }
        if (id_eq(start, len, KW_f64) == 1) { return Tok::Kw_f64 as i64; }
        return Tok::Ident as i64;
    }
    if (len == 4) {
        if (id_eq(start, len, KW_else) == 1) { return Tok::Kw_else as i64; }
        if (id_eq(start, len, KW_case) == 1) { return Tok::Kw_case as i64; }
        if (id_eq(start, len, KW_void) == 1) { return Tok::Kw_void as i64; }
        if (id_eq(start, len, KW_enum) == 1) { return Tok::Kw_enum as i64; }
        if (id_eq(start, len, KW_link) == 1) { return Tok::Kw_link as i64; }
        if (id_eq(start, len, KW_bool) == 1) { return Tok::Kw_bool as i64; }
        if (id_eq(start, len, KW_auto) == 1) { return Tok::Kw_auto as i64; }
        if (id_eq(start, len, KW_priv) == 1) { return Tok::Kw_priv as i64; }
        if (id_eq(start, len, KW_true) == 1) { return Tok::BoolLit as i64; }
        return Tok::Ident as i64;
    }
    if (len == 5) {
        if (id_eq(start, len, KW_while) == 1) { return Tok::Kw_while as i64; }
        if (id_eq(start, len, KW_break) == 1) { return Tok::Kw_break as i64; }
        if (id_eq(start, len, KW_catch) == 1) { return Tok::Kw_catch as i64; }
        if (id_eq(start, len, KW_const) == 1) { return Tok::Kw_const as i64; }
        if (id_eq(start, len, KW_defer) == 1) { return Tok::Kw_defer as i64; }
        if (id_eq(start, len, KW_match) == 1) { return Tok::Kw_match as i64; }
        if (id_eq(start, len, KW_yield) == 1) { return Tok::Kw_yield as i64; }
        if (id_eq(start, len, KW_throw) == 1) { return Tok::Kw_throw as i64; }
        if (id_eq(start, len, KW_false) == 1) { return Tok::BoolLit as i64; }
        return Tok::Ident as i64;
    }
    if (len == 6) {
        if (id_eq(start, len, KW_return) == 1) { return Tok::Kw_return as i64; }
        if (id_eq(start, len, KW_struct) == 1) { return Tok::Kw_struct as i64; }
        if (id_eq(start, len, KW_switch) == 1) { return Tok::Kw_switch as i64; }
        if (id_eq(start, len, KW_global) == 1) { return Tok::Kw_global as i64; }
        if (id_eq(start, len, KW_sizeof) == 1) { return Tok::Kw_sizeof as i64; }
        return Tok::Ident as i64;
    }
    if (len == 7) {
        if (id_eq(start, len, KW_default) == 1) { return Tok::Kw_default as i64; }
        return Tok::Ident as i64;
    }
    if (len == 8) {
        if (id_eq(start, len, KW_continue) == 1) { return Tok::Kw_continue as i64; }
        if (id_eq(start, len, KW_offsetof) == 1) { return Tok::Kw_offsetof as i64; }
        return Tok::Ident as i64;
    }
    if (len == 9) {
        if (id_eq(start, len, KW_namespace) == 1) { return Tok::Kw_namespace as i64; }
        if (id_eq(start, len, KW_constexpr) == 1) { return Tok::Kw_constexpr as i64; }
        return Tok::Ident as i64;
    }
    if (len == 13) {
        if (id_eq(start, len, KW_static_assert) == 1) { return Tok::Kw_static_assert as i64; }
        return Tok::Ident as i64;
    }
    return Tok::Ident as i64;
}

// -----------------------------------------------------------------------------
// number lexing. Handles decimal, hex (0x/0X), float (fractional '.', exponent
// e[+-]?digits), and the 'f'/'F' f32-forcing suffix. Rejects the unsupported
// integer width suffixes (u/i) the way the C++ lexer does. Decodes the integer
// value into ivalue (decimal and hex); the float value is decoded on
// demand by tok_fvalue from the source span (no stored fvalue).
// Returns 0 on success, -1 on error.
// -----------------------------------------------------------------------------

// parse a hex digit's value (0..15), or -1 if not a hex digit.
fn hexval(ch: i64) -> i64 {
    if (ch >= 48 && ch <= 57) { return ch - 48; }     // '0'..'9'
    if (ch >= 65 && ch <= 70) { return ch - 65 + 10; } // 'A'..'F'
    if (ch >= 97 && ch <= 102) { return ch - 97 + 10; } // 'a'..'f'
    return -1;
}

// power of 10 for the float exponent: pow10(e). Handles negative e (returns
// 1.0 / 10^|e|) so fractional-digit scaling like `3.14` -> mant=314, e=-2
// -> 314 * 0.01 = 3.14 works. e is small here (literal digit counts).
fn pow10(e: i64) -> f64 {
    if (e >= 0) {
        let mut r: f64 = 1.0;
        let mut i: i64 = 0;
        while (i < e) { r = r * 10.0; i = i + 1; }
        return r;
    }
    let mut r: f64 = 1.0;
    let mut i: i64 = 0;
    while (i < 0 - e) { r = r / 10.0; i = i + 1; }
    return r;
}

// Decode a float literal's f64 value from g_src[start..start+len). Walks the
// span once: accumulates the mantissa as a single digit stream, counts digits
// after the '.' (fdigits), reads the explicit exponent (e[+-]?digits) into
// eexp. The value is  mant * 10^(eexp - fdigits), correct for `3.14`,
// `3.14f`, `1e3`, `1.5e-2`, etc. Called on demand by tok_fvalue (the float
// value is not stored at lex time — it is re-derived from the source span
// when read, which avoids needing a global f64 array for fvalues).
fn decode_float(start: i64, len: i64) -> f64 {
    let end: i64 = start + len;
    let mut mant: f64 = 0.0;
    let mut fdigits: i64 = 0;
    let mut eexp: i64 = 0;
    let mut seen_dot: i64 = 0;
    let mut k: i64 = start;
    while (k < end) {
        let ch: i64 = string_char_at(g_src, k);
        if (ch == 46) { seen_dot = 1; k = k + 1; continue; }       // '.'
        if (ch == 102 || ch == 70) { k = k + 1; continue; }         // 'f'/'F' suffix
        if (ch == 101 || ch == 69) {                                 // 'e'/'E'
            k = k + 1;
            let mut esign: i64 = 1;
            if (k < end) {
                let ec: i64 = string_char_at(g_src, k);
                if (ec == 43) { k = k + 1; }
                else if (ec == 45) { esign = -1; k = k + 1; }
            }
            let mut e: i64 = 0;
            while (k < end && is_digit(string_char_at(g_src, k)) == 1) {
                e = e * 10 + (string_char_at(g_src, k) - 48);
                k = k + 1;
            }
            eexp = esign * e;
            break;
        }
        let d: i64 = ch - 48;
        mant = mant * 10.0 + (d as f64);
        if (seen_dot == 1) { fdigits = fdigits + 1; }
        k = k + 1;
    }
    return mant * pow10(eexp - fdigits);
}

fn lex_number() -> i64 {
    let start: i64 = g_pos;
    let sl: i64 = g_tok_line;
    let sc: i64 = g_tok_col;
    let c0: i64 = peek(0);

    // --- hex: 0x / 0X ---
    if (c0 == 48 && (peek(1) == 120 || peek(1) == 88)) {   // '0' 'x'/'X'
        adv(2);
        let digits_start: i64 = g_pos;
        while (is_xdigit(peek(0)) == 1) { adv(1); }
        if (g_pos == digits_start) { return lex_error(sl, sc); } // "hex literal requires at least one digit"
        // trailing alnum/_ is a malformed suffix
        let after: i64 = peek(0);
        if (is_alnum(after) == 1 || after == 95) { return lex_error(sl, sc); }
        // decode hex digits -> ivalue
        let mut value: i64 = 0;
        let mut j: i64 = digits_start;
        while (j < g_pos) {
            let d: i64 = hexval(string_char_at(g_src, j));
            value = value * 16 + d;
            j = j + 1;
        }
        let len: i64 = g_pos - start;
        push_tok(Tok::IntLit as i64, start, len, value);
        return 0;
    }

    // --- decimal integer part ---
    let mut isfloat: i64 = 0;
    while (is_digit(peek(0)) == 1) { adv(1); }

    // fractional part: '.' unless it is '..' (slice view — belongs to next token)
    if (peek(0) == 46) {   // '.'
        if (peek(1) == 46) {
            // '..' — leave for the next token; do not consume
        } else {
            isfloat = 1;
            adv(1);
            while (is_digit(peek(0)) == 1) { adv(1); }
        }
    }

    // exponent: e[+-]?digits  (only when not already a float via '.')
    if (isfloat == 0 && (peek(0) == 101 || peek(0) == 69)) {   // 'e' / 'E'
        let save: i64 = g_pos;
        let savecol: i64 = g_col;
        adv(1);
        if (peek(0) == 43 || peek(0) == 45) { adv(1); }   // '+' / '-'
        if (is_digit(peek(0)) == 1) {
            isfloat = 1;
            while (is_digit(peek(0)) == 1) { adv(1); }
        } else {
            // not a real exponent — rewind, leave 'e' for the next token
            g_pos = save;
            g_col = savecol;
        }
    }

    // reject unsupported integer width suffixes (u/i) on a non-float literal
    if (isfloat == 0 && (peek(0) == 117 || peek(0) == 105)) {   // 'u' / 'i'
        return lex_error(sl, sc);
    }

    // 'f'/'F' suffix forces float (f32). The suffix distinction (f32 vs f64)
    // is not recorded as a separate field in this Stage 1 lexer — the C++
    // lexer's `f32_suffix` flag is a semantic detail the parser/sema layer
    // uses; the token kind (FloatLit) and source span (which retains the 'f')
    // are recorded here, and the on-demand fvalue decode handles either width.
    if (peek(0) == 102 || peek(0) == 70) {   // 'f' / 'F'
        isfloat = 1;
        adv(1);
    }

    let len: i64 = g_pos - start;

    if (isfloat == 1) {
        // The float value is decoded on demand by tok_fvalue (from the source
        // span), so we only record the token here.
        push_tok(Tok::FloatLit as i64, start, len, 0);
        return 0;
    }

    // --- decimal integer: decode the digit run -> ivalue ---
    let mut value: i64 = 0;
    let mut j: i64 = start;
    while (j < start + len) {
        let d: i64 = string_char_at(g_src, j) - 48;
        value = value * 10 + d;
        j = j + 1;
    }
    push_tok(Tok::IntLit as i64, start, len, value);
    return 0;
}

// -----------------------------------------------------------------------------
// string literal: "..." with escapes \n \t \r \\ \" \0 and '\' line
// continuation. Scans past escapes so the real closing quote is found; rejects
// an unescaped newline and unknown escapes. The recorded text is the raw source
// span (quotes + escapes); decoded content is not materialized at lex time.
// Returns 0 on success, -1 on error.
// -----------------------------------------------------------------------------
fn lex_string() -> i64 {
    let start: i64 = g_pos;     // include the opening quote in the span
    let sl: i64 = g_tok_line;
    let sc: i64 = g_tok_col;
    adv(1);                     // opening '"'
    let mut go: i64 = 1;
    while (go == 1) {
        if (g_pos >= g_len) { return lex_error(sl, sc); }   // unterminated
        let ch: i64 = peek(0);
        if (ch == 34) { adv(1); go = 0; continue; }   // closing '"'
        if (ch == 10) { return lex_error(sl, sc); }    // unescaped newline
        if (ch == 92) {   // backslash escape
            adv(1);
            if (g_pos >= g_len) { return lex_error(sl, sc); }
            let e: i64 = peek(0);
            if (e == 10) { adv_nl(10); continue; }   // line continuation
            // valid escapes: n t r \ " 0
            if (e == 110 || e == 116 || e == 114 || e == 92 || e == 34 || e == 48) {
                adv(1);
                continue;
            }
            return lex_error(g_line, g_col);   // unknown escape
        }
        adv(1);
    }
    let len: i64 = g_pos - start;
    push_tok(Tok::StringLit as i64, start, len, 0);
    return 0;
}

// -----------------------------------------------------------------------------
// f-string: f"..." with brace-depth-aware scanning. At depth 0 a bare '"' ends
// the literal and '{{'/'}}' collapse to one literal brace; at depth > 0 (inside
// an interpolation) a '"' starts a nested plain string scanned to its own close.
// The recorded text is the raw body (between the outer quotes). Returns 0 / -1.
// -----------------------------------------------------------------------------
fn lex_fstring() -> i64 {
    let start: i64 = g_pos;     // include the leading 'f' in the span
    let sl: i64 = g_tok_line;
    let sc: i64 = g_tok_col;
    adv(2);                     // 'f' + opening '"'
    let mut depth: i64 = 0;
    let mut go: i64 = 1;
    while (go == 1) {
        if (g_pos >= g_len) { return lex_error(sl, sc); }   // unterminated f-string
        let ch: i64 = peek(0);
        if (depth == 0) {
            if (ch == 34) { adv(1); go = 0; continue; }   // real terminator
            if (ch == 123) {   // '{'
                if (peek(1) == 123) { adv(2); continue; }   // '{{' literal
                depth = 1; adv(1); continue;
            }
            if (ch == 125) {   // '}'
                if (peek(1) == 125) { adv(2); continue; }   // '}}' literal
                adv(1); continue;   // unmatched '}' — parser reports
            }
            adv_nl(ch);
            continue;
        }
        // depth > 0: inside an interpolation
        if (ch == 34) {   // nested plain string
            adv(1);
            let mut ng: i64 = 1;
            while (ng == 1) {
                if (g_pos >= g_len) { return lex_error(sl, sc); }
                let nc: i64 = peek(0);
                if (nc == 92) {   // escape: skip two bytes
                    adv(1);
                    if (g_pos < g_len) { adv_nl(peek(0)); }
                    continue;
                }
                if (nc == 34) { adv(1); ng = 0; continue; }
                adv_nl(nc);
            }
            continue;
        }
        if (ch == 123) { depth = depth + 1; adv(1); continue; }
        if (ch == 125) { depth = depth - 1; adv(1); continue; }
        adv_nl(ch);
    }
    let len: i64 = g_pos - start;
    push_tok(Tok::FStringLit as i64, start, len, 0);
    return 0;
}

// -----------------------------------------------------------------------------
// raw string: r"""...""" — every byte literal until the next literal '"""'.
// No escape processing at all (not even backslash). Returns 0 / -1.
// -----------------------------------------------------------------------------
fn lex_rawstring() -> i64 {
    let start: i64 = g_pos;     // include the leading 'r' in the span
    let sl: i64 = g_tok_line;
    let sc: i64 = g_tok_col;
    adv(4);                     // 'r' + '"""'
    let mut go: i64 = 1;
    while (go == 1) {
        if (g_pos >= g_len) { return lex_error(sl, sc); }   // unterminated
        let ch: i64 = peek(0);
        if (ch == 34 && peek(1) == 34 && peek(2) == 34) {
            adv(3);
            go = 0;
            continue;
        }
        adv_nl(ch);
    }
    let len: i64 = g_pos - start;
    push_tok(Tok::RawStringLit as i64, start, len, 0);
    return 0;
}

// -----------------------------------------------------------------------------
// identifier / keyword. Scans [a-zA-Z_][a-zA-Z0-9_]*, then classifies via
// keyword_kind. true/false become BoolLit. Returns 0 / -1.
// -----------------------------------------------------------------------------
fn lex_ident() -> i64 {
    let start: i64 = g_pos;
    let sl: i64 = g_tok_line;
    let sc: i64 = g_tok_col;
    while (is_alnum(peek(0)) == 1) { adv(1); }
    let len: i64 = g_pos - start;
    let kind: i64 = keyword_kind(start, len);
    push_tok(kind, start, len, 0);
    return 0;
}

// -----------------------------------------------------------------------------
// the main lexer. Tokenize `source` into the flat token array and return the
// array handle (an i64). On error, g_err is set and the tokens parsed so far
// are in the array (best-effort, like the C++ lexer). The handle is always
// returned so the caller can inspect what was produced.
// -----------------------------------------------------------------------------
fn lex(source: string) -> i64 {
    // reset state
    g_src = source;
    g_len = string_length(source);
    g_pos = 0;
    g_line = 1;
    g_col = 1;
    g_err = 0;
    g_errline = 0;
    g_errcol = 0;
    // Reuse the token store across lex() calls instead of allocating a fresh
    // array each time. The host array extension has no array_free, so a fresh
    // array_new on every lex() leaks the previous buffer (the slot is never
    // reclaimed); the leaked buffers accumulate in the GC trace-callback scan
    // and eventually crash the host at scale. array_clear() resets the logical
    // length to 0 while keeping the backing buffer, so the slot is reused and
    // the store stops growing. The first call (g_arr == 0) still allocates.
    if (g_arr != 0) {
        array_clear(g_arr);
    } else {
        g_arr = array_new(8, 0);   // growable i64 store, elem_size 8
    }

    let mut go: i64 = 1;
    while (go == 1) {
        if (g_pos >= g_len) { go = 0; break; }
        let c: i64 = peek(0);

        // whitespace
        if (c == 32 || c == 9 || c == 13) { adv(1); continue; }    // ' ' '\t' '\r'
        if (c == 10) { adv_nl(10); continue; }                      // '\n'

        // line comment
        if (c == 47 && peek(1) == 47) {   // '//'
            while (g_pos < g_len && peek(0) != 10) { adv(1); }
            continue;
        }
        // block comment
        if (c == 47 && peek(1) == 42) {   // '/*'
            let csl: i64 = g_line;
            let csc: i64 = g_col;
            adv(2);
            let mut found: i64 = 0;
            let mut cg: i64 = 1;
            while (cg == 1) {
                if (g_pos + 1 >= g_len) { cg = 0; continue; }
                if (peek(0) == 42 && peek(1) == 47) { adv(2); found = 1; cg = 0; continue; }
                adv_nl(peek(0));
            }
            if (found == 0) { lex_error(csl, csc); go = 0; break; }
            continue;
        }

        // record the token's start position before consuming
        g_tok_line = g_line;
        g_tok_col = g_col;

        // annotation '@'
        if (c == 64) { push_tok(Tok::At as i64, g_pos, 1, 0); adv(1); continue; }

        // f-string: f"  (checked before the identifier branch — 'f' is alpha)
        if (c == 102 && peek(1) == 34) {   // 'f' '"'
            if (lex_fstring() != 0) { go = 0; break; }
            continue;
        }
        // raw string: r"""  (checked before the identifier branch — 'r' is alpha)
        if (c == 114 && peek(1) == 34 && peek(2) == 34 && peek(3) == 34) {   // 'r' '"""'
            if (lex_rawstring() != 0) { go = 0; break; }
            continue;
        }

        // identifier / keyword
        if (is_alpha(c) == 1) {
            if (lex_ident() != 0) { go = 0; break; }
            continue;
        }

        // number
        if (is_digit(c) == 1) {
            if (lex_number() != 0) { go = 0; break; }
            continue;
        }

        // string literal
        if (c == 34) {   // '"'
            if (lex_string() != 0) { go = 0; break; }
            continue;
        }

        // punctuation / operators (maximal munch, longest first per char)
        let st: i64 = g_pos;
        switch (c) {
            case 40: push_tok(Tok::LParen as i64, st, 1, 0); adv(1); continue;     // (
            case 41: push_tok(Tok::RParen as i64, st, 1, 0); adv(1); continue;     // )
            case 123: push_tok(Tok::LBrace as i64, st, 1, 0); adv(1); continue;    // {
            case 125: push_tok(Tok::RBrace as i64, st, 1, 0); adv(1); continue;    // }
            case 91: push_tok(Tok::LBracket as i64, st, 1, 0); adv(1); continue;   // [
            case 93: push_tok(Tok::RBracket as i64, st, 1, 0); adv(1); continue;   // ]
            case 44: push_tok(Tok::Comma as i64, st, 1, 0); adv(1); continue;      // ,
            case 59: push_tok(Tok::Semicolon as i64, st, 1, 0); adv(1); continue;  // ;
            case 63: push_tok(Tok::Question as i64, st, 1, 0); adv(1); continue;   // ?
            case 126: push_tok(Tok::Tilde as i64, st, 1, 0); adv(1); continue;     // ~
            case 58:   // :  ->  ::
                if (peek(1) == 58) { push_tok(Tok::DoubleColon as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Colon as i64, st, 1, 0); adv(1); continue;
            case 46:   // .  ->  ..
                if (peek(1) == 46) { push_tok(Tok::DotDot as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Dot as i64, st, 1, 0); adv(1); continue;
            case 45:   // -  ->  --  ->  ->  ->  -=
                if (peek(1) == 45) { push_tok(Tok::Dec as i64, st, 2, 0); adv(2); continue; }
                if (peek(1) == 62) { push_tok(Tok::Arrow as i64, st, 2, 0); adv(2); continue; }
                if (peek(1) == 61) { push_tok(Tok::MinusAssign as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Minus as i64, st, 1, 0); adv(1); continue;
            case 43:   // +  ->  ++  ->  +=
                if (peek(1) == 43) { push_tok(Tok::Inc as i64, st, 2, 0); adv(2); continue; }
                if (peek(1) == 61) { push_tok(Tok::PlusAssign as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Plus as i64, st, 1, 0); adv(1); continue;
            case 42:   // *  ->  *=
                if (peek(1) == 61) { push_tok(Tok::StarAssign as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Star as i64, st, 1, 0); adv(1); continue;
            case 47:   // /  ->  /=   (comments handled above)
                if (peek(1) == 61) { push_tok(Tok::SlashAssign as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Slash as i64, st, 1, 0); adv(1); continue;
            case 37:   // %  ->  %=
                if (peek(1) == 61) { push_tok(Tok::PercentAssign as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Percent as i64, st, 1, 0); adv(1); continue;
            case 61:   // =  ->  ==  ->  =>
                if (peek(1) == 61) { push_tok(Tok::Eq as i64, st, 2, 0); adv(2); continue; }
                if (peek(1) == 62) { push_tok(Tok::FatArrow as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Assign as i64, st, 1, 0); adv(1); continue;
            case 33:   // !  ->  !=
                if (peek(1) == 61) { push_tok(Tok::Neq as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Not as i64, st, 1, 0); adv(1); continue;
            case 60:   // <  ->  <=  ->  <<  ->  <<=
                if (peek(1) == 60 && peek(2) == 61) { push_tok(Tok::ShlAssign as i64, st, 3, 0); adv(3); continue; }
                if (peek(1) == 60) { push_tok(Tok::Shl as i64, st, 2, 0); adv(2); continue; }
                if (peek(1) == 61) { push_tok(Tok::Le as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Lt as i64, st, 1, 0); adv(1); continue;
            case 62:   // >  ->  >=  ->  >>  ->  >>=
                if (peek(1) == 62 && peek(2) == 61) { push_tok(Tok::ShrAssign as i64, st, 3, 0); adv(3); continue; }
                if (peek(1) == 62) { push_tok(Tok::Shr as i64, st, 2, 0); adv(2); continue; }
                if (peek(1) == 61) { push_tok(Tok::Ge as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Gt as i64, st, 1, 0); adv(1); continue;
            case 38:   // &  ->  &&  ->  &=
                if (peek(1) == 38) { push_tok(Tok::AndAnd as i64, st, 2, 0); adv(2); continue; }
                if (peek(1) == 61) { push_tok(Tok::AmpAssign as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Amp as i64, st, 1, 0); adv(1); continue;
            case 124:   // |  ->  ||  ->  |=
                if (peek(1) == 124) { push_tok(Tok::OrOr as i64, st, 2, 0); adv(2); continue; }
                if (peek(1) == 61) { push_tok(Tok::PipeAssign as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Pipe as i64, st, 1, 0); adv(1); continue;
            case 94:   // ^  ->  ^=
                if (peek(1) == 61) { push_tok(Tok::CaretAssign as i64, st, 2, 0); adv(2); continue; }
                push_tok(Tok::Caret as i64, st, 1, 0); adv(1); continue;
            default:
                lex_error(g_line, g_col);   // unexpected character
                go = 0;
                break;
        }
    }

    // EOF token (always last), at the current position.
    g_tok_line = g_line;
    g_tok_col = g_col;
    push_tok(Tok::Eof as i64, g_pos, 0, 0);
    return g_arr;
}

// -----------------------------------------------------------------------------
// typed read surface over the flat token store. Callers use these to inspect
// the token stream; get_token() builds a real Token struct for convenience.
// -----------------------------------------------------------------------------

// number of tokens in the array (including the trailing Eof).
fn tok_count(arr: i64) -> i64 {
    let n: i64 = array_length(arr);
    return n / LEX_STRIDE;
}

fn tok_kind(arr: i64, i: i64) -> i64 {
    return array_get_i64(arr, i * LEX_STRIDE + 0);
}

fn tok_start(arr: i64, i: i64) -> i64 {
    return array_get_i64(arr, i * LEX_STRIDE + 1);
}

fn tok_len(arr: i64, i: i64) -> i64 {
    return array_get_i64(arr, i * LEX_STRIDE + 2);
}

fn tok_line(arr: i64, i: i64) -> i64 {
    return array_get_i64(arr, i * LEX_STRIDE + 3);
}

fn tok_col(arr: i64, i: i64) -> i64 {
    return array_get_i64(arr, i * LEX_STRIDE + 4);
}

fn tok_ivalue(arr: i64, i: i64) -> i64 {
    return array_get_i64(arr, i * LEX_STRIDE + 5);
}

// the token's text — the raw source span sliced out of the original source.
fn tok_text(arr: i64, i: i64) -> string {
    let s: i64 = tok_start(arr, i);
    let l: i64 = tok_len(arr, i);
    if (l <= 0) { return string_from_slice(""); }
    return string_substr(g_src, s, l);
}

// the float value (FloatLit only). Decoded on demand from the source span —
// ember has no working global f64 array (the element read returns 0.0 at
// runtime despite passing sema) and no f64 slot in the array extension, so the
// float value is re-derived from g_src by decode_float whenever it is read.
// Returns 0.0 for non-FloatLit tokens.
fn tok_fvalue(arr: i64, i: i64) -> f64 {
    if (tok_kind(arr, i) != (Tok::FloatLit as i64)) { return 0.0; }
    let s: i64 = tok_start(arr, i);
    let l: i64 = tok_len(arr, i);
    return decode_float(s, l);
}

// build a real Token struct for token i, assembling all fields from the flat
// store. fvalue is decoded on demand from the source span. This is the typed
// surface the task's Token struct describes.
fn get_token(arr: i64, i: i64) -> Token {
    let k: i64 = tok_kind(arr, i);
    let t: string = tok_text(arr, i);
    let ln: i64 = tok_line(arr, i);
    let co: i64 = tok_col(arr, i);
    let iv: i64 = tok_ivalue(arr, i);
    let fv: f64 = tok_fvalue(arr, i);
    let tk: Token = Token { kind: k, text: t, line: ln, col: co, ivalue: iv, fvalue: fv };
    return tk;
}

// whether the lexer hit an error (set by lex_error during lex()).
fn lex_failed() -> i64 {
    return g_err;
}

// self_hosted/parse.ember — the ember parser, written IN ember.
//
// Self-hosting Stage 2: prove ember can parse itself. This is a port of
// src/parser.cpp (the C++ reference recursive-descent parser) to ember
// source. It consumes the token stream from Stage 1's lexer (lex.ember) and
// builds an AST in a flat node pool.
//
// === AST storage design ===
//
// Like the lexer's flat token store, the AST is a growable `array`-extension
// buffer of i64s with a fixed stride per node. ember's type system cannot
// store strings in the array extension (array_push_i64 is i64-only), so node
// names are stored as TOKEN INDICES: a node's `tok` field is an index into the
// lexer's token array, and the name is retrieved on demand via
// `tok_text(g_toks, tok)`. This reuses the lexer's existing text-decoding
// infrastructure and avoids a separate string pool. For synthetic nodes with
// no source token (e.g. a program root), `tok` is -1.
//
//   flat stride (8 i64s per node): [ kind, tok, a, b, c, d, e, f ]
//     kind  — NK enum value (which production)
//     tok   — token index for the node's name/text, or -1
//     a..f  — general-purpose child/field slots (node indices, flags, op
//             codes, primitive enum values, etc.). -1 = "no value" for a
//             child slot.
//
// Lists (block statements, params, args, fields, enum variants, struct-lit
// field inits, array-lit elements) are first-child + next-sibling linked via
// the `c` slot (next). This is the classic compact tree representation: a
// Block node's `a` = first stmt; each stmt's `c` = next stmt (or -1).
//
// === Operator encodings ===
//
// Binary ops (BinExpr `d` slot) and compound-assign ops (AssignExpr `d` slot)
// use the BinOp enum below (matching the C++ BinExpr::Op order). Unary ops
// (UnaryExpr `d` slot) use the UnOp enum.
//
// === Error handling ===
//
// The C++ parser throws ParseError; ember has no exceptions, so this parser
// uses a global error flag (p_err). On a structural mismatch, `err(msg)` sets
// the flag + records the current token's position; every parse_* fn checks
// p_err / a -1 return and bails. parse() returns the program node index on
// success or -1 on failure; parse_failed() / parse_error_* expose the state.


// -----------------------------------------------------------------------------
// AST node kinds. i64 constants (Tier 1 enum), usable in switch + comparisons.
// Grouped by category; values are dense within a group but groups are spaced
// so new kinds can be inserted without renumbering.
// -----------------------------------------------------------------------------

// types
enum NK {
    Type         = 1,   // d=prim (Prim), tok=struct-name tok (or -1), a=elem type, e=array_len, f=is_slice
    // declarations
    FnDecl       = 10,  // tok=name, a=first Param, b=ret Type, c=body BlockStmt, d=flags
    Param        = 11,  // tok=name, a=type, next=next Param
    StructDecl   = 12,  // tok=name, a=first Field
    Field        = 13,  // tok=name, a=type, next=next Field
    EnumDecl     = 14,  // tok=name, a=first Variant
    Variant      = 15,  // tok=name, a=value expr (or -1), next=next Variant
    GlobalDecl   = 16,  // tok=name, a=type, b=init expr, d=is_const
    LinkDecl     = 17,  // tok=target, a=alias tok (or -1)
    StaticAssertDecl = 18, // a=cond expr, tok=msg tok
    NamespaceDecl = 19, // tok=name, a=first member decl
    // statements
    LetStmt      = 20,  // tok=name, a=type (or -1), b=init expr (or -1), d=flags
    IfStmt       = 21,  // a=cond, b=then BlockStmt, c=else BlockStmt (or -1)
    WhileStmt    = 22,  // a=cond, b=body BlockStmt
    ForStmt      = 23,  // a=init (LetStmt or -1), b=cond (or -1), c=step (or -1), e=body BlockStmt
    ForEachStmt  = 24,  // tok=var name, a=iter expr, b=body BlockStmt
    DoWhileStmt  = 25,  // a=body BlockStmt, b=cond expr
    ReturnStmt   = 26,  // a=value expr (or -1)
    BreakStmt    = 27,
    ContinueStmt = 28,
    DeferStmt    = 29,  // a=expr
    ExprStmt     = 30,  // a=expr
    BlockStmt    = 31,  // a=first stmt (linked via next)
    SwitchStmt   = 32,  // a=subject expr, b=first Case
    Case         = 33,  // a=value expr (or -1 for default), b=first body stmt, next=next Case, d=is_default
    MatchStmt    = 34,  // a=subject expr, b=first MatchArm
    MatchArm     = 35,  // a=pattern expr (or -1 for wildcard/struct-pat), b=body BlockStmt, next=next MatchArm, d=is_wildcard, e=guard, f=has_struct_pat, tok=struct type-name, c=first struct-pattern FieldInit
    YieldStmt    = 36,  // a=value expr (or -1)
    ThrowStmt    = 37,  // a=value expr
    TryCatchStmt = 38,  // a=try BlockStmt, b=catch BlockStmt, tok=catch-name tok
    StaticAssertStmt = 39, // a=cond expr, tok=msg tok
    // expressions
    IntLit       = 50,  // d=ivalue
    BoolLit      = 51,  // d=bvalue (0 or 1)
    FloatLit     = 52,  // tok=token idx (fvalue decoded on demand from token)
    StringLit    = 53,  // tok=token idx (text from token)
    Ident        = 54,  // tok=token idx (name from token)
    BinExpr      = 55,  // d=op (BinOp), a=lhs, b=rhs
    UnaryExpr    = 56,  // d=op (UnOp), a=operand
    AssignExpr   = 57,  // a=target, b=value, d=compound op (or -1), e=postfix flag
    CallExpr     = 58,  // tok=name tok (or -1 for indirect), a=first arg, next=next arg, b=receiver (or -1), e=indirect target (or -1)
    FieldExpr    = 59,  // a=base, tok=field tok
    IndexExpr    = 60,  // a=base, b=index
    CastExpr     = 61,  // a=operand, b=to Type
    TernaryExpr  = 62,  // a=cond, b=then_e, c=else_e
    StructLit    = 63,  // tok=type-name tok, a=first FieldInit
    FieldInit    = 64,  // tok=field-name tok, a=value expr, next=next FieldInit
    ArrayLit     = 65,  // a=first element (linked via next)
    ViewExpr     = 66,  // a=base
    FnHandleExpr = 67,  // a=operand (or -1 for cross-module), tok=fn-name tok, e=module-alias tok (or -1)
    LambdaExpr   = 68,  // a=first Param, b=ret Type, c=body BlockStmt, e=first by-ref capture Ident (d=1), next=next capture
    EnumAccess   = 69,  // tok=variant tok, a=enum-name tok (the base Ident's tok)
    SizeofExpr   = 70,  // a=Type
    OffsetofExpr = 71,  // a=Type, tok=field tok
    // root
    Program      = 90,  // a=first top-level decl (linked via next)
}

// Binary operator encoding (matches C++ BinExpr::Op order: Add=0..LOr=15).
enum BinOp {
    Add  = 0,  Sub  = 1,  Mul  = 2,  Div  = 3,  Mod  = 4,
    And  = 5,  Or   = 6,  Xor  = 7,  Shl  = 8,  Shr  = 9,
    Eq   = 10, Neq  = 11, Lt   = 12, Le   = 13, Gt   = 14, Ge   = 15,
    LAnd = 16, LOr  = 17,
}

// Unary operator encoding (matches C++ UnaryExpr::Op: Neg=0, Not=1, BitNot=2).
enum UnOp {
    Neg    = 0,
    Not    = 1,
    BitNot = 2,
}

// Primitive type encoding (matches C++ Prim order: Void=0..F64=12).
enum Prim {
    Void = 0, Bool = 1,
    I8 = 2, I16 = 3, I32 = 4, I64 = 5,
    U8 = 6, U16 = 7, U32 = 8, U64 = 9,
    F32 = 10, F64 = 11,
}

// --- LetStmt / FnDecl flag bits (stored in the `d` slot) ---
global LF_MUT  : i64 = 1;    // LetStmt: `mut`
global LF_CONST: i64 = 2;    // LetStmt: `const`
global LF_AUTO : i64 = 4;    // LetStmt: `auto` (no declared type)
global FD_PRIV : i64 = 1;    // FnDecl: `priv`
global FD_CEXPR: i64 = 2;    // FnDecl: `constexpr`

// -----------------------------------------------------------------------------
// parser state (scalar globals — same pattern as the lexer's g_src/g_arr/etc.)
// -----------------------------------------------------------------------------

global g_toks : i64 = 0;     // the token array handle (from lex())
global g_ti   : i64 = 0;     // current token index (cursor into g_toks)
global g_tcount: i64 = 0;    // token count (including trailing Eof)
global g_nodes : i64 = 0;    // the AST node array handle (flat store, elem_size 8)
global p_err   : i64 = 0;    // 1 once a parse error is flagged
global p_errline : i64 = 0;
global p_errcol  : i64 = 0;
global p_errmsg  : string = "";

// node stride: 9 i64s per node.
//   [ kind, tok, a, b, c, d, e, f, next ]
// `next` is the DEDICATED next-sibling link for list nodes (block stmts,
// params, args, fields, variants, enum variants, struct-lit field inits,
// array-lit elements, top-level decls). It is NEVER used for node-specific
// data, so statement types can freely use a..f for their own fields without
// clobbering the sibling chain. (An earlier 8-slot design overloaded `c` for
// both next-sibling AND IfStmt's else-branch / ForStmt's step — a conflict
// that silently broke list traversal.)
global PARSE_STRIDE : i64 = 9;

// -----------------------------------------------------------------------------
// node pool — allocate + accessors.
// -----------------------------------------------------------------------------

// Allocate one node of `kind`, zero all slots, bump the count. Returns the
// new node's index, or -1 on error.
fn alloc_node(kind: i64) -> i64 {
    let idx: i64 = array_length(g_nodes) / PARSE_STRIDE;
    array_push_i64(g_nodes, kind);
    array_push_i64(g_nodes, -1);   // tok
    array_push_i64(g_nodes, -1);   // a
    array_push_i64(g_nodes, -1);   // b
    array_push_i64(g_nodes, -1);   // c
    array_push_i64(g_nodes, 0);    // d
    array_push_i64(g_nodes, -1);   // e
    array_push_i64(g_nodes, -1);   // f
    array_push_i64(g_nodes, -1);   // next (sibling link)
    return idx;
}

// typed accessors — each returns the i64 at slot offset within node i.
fn nk_kind(i: i64) -> i64 { return array_get_i64(g_nodes, i * PARSE_STRIDE + 0); }
fn nk_tok(i: i64) -> i64 { return array_get_i64(g_nodes, i * PARSE_STRIDE + 1); }
fn nk_a(i: i64)   -> i64 { return array_get_i64(g_nodes, i * PARSE_STRIDE + 2); }
fn nk_b(i: i64)   -> i64 { return array_get_i64(g_nodes, i * PARSE_STRIDE + 3); }
fn nk_c(i: i64)   -> i64 { return array_get_i64(g_nodes, i * PARSE_STRIDE + 4); }
fn nk_d(i: i64)   -> i64 { return array_get_i64(g_nodes, i * PARSE_STRIDE + 5); }
fn nk_e(i: i64)   -> i64 { return array_get_i64(g_nodes, i * PARSE_STRIDE + 6); }
fn nk_f(i: i64)   -> i64 { return array_get_i64(g_nodes, i * PARSE_STRIDE + 7); }
fn nk_next(i: i64) -> i64 { return array_get_i64(g_nodes, i * PARSE_STRIDE + 8); }

// setters for the general-purpose slots + the dedicated next-sibling link.
fn set_tok(i: i64, v: i64) -> i64 { array_set_i64(g_nodes, i * PARSE_STRIDE + 1, v); return 0; }
fn set_a(i: i64, v: i64) -> i64 { array_set_i64(g_nodes, i * PARSE_STRIDE + 2, v); return 0; }
fn set_b(i: i64, v: i64) -> i64 { array_set_i64(g_nodes, i * PARSE_STRIDE + 3, v); return 0; }
fn set_c(i: i64, v: i64) -> i64 { array_set_i64(g_nodes, i * PARSE_STRIDE + 4, v); return 0; }
fn set_d(i: i64, v: i64) -> i64 { array_set_i64(g_nodes, i * PARSE_STRIDE + 5, v); return 0; }
fn set_e(i: i64, v: i64) -> i64 { array_set_i64(g_nodes, i * PARSE_STRIDE + 6, v); return 0; }
fn set_f(i: i64, v: i64) -> i64 { array_set_i64(g_nodes, i * PARSE_STRIDE + 7, v); return 0; }
fn set_next(i: i64, v: i64) -> i64 { array_set_i64(g_nodes, i * PARSE_STRIDE + 8, v); return 0; }

// number of nodes allocated.
fn node_count() -> i64 {
    return array_length(g_nodes) / PARSE_STRIDE;
}

// retrieve a node's name text (from its `tok` index into the token array).
// Returns "" if tok < 0.
fn nk_name(i: i64) -> string {
    let t: i64 = nk_tok(i);
    if (t < 0) { return string_from_slice(""); }
    return tok_text(g_toks, t);
}

// retrieve an arbitrary token's text by token index (convenience for callers
// that hold a raw token index, e.g. the fn-handle module alias).
fn tok_text_at(ti: i64) -> string {
    if (ti < 0) { return string_from_slice(""); }
    return tok_text(g_toks, ti);
}

// the decoded body of a string-literal token (quotes stripped). The lexer
// records StringLit / RawStringLit tokens as the RAW source span (quotes +
// escapes included — see lex.ember's tok_text doc). This helper strips the
// surrounding quotes so callers comparing against a decoded literal get the
// content, not the raw source. For a plain "...": strips the leading + trailing
// '"'. For a raw r"""...""": strips the leading r""" + trailing """.
// Non-string tokens return their raw text unchanged.
fn tok_string_body(ti: i64) -> string {
    if (ti < 0) { return string_from_slice(""); }
    let k: i64 = tok_kind(g_toks, ti);
    let raw: string = tok_text(g_toks, ti);
    let n: i64 = string_length(raw);
    if (k == (Tok::StringLit as i64)) {
        // "..."  — strip first + last char (the quotes)
        if (n >= 2) { return string_substr(raw, 1, n - 2); }
        return string_from_slice("");
    }
    if (k == (Tok::RawStringLit as i64)) {
        // r"""..."""  — strip leading 4 (r""") + trailing 3 (""")
        if (n >= 7) { return string_substr(raw, 4, n - 7); }
        return string_from_slice("");
    }
    // non-string: return the raw text (idents, keywords, etc.)
    return raw;
}

// the decoded string body of a node's `tok` (for nodes whose name token is a
// string literal, e.g. LinkDecl's target, StaticAssert's message, StringLit
// expr). For non-string tokens this is the same as nk_name.
fn nk_string_body(i: i64) -> string {
    let t: i64 = nk_tok(i);
    return tok_string_body(t);
}

// -----------------------------------------------------------------------------
// token cursor — peek / advance / accept / expect, all over g_toks at g_ti.
// -----------------------------------------------------------------------------

// the current token's kind.
fn cur_kind() -> i64 {
    return tok_kind(g_toks, g_ti);
}

// peek a token kind at offset off (clamped to the trailing Eof).
fn peek_kind(off: i64) -> i64 {
    let idx: i64 = g_ti + off;
    if (idx >= g_tcount) { return Tok::Eof as i64; }
    if (idx < 0) { return tok_kind(g_toks, 0); }
    return tok_kind(g_toks, idx);
}

// is the current token of this kind?
fn at(kind: i64) -> i64 {
    if (cur_kind() == kind) { return 1; }
    return 0;
}

// advance the cursor; return the index of the token that was consumed. Clamps
// at the trailing Eof so p_adv() past EOF stays on EOF.
fn p_adv() -> i64 {
    let idx: i64 = g_ti;
    if (g_ti < g_tcount - 1) { g_ti = g_ti + 1; }
    return idx;
}

// if the current token is `kind`, consume it and return 1; else return 0.
fn accept(kind: i64) -> i64 {
    if (cur_kind() == kind) { p_adv(); return 1; }
    return 0;
}

// the current token's text (for error messages + identifier consumption).
fn cur_text() -> string {
    return tok_text(g_toks, g_ti);
}

// the current token's ivalue (for integer literals).
fn cur_ivalue() -> i64 {
    return tok_ivalue(g_toks, g_ti);
}

// -----------------------------------------------------------------------------
// error reporting. err(msg) flags the error at the current token and returns
// -1 so callers can `return err(...)` inline. err_after(msg) anchors the error
// one token back (for "expected X after Y" messages, matching the C++ parser's
// end-of-last-consumed-token anchoring).
// -----------------------------------------------------------------------------

fn err(msg: string) -> i64 {
    if (p_err == 0) {
        p_err = 1;
        p_errline = tok_line(g_toks, g_ti);
        p_errcol = tok_col(g_toks, g_ti);
        p_errmsg = msg;
    }
    return -1;
}

fn err_at(msg: string, line: i64, col: i64) -> i64 {
    if (p_err == 0) {
        p_err = 1;
        p_errline = line;
        p_errcol = col;
        p_errmsg = msg;
    }
    return -1;
}

// expect a token of `kind`; consume + return its index on success, or set an
// error and return -1. `what` is the human-readable description for the error.
fn expect(kind: i64, what: string) -> i64 {
    if (cur_kind() != kind) {
        return err(what);
    }
    return p_adv();
}

// -----------------------------------------------------------------------------
// type parsing. Mirrors the C++ parse_type: a primitive / named struct / fn
// type, then postfix [N] (fixed array) or [] (slice) suffixes.
//
//   type := prim | ident | fn ['(' [type {',' type}] ')' '->' type]
//         { '[' ']' | '[' IntLit ']' }
// -----------------------------------------------------------------------------

// Map a primitive-type keyword token kind to a Prim value, or -1 if not a prim.
fn prim_of_kind(kind: i64) -> i64 {
    if (kind == (Tok::Kw_void as i64)) { return Prim::Void as i64; }
    if (kind == (Tok::Kw_bool as i64)) { return Prim::Bool as i64; }
    if (kind == (Tok::Kw_i8 as i64))   { return Prim::I8 as i64; }
    if (kind == (Tok::Kw_i16 as i64))  { return Prim::I16 as i64; }
    if (kind == (Tok::Kw_i32 as i64))  { return Prim::I32 as i64; }
    if (kind == (Tok::Kw_i64 as i64))  { return Prim::I64 as i64; }
    if (kind == (Tok::Kw_u8 as i64))   { return Prim::U8 as i64; }
    if (kind == (Tok::Kw_u16 as i64))  { return Prim::U16 as i64; }
    if (kind == (Tok::Kw_u32 as i64))  { return Prim::U32 as i64; }
    if (kind == (Tok::Kw_u64 as i64))  { return Prim::U64 as i64; }
    if (kind == (Tok::Kw_f32 as i64))  { return Prim::F32 as i64; }
    if (kind == (Tok::Kw_f64 as i64))  { return Prim::F64 as i64; }
    return -1;
}

// parse a type, returning a Type node index (or -1 on error).
fn parse_type() -> i64 {
    let k: i64 = cur_kind();
    let p: i64 = prim_of_kind(k);
    let mut n: i64 = 0;

    if (p >= 0) {
        // primitive
        p_adv();
        n = alloc_node(NK::Type as i64);
        if (p_err != 0) { return -1; }
        set_d(n, p);
        return parse_type_suffix(n);
    }

    if (k == (Tok::Kw_fn as i64)) {
        // fn type (function handle). prim=I64, is_fn_handle carried implicitly.
        p_adv();
        n = alloc_node(NK::Type as i64);
        if (p_err != 0) { return -1; }
        set_d(n, Prim::I64 as i64);
        set_f(n, 2);  // function/closure type marker (distinct from f=1 slice)
        // optional '(' params ')' '->' ret signature
        if (at(Tok::LParen as i64) == 1) {
            p_adv();
            // parse param types (stored as a list in `a` via c=next)
            let mut first: i64 = -1;
            let mut prev: i64 = -1;
            if (at(Tok::RParen as i64) == 0) {
                let mut go: i64 = 1;
                while (go == 1) {
                    let pt: i64 = parse_type();
                    if (p_err != 0) { return -1; }
                    if (first < 0) { first = pt; }
                    else { set_next(prev, pt); }
                    prev = pt;
                    if (accept(Tok::Comma as i64) == 0) { go = 0; }
                }
            }
            if (first >= 0) { set_a(n, first); }
            if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
            if (expect(Tok::Arrow as i64, string_from_slice("expected '->' in function type")) < 0) { return -1; }
            let rt: i64 = parse_type();
            if (p_err != 0) { return -1; }
            set_b(n, rt);   // ret type in `b` for fn types
        }
        return parse_type_suffix(n);
    }

    if (k == (Tok::Ident as i64)) {
        // named struct type
        let ntok: i64 = p_adv();
        n = alloc_node(NK::Type as i64);
        if (p_err != 0) { return -1; }
        set_d(n, Prim::Void as i64);   // Void prim = named-type marker
        set_tok(n, ntok);
        return parse_type_suffix(n);
    }

    return err(string_from_slice("expected type"));
}

// postfix [N] / [] suffixes on a base type. Returns `n` (possibly wrapped in a
// new array/slice Type node).
fn parse_type_suffix(n: i64) -> i64 {
    let mut base: i64 = n;
    let mut go: i64 = 1;
    while (go == 1) {
        if (at(Tok::LBracket as i64) == 0) { go = 0; continue; }
        p_adv();  // '['
        if (accept(Tok::RBracket as i64) == 1) {
            // slice T[]
            let s: i64 = alloc_node(NK::Type as i64);
            if (p_err != 0) { return -1; }
            set_f(s, 1);            // is_slice
            set_a(s, base);         // elem
            base = s;
            continue;
        }
        // fixed array T[N]
        let ntok: i64 = expect(Tok::IntLit as i64, string_from_slice("expected integer array size"));
        if (p_err != 0) { return -1; }
        let sz: i64 = tok_ivalue(g_toks, ntok);
        if (sz <= 0) {
            return err(string_from_slice("array size must be a positive integer"));
        }
        if (expect(Tok::RBracket as i64, string_from_slice("expected ']'")) < 0) { return -1; }
        let arr: i64 = alloc_node(NK::Type as i64);
        if (p_err != 0) { return -1; }
        set_e(arr, sz);         // array_len
        set_a(arr, base);       // elem
        base = arr;
    }
    return base;
}

// helpers for type nodes (used by the test + future sema).
fn type_is_slice(t: i64) -> i64 { return nk_f(t); }
fn type_array_len(t: i64) -> i64 { return nk_e(t); }
fn type_prim(t: i64) -> i64 { return nk_d(t); }
fn type_elem(t: i64) -> i64 { return nk_a(t); }
fn type_ret(t: i64) -> i64 { return nk_b(t); }   // fn type's ret (in b)
fn type_name(t: i64) -> string { return nk_name(t); }

// -----------------------------------------------------------------------------
// parameter parsing: NAME ':' type ['=' literal]. Returns a Param node index
// (or -1 on error). For v1 the default value is recorded as a parsed expr in
// `b` (the C++ parser restricts it to a literal; we parse an expr and let a
// later pass restrict — keeps the parser simple).
// -----------------------------------------------------------------------------

fn parse_param() -> i64 {
    let ntok: i64 = expect(Tok::Ident as i64, string_from_slice("expected parameter name"));
    if (p_err != 0) { return -1; }
    if (expect(Tok::Colon as i64, string_from_slice("expected ':'")) < 0) { return -1; }
    let ty: i64 = parse_type();
    if (p_err != 0) { return -1; }
    let p: i64 = alloc_node(NK::Param as i64);
    if (p_err != 0) { return -1; }
    set_tok(p, ntok);
    set_a(p, ty);
    if (accept(Tok::Assign as i64) == 1) {
        let dv: i64 = parse_expr();
        if (p_err != 0) { return -1; }
        set_b(p, dv);
    }
    return p;
}

// -----------------------------------------------------------------------------
// expression parsing — precedence climbing, mirroring the C++ parse_expr chain:
//   expr    := assign
//   assign  := ternary [ ('=' | '+=' | ...) assign ]
//   ternary := or [ '?' expr ':' ternary ]
//   or      := and { '||' and }
//   and     := bxor { '&&' bxor }
//   bxor    := bor { '^' bor }
//   bor     := band { '|' band }
//   band    := eq { '&' eq }
//   eq      := rel { ('==' | '!=') rel }
//   rel     := shift { ('<' | '<=' | '>' | '>=') shift }
//   shift   := add { ('<<' | '>>') add }
//   add     := mul { ('+' | '-') mul }
//   mul     := cast { ('*' | '/' | '%') cast }
//   cast    := unary { 'as' type }
//   unary   := ('-' | '!' | '~' | '&' | '++' | '--') unary | postfix
//   postfix := primary { '::' ident ['(' args ')'] | '(' args ')' | '[' ... ']' | '.' ident | '++' | '--' }
//   primary := IntLit | FloatLit | BoolLit | StringLit | ident [struct-lit] | '(' expr ')' | '[' array-lit ']' | ...
// -----------------------------------------------------------------------------

// map a binary-operator token kind to a BinOp value (or -1 if not a binop).
fn binop_of(kind: i64) -> i64 {
    if (kind == (Tok::Plus as i64))    { return BinOp::Add as i64; }
    if (kind == (Tok::Minus as i64))   { return BinOp::Sub as i64; }
    if (kind == (Tok::Star as i64))    { return BinOp::Mul as i64; }
    if (kind == (Tok::Slash as i64))   { return BinOp::Div as i64; }
    if (kind == (Tok::Percent as i64)) { return BinOp::Mod as i64; }
    if (kind == (Tok::Amp as i64))     { return BinOp::And as i64; }
    if (kind == (Tok::Pipe as i64))    { return BinOp::Or as i64; }
    if (kind == (Tok::Caret as i64))   { return BinOp::Xor as i64; }
    if (kind == (Tok::Shl as i64))     { return BinOp::Shl as i64; }
    if (kind == (Tok::Shr as i64))     { return BinOp::Shr as i64; }
    if (kind == (Tok::Eq as i64))      { return BinOp::Eq as i64; }
    if (kind == (Tok::Neq as i64))     { return BinOp::Neq as i64; }
    if (kind == (Tok::Lt as i64))      { return BinOp::Lt as i64; }
    if (kind == (Tok::Le as i64))      { return BinOp::Le as i64; }
    if (kind == (Tok::Gt as i64))      { return BinOp::Gt as i64; }
    if (kind == (Tok::Ge as i64))      { return BinOp::Ge as i64; }
    if (kind == (Tok::AndAnd as i64))  { return BinOp::LAnd as i64; }
    if (kind == (Tok::OrOr as i64))    { return BinOp::LOr as i64; }
    return -1;
}

// parse a comma-separated arg list into a first-child/next-sibling list.
// Returns the first arg node index (or -1 if no args). The caller has already
// NOT consumed the '('; this fn consumes '(' ... ')'.
fn parse_arg_list() -> i64 {
    if (expect(Tok::LParen as i64, string_from_slice("expected '('")) < 0) { return -1; }
    let mut first: i64 = -1;
    let mut prev: i64 = -1;
    if (at(Tok::RParen as i64) == 0) {
        let mut go: i64 = 1;
        while (go == 1) {
            let a: i64 = parse_expr();
            if (p_err != 0) { return -1; }
            if (first < 0) { first = a; }
            else { set_next(prev, a); }
            prev = a;
            if (accept(Tok::Comma as i64) == 0) { go = 0; }
        }
    }
    if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
    return first;
}

// parse_primary — literals, idents, parenthesized exprs, array literals, etc.
fn parse_primary() -> i64 {
    let k: i64 = cur_kind();

    if (k == (Tok::IntLit as i64)) {
        let v: i64 = cur_ivalue();
        p_adv();
        let n: i64 = alloc_node(NK::IntLit as i64);
        if (p_err != 0) { return -1; }
        set_d(n, v);
        return n;
    }
    if (k == (Tok::FloatLit as i64)) {
        let t: i64 = p_adv();
        let n: i64 = alloc_node(NK::FloatLit as i64);
        if (p_err != 0) { return -1; }
        set_tok(n, t);
        return n;
    }
    if (k == (Tok::BoolLit as i64)) {
        // true/false — decode from the token text (true=1, false=0)
        let t: i64 = p_adv();
        let txt: string = tok_text(g_toks, t);
        let mut bv: i64 = 0;
        if (txt == string_from_slice("true")) { bv = 1; }
        let n: i64 = alloc_node(NK::BoolLit as i64);
        if (p_err != 0) { return -1; }
        set_d(n, bv);
        set_tok(n, t);
        return n;
    }
    if (k == (Tok::StringLit as i64) || k == (Tok::RawStringLit as i64)) {
        let t: i64 = p_adv();
        let n: i64 = alloc_node(NK::StringLit as i64);
        if (p_err != 0) { return -1; }
        set_tok(n, t);
        return n;
    }
    if (k == (Tok::FStringLit as i64)) {
        // v1 simplification: record the f-string token; a later pass desugars
        // it (the C++ parser splits it into literal+interpolation segments).
        let t: i64 = p_adv();
        let n: i64 = alloc_node(NK::StringLit as i64);
        if (p_err != 0) { return -1; }
        set_tok(n, t);
        set_d(n, 1);   // flag: this is an f-string, not a plain string
        return n;
    }
    if (k == (Tok::Ident as i64)) {
        let ntok: i64 = p_adv();
        // struct literal?  IDENT '{' field: expr, ... '}'
        if (at(Tok::LBrace as i64) == 1) {
            p_adv();  // '{'
            let sl: i64 = alloc_node(NK::StructLit as i64);
            if (p_err != 0) { return -1; }
            set_tok(sl, ntok);
            let mut first: i64 = -1;
            let mut prev: i64 = -1;
            if (at(Tok::RBrace as i64) == 0) {
                let mut go: i64 = 1;
                while (go == 1) {
                    let ft: i64 = expect(Tok::Ident as i64, string_from_slice("expected field name"));
                    if (p_err != 0) { return -1; }
                    if (expect(Tok::Colon as i64, string_from_slice("expected ':'")) < 0) { return -1; }
                    let fv: i64 = parse_expr();
                    if (p_err != 0) { return -1; }
                    let fi: i64 = alloc_node(NK::FieldInit as i64);
                    if (p_err != 0) { return -1; }
                    set_tok(fi, ft);
                    set_a(fi, fv);
                    if (first < 0) { first = fi; }
                    else { set_next(prev, fi); }
                    prev = fi;
                    if (accept(Tok::Comma as i64) == 0) { go = 0; }
                }
            }
            if (first >= 0) { set_a(sl, first); }
            if (expect(Tok::RBrace as i64, string_from_slice("expected '}'")) < 0) { return -1; }
            return sl;
        }
        // plain identifier
        let n: i64 = alloc_node(NK::Ident as i64);
        if (p_err != 0) { return -1; }
        set_tok(n, ntok);
        return n;
    }
    if (k == (Tok::LParen as i64)) {
        p_adv();  // '('
        let e: i64 = parse_expr();
        if (p_err != 0) { return -1; }
        if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
        return e;
    }
    if (k == (Tok::LBracket as i64)) {
        // array literal [ expr, expr, ... ]
        p_adv();  // '['
        let al: i64 = alloc_node(NK::ArrayLit as i64);
        if (p_err != 0) { return -1; }
        let mut first: i64 = -1;
        let mut prev: i64 = -1;
        if (at(Tok::RBracket as i64) == 0) {
            let mut go: i64 = 1;
            while (go == 1) {
                let e: i64 = parse_expr();
                if (p_err != 0) { return -1; }
                if (first < 0) { first = e; }
                else { set_next(prev, e); }
                prev = e;
                if (accept(Tok::Comma as i64) == 0) { go = 0; }
            }
        }
        if (first >= 0) { set_a(al, first); }
        if (expect(Tok::RBracket as i64, string_from_slice("expected ']'")) < 0) { return -1; }
        return al;
    }
    if (k == (Tok::Kw_sizeof as i64)) {
        p_adv();
        if (expect(Tok::LParen as i64, string_from_slice("expected '('")) < 0) { return -1; }
        let ty: i64 = parse_type();
        if (p_err != 0) { return -1; }
        if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
        let n: i64 = alloc_node(NK::SizeofExpr as i64);
        if (p_err != 0) { return -1; }
        set_a(n, ty);
        return n;
    }
    if (k == (Tok::Kw_offsetof as i64)) {
        p_adv();
        if (expect(Tok::LParen as i64, string_from_slice("expected '('")) < 0) { return -1; }
        let ty: i64 = parse_type();
        if (p_err != 0) { return -1; }
        if (expect(Tok::Comma as i64, string_from_slice("expected ','")) < 0) { return -1; }
        let ft: i64 = expect(Tok::Ident as i64, string_from_slice("expected field name"));
        if (p_err != 0) { return -1; }
        if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
        let n: i64 = alloc_node(NK::OffsetofExpr as i64);
        if (p_err != 0) { return -1; }
        set_a(n, ty);
        set_tok(n, ft);
        return n;
    }
    if (k == (Tok::Kw_fn as i64)) {
        // lambda: fn [capture-list]? (params) -> ret { body }
        // The optional capture list `[&x, y]` mirrors src/parser.cpp:949-958:
        // after `fn`, if a `[` is present, consume it + parse comma-separated
        // capture idents (each optionally prefixed with `&` for by-ref). Only
        // the by-ref captures are recorded (a linked list of Ident nodes off
        // the LambdaExpr's `e` slot, each with d=1 marking by-ref); bare
        // by-value names are accepted syntactically but not stored (sema's
        // implicit capture walk finds them), matching the C++ parser. The list
        // is unambiguous here: a `[` after `fn` can only be a capture list (an
        // array literal `[` never follows `fn`), and `fn` types are parsed in
        // parse_type, not here.
        p_adv();  // 'fn'
        let mut first_cap: i64 = -1;
        let mut prev_cap: i64 = -1;
        if (at(Tok::LBracket as i64) == 1) {
            p_adv();  // '['
            if (at(Tok::RBracket as i64) == 0) {
                let mut go_cap: i64 = 1;
                while (go_cap == 1) {
                    let by_ref: i64 = accept(Tok::Amp as i64);  // optional '&'
                    let cap_tok: i64 = expect(Tok::Ident as i64, string_from_slice("capture name in lambda capture list"));
                    if (p_err != 0) { return -1; }
                    // record only by-ref captures (matches C++ ref_caps)
                    if (by_ref == 1) {
                        let cap: i64 = alloc_node(NK::Ident as i64);
                        if (p_err != 0) { return -1; }
                        set_tok(cap, cap_tok);
                        set_d(cap, 1);  // by-ref flag
                        if (first_cap < 0) { first_cap = cap; }
                        else { set_next(prev_cap, cap); }
                        prev_cap = cap;
                    }
                    if (accept(Tok::Comma as i64) == 0) { go_cap = 0; }
                }
            }
            if (expect(Tok::RBracket as i64, string_from_slice("expected ']' to close lambda capture list")) < 0) { return -1; }
        }
        if (expect(Tok::LParen as i64, string_from_slice("expected '(' after 'fn'")) < 0) { return -1; }
        let mut first_p: i64 = -1;
        let mut prev_p: i64 = -1;
        if (at(Tok::RParen as i64) == 0) {
            let mut go: i64 = 1;
            while (go == 1) {
                let p: i64 = parse_param();
                if (p_err != 0) { return -1; }
                if (first_p < 0) { first_p = p; }
                else { set_next(prev_p, p); }
                prev_p = p;
                if (accept(Tok::Comma as i64) == 0) { go = 0; }
            }
        }
        if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
        let mut ret: i64 = 0;
        if (accept(Tok::Arrow as i64) == 1) {
            ret = parse_type();
            if (p_err != 0) { return -1; }
        } else {
            ret = alloc_node(NK::Type as i64);
            if (p_err != 0) { return -1; }
            set_d(ret, Prim::Void as i64);
        }
        let body: i64 = parse_block();
        if (p_err != 0) { return -1; }
        let le: i64 = alloc_node(NK::LambdaExpr as i64);
        if (p_err != 0) { return -1; }
        if (first_p >= 0) { set_a(le, first_p); }
        set_b(le, ret);
        set_c(le, body);
        // by-ref captures: linked list of Ident nodes (d=1) off slot e. -1 = none.
        if (first_cap >= 0) { set_e(le, first_cap); }
        return le;
    }

    return err(string_from_slice("unexpected token in expression"));
}

// parse_postfix — primary followed by :: / ( / [ / . / ++ / --
fn parse_postfix() -> i64 {
    let mut e: i64 = parse_primary();
    if (p_err != 0) { return -1; }
    let mut go: i64 = 1;
    while (go == 1) {
        let k: i64 = cur_kind();
        if (k == (Tok::DoubleColon as i64)) {
            // mod::fn(args)  or  Enum::variant
            // e must be an Ident
            if (nk_kind(e) != (NK::Ident as i64)) {
                return err(string_from_slice("expected '::' to follow a name"));
            }
            let base_tok: i64 = nk_tok(e);
            p_adv();  // '::'
            let name_tok: i64 = expect(Tok::Ident as i64, string_from_slice("expected name after '::'"));
            if (p_err != 0) { return -1; }
            if (at(Tok::LParen as i64) == 1) {
                // cross-module call mod::fn(args)
                let c: i64 = alloc_node(NK::CallExpr as i64);
                if (p_err != 0) { return -1; }
                set_tok(c, name_tok);
                set_e(c, base_tok);   // module-alias tok in `e`
                let args: i64 = parse_arg_list();
                if (p_err != 0) { return -1; }
                if (args >= 0) { set_a(c, args); }
                e = c;
                continue;
            }
            // enum variant access E::A
            let ea: i64 = alloc_node(NK::EnumAccess as i64);
            if (p_err != 0) { return -1; }
            set_tok(ea, name_tok);
            set_a(ea, base_tok);
            e = ea;
            continue;
        }
        if (k == (Tok::LParen as i64)) {
            // call e(args)
            let c: i64 = alloc_node(NK::CallExpr as i64);
            if (p_err != 0) { return -1; }
            if (nk_kind(e) == (NK::Ident as i64)) {
                // free fn call name(args)
                set_tok(c, nk_tok(e));
            } else if (nk_kind(e) == (NK::FieldExpr as i64)) {
                // method call obj.method(args) -> method(obj, args)
                set_tok(c, nk_tok(e));      // method name
                set_b(c, nk_a(e));           // receiver = base
            } else {
                // indirect call through a runtime handle
                set_e(c, e);                 // indirect target
            }
            let args: i64 = parse_arg_list();
            if (p_err != 0) { return -1; }
            if (args >= 0) { set_a(c, args); }
            e = c;
            continue;
        }
        if (k == (Tok::LBracket as i64)) {
            p_adv();  // '['
            if (at(Tok::DotDot as i64) == 1) {
                p_adv();  // '..'
                if (expect(Tok::RBracket as i64, string_from_slice("expected ']'")) < 0) { return -1; }
                let v: i64 = alloc_node(NK::ViewExpr as i64);
                if (p_err != 0) { return -1; }
                set_a(v, e);
                e = v;
                continue;
            }
            let idx: i64 = parse_expr();
            if (p_err != 0) { return -1; }
            if (expect(Tok::RBracket as i64, string_from_slice("expected ']'")) < 0) { return -1; }
            let x: i64 = alloc_node(NK::IndexExpr as i64);
            if (p_err != 0) { return -1; }
            set_a(x, e);
            set_b(x, idx);
            e = x;
            continue;
        }
        if (k == (Tok::Dot as i64)) {
            p_adv();
            let ft: i64 = expect(Tok::Ident as i64, string_from_slice("expected field name"));
            if (p_err != 0) { return -1; }
            let fl: i64 = alloc_node(NK::FieldExpr as i64);
            if (p_err != 0) { return -1; }
            set_a(fl, e);
            set_tok(fl, ft);
            e = fl;
            continue;
        }
        if (k == (Tok::Inc as i64) || k == (Tok::Dec as i64)) {
            p_adv();
            let a: i64 = alloc_node(NK::AssignExpr as i64);
            if (p_err != 0) { return -1; }
            set_a(a, e);    // target
            set_e(a, 1);    // postfix flag
            if (k == (Tok::Inc as i64)) { set_d(a, BinOp::Add as i64); }
            else { set_d(a, BinOp::Sub as i64); }
            e = a;
            continue;
        }
        go = 0;
    }
    return e;
}

// parse_unary — prefix - ! ~ & ++ --
fn parse_unary() -> i64 {
    let k: i64 = cur_kind();
    if (k == (Tok::Minus as i64) || k == (Tok::Not as i64) || k == (Tok::Tilde as i64)) {
        p_adv();
        let operand: i64 = parse_unary();
        if (p_err != 0) { return -1; }
        let u: i64 = alloc_node(NK::UnaryExpr as i64);
        if (p_err != 0) { return -1; }
        if (k == (Tok::Minus as i64)) { set_d(u, UnOp::Neg as i64); }
        else if (k == (Tok::Not as i64)) { set_d(u, UnOp::Not as i64); }
        else { set_d(u, UnOp::BitNot as i64); }
        set_a(u, operand);
        return u;
    }
    if (k == (Tok::Amp as i64)) {
        // &fn  or  &mod::fn  (function handle)
        p_adv();
        // &mod::fn (no call parens)
        if (peek_kind(0) == (Tok::Ident as i64) && peek_kind(1) == (Tok::DoubleColon as i64)
            && peek_kind(2) == (Tok::Ident as i64) && peek_kind(3) != (Tok::LParen as i64)) {
            let mod_tok: i64 = p_adv();
            p_adv();  // '::'
            let fn_tok: i64 = p_adv();
            let h: i64 = alloc_node(NK::FnHandleExpr as i64);
            if (p_err != 0) { return -1; }
            set_tok(h, fn_tok);
            set_e(h, mod_tok);
            return h;
        }
        let operand: i64 = parse_unary();
        if (p_err != 0) { return -1; }
        let h: i64 = alloc_node(NK::FnHandleExpr as i64);
        if (p_err != 0) { return -1; }
        set_a(h, operand);
        // tok = the fn-name token (per the node layout: `tok=fn-name tok`).
        // For `&id` the operand is the Ident holding the name, so mirror its
        // tok; this lets nk_name(fh) resolve to "id" (matching the
        // cross-module branch, which sets tok to fn_tok). For a non-Ident
        // operand nk_tok returns -1 and nk_name yields "" (same as before).
        if (nk_kind(operand) == (NK::Ident as i64)) { set_tok(h, nk_tok(operand)); }
        return h;
    }
    if (k == (Tok::Inc as i64) || k == (Tok::Dec as i64)) {
        // prefix ++/-- desugars to assign
        p_adv();
        let operand: i64 = parse_unary();
        if (p_err != 0) { return -1; }
        let a: i64 = alloc_node(NK::AssignExpr as i64);
        if (p_err != 0) { return -1; }
        set_a(a, operand);
        if (k == (Tok::Inc as i64)) { set_d(a, BinOp::Add as i64); }
        else { set_d(a, BinOp::Sub as i64); }
        let one: i64 = alloc_node(NK::IntLit as i64);
        if (p_err != 0) { return -1; }
        set_d(one, 1);
        set_b(a, one);
        return a;
    }
    return parse_postfix();
}

// parse_cast — unary { 'as' type }
fn parse_cast() -> i64 {
    let mut e: i64 = parse_unary();
    if (p_err != 0) { return -1; }
    let mut go: i64 = 1;
    while (go == 1) {
        if (at(Tok::Kw_as as i64) == 0) { go = 0; continue; }
        p_adv();
        let ty: i64 = parse_type();
        if (p_err != 0) { return -1; }
        let c: i64 = alloc_node(NK::CastExpr as i64);
        if (p_err != 0) { return -1; }
        set_a(c, e);
        set_b(c, ty);
        e = c;
    }
    return e;
}

// generic left-assoc binary level: parse `lower`, then while the current token
// is one of the ops in the predicate, fold into a BinExpr. `pred` is a fn that
// returns 1 if the token kind is an operator at this level.
fn p_mul(k: i64) -> i64 {
    if (k == (Tok::Star as i64)) { return 1; }
    if (k == (Tok::Slash as i64)) { return 1; }
    if (k == (Tok::Percent as i64)) { return 1; }
    return 0;
}
fn p_add(k: i64) -> i64 {
    if (k == (Tok::Plus as i64)) { return 1; }
    if (k == (Tok::Minus as i64)) { return 1; }
    return 0;
}
fn p_shift(k: i64) -> i64 {
    if (k == (Tok::Shl as i64)) { return 1; }
    if (k == (Tok::Shr as i64)) { return 1; }
    return 0;
}
fn p_rel(k: i64) -> i64 {
    if (k == (Tok::Lt as i64)) { return 1; }
    if (k == (Tok::Le as i64)) { return 1; }
    if (k == (Tok::Gt as i64)) { return 1; }
    if (k == (Tok::Ge as i64)) { return 1; }
    return 0;
}
fn p_eq(k: i64) -> i64 {
    if (k == (Tok::Eq as i64)) { return 1; }
    if (k == (Tok::Neq as i64)) { return 1; }
    return 0;
}
fn p_band(k: i64) -> i64 { if (k == (Tok::Amp as i64)) { return 1; } return 0; }
fn p_bor(k: i64) -> i64  { if (k == (Tok::Pipe as i64)) { return 1; } return 0; }
fn p_bxor(k: i64) -> i64 { if (k == (Tok::Caret as i64)) { return 1; } return 0; }
fn p_and(k: i64) -> i64  { if (k == (Tok::AndAnd as i64)) { return 1; } return 0; }
fn p_or(k: i64) -> i64   { if (k == (Tok::OrOr as i64)) { return 1; } return 0; }

// a binary-level helper that takes the lower-level parser fn name and the
// predicate fn name. ember has no fn-pointer-as-param in the simple call ABI
// we use, so each level is spelled out below calling the level under it.
// (The C++ parser uses a member-fn-pointer template; ember uses explicit
// per-level fns.)

fn parse_mul() -> i64 {
    let mut lhs: i64 = parse_cast();
    if (p_err != 0) { return -1; }
    let mut go: i64 = 1;
    while (go == 1) {
        let k: i64 = cur_kind();
        if (p_mul(k) == 1) {
            let op: i64 = binop_of(k);
            p_adv();
            let rhs: i64 = parse_cast();
            if (p_err != 0) { return -1; }
            let b: i64 = alloc_node(NK::BinExpr as i64);
            if (p_err != 0) { return -1; }
            set_d(b, op);
            set_a(b, lhs);
            set_b(b, rhs);
            lhs = b;
        } else { go = 0; }
    }
    return lhs;
}

fn parse_add() -> i64 {
    let mut lhs: i64 = parse_mul();
    if (p_err != 0) { return -1; }
    let mut go: i64 = 1;
    while (go == 1) {
        let k: i64 = cur_kind();
        if (p_add(k) == 1) {
            let op: i64 = binop_of(k);
            p_adv();
            let rhs: i64 = parse_mul();
            if (p_err != 0) { return -1; }
            let b: i64 = alloc_node(NK::BinExpr as i64);
            if (p_err != 0) { return -1; }
            set_d(b, op);
            set_a(b, lhs);
            set_b(b, rhs);
            lhs = b;
        } else { go = 0; }
    }
    return lhs;
}

fn parse_shift() -> i64 {
    let mut lhs: i64 = parse_add();
    if (p_err != 0) { return -1; }
    let mut go: i64 = 1;
    while (go == 1) {
        let k: i64 = cur_kind();
        if (p_shift(k) == 1) {
            let op: i64 = binop_of(k);
            p_adv();
            let rhs: i64 = parse_add();
            if (p_err != 0) { return -1; }
            let b: i64 = alloc_node(NK::BinExpr as i64);
            if (p_err != 0) { return -1; }
            set_d(b, op);
            set_a(b, lhs);
            set_b(b, rhs);
            lhs = b;
        } else { go = 0; }
    }
    return lhs;
}

fn parse_rel() -> i64 {
    let mut lhs: i64 = parse_shift();
    if (p_err != 0) { return -1; }
    let mut go: i64 = 1;
    while (go == 1) {
        let k: i64 = cur_kind();
        if (p_rel(k) == 1) {
            let op: i64 = binop_of(k);
            p_adv();
            let rhs: i64 = parse_shift();
            if (p_err != 0) { return -1; }
            let b: i64 = alloc_node(NK::BinExpr as i64);
            if (p_err != 0) { return -1; }
            set_d(b, op);
            set_a(b, lhs);
            set_b(b, rhs);
            lhs = b;
        } else { go = 0; }
    }
    return lhs;
}

fn parse_eq() -> i64 {
    let mut lhs: i64 = parse_rel();
    if (p_err != 0) { return -1; }
    let mut go: i64 = 1;
    while (go == 1) {
        let k: i64 = cur_kind();
        if (p_eq(k) == 1) {
            let op: i64 = binop_of(k);
            p_adv();
            let rhs: i64 = parse_rel();
            if (p_err != 0) { return -1; }
            let b: i64 = alloc_node(NK::BinExpr as i64);
            if (p_err != 0) { return -1; }
            set_d(b, op);
            set_a(b, lhs);
            set_b(b, rhs);
            lhs = b;
        } else { go = 0; }
    }
    return lhs;
}

fn parse_band() -> i64 {
    let mut lhs: i64 = parse_eq();
    if (p_err != 0) { return -1; }
    let mut go: i64 = 1;
    while (go == 1) {
        let k: i64 = cur_kind();
        if (p_band(k) == 1) {
            let op: i64 = binop_of(k);
            p_adv();
            let rhs: i64 = parse_eq();
            if (p_err != 0) { return -1; }
            let b: i64 = alloc_node(NK::BinExpr as i64);
            if (p_err != 0) { return -1; }
            set_d(b, op);
            set_a(b, lhs);
            set_b(b, rhs);
            lhs = b;
        } else { go = 0; }
    }
    return lhs;
}

fn parse_bxor() -> i64 {
    let mut lhs: i64 = parse_band();
    if (p_err != 0) { return -1; }
    let mut go: i64 = 1;
    while (go == 1) {
        let k: i64 = cur_kind();
        if (p_bxor(k) == 1) {
            let op: i64 = binop_of(k);
            p_adv();
            let rhs: i64 = parse_band();
            if (p_err != 0) { return -1; }
            let b: i64 = alloc_node(NK::BinExpr as i64);
            if (p_err != 0) { return -1; }
            set_d(b, op);
            set_a(b, lhs);
            set_b(b, rhs);
            lhs = b;
        } else { go = 0; }
    }
    return lhs;
}

fn parse_bor() -> i64 {
    let mut lhs: i64 = parse_bxor();
    if (p_err != 0) { return -1; }
    let mut go: i64 = 1;
    while (go == 1) {
        let k: i64 = cur_kind();
        if (p_bor(k) == 1) {
            let op: i64 = binop_of(k);
            p_adv();
            let rhs: i64 = parse_bxor();
            if (p_err != 0) { return -1; }
            let b: i64 = alloc_node(NK::BinExpr as i64);
            if (p_err != 0) { return -1; }
            set_d(b, op);
            set_a(b, lhs);
            set_b(b, rhs);
            lhs = b;
        } else { go = 0; }
    }
    return lhs;
}

fn parse_and() -> i64 {
    let mut lhs: i64 = parse_bor();
    if (p_err != 0) { return -1; }
    let mut go: i64 = 1;
    while (go == 1) {
        let k: i64 = cur_kind();
        if (p_and(k) == 1) {
            let op: i64 = binop_of(k);
            p_adv();
            let rhs: i64 = parse_bor();
            if (p_err != 0) { return -1; }
            let b: i64 = alloc_node(NK::BinExpr as i64);
            if (p_err != 0) { return -1; }
            set_d(b, op);
            set_a(b, lhs);
            set_b(b, rhs);
            lhs = b;
        } else { go = 0; }
    }
    return lhs;
}

fn parse_or() -> i64 {
    let mut lhs: i64 = parse_and();
    if (p_err != 0) { return -1; }
    let mut go: i64 = 1;
    while (go == 1) {
        let k: i64 = cur_kind();
        if (p_or(k) == 1) {
            let op: i64 = binop_of(k);
            p_adv();
            let rhs: i64 = parse_and();
            if (p_err != 0) { return -1; }
            let b: i64 = alloc_node(NK::BinExpr as i64);
            if (p_err != 0) { return -1; }
            set_d(b, op);
            set_a(b, lhs);
            set_b(b, rhs);
            lhs = b;
        } else { go = 0; }
    }
    return lhs;
}

// parse_ternary — or [ '?' expr ':' ternary ]
fn parse_ternary() -> i64 {
    let c: i64 = parse_or();
    if (p_err != 0) { return -1; }
    if (accept(Tok::Question as i64) == 0) { return c; }
    let t: i64 = parse_expr();
    if (p_err != 0) { return -1; }
    if (expect(Tok::Colon as i64, string_from_slice("expected ':'")) < 0) { return -1; }
    let el: i64 = parse_ternary();
    if (p_err != 0) { return -1; }
    let r: i64 = alloc_node(NK::TernaryExpr as i64);
    if (p_err != 0) { return -1; }
    set_a(r, c);
    set_b(r, t);
    set_c(r, el);
    return r;
}

// map a compound-assignment token kind to a BinOp value (or -1).
fn compound_op_of(kind: i64) -> i64 {
    if (kind == (Tok::PlusAssign as i64))    { return BinOp::Add as i64; }
    if (kind == (Tok::MinusAssign as i64))   { return BinOp::Sub as i64; }
    if (kind == (Tok::StarAssign as i64))    { return BinOp::Mul as i64; }
    if (kind == (Tok::SlashAssign as i64))   { return BinOp::Div as i64; }
    if (kind == (Tok::PercentAssign as i64)) { return BinOp::Mod as i64; }
    if (kind == (Tok::AmpAssign as i64))     { return BinOp::And as i64; }
    if (kind == (Tok::PipeAssign as i64))    { return BinOp::Or as i64; }
    if (kind == (Tok::CaretAssign as i64))   { return BinOp::Xor as i64; }
    if (kind == (Tok::ShlAssign as i64))     { return BinOp::Shl as i64; }
    if (kind == (Tok::ShrAssign as i64))     { return BinOp::Shr as i64; }
    return -1;
}

// is this token an assignment operator (=, +=, -=, ...)?
fn is_assign_op(kind: i64) -> i64 {
    if (kind == (Tok::Assign as i64)) { return 1; }
    if (compound_op_of(kind) >= 0) { return 1; }
    return 0;
}

// parse_assign — ternary [ ('=' | '+=' | ...) assign ]
fn parse_assign() -> i64 {
    let lhs: i64 = parse_ternary();
    if (p_err != 0) { return -1; }
    let k: i64 = cur_kind();
    if (is_assign_op(k) == 0) { return lhs; }
    let cop: i64 = compound_op_of(k);
    p_adv();
    let rhs: i64 = parse_assign();
    if (p_err != 0) { return -1; }
    let a: i64 = alloc_node(NK::AssignExpr as i64);
    if (p_err != 0) { return -1; }
    set_a(a, lhs);
    set_b(a, rhs);
    set_d(a, cop);   // compound op (or -1 for plain '=')
    return a;
}

// parse_expr — the entry point (= parse_assign).
fn parse_expr() -> i64 {
    return parse_assign();
}

// -----------------------------------------------------------------------------
// statement parsing.
// -----------------------------------------------------------------------------

// parse a block: '{' stmts... '}'. Returns a BlockStmt node whose `a` is the
// first stmt (linked via c=next). Returns -1 on error.
fn parse_block() -> i64 {
    if (expect(Tok::LBrace as i64, string_from_slice("expected '{'")) < 0) { return -1; }
    let blk: i64 = alloc_node(NK::BlockStmt as i64);
    if (p_err != 0) { return -1; }
    let mut first: i64 = -1;
    let mut prev: i64 = -1;
    while (at(Tok::RBrace as i64) == 0 && at(Tok::Eof as i64) == 0) {
        let s: i64 = parse_stmt();
        if (p_err != 0) { return -1; }
        if (first < 0) { first = s; }
        else { set_next(prev, s); }
        prev = s;
    }
    if (first >= 0) { set_a(blk, first); }
    if (expect(Tok::RBrace as i64, string_from_slice("expected '}'")) < 0) { return -1; }
    return blk;
}

// parse a let statement: ('let' | 'auto' | 'const') ['mut'] IDENT [':' type] ['=' expr] ';'
// `t` is the leading keyword token kind (already peeked, not consumed).
fn parse_let_stmt(kw_kind: i64) -> i64 {
    let mut is_auto: i64 = 0;
    let mut is_const: i64 = 0;
    if (kw_kind == (Tok::Kw_auto as i64)) { is_auto = 1; }
    if (kw_kind == (Tok::Kw_const as i64)) { is_const = 1; }
    p_adv();  // consume the keyword
    let is_mut: i64 = accept(Tok::Kw_mut as i64);
    let mut flags: i64 = 0;
    if (is_mut == 1) { flags = flags | LF_MUT; }
    if (is_const == 1) { flags = flags | LF_CONST; }

    let ntok: i64 = expect(Tok::Ident as i64, string_from_slice("expected variable name"));
    if (p_err != 0) { return -1; }

    let mut ty: i64 = -1;
    if (is_auto == 0) {
        if (accept(Tok::Colon as i64) == 1) {
            ty = parse_type();
            if (p_err != 0) { return -1; }
        } else {
            // no ':TYPE' — infer from initializer (is_auto semantics)
            is_auto = 1;
        }
    }
    let mut init: i64 = -1;
    if (accept(Tok::Assign as i64) == 1) {
        init = parse_expr();
        if (p_err != 0) { return -1; }
    }
    if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }

    let s: i64 = alloc_node(NK::LetStmt as i64);
    if (p_err != 0) { return -1; }
    set_tok(s, ntok);
    if (ty >= 0) { set_a(s, ty); }
    if (init >= 0) { set_b(s, init); }
    let mut f: i64 = flags;
    if (is_auto == 1) { f = f | LF_AUTO; }
    set_d(s, f);
    return s;
}

// parse a static_assert (cond, msg): the shared body for both the statement
// and top-level forms. Returns a node index; the caller wraps it in the right
// kind (StaticAssertStmt / StaticAssertDecl).
fn parse_static_assert_body(kind: i64) -> i64 {
    if (expect(Tok::Kw_static_assert as i64, string_from_slice("expected 'static_assert'")) < 0) { return -1; }
    if (expect(Tok::LParen as i64, string_from_slice("expected '('")) < 0) { return -1; }
    let cond: i64 = parse_expr();
    if (p_err != 0) { return -1; }
    if (expect(Tok::Comma as i64, string_from_slice("expected ','")) < 0) { return -1; }
    let mt: i64 = expect(Tok::StringLit as i64, string_from_slice("expected string literal"));
    if (p_err != 0) { return -1; }
    if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
    if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
    let n: i64 = alloc_node(kind);
    if (p_err != 0) { return -1; }
    set_a(n, cond);
    set_tok(n, mt);
    return n;
}

// parse_stmt — dispatch on the leading token.
fn parse_stmt() -> i64 {
    let k: i64 = cur_kind();

    if (k == (Tok::Kw_let as i64) || k == (Tok::Kw_auto as i64) || k == (Tok::Kw_const as i64)) {
        return parse_let_stmt(k);
    }
    if (k == (Tok::Kw_defer as i64)) {
        p_adv();
        let e: i64 = parse_expr();
        if (p_err != 0) { return -1; }
        if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
        let s: i64 = alloc_node(NK::DeferStmt as i64);
        if (p_err != 0) { return -1; }
        set_a(s, e);
        return s;
    }
    if (k == (Tok::Kw_static_assert as i64)) {
        return parse_static_assert_body(NK::StaticAssertStmt as i64);
    }
    if (k == (Tok::Kw_if as i64)) {
        p_adv();
        if (expect(Tok::LParen as i64, string_from_slice("expected '('")) < 0) { return -1; }
        let cond: i64 = parse_expr();
        if (p_err != 0) { return -1; }
        if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
        let then_b: i64 = parse_block();
        if (p_err != 0) { return -1; }
        let s: i64 = alloc_node(NK::IfStmt as i64);
        if (p_err != 0) { return -1; }
        set_a(s, cond);
        set_b(s, then_b);
        if (accept(Tok::Kw_else as i64) == 1) {
            if (at(Tok::Kw_if as i64) == 1) {
                // else if — wrap the nested if stmt in a block
                let sub: i64 = parse_stmt();
                if (p_err != 0) { return -1; }
                let eb: i64 = alloc_node(NK::BlockStmt as i64);
                if (p_err != 0) { return -1; }
                set_a(eb, sub);
                set_c(s, eb);
            } else {
                let eb: i64 = parse_block();
                if (p_err != 0) { return -1; }
                set_c(s, eb);
            }
        }
        return s;
    }
    if (k == (Tok::Kw_while as i64)) {
        p_adv();
        if (expect(Tok::LParen as i64, string_from_slice("expected '('")) < 0) { return -1; }
        let cond: i64 = parse_expr();
        if (p_err != 0) { return -1; }
        if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
        let body: i64 = parse_block();
        if (p_err != 0) { return -1; }
        let s: i64 = alloc_node(NK::WhileStmt as i64);
        if (p_err != 0) { return -1; }
        set_a(s, cond);
        set_b(s, body);
        return s;
    }
    if (k == (Tok::Kw_do as i64)) {
        p_adv();
        let body: i64 = parse_block();
        if (p_err != 0) { return -1; }
        if (expect(Tok::Kw_while as i64, string_from_slice("expected 'while'")) < 0) { return -1; }
        if (expect(Tok::LParen as i64, string_from_slice("expected '('")) < 0) { return -1; }
        let cond: i64 = parse_expr();
        if (p_err != 0) { return -1; }
        if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
        if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
        let s: i64 = alloc_node(NK::DoWhileStmt as i64);
        if (p_err != 0) { return -1; }
        set_a(s, body);
        set_b(s, cond);
        return s;
    }
    if (k == (Tok::Kw_for as i64)) {
        p_adv();
        if (expect(Tok::LParen as i64, string_from_slice("expected '('")) < 0) { return -1; }
        // for-each?  IDENT 'in' ...
        if (peek_kind(0) == (Tok::Ident as i64) && peek_kind(1) == (Tok::Kw_in as i64)) {
            let vtok: i64 = p_adv();
            p_adv();  // 'in'
            let iter: i64 = parse_expr();
            if (p_err != 0) { return -1; }
            if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
            let body: i64 = parse_block();
            if (p_err != 0) { return -1; }
            let s: i64 = alloc_node(NK::ForEachStmt as i64);
            if (p_err != 0) { return -1; }
            set_tok(s, vtok);
            set_a(s, iter);
            set_b(s, body);
            return s;
        }
        // C-style for ( init ; cond ; step ) body
        let mut init: i64 = -1;
        if (at(Tok::Kw_let as i64) == 1 || at(Tok::Kw_auto as i64) == 1 || at(Tok::Kw_const as i64) == 1) {
            init = parse_let_stmt(cur_kind());
            if (p_err != 0) { return -1; }
        } else {
            if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
        }
        let mut cond: i64 = -1;
        if (at(Tok::Semicolon as i64) == 0) {
            cond = parse_expr();
            if (p_err != 0) { return -1; }
        }
        if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
        let mut step: i64 = -1;
        if (at(Tok::RParen as i64) == 0) {
            step = parse_expr();
            if (p_err != 0) { return -1; }
        }
        if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
        let body: i64 = parse_block();
        if (p_err != 0) { return -1; }
        let s: i64 = alloc_node(NK::ForStmt as i64);
        if (p_err != 0) { return -1; }
        if (init >= 0) { set_a(s, init); }
        if (cond >= 0) { set_b(s, cond); }
        if (step >= 0) { set_c(s, step); }
        set_e(s, body);
        return s;
    }
    if (k == (Tok::Kw_switch as i64)) {
        p_adv();
        if (expect(Tok::LParen as i64, string_from_slice("expected '('")) < 0) { return -1; }
        let subject: i64 = parse_expr();
        if (p_err != 0) { return -1; }
        if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
        if (expect(Tok::LBrace as i64, string_from_slice("expected '{'")) < 0) { return -1; }
        let s: i64 = alloc_node(NK::SwitchStmt as i64);
        if (p_err != 0) { return -1; }
        set_a(s, subject);
        let mut first_c: i64 = -1;
        let mut prev_c: i64 = -1;
        while (at(Tok::RBrace as i64) == 0 && at(Tok::Eof as i64) == 0) {
            let is_default: i64 = accept(Tok::Kw_default as i64);
            let mut cval: i64 = -1;
            if (is_default == 0) {
                if (expect(Tok::Kw_case as i64, string_from_slice("expected 'case' or 'default'")) < 0) { return -1; }
                cval = parse_expr();
                if (p_err != 0) { return -1; }
            }
            if (expect(Tok::Colon as i64, string_from_slice("expected ':'")) < 0) { return -1; }
            let mut first_s: i64 = -1;
            let mut prev_s: i64 = -1;
            while (at(Tok::Kw_case as i64) == 0 && at(Tok::Kw_default as i64) == 0
                   && at(Tok::RBrace as i64) == 0 && at(Tok::Eof as i64) == 0) {
                let st: i64 = parse_stmt();
                if (p_err != 0) { return -1; }
                if (first_s < 0) { first_s = st; }
                else { set_next(prev_s, st); }
                prev_s = st;
            }
            let cnode: i64 = alloc_node(NK::Case as i64);
            if (p_err != 0) { return -1; }
            if (cval >= 0) { set_a(cnode, cval); }
            if (first_s >= 0) { set_b(cnode, first_s); }
            if (is_default == 1) { set_d(cnode, 1); }
            if (first_c < 0) { first_c = cnode; }
            else { set_next(prev_c, cnode); }
            prev_c = cnode;
        }
        if (first_c >= 0) { set_b(s, first_c); }
        if (expect(Tok::RBrace as i64, string_from_slice("expected '}'")) < 0) { return -1; }
        return s;
    }
    if (k == (Tok::Kw_match as i64)) {
        p_adv();
        if (expect(Tok::LParen as i64, string_from_slice("expected '('")) < 0) { return -1; }
        let subject: i64 = parse_expr();
        if (p_err != 0) { return -1; }
        if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
        if (expect(Tok::LBrace as i64, string_from_slice("expected '{'")) < 0) { return -1; }
        let s: i64 = alloc_node(NK::MatchStmt as i64);
        if (p_err != 0) { return -1; }
        set_a(s, subject);
        let mut first_a: i64 = -1;
        let mut prev_a: i64 = -1;
        while (at(Tok::RBrace as i64) == 0 && at(Tok::Eof as i64) == 0) {
            let arm: i64 = alloc_node(NK::MatchArm as i64);
            if (p_err != 0) { return -1; }
            // wildcard '_' / struct-destructure pattern / expr pattern
            if (at(Tok::Ident as i64) == 1 && cur_text() == string_from_slice("_")) {
                p_adv();
                set_d(arm, 1);   // is_wildcard
            } else if (at(Tok::Ident as i64) == 1 && peek_kind(1) == (Tok::LBrace as i64)) {
                // Tier 1 struct-destructure pattern: TypeName{field, field: literal, ...}
                // mirrors src/parser.cpp ~1144-1157. Each field is a name with
                // an OPTIONAL `: value` (a literal to match); a bare name binds
                // a local of the same name. Stored on the MatchArm as:
                //   tok = struct type-name token, c = first FieldInit node,
                //   f = 1 (has_struct_pat). Each FieldInit: tok = field-name
                //   token, a = literal expr (-1 = capture-only), next = next field.
                let type_tok: i64 = p_adv();  // the type name (an Ident)
                if (expect(Tok::LBrace as i64, string_from_slice("expected '{' after struct pattern name")) < 0) { return -1; }
                set_tok(arm, type_tok);
                set_f(arm, 1);   // has_struct_pat
                let mut first_fld: i64 = -1;
                let mut prev_fld: i64 = -1;
                if (at(Tok::RBrace as i64) == 0) {
                    let mut go_fld: i64 = 1;
                    while (go_fld == 1) {
                        let fname_tok: i64 = expect(Tok::Ident as i64, string_from_slice("field name in struct pattern"));
                        if (p_err != 0) { return -1; }
                        let fld: i64 = alloc_node(NK::FieldInit as i64);
                        if (p_err != 0) { return -1; }
                        set_tok(fld, fname_tok);
                        if (accept(Tok::Colon as i64) == 1) {
                            let lit: i64 = parse_expr();
                            if (p_err != 0) { return -1; }
                            set_a(fld, lit);   // field: literal (match value)
                        } else {
                            set_a(fld, -1);    // capture-only (binds a local)
                        }
                        if (first_fld < 0) { first_fld = fld; }
                        else { set_next(prev_fld, fld); }
                        prev_fld = fld;
                        if (accept(Tok::Comma as i64) == 0) { go_fld = 0; }
                    }
                }
                if (first_fld >= 0) { set_c(arm, first_fld); }
                if (expect(Tok::RBrace as i64, string_from_slice("expected '}' after struct pattern fields")) < 0) { return -1; }
            } else {
                let pat: i64 = parse_expr();
                if (p_err != 0) { return -1; }
                set_a(arm, pat);
            }
            // optional guard
            if (accept(Tok::Kw_if as i64) == 1) {
                let g: i64 = parse_expr();
                if (p_err != 0) { return -1; }
                set_e(arm, g);
            }
            if (expect(Tok::FatArrow as i64, string_from_slice("expected '=>'")) < 0) { return -1; }
            if (at(Tok::LBrace as i64) == 1) {
                let b: i64 = parse_block();
                if (p_err != 0) { return -1; }
                set_b(arm, b);
            } else {
                let st: i64 = parse_stmt();
                if (p_err != 0) { return -1; }
                let b: i64 = alloc_node(NK::BlockStmt as i64);
                if (p_err != 0) { return -1; }
                set_a(b, st);
                set_b(arm, b);
            }
            accept(Tok::Comma as i64);
            if (first_a < 0) { first_a = arm; }
            else { set_next(prev_a, arm); }
            prev_a = arm;
        }
        if (first_a >= 0) { set_b(s, first_a); }
        if (expect(Tok::RBrace as i64, string_from_slice("expected '}'")) < 0) { return -1; }
        return s;
    }
    if (k == (Tok::Kw_return as i64)) {
        p_adv();
        let mut val: i64 = -1;
        if (at(Tok::Semicolon as i64) == 0) {
            val = parse_expr();
            if (p_err != 0) { return -1; }
        }
        if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
        let s: i64 = alloc_node(NK::ReturnStmt as i64);
        if (p_err != 0) { return -1; }
        if (val >= 0) { set_a(s, val); }
        return s;
    }
    if (k == (Tok::Kw_break as i64)) {
        p_adv();
        if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
        let s: i64 = alloc_node(NK::BreakStmt as i64);
        if (p_err != 0) { return -1; }
        return s;
    }
    if (k == (Tok::Kw_continue as i64)) {
        p_adv();
        if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
        let s: i64 = alloc_node(NK::ContinueStmt as i64);
        if (p_err != 0) { return -1; }
        return s;
    }
    if (k == (Tok::Kw_yield as i64)) {
        p_adv();
        let mut val: i64 = -1;
        if (at(Tok::Semicolon as i64) == 0) {
            val = parse_expr();
            if (p_err != 0) { return -1; }
        }
        if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
        let s: i64 = alloc_node(NK::YieldStmt as i64);
        if (p_err != 0) { return -1; }
        if (val >= 0) { set_a(s, val); }
        return s;
    }
    if (k == (Tok::Kw_throw as i64)) {
        p_adv();
        let val: i64 = parse_expr();
        if (p_err != 0) { return -1; }
        if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
        let s: i64 = alloc_node(NK::ThrowStmt as i64);
        if (p_err != 0) { return -1; }
        set_a(s, val);
        return s;
    }
    if (k == (Tok::Kw_try as i64)) {
        p_adv();
        let try_b: i64 = parse_block();
        if (p_err != 0) { return -1; }
        if (expect(Tok::Kw_catch as i64, string_from_slice("expected 'catch'")) < 0) { return -1; }
        if (expect(Tok::LParen as i64, string_from_slice("expected '('")) < 0) { return -1; }
        let cnametok: i64 = expect(Tok::Ident as i64, string_from_slice("expected catch variable name"));
        if (p_err != 0) { return -1; }
        if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
        let catch_b: i64 = parse_block();
        if (p_err != 0) { return -1; }
        let s: i64 = alloc_node(NK::TryCatchStmt as i64);
        if (p_err != 0) { return -1; }
        set_a(s, try_b);
        set_b(s, catch_b);
        set_tok(s, cnametok);
        return s;
    }
    if (k == (Tok::LBrace as i64)) {
        let b: i64 = parse_block();
        if (p_err != 0) { return -1; }
        let s: i64 = alloc_node(NK::BlockStmt as i64);
        if (p_err != 0) { return -1; }
        set_a(s, b);
        return s;
    }

    // expression statement
    let e: i64 = parse_expr();
    if (p_err != 0) { return -1; }
    if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
    let s: i64 = alloc_node(NK::ExprStmt as i64);
    if (p_err != 0) { return -1; }
    set_a(s, e);
    return s;
}

// -----------------------------------------------------------------------------
// top-level declaration parsing.
// -----------------------------------------------------------------------------

// parse an annotation: @name [( literal {, literal} )]
// Returns the annotation's name token index (v1: args not recorded), or -1.
fn parse_annotation() -> i64 {
    if (expect(Tok::At as i64, string_from_slice("expected '@'")) < 0) { return -1; }
    let ntok: i64 = expect(Tok::Ident as i64, string_from_slice("expected annotation name"));
    if (p_err != 0) { return -1; }
    if (accept(Tok::LParen as i64) == 1) {
        if (at(Tok::RParen as i64) == 0) {
            let mut go: i64 = 1;
            while (go == 1) {
                let k: i64 = cur_kind();
                if (k == (Tok::IntLit as i64) || k == (Tok::FloatLit as i64)
                    || k == (Tok::StringLit as i64) || k == (Tok::RawStringLit as i64)
                    || k == (Tok::BoolLit as i64)) {
                    p_adv();
                } else {
                    return err(string_from_slice("expected literal in annotation args"));
                }
                if (accept(Tok::Comma as i64) == 0) { go = 0; }
            }
        }
        if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }
    }
    return ntok;
}

// parse a function declaration: ['priv' | 'constexpr']* 'fn' name '(' params ')' ['->' type] block
// The modifiers (priv/constexpr) are consumed by the caller and passed as flags.
fn parse_func(flags: i64) -> i64 {
    if (expect(Tok::Kw_fn as i64, string_from_slice("expected 'fn'")) < 0) { return -1; }
    let ntok: i64 = expect(Tok::Ident as i64, string_from_slice("expected function name"));
    if (p_err != 0) { return -1; }
    let f: i64 = alloc_node(NK::FnDecl as i64);
    if (p_err != 0) { return -1; }
    set_tok(f, ntok);
    set_d(f, flags);

    if (expect(Tok::LParen as i64, string_from_slice("expected '('")) < 0) { return -1; }
    let mut first_p: i64 = -1;
    let mut prev_p: i64 = -1;
    if (at(Tok::RParen as i64) == 0) {
        let mut go: i64 = 1;
        while (go == 1) {
            let p: i64 = parse_param();
            if (p_err != 0) { return -1; }
            if (first_p < 0) { first_p = p; }
            else { set_next(prev_p, p); }
            prev_p = p;
            if (accept(Tok::Comma as i64) == 0) { go = 0; }
        }
    }
    if (first_p >= 0) { set_a(f, first_p); }
    if (expect(Tok::RParen as i64, string_from_slice("expected ')'")) < 0) { return -1; }

    let mut ret: i64 = -1;
    if (accept(Tok::Arrow as i64) == 1) {
        ret = parse_type();
        if (p_err != 0) { return -1; }
    } else {
        ret = alloc_node(NK::Type as i64);
        if (p_err != 0) { return -1; }
        set_d(ret, Prim::Void as i64);
    }
    set_b(f, ret);

    let body: i64 = parse_block();
    if (p_err != 0) { return -1; }
    set_c(f, body);
    return f;
}

// parse a struct declaration: 'struct' name '{' field: type ; ... '}'
fn parse_struct() -> i64 {
    if (expect(Tok::Kw_struct as i64, string_from_slice("expected 'struct'")) < 0) { return -1; }
    let ntok: i64 = expect(Tok::Ident as i64, string_from_slice("expected struct name"));
    if (p_err != 0) { return -1; }
    let s: i64 = alloc_node(NK::StructDecl as i64);
    if (p_err != 0) { return -1; }
    set_tok(s, ntok);
    if (expect(Tok::LBrace as i64, string_from_slice("expected '{'")) < 0) { return -1; }
    let mut first_f: i64 = -1;
    let mut prev_f: i64 = -1;
    while (at(Tok::RBrace as i64) == 0 && at(Tok::Eof as i64) == 0) {
        let ft: i64 = expect(Tok::Ident as i64, string_from_slice("expected field name"));
        if (p_err != 0) { return -1; }
        if (expect(Tok::Colon as i64, string_from_slice("expected ':'")) < 0) { return -1; }
        let ty: i64 = parse_type();
        if (p_err != 0) { return -1; }
        if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
        let fd: i64 = alloc_node(NK::Field as i64);
        if (p_err != 0) { return -1; }
        set_tok(fd, ft);
        set_a(fd, ty);
        if (first_f < 0) { first_f = fd; }
        else { set_next(prev_f, fd); }
        prev_f = fd;
    }
    if (first_f >= 0) { set_a(s, first_f); }
    if (expect(Tok::RBrace as i64, string_from_slice("expected '}'")) < 0) { return -1; }
    return s;
}

// parse an enum: 'enum' name [':' type] '{' variant ['=' expr] {, variant} [,] '}'
fn parse_enum() -> i64 {
    if (expect(Tok::Kw_enum as i64, string_from_slice("expected 'enum'")) < 0) { return -1; }
    let ntok: i64 = expect(Tok::Ident as i64, string_from_slice("expected enum name"));
    if (p_err != 0) { return -1; }
    let e: i64 = alloc_node(NK::EnumDecl as i64);
    if (p_err != 0) { return -1; }
    set_tok(e, ntok);
    // optional backing type
    if (accept(Tok::Colon as i64) == 1) {
        let bt: i64 = parse_type();
        if (p_err != 0) { return -1; }
        set_a(e, bt);   // backing type in `a` (also used for first variant — see below)
    }
    if (expect(Tok::LBrace as i64, string_from_slice("expected '{'")) < 0) { return -1; }
    // NOTE: `a` is overloaded — if a backing type was parsed it's there; otherwise
    // it holds the first variant. A production parser would use distinct slots;
    // for v1 we keep variants in `b` (first-child) and backing type in `a`.
    let mut first_v: i64 = -1;
    let mut prev_v: i64 = -1;
    if (at(Tok::RBrace as i64) == 0 && at(Tok::Eof as i64) == 0) {
        let mut go: i64 = 1;
        while (go == 1) {
            let vtok: i64 = expect(Tok::Ident as i64, string_from_slice("expected enum variant name"));
            if (p_err != 0) { return -1; }
            let v: i64 = alloc_node(NK::Variant as i64);
            if (p_err != 0) { return -1; }
            set_tok(v, vtok);
            if (accept(Tok::Assign as i64) == 1) {
                let val: i64 = parse_expr();
                if (p_err != 0) { return -1; }
                set_a(v, val);
            }
            if (first_v < 0) { first_v = v; }
            else { set_next(prev_v, v); }
            prev_v = v;
            if (accept(Tok::Comma as i64) == 0) { go = 0; }
            if (at(Tok::RBrace as i64) == 1 || at(Tok::Eof as i64) == 1) { go = 0; }
        }
    }
    if (first_v >= 0) { set_b(e, first_v); }
    if (expect(Tok::RBrace as i64, string_from_slice("expected '}'")) < 0) { return -1; }
    return e;
}

// parse a global / const declaration: ('global' | 'const') name ':' type '=' expr ';'
fn parse_global(is_const: i64) -> i64 {
    // the 'global'/'const' keyword is consumed by the caller
    let ntok: i64 = expect(Tok::Ident as i64, string_from_slice("expected global name"));
    if (p_err != 0) { return -1; }
    if (expect(Tok::Colon as i64, string_from_slice("expected ':'")) < 0) { return -1; }
    let ty: i64 = parse_type();
    if (p_err != 0) { return -1; }
    if (expect(Tok::Assign as i64, string_from_slice("expected '='")) < 0) { return -1; }
    let init: i64 = parse_expr();
    if (p_err != 0) { return -1; }
    if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
    let g: i64 = alloc_node(NK::GlobalDecl as i64);
    if (p_err != 0) { return -1; }
    set_tok(g, ntok);
    set_a(g, ty);
    set_b(g, init);
    if (is_const == 1) { set_d(g, 1); }
    return g;
}

// parse a link declaration: 'link' string ['as' ident] ';'
fn parse_link() -> i64 {
    if (expect(Tok::Kw_link as i64, string_from_slice("expected 'link'")) < 0) { return -1; }
    let t: i64 = expect(Tok::StringLit as i64, string_from_slice("expected module name or .em path"));
    if (p_err != 0) { return -1; }
    let ld: i64 = alloc_node(NK::LinkDecl as i64);
    if (p_err != 0) { return -1; }
    set_tok(ld, t);
    if (accept(Tok::Kw_as as i64) == 1) {
        let a: i64 = expect(Tok::Ident as i64, string_from_slice("expected module alias"));
        if (p_err != 0) { return -1; }
        set_a(ld, a);
    }
    if (expect(Tok::Semicolon as i64, string_from_slice("expected ';'")) < 0) { return -1; }
    return ld;
}

// parse a namespace: 'namespace' name '{' decls... '}'
// v1: namespace members are flattened into the program's top-level list, each
// tagged with the namespace name via the node's `e` slot (the ns-name token
// index). This mirrors the C++ parser's ns-stamping, simplified.
fn parse_namespace() -> i64 {
    if (expect(Tok::Kw_namespace as i64, string_from_slice("expected 'namespace'")) < 0) { return -1; }
    let ntok: i64 = expect(Tok::Ident as i64, string_from_slice("expected namespace name"));
    if (p_err != 0) { return -1; }
    let ns: i64 = alloc_node(NK::NamespaceDecl as i64);
    if (p_err != 0) { return -1; }
    set_tok(ns, ntok);
    if (expect(Tok::LBrace as i64, string_from_slice("expected '{'")) < 0) { return -1; }
    let mut first_d: i64 = -1;
    let mut prev_d: i64 = -1;
    while (at(Tok::RBrace as i64) == 0 && at(Tok::Eof as i64) == 0) {
        let d: i64 = parse_top_decl();
        if (p_err != 0) { return -1; }
        // stamp the namespace name on the member (in `e`, if the kind supports it)
        set_e(d, ntok);
        if (first_d < 0) { first_d = d; }
        else { set_next(prev_d, d); }
        prev_d = d;
    }
    if (first_d >= 0) { set_a(ns, first_d); }
    if (expect(Tok::RBrace as i64, string_from_slice("expected '}'")) < 0) { return -1; }
    return ns;
}

// parse one top-level declaration (annotations + modifiers + fn/struct/enum/
// global/const/link/namespace/static_assert). Returns the decl node index.
fn parse_top_decl() -> i64 {
    // gather annotations
    let mut ann_first: i64 = -1;
    let mut ann_prev: i64 = -1;
    while (at(Tok::At as i64) == 1) {
        let a: i64 = parse_annotation();
        if (p_err != 0) { return -1; }
        // annotations are recorded as token indices in a linked list via a
        // synthetic node; v1 discards them (the C++ parser stores them on the
        // fn only). We consume them so parsing advances. Store the first ann
        // token on a lightweight list for completeness.
        if (ann_first < 0) { ann_first = a; }
        else { ann_first = ann_first; }  // no-op; v1 keeps only the first
        ann_prev = a;
    }
    // v1: annotations are consumed but not attached (a later pass can extend
    // the node layout to carry them). The C++ parser attaches to fn only.
    let dummy: i64 = ann_first;
    let _u: i64 = ann_prev;
    let _u2: i64 = dummy;

    // modifiers: priv / constexpr, in any order, at most once each
    let mut flags: i64 = 0;
    let mut pass: i64 = 0;
    while (pass < 2) {
        if (at(Tok::Kw_priv as i64) == 1 && (flags & FD_PRIV) == 0) {
            p_adv();
            flags = flags | FD_PRIV;
            pass = pass + 1;
            continue;
        }
        if (at(Tok::Kw_constexpr as i64) == 1 && (flags & FD_CEXPR) == 0) {
            p_adv();
            flags = flags | FD_CEXPR;
            pass = pass + 1;
            continue;
        }
        pass = 2;
    }

    let k: i64 = cur_kind();
    if (k == (Tok::Kw_fn as i64)) {
        return parse_func(flags);
    }
    if (k == (Tok::Kw_struct as i64)) {
        return parse_struct();
    }
    if (k == (Tok::Kw_global as i64) || k == (Tok::Kw_const as i64)) {
        let mut is_c: i64 = 0;
        if (k == (Tok::Kw_const as i64)) { is_c = 1; }
        p_adv();  // consume 'global' or 'const'
        return parse_global(is_c);
    }
    if (k == (Tok::Kw_link as i64)) {
        return parse_link();
    }
    if (k == (Tok::Kw_enum as i64)) {
        return parse_enum();
    }
    if (k == (Tok::Kw_static_assert as i64)) {
        return parse_static_assert_body(NK::StaticAssertDecl as i64);
    }
    if (k == (Tok::Kw_namespace as i64)) {
        return parse_namespace();
    }
    if (k == (Tok::Semicolon as i64)) {
        p_adv();  // empty top-level stmt — skip (return a no-op node)
        let n: i64 = alloc_node(NK::ExprStmt as i64);
        if (p_err != 0) { return -1; }
        // an empty expr stmt with a = -1 (no expr) = no-op
        return n;
    }
    return err(string_from_slice("expected fn/struct/enum/global/namespace at top level"));
}

// parse_program — loop over top-level decls until EOF. Returns a Program node
// whose `a` = first decl (linked via c=next).
fn parse_program() -> i64 {
    let prog: i64 = alloc_node(NK::Program as i64);
    if (p_err != 0) { return -1; }
    let mut first: i64 = -1;
    let mut prev: i64 = -1;
    while (at(Tok::Eof as i64) == 0) {
        let d: i64 = parse_top_decl();
        if (p_err != 0) { return -1; }
        if (first < 0) { first = d; }
        else { set_next(prev, d); }
        prev = d;
    }
    if (first >= 0) { set_a(prog, first); }
    return prog;
}

// -----------------------------------------------------------------------------
// the entry point. Lex `source`, then parse the token stream into an AST.
// Returns the Program node index on success, or -1 on error. The AST lives in
// g_nodes (a fresh array per call); g_toks holds the tokens (so tok_text works
// for name retrieval).
// -----------------------------------------------------------------------------

fn parse(source: string) -> i64 {
    // lex
    g_toks = lex(source);
    if (lex_failed() != 0) {
        p_err = 1;
        p_errline = g_errline;   // the lexer's error position (its own globals)
        p_errcol = g_errcol;
        p_errmsg = string_from_slice("lex error");
        return -1;
    }
    g_tcount = tok_count(g_toks);
    g_ti = 0;
    // Reuse the node pool across parse() calls instead of allocating a fresh
    // array each time. The host array extension has no array_free (slots in
    // the process-wide store are never reclaimed until reset()), so a fresh
    // array_new on every parse() leaks the previous buffer — and the leaked
    // buffers accumulate in the trace-callback scan, eventually crashing the
    // host at scale (repeated parses of a large module trap with a bare
    // RUNTIME TRAP). array_clear() resets the logical length to 0 while
    // keeping the backing buffer, so the slot is reused and the store stops
    // growing. The first call (g_nodes == 0) still allocates.
    if (g_nodes != 0) {
        array_clear(g_nodes);
    } else {
        g_nodes = array_new(8, 0);
    }
    p_err = 0;
    p_errline = 0;
    p_errcol = 0;
    p_errmsg = string_from_slice("");

    let prog: i64 = parse_program();
    if (p_err != 0) { return -1; }
    return prog;
}

// whether the parser hit an error (set by err() during parse()).
fn parse_failed() -> i64 {
    return p_err;
}

// the error position (1-based line/col) and message, for diagnostics.
fn parse_err_line() -> i64 { return p_errline; }
fn parse_err_col() -> i64 { return p_errcol; }
fn parse_err_msg() -> string { return p_errmsg; }

// the AST node array handle (for callers that want to traverse it directly).
fn parse_nodes() -> i64 { return g_nodes; }

// the token array handle (for callers that want to re-derive token text).
fn parse_tokens() -> i64 { return g_toks; }

// self_hosted/sema.ember — the ember semantic analyzer (type checker),
// written IN ember.
//
// Self-hosting Stage 3: prove ember can type-check itself. This is a port of
// the CORE passes of src/sema.cpp (the C++ reference multi-pass type checker)
// to ember source. It consumes the AST built by Stage 2's parser (parse.ember)
// and type-checks it: resolves types, checks expressions / statements /
// declarations, and manages scopes.
//
// === v1 subset ===
//
// Stage 3 v1 type-checks a SUBSET of ember, matching the task scope:
//   - fn declarations with i64 / bool / void params + returns
//   - let with a declared type (check init matches); auto (infer from init)
//   - if / while with bool conditions
//   - return with a value matching the fn return type
//   - binary ops: arithmetic (+ - * / %) + bitwise (& | ^ << >>) -> i64,
//     comparison (== != < <= > >=) -> bool, logical (&& ||) -> bool
//   - unary: - (i64), ! (bool), ~ (i64)
//   - calls: check arg count + each arg type against the fn signature
//   - int literals -> i64, bool literals -> bool
//   - identifiers: look up in the local scope, then globals
//
// Everything outside that subset is rejected before codegen. Unsupported
// syntax returns a stable -3xx code rather than being ignored or accidentally
// accepted.
//
// === Type representation ===
//
// A "type" in this sema is an i64 index into the parser's AST node array
// (g_nodes), pointing at a Type node. The parser's Type node already encodes
// everything sema needs:
//   d (prim)      — Prim enum value (I64=5, Bool=1, Void=0, ...)
//   tok           — struct-name token index (or -1 for primitives)
//   a (elem)      — element type for array/slice types
//   e (array_len) — fixed-array length
//   f (is_slice)  — 1 for slice types
// So `type_eq` is a structural comparison of two Type nodes. Canonical
// primitive types (i64, bool, void) are created once at init and reused, so
// i64-ness is a single node-index comparison in the common case.
//
// === Symbol tables ===
//
// ember has no map<string, Type> builtin, so every table is a flat i64 array
// (the array extension, elem_size 8) with a fixed stride. Names are stored as
// TOKEN INDICES (into the lexer's token array, g_toks) — the same trick the
// parser uses for AST node names — and compared on demand via tok_text, so a
// lookup is a linear scan comparing tok_text(g_toks, entry_tok). This is O(n)
// per lookup but n is small (a handful of fns / globals / locals), fine for a
// v1 sema.
//
//   g_fns    : stride 6  [ name_tok, ret_type, first_param, param_count, ns_tok, flags ]
//   g_structs: stride 2  [ name_tok, first_field ]
//   g_globals: stride 3  [ name_tok, type, ns_tok ]
//   g_scope  : stride 3  [ name_tok, type, array_elem_ty ]  (local-variable stack)
//   g_marks  : stride 1  [ mark_index ]        (scope-push marks into g_scope)
//   array_elem_ty is -1 for a non-array local, or the inferred element Type
//   node for a local initialized from array_new(esz,n) (the iterable() hook:
//   `for (x in a)` reads this tag to type the loop variable, mirroring the
//   native Var::array_elem_ty).
//
// === Error handling ===
//
// The C++ sema collects a vector of SemaError; ember has no exceptions, so this
// sema uses a global error flag (s_err) + first-error message/position, like
// the parser's p_err. check_* fns set the flag on a type error and return a
// fallback type (void) so checking continues and downstream nodes still get a
// type. sema() returns 0 on success, 1 for an ordinary type error, 2 for a
// parse error, or a stable -3xx unsupported-subset code. sema_failed() /
// sema_err_* expose the state for the test.


// -----------------------------------------------------------------------------
// canonical primitive types. Created once at init so every i64/bool/void in the
// program shares one Type node index (making type_eq a single-index compare in
// the common case). These are appended to the parser's g_nodes array, so they
// live for the lifetime of the AST.
// -----------------------------------------------------------------------------
global TY_I64   : i64 = 0;
global TY_BOOL  : i64 = 0;
global TY_VOID  : i64 = 0;
global TY_F32   : i64 = 0;
global TY_F64   : i64 = 0;
global TY_STRING: i64 = 0;
// Phase 2: canonical nodes for every integer width so resolve_type returns a
// shared index for each (making type_eq a single-index compare in the common
// case, matching how TY_I64/TY_BOOL/TY_VOID work). Mirrors src/sema.cpp's
// intern(make_prim(...)) canonical primitive table.
global TY_I8  : i64 = 0;
global TY_I16 : i64 = 0;
global TY_I32 : i64 = 0;
global TY_U8  : i64 = 0;
global TY_U16 : i64 = 0;
global TY_U32 : i64 = 0;
global TY_U64 : i64 = 0;

// -----------------------------------------------------------------------------
// symbol tables (flat i64 arrays).
// -----------------------------------------------------------------------------
global g_fns     : i64 = 0;   // array, stride FN_STRIDE
global g_structs : i64 = 0;   // array, stride STRUCT_STRIDE
global g_enums   : i64 = 0;   // array, stride 2 [name_tok, first_variant]
global g_enum_types : i64 = 0; // Phase 3b: typed-enum types, stride 2 [name_tok, type_node]
global g_globals : i64 = 0;   // array, stride GLOBAL_STRIDE
global g_scope   : i64 = 0;   // array, stride SCOPE_STRIDE (local vars)
global g_marks   : i64 = 0;   // array, stride 1 (scope-push marks)
// Tier 1 namespaces: the set of declared namespace name tokens (for Foo::bar
// resolution). A flat array of tokens (no stride). Built during registration.
global g_ns_names : i64 = 0;
// Lambda metadata. g_lambdas is the creation-order list of LambdaExpr nodes.
// g_lambda_caps rows are [lambda_node,name_tok,type,env_offset,by_ref].
global g_lambdas : i64 = 0;
global g_lambda_caps : i64 = 0;
global LAMBDA_CAP_STRIDE : i64 = 5;
// the namespace of the fn currently being checked (-1 = top-level). Used so a
// bare call inside a namespace fn resolves to the sibling Ns::fn first
// (mirrors src/sema.cpp's current_ns).
global s_cur_ns : i64 = -1;

// Host extension native signature table (array/math/map/string/io). A flat
// i64 array, stride NAT_STRIDE = 7, one row per registered native:
//   [ param_count, p0, p1, p2, p3, ret_type, perm ]
// p0..p3 are sema Type node indices (TY_I64 / TY_F64 / TY_F32 / TY_BOOL /
// TY_STRING / TY_U8, or -1 if unused). perm is 0 (none) for array/math/map/
// string and 1 (PERM_FFI) for io. The row ORDER is fixed and matched 1:1 by
// native_find's if-chain (the only source of truth for the name->row mapping;
// ember's type system keeps `string` handles distinct from `i64`, so names
// cannot live in this i64 array and are compared as string==string in the
// chain). Built once at s_init by init_natives(); mirrors the host's
// registered NativeSig table (extensions/{array,math,map,string,io}/ext_*.cpp)
// EXACTLY so the sema type check + the codegen's ABS64_NATIVE fingerprint match
// the loader's check.
global g_natives : i64 = 0;
global NAT_STRIDE : i64 = 7;

global FN_STRIDE     : i64 = 6;
global STRUCT_STRIDE : i64 = 2;
global GLOBAL_STRIDE : i64 = 3;
global SCOPE_STRIDE  : i64 = 3;

// the token array handle (copied from the parser's g_toks at sema() entry, so
// name lookups can call tok_text without re-threading it through every call).
global s_toks : i64 = 0;

// -----------------------------------------------------------------------------
// error state. s_err = 1 once a type error is flagged; the first error's
// message + position are recorded (later errors are suppressed so the test
// sees the root cause, matching the parser's err() first-error policy).
// -----------------------------------------------------------------------------
global s_err     : i64 = 0;
global s_errcode : i64 = 0;   // 1=type error; -3xx=outside self-hosted subset
global s_errline : i64 = 0;
global s_errcol  : i64 = 0;
global s_errmsg  : string = "";

// the current function's return type (for return-stmt checking). -1 = not in a fn.
global s_cur_ret : i64 = 0;

// struct-returning-call allowance flag. Mirrors src/sema.cpp's
// allow_struct_ret_call parameter: a struct-returning CallExpr is only valid
// as a LetStmt initializer or a ReturnStmt value (the two positions where
// codegen has a concrete destination address for the callee's hidden return
// pointer), OR as a struct-by-value call argument of the matching struct
// type (gated in check_callexpr by the param type). Set to 1 around the
// check_expr of a let-init / return-value, 0 elsewhere. A struct-returning
// call in any other position (e.g. a discarded expr stmt, or the base of a
// field access) is rejected here so codegen never has to materialize a
// struct-returning call's result into a register.
global s_allow_struct_ret_call : i64 = 0;

// Logical scope-mark depth and current loop nesting. The backing arrays cannot
// shrink, so live stack depth must be tracked independently of physical size.
global s_mark_len  : i64 = 0;
global s_scope_len : i64 = 0;
global s_loop_depth: i64 = 0;
global s_switch_depth: i64 = 0;   // Phase 3b: switch nesting (break valid inside a switch)

// -----------------------------------------------------------------------------
// init — allocate the symbol tables + canonical types. Called once at sema()
// entry (and safe to call repeatedly: it resets every table). The canonical
// primitive Type nodes are appended to g_nodes so type_eq can compare by index.
// -----------------------------------------------------------------------------
fn s_init() -> i64 {
    s_toks = parse_tokens();
    // Reuse the symbol-table arrays across s_init() calls instead of
    // allocating fresh ones each time. The host array extension has no
    // array_free (slots in the process-wide store are never reclaimed until
    // reset()), so a fresh array_new on every sema() leaks the previous
    // buffer — and the leaked buffers accumulate in the trace-callback scan,
    // eventually crashing the host at scale (a bare RUNTIME TRAP / exit 70).
    // array_clear() resets the logical length to 0 while keeping the backing
    // buffer, so the slot is reused and the store stops growing. The first
    // call (handle == 0) still allocates.
    if (g_fns != 0) { array_clear(g_fns); } else { g_fns = array_new(8, 0); }
    if (g_structs != 0) { array_clear(g_structs); } else { g_structs = array_new(8, 0); }
    if (g_enums != 0) { array_clear(g_enums); } else { g_enums = array_new(8, 0); }
    if (g_enum_types != 0) { array_clear(g_enum_types); } else { g_enum_types = array_new(8, 0); }
    if (g_globals != 0) { array_clear(g_globals); } else { g_globals = array_new(8, 0); }
    if (g_scope != 0) { array_clear(g_scope); } else { g_scope = array_new(8, 0); }
    if (g_marks != 0) { array_clear(g_marks); } else { g_marks = array_new(8, 0); }
    if (g_ns_names != 0) { array_clear(g_ns_names); } else { g_ns_names = array_new(8, 0); }
    if (g_lambdas != 0) { array_clear(g_lambdas); } else { g_lambdas = array_new(8, 0); }
    if (g_lambda_caps != 0) { array_clear(g_lambda_caps); } else { g_lambda_caps = array_new(8, 0); }
    s_cur_ns = -1;
    if (ce_params != 0) { array_clear(ce_params); } else { ce_params = array_new(8, 0); }
    if (ce_param_marks != 0) { array_clear(ce_param_marks); } else { ce_param_marks = array_new(8, 0); }
    ce_params_len = 0;
    ce_param_mark_len = 0;
    ce_depth = 0;
    ce_iters = 0;
    ce_returned = 0;
    ce_ret_val = 0;
    s_err = 0;
    s_errcode = 0;
    s_errline = 0;
    s_errcol = 0;
    s_errmsg = string_from_slice("");
    s_cur_ret = -1;
    s_mark_len = 0;
    s_scope_len = 0;
    s_loop_depth = 0;
    s_switch_depth = 0;

    // canonical primitive types: three Type nodes appended to g_nodes.
    TY_I64 = alloc_node(NK::Type as i64);
    set_d(TY_I64, Prim::I64 as i64);

    TY_BOOL = alloc_node(NK::Type as i64);
    set_d(TY_BOOL, Prim::Bool as i64);

    TY_VOID = alloc_node(NK::Type as i64);
    set_d(TY_VOID, Prim::Void as i64);

    TY_F32 = alloc_node(NK::Type as i64);
    set_d(TY_F32, Prim::F32 as i64);
    TY_F64 = alloc_node(NK::Type as i64);
    set_d(TY_F64, Prim::F64 as i64);
    // Phase 2: canonical nodes for every integer width.
    TY_I8  = alloc_node(NK::Type as i64); set_d(TY_I8,  Prim::I8  as i64);
    TY_I16 = alloc_node(NK::Type as i64); set_d(TY_I16, Prim::I16 as i64);
    TY_I32 = alloc_node(NK::Type as i64); set_d(TY_I32, Prim::I32 as i64);
    TY_U8  = alloc_node(NK::Type as i64); set_d(TY_U8,  Prim::U8  as i64);
    TY_U16 = alloc_node(NK::Type as i64); set_d(TY_U16, Prim::U16 as i64);
    TY_U32 = alloc_node(NK::Type as i64); set_d(TY_U32, Prim::U32 as i64);
    TY_U64 = alloc_node(NK::Type as i64); set_d(TY_U64, Prim::U64 as i64);
    // `string` is a builtin opaque handle. Prim 12 is private to the
    // self-hosted compiler and deliberately does not collide with v1 Prim.
    TY_STRING = alloc_node(NK::Type as i64);
    set_d(TY_STRING, 12);
    // build the host-extension native signature table (array/math/map/string/
    // io). Must run after the canonical TY_* nodes exist (rows reference them).
    init_natives();
    return 0;
}

// -----------------------------------------------------------------------------
// error reporting. serr(msg, line, col) flags the first error and returns the
// void type (so callers can `return serr(...)` and keep checking with a
// fallback). The line/col come from the relevant token's position.
// -----------------------------------------------------------------------------
fn serr(msg: string, line: i64, col: i64) -> i64 {
    if (s_err == 0) {
        s_err = 1;
        s_errcode = 1;
        s_errline = line;
        s_errcol = col;
        s_errmsg = msg;
    }
    return TY_VOID;
}

// Record a machine-readable subset violation. These codes are deliberately
// distinct from ordinary type errors so emberc never sends unsupported AST
// nodes into the x64 emitter.
fn unsupported(code: i64, feature: string, node: i64) -> i64 {
    if (s_err == 0) {
        s_err = 1;
        s_errcode = code;
        s_errline = node_line(node);
        s_errcol = node_col(node);
        s_errmsg = string_from_slice("unsupported by self-hosted subset: ") + feature;
    }
    return TY_VOID;
}

// Stage 2 currently consumes annotations without attaching them to AST nodes.
// Reject their preserved lexer tokens here so semantic contracts are never
// silently erased before the self-hosted compiler supports annotation metadata.
fn reject_annotations() -> i64 {
    let n: i64 = tok_count(s_toks);
    let mut i: i64 = 0;
    while (i < n) {
        if (tok_kind(s_toks, i) == (Tok::At as i64)) {
            if (s_err == 0) {
                s_err = 1;
                s_errcode = -318;
                s_errline = tok_line(s_toks, i);
                s_errcol = tok_col(s_toks, i);
                s_errmsg = string_from_slice("unsupported by self-hosted subset: annotation");
            }
            return -318;
        }
        i = i + 1;
    }
    return 0;
}

// a node's position (line/col) from its `tok` token, for error messages. Falls
// back to (0,0) for synthetic nodes (tok < 0).
fn node_line(i: i64) -> i64 {
    let t: i64 = nk_tok(i);
    if (t < 0) { return 0; }
    return tok_line(s_toks, t);
}
fn node_col(i: i64) -> i64 {
    let t: i64 = nk_tok(i);
    if (t < 0) { return 0; }
    return tok_col(s_toks, t);
}

// retrieve a name from a token index (the symbol-table key).
fn tok_name(t: i64) -> string {
    if (t < 0) { return string_from_slice(""); }
    return tok_text(s_toks, t);
}

// -----------------------------------------------------------------------------
// type accessors + equality. A type is a Type-node index.
// -----------------------------------------------------------------------------

// the Prim value of a type node (the `d` slot).
fn ty_prim(t: i64) -> i64 { return nk_d(t); }

// the struct-name token index of a type node (the `tok` slot, -1 for prims).
fn ty_struct_tok(t: i64) -> i64 { return nk_tok(t); }

// the struct name as a string ("" for primitives).
fn ty_struct_name(t: i64) -> string { return tok_name(nk_tok(t)); }

// is_slice flag (the `f` slot).
fn ty_is_slice(t: i64) -> i64 { if (nk_f(t) == 1) { return 1; } return 0; }
fn ty_is_fn(t: i64) -> i64 { if (t >= 0 && nk_kind(t) == (NK::Type as i64) && nk_f(t) == 2) { return 1; } return 0; }

// array_len (the `e` slot).
fn ty_array_len(t: i64) -> i64 { return nk_e(t); }

// element type (the `a` slot) for array/slice types.
fn ty_elem(t: i64) -> i64 { return nk_a(t); }

// is this type a REGISTERED struct? Mirrors src/sema.cpp's
// is_registered_struct: a Type whose struct_name resolves in g_structs.
// Used by the struct by-value arg/return ABI (check_callexpr's struct-arg
// shape gate + register_fn's allowance of struct returns/params).
fn ty_is_struct(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    if (nk_tok(t) < 0) { return 0; }
    let nm: string = tok_name(nk_tok(t));
    if (nm == string_from_slice("string")) { return 0; }   // opaque handle
    if (find_struct(nm) >= 0) { return 1; }
    return 0;
}

// is this an aggregate type (slice, fixed array, or struct)? Scalars
// (int/float/bool/void/handle) are NOT aggregates. Used by check_let's
// array-literal target validation. (Struct fn params/returns are now ALLOWED
// — register_fn only rejects slice/fixed-array aggregates via
// ty_is_slice_or_array, so structs flow through the by-value ABI.)
fn ty_is_aggregate(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    if (nk_f(t) == 1) { return 1; }          // slice
    if (nk_e(t) > 0) { return 1; }           // fixed array
    if (ty_is_struct(t) == 1) { return 1; }  // struct
    return 0;
}

// is this a slice or fixed-array aggregate (NOT a struct)? register_fn
// rejects these as fn params/returns (-310) since the self-hosted call ABI
// has the struct by-value path but not the slice/array by-value path yet.
fn ty_is_slice_or_array(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    if (nk_f(t) == 1) { return 1; }          // slice
    if (nk_e(t) > 0) { return 1; }           // fixed array
    return 0;
}

// is this type the integer type i64? (v1 subset: only i64 is a "plain integer")
fn ty_is_i64(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    if (nk_d(t) != (Prim::I64 as i64)) { return 0; }
    if (nk_tok(t) >= 0) { return 0; }   // a named/handle type, not plain i64
    if (nk_f(t) == 1) { return 0; }     // a slice, not a scalar (f=1 marks a slice; the
                                        // parser's alloc_node defaults f to -1, so a
                                        // plain scalar has f=-1, not 0)
    return 1;
}

// is this type a plain integer (any int width)? v1's binary-op check accepts
// any integer primitive (i8/i16/i32/i64/u8/u16/u32/u64) for arithmetic; the
// canonical test uses i64 but the rule generalizes.
fn ty_is_int(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    let p: i64 = nk_d(t);
    if (nk_tok(t) >= 0) { return 0; }
    if (nk_f(t) == 1) { return 0; }   // f=1 marks a slice; scalars default to f=-1
    // Prim I8..U64 = 2..9
    if (p >= 2 && p <= 9) { return 1; }
    return 0;
}

// is this type an integer OR a typed enum (which IS an integer per
// src/ast.hpp: is_int() returns true for a typed enum)? Used by the
// comparison + arithmetic same-type rule so `Color::Red == 0` (typed enum vs
// plain int) is accepted as both-integer, mirroring the native.
fn ty_is_int_or_typed_enum(t: i64) -> i64 {
    if (ty_is_int(t) == 1) { return 1; }
    if (is_typed_enum_type(t) == 1) { return 1; }
    return 0;
}

// is this type an UNSIGNED integer (u8/u16/u32/u64)?
fn ty_is_uint(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    let p: i64 = nk_d(t);
    if (nk_tok(t) >= 0) { return 0; }
    if (nk_f(t) == 1) { return 0; }
    // Prim U8..U64 = 6..9
    if (p >= 6 && p <= 9) { return 1; }
    return 0;
}

// the bit width of an integer type (8/16/32/64), mirroring src/sema.cpp's
// int_width. Non-integer types return 0.
fn ty_int_width(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    let p: i64 = nk_d(t);
    if (p == (Prim::I8  as i64) || p == (Prim::U8  as i64)) { return 8; }
    if (p == (Prim::I16 as i64) || p == (Prim::U16 as i64)) { return 16; }
    if (p == (Prim::I32 as i64) || p == (Prim::U32 as i64)) { return 32; }
    if (p == (Prim::I64 as i64) || p == (Prim::U64 as i64)) { return 64; }
    return 0;
}

// is this type bool?
fn ty_is_bool(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    if (nk_d(t) != (Prim::Bool as i64)) { return 0; }
    if (nk_tok(t) >= 0) { return 0; }
    return 1;
}

// is this type void?
fn ty_is_void(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    if (nk_d(t) != (Prim::Void as i64)) { return 0; }
    if (nk_tok(t) >= 0) { return 0; }
    if (nk_f(t) == 1) { return 0; }   // a slice is not void
    if (nk_e(t) > 0) { return 0; }   // a fixed array is not void
    return 1;
}

fn ty_is_string(t: i64) -> i64 {
    if (t < 0 || nk_kind(t) != (NK::Type as i64)) { return 0; }
    if (nk_d(t) == 12 && nk_tok(t) < 0) { return 1; }
    return 0;
}

// is this a numeric type (int or float)? floats are Prim F32=10 / F64=11.
fn ty_is_float(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    let p: i64 = nk_d(t);
    if (nk_tok(t) >= 0) { return 0; }
    if (nk_f(t) == 1) { return 0; }   // f=1 marks a slice; scalars default to f=-1
    if (p == 10 || p == 11) { return 1; }
    return 0;
}

// Structural type equality: two Type nodes are the same type iff their prim,
// struct name, slice flag, array len, and element type all match. Canonical
// primitives share one node index so the common case is a single `t1 == t2`.
fn type_eq(t1: i64, t2: i64) -> i64 {
    if (t1 == t2) { return 1; }
    if (t1 < 0 || t2 < 0) { return 0; }
    if (nk_kind(t1) != (NK::Type as i64)) { return 0; }
    if (nk_kind(t2) != (NK::Type as i64)) { return 0; }
    if (nk_d(t1) != nk_d(t2)) { return 0; }
    // Avoid `!=` on string handles: the host overload path is reliable for
    // `==`, while direct handle inequality is identity-based in some builds.
    if ((tok_name(nk_tok(t1)) == tok_name(nk_tok(t2))) == false) { return 0; }
    if (nk_f(t1) != nk_f(t2)) { return 0; }
    if (nk_e(t1) != nk_e(t2)) { return 0; }
    if (nk_f(t1) == 2) {
        if (type_eq(resolve_type(nk_b(t1)), resolve_type(nk_b(t2))) == 0) { return 0; }
        let mut p1: i64 = nk_a(t1); let mut p2: i64 = nk_a(t2);
        while (p1 >= 0 && p2 >= 0) {
            let mut a1: i64 = p1; if (nk_kind(p1) == (NK::Param as i64)) { a1 = nk_a(p1); }
            let mut a2: i64 = p2; if (nk_kind(p2) == (NK::Param as i64)) { a2 = nk_a(p2); }
            if (type_eq(resolve_type(a1), resolve_type(a2)) == 0) { return 0; }
            p1 = nk_next(p1); p2 = nk_next(p2);
        }
        if (p1 >= 0 || p2 >= 0) { return 0; }
        return 1;
    }
    // element type for array/slice — recurse
    let e1: i64 = nk_a(t1);
    let e2: i64 = nk_a(t2);
    if (e1 < 0 && e2 < 0) { return 1; }
    if (e1 < 0 || e2 < 0) { return 0; }
    return type_eq(e1, e2);
}

// types_compatible: true iff `want` and `got` are compatible. Mirrors
// src/sema.cpp's types_compatible + can_implicitly_convert:
//   - same type (type_eq)
//   - same-signedness integer widening (int_width(got) < int_width(want))
//   - f32 -> f64 widening
// A literal-adaptation path is NOT needed here because check_expr always
// returns TY_I64 for an IntLit; the let/return/arg/call sites that compare a
// declared int type against an IntLit's TY_I64 go through the widening rule
// (i64 widens nothing, but the literal check is handled at the let site via
// the int-literal-fits-int-type gate in check_let). For a typed int target
// receiving an i64 IntLit, check_let/check_value use ty_int_fits_lit instead.
fn types_compatible(want: i64, got: i64) -> i64 {
    if (type_eq(want, got) == 1) { return 1; }
    // same-signedness integer widening: i8->i16->i32->i64, u8->u16->u32->u64
    if (ty_is_int(want) == 1 && ty_is_int(got) == 1) {
        if (ty_is_uint(want) == ty_is_uint(got)) {
            if (ty_int_width(got) < ty_int_width(want)) { return 1; }
        }
    }
    // Phase 3b: typed-enum -> backing-int implicit widening. A typed-enum value
    // (a Type with nk_tok = enum name + an integer backing prim) flows to a
    // plain integer target when same-signedness + backing width <= target
    // width. The reverse (int->enum) is NOT implicit. Mirrors src/sema.cpp's
    // can_implicitly_convert enum branch.
    if (ty_is_int(want) == 1 && is_typed_enum_type(got) == 1) {
        if (ty_is_uint(want) == typed_enum_is_uint(got)) {
            if (typed_enum_width(got) <= ty_int_width(want)) { return 1; }
        }
    }
    // f32 -> f64 widening
    if (ty_is_float(got) == 1 && ty_is_float(want) == 1) {
        if (nk_d(got) == (Prim::F32 as i64) && nk_d(want) == (Prim::F64 as i64)) { return 1; }
    }
    return 0;
}

// a human-readable type name for error messages ("i64", "bool", "void", or the
// struct name). v1 keeps it short; the canonical subset only needs the prims.
fn ty_name(t: i64) -> string {
    if (t < 0) { return string_from_slice("?"); }
    if (nk_kind(t) != (NK::Type as i64)) { return string_from_slice("?"); }
    let p: i64 = nk_d(t);
    if (nk_tok(t) >= 0) { return tok_name(nk_tok(t)); }
    if (p == (Prim::I64 as i64)) { return string_from_slice("i64"); }
    if (p == (Prim::I32 as i64)) { return string_from_slice("i32"); }
    if (p == (Prim::I16 as i64)) { return string_from_slice("i16"); }
    if (p == (Prim::I8  as i64)) { return string_from_slice("i8"); }
    if (p == (Prim::U64 as i64)) { return string_from_slice("u64"); }
    if (p == (Prim::U32 as i64)) { return string_from_slice("u32"); }
    if (p == (Prim::U16 as i64)) { return string_from_slice("u16"); }
    if (p == (Prim::U8  as i64)) { return string_from_slice("u8"); }
    if (p == (Prim::Bool as i64)) { return string_from_slice("bool"); }
    if (p == (Prim::Void as i64)) { return string_from_slice("void"); }
    if (p == (Prim::F32 as i64)) { return string_from_slice("f32"); }
    if (p == (Prim::F64 as i64)) { return string_from_slice("f64"); }
    if (p == 12) { return string_from_slice("string"); }
    return string_from_slice("?");
}

// -----------------------------------------------------------------------------
// type resolution. resolve_type(t) verifies a Type node is well-formed: a
// primitive prim, or a named struct that was declared. Returns the canonical
// type (for i64/bool/void, the shared TY_* node; otherwise the node itself),
// or TY_VOID + an error if the named struct is unknown.
//
// For the v1 subset, the only named types the test uses are primitives; struct
// types are resolved by looking up g_structs. An unknown name is a type error.
// -----------------------------------------------------------------------------
fn resolve_type(t: i64) -> i64 {
    if (t < 0) { return serr(string_from_slice("missing type"), 0, 0); }
    if (nk_kind(t) != (NK::Type as i64)) {
        return serr(string_from_slice("expected a type"), node_line(t), node_col(t));
    }
    let p: i64 = nk_d(t);
    // named struct/handle type: tok set, prim=Void (the parser's named-type
    // marker). Look it up in the struct table.
    if (nk_tok(t) >= 0) {
        let nm: string = tok_name(nk_tok(t));
        if (nm == string_from_slice("string")) { return TY_STRING; }
        if (find_struct(nm) >= 0) { return t; }
        // Phase 3b: a typed enum name is a real type — return the canonical
        // typed-enum Type (prim=backing, tok=name). An UNTYPED enum name in a
        // type position is rejected (mirror src/sema.cpp's check_type_not_enum:
        // `let x: Color = ...` for an untyped enum is a clean error).
        if (is_typed_enum_name(nm) == 1) { return typed_enum_type(nm); }
        if (find_enum(nm) >= 0) {
            return serr(string_from_slice("enum '") + nm + string_from_slice("' is untyped; declare the binding with an integer type, or declare the enum as `enum ") + nm + string_from_slice(" : <int>`"),
                        node_line(t), node_col(t));
        }
        return serr(string_from_slice("unknown type '") + nm + string_from_slice("'"),
                    node_line(t), node_col(t));
    }
    if (nk_f(t) == 2) {
        let mut fp: i64 = nk_a(t);
        while (fp >= 0) {
            let mut fpt: i64 = fp; if (nk_kind(fp) == (NK::Param as i64)) { fpt = nk_a(fp); }
            resolve_type(fpt); if (s_err != 0) { return TY_VOID; }
            fp = nk_next(fp);
        }
        if (nk_b(t) >= 0) { resolve_type(nk_b(t)); if (s_err != 0) { return TY_VOID; } }
        return t;
    }
    if (nk_f(t) == 1) {
        // slice T[]: resolve the element type recursively. A slice is a valid
        // Phase 3 type (16 bytes {ptr,len}).
        let elem: i64 = nk_a(t);
        if (elem < 0) { return serr(string_from_slice("slice type missing element type"), node_line(t), node_col(t)); }
        let re: i64 = resolve_type(elem);
        if (s_err != 0) { return TY_VOID; }
        set_a(t, re);
        return t;
    }
    if (nk_e(t) > 0) {
        // fixed array T[N]: resolve the element type recursively. A fixed
        // array is a valid Phase 3 type (N*elem bytes, inline). Reject an
        // absurdly large N (mirrors src/sema.cpp's MAX_ARRAY_LEN + the frame
        // budget) so a malformed huge size can't build a frame that overflows.
        let n: i64 = nk_e(t);
        if (n > 2147483647) {
            return serr(string_from_slice("array size exceeds the supported maximum"), node_line(t), node_col(t));
        }
        let elem: i64 = nk_a(t);
        if (elem < 0) { return serr(string_from_slice("array type missing element type"), node_line(t), node_col(t)); }
        let re: i64 = resolve_type(elem);
        if (s_err != 0) { return TY_VOID; }
        set_a(t, re);
        return t;
    }
    if (p == (Prim::I64 as i64)) { return TY_I64; }
    if (p == (Prim::Bool as i64)) { return TY_BOOL; }
    if (p == (Prim::Void as i64)) { return TY_VOID; }
    if (p == (Prim::F32 as i64)) { return TY_F32; }
    if (p == (Prim::F64 as i64)) { return TY_F64; }
    // Phase 2: all integer widths (i8/i16/i32/u8/u16/u32/u64) are now
    // accepted, mirroring src/sema.cpp's full primitive resolution. Each
    // resolves to its canonical Type node so type_eq is a single-index compare.
    if (p == (Prim::I8  as i64)) { return TY_I8;  }
    if (p == (Prim::I16 as i64)) { return TY_I16; }
    if (p == (Prim::I32 as i64)) { return TY_I32; }
    if (p == (Prim::U8  as i64)) { return TY_U8;  }
    if (p == (Prim::U16 as i64)) { return TY_U16; }
    if (p == (Prim::U32 as i64)) { return TY_U32; }
    if (p == (Prim::U64 as i64)) { return TY_U64; }
    return unsupported(-315, string_from_slice("non-i64 integer or function-handle type"), t);
}

// -----------------------------------------------------------------------------
// struct table. find_struct(name) returns the struct's entry index in
// g_structs (row = index / STRUCT_STRIDE), or -1 if not declared.
// -----------------------------------------------------------------------------
fn find_struct(name: string) -> i64 {
    let n: i64 = array_length(g_structs) / STRUCT_STRIDE;
    let mut i: i64 = 0;
    while (i < n) {
        let tok: i64 = array_get_i64(g_structs, i * STRUCT_STRIDE + 0);
        if (tok_name(tok) == name) { return i; }
        i = i + 1;
    }
    return -1;
}

// register a struct decl: append (name_tok, first_field) to g_structs.
fn find_enum(name: string) -> i64 {
    let n: i64 = array_length(g_enums) / 2;
    let mut i: i64 = 0;
    while (i < n) {
        if (tok_name(array_get_i64(g_enums, i * 2)) == name) { return i; }
        i = i + 1;
    }
    return -1;
}

fn register_enum(ed: i64) -> i64 {
    let nm: string = nk_name(ed);
    if (find_enum(nm) >= 0) {
        return serr(string_from_slice("duplicate enum declaration '") + nm + string_from_slice("'"), node_line(ed), node_col(ed));
    }
    array_push_i64(g_enums, nk_tok(ed));
    array_push_i64(g_enums, nk_b(ed));
    // Phase 3b: typed enum (`enum E : T`). A typed enum is a real type backed
    // by the integer T: build a canonical Type node (prim=backing, tok=E-name)
    // so `let e: E = E::B` type-checks (E==E) and `e as i64` widens the
    // backing int. Mirrors src/sema.cpp's register_typed_enums + the interned
    // typed_enum_types map. An untyped enum (no `: type`) gets NO entry here —
    // its name is not a type, and using it in a type position is rejected
    // (check_type_not_enum), matching the C++ untyped-enum rule.
    let backing_node: i64 = nk_a(ed);
    if (backing_node >= 0 && nk_kind(backing_node) == (NK::Type as i64)) {
        let bt: i64 = resolve_type(backing_node);
        if (s_err != 0) { return 0; }
        // the backing must be an integer primitive (mirror the C++ guard).
        if (ty_is_int(bt) == 0) {
            return serr(string_from_slice("enum '") + nm + string_from_slice("' backing type must be an integer"),
                        node_line(ed), node_col(ed));
        }
        // build the canonical typed-enum type: prim=backing, tok=enum-name.
        let et: i64 = alloc_node(NK::Type as i64);
        set_d(et, nk_d(bt));            // backing prim
        set_tok(et, nk_tok(ed));        // enum name token
        array_push_i64(g_enum_types, nk_tok(ed));
        array_push_i64(g_enum_types, et);
    }
    return 0;
}

// Phase 3b: typed-enum helpers (mirror src/sema.cpp's is_typed_enum /
// typed_enum_types). is_typed_enum(name) -> 1 if `enum E : T` declared.
fn is_typed_enum_name(name: string) -> i64 {
    let n: i64 = array_length(g_enum_types) / 2;
    let mut i: i64 = 0;
    while (i < n) {
        if (tok_name(array_get_i64(g_enum_types, i * 2)) == name) { return 1; }
        i = i + 1;
    }
    return 0;
}

// the canonical typed-enum Type node for `name`, or -1 if it is untyped.
fn typed_enum_type(name: string) -> i64 {
    let n: i64 = array_length(g_enum_types) / 2;
    let mut i: i64 = 0;
    while (i < n) {
        if (tok_name(array_get_i64(g_enum_types, i * 2)) == name) { return array_get_i64(g_enum_types, i * 2 + 1); }
        i = i + 1;
    }
    return -1;
}

// is a Type node a typed-enum type? (nk_tok names a typed enum). The typed-enum
// type carries prim=backing + tok=enum-name, so it is distinguished from a
// plain int (which has nk_tok < 0) and from a struct (which is in g_structs).
fn is_typed_enum_type(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    if (nk_tok(t) < 0) { return 0; }
    return is_typed_enum_name(tok_name(nk_tok(t)));
}

// is a typed-enum type's backing UNSIGNED? (u8/u16/u32/u64)
fn typed_enum_is_uint(t: i64) -> i64 {
    if (is_typed_enum_type(t) == 0) { return 0; }
    let p: i64 = nk_d(t);
    if (p == (Prim::U8 as i64) || p == (Prim::U16 as i64) || p == (Prim::U32 as i64) || p == (Prim::U64 as i64)) { return 1; }
    return 0;
}

// the bit width of a typed-enum type's backing integer (8/16/32/64).
fn typed_enum_width(t: i64) -> i64 {
    if (is_typed_enum_type(t) == 0) { return 64; }
    return ty_int_width(t);   // ty_int_width reads nk_d only; the backing prim is there
}

// resolve a variant's compile-time i64 value (explicit `= constexpr` or
// auto-increment from 0 / prev+1). Mirrors src/sema.cpp's resolve_enums + the
// self-hosted cg_enum_value, lifted to a shared sema helper so check_expr can
// type-check a typed enum's variant value range + EnumAccess can report it.
// Returns 1 + sets g_enum_val_out on success, 0 on failure (unknown variant).
global g_enum_val_out: i64 = 0;
fn enum_variant_value(row: i64, variant_name: string) -> i64 {
    let mut value: i64 = 0;
    let mut v: i64 = array_get_i64(g_enums, row * 2 + 1);
    while (v >= 0) {
        if (nk_a(v) >= 0) {
            // explicit value: fold the const expr. try_eval_const_i64 handles
            // IntLit / -IntLit / BinExpr of literals AND constexpr fn calls
            // (e.g. `X = base()`), matching the C++ resolve_enums pre-pass.
            if (try_eval_const_i64(nk_a(v)) == 1) { value = ce_int_out; }
            else if (try_const_i64(nk_a(v)) == 1) { value = s_constval; }
        }
        if (nk_name(v) == variant_name) { g_enum_val_out = value; return 1; }
        value = value + 1;
        v = nk_next(v);
    }
    return 0;
}

fn enum_variant_exists(row: i64, name: string) -> i64 {
    let mut v: i64 = array_get_i64(g_enums, row * 2 + 1);
    while (v >= 0) {
        if (nk_name(v) == name) { return 1; }
        v = nk_next(v);
    }
    return 0;
}

fn register_struct(sd: i64) -> i64 {
    let nm_tok: i64 = nk_tok(sd);
    let nm: string = tok_name(nm_tok);
    if (find_struct(nm) >= 0) {
        return serr(string_from_slice("duplicate struct declaration '") + nm + string_from_slice("'"),
                    node_line(sd), node_col(sd));
    }
    array_push_i64(g_structs, nm_tok);
    array_push_i64(g_structs, nk_a(sd));   // first field (or -1)
    return 0;
}

// look up a struct field's type by name. Returns the field's Type node, or -1
// if the struct / field is not found. Fields are linked via nk_next from the
// struct's first-field slot.
fn struct_field_type(struct_row: i64, field_name: string) -> i64 {
    let first: i64 = array_get_i64(g_structs, struct_row * STRUCT_STRIDE + 1);
    let mut f: i64 = first;
    while (f >= 0) {
        if (tok_name(nk_tok(f)) == field_name) {
            return resolve_type(nk_a(f));
        }
        f = nk_next(f);
    }
    return -1;
}

// -----------------------------------------------------------------------------
// function table. find_fn(name) returns the fn's entry row, or -1.
//   row layout (FN_STRIDE = 5): [ name_tok, ret_type, first_param, param_count, ns_tok ]
// first_param is the first Param node (linked via nk_next); param_count is the
// total; ns_tok is the namespace name token (-1 for a top-level fn).
// find_fn matches a TOP-LEVEL fn by bare name (ns_tok == -1). A namespaced fn
// is found via find_fn_qualified(name, ns_name) (Ns::fn) — two namespaces may
// each declare a fn with the same bare name, so the bare-name scan must NOT
// cross into namespaced rows.
// -----------------------------------------------------------------------------
fn find_fn(name: string) -> i64 {
    let n: i64 = array_length(g_fns) / FN_STRIDE;
    let mut i: i64 = 0;
    while (i < n) {
        let tok: i64 = array_get_i64(g_fns, i * FN_STRIDE + 0);
        if (tok_name(tok) == name) {
            if (array_get_i64(g_fns, i * FN_STRIDE + 4) < 0) { return i; }  // top-level only
        }
        i = i + 1;
    }
    return -1;
}

// find a fn by qualified name (Ns::fn). ns_name "" matches a top-level fn
// (ns_tok == -1); a nonempty ns_name matches a fn whose ns_tok names ns_name.
// Returns the row, or -1. Mirrors the native qualified-name script_sigs lookup.
fn find_fn_qualified(name: string, ns_name: string) -> i64 {
    let n: i64 = array_length(g_fns) / FN_STRIDE;
    let mut i: i64 = 0;
    while (i < n) {
        let tok: i64 = array_get_i64(g_fns, i * FN_STRIDE + 0);
        if (tok_name(tok) == name) {
            let ns_tok: i64 = array_get_i64(g_fns, i * FN_STRIDE + 4);
            let mut ok: i64 = 0;
            if (ns_tok < 0) {
                if (string_length(ns_name) == 0) { ok = 1; }
            } else {
                if (tok_name(ns_tok) == ns_name) { ok = 1; }
            }
            if (ok == 1) { return i; }
        }
        i = i + 1;
    }
    return -1;
}

// the namespace name token of a fn row (-1 for a top-level fn).
fn fn_ns_tok(fn_row: i64) -> i64 {
    return array_get_i64(g_fns, fn_row * FN_STRIDE + 4);
}

// is a fn row a constexpr fn? (FD_CEXPR bit set on the stored FnDecl flags.)
fn fn_is_constexpr(fn_row: i64) -> i64 {
    let flags: i64 = array_get_i64(g_fns, fn_row * FN_STRIDE + 5);
    if ((flags & FD_CEXPR) != 0) { return 1; }
    return 0;
}

// the first Param node of a fn row (for the constexpr interpreter to bind args).
fn fn_first_param(fn_row: i64) -> i64 {
    return array_get_i64(g_fns, fn_row * FN_STRIDE + 2);
}

// the body BlockStmt node of a fn row. The g_fns row stores the ret type +
// first param, not the body; recover the FnDecl node by scanning g_nodes for
// the FnDecl with the matching name tok + ns tok (qualified identity), then
// read its slot c (body). Used by the constexpr interpreter.
fn fn_body_block(fn_row: i64) -> i64 {
    let nm_tok: i64 = array_get_i64(g_fns, fn_row * FN_STRIDE + 0);
    let ns_tok: i64 = array_get_i64(g_fns, fn_row * FN_STRIDE + 4);
    let nn: i64 = array_length(g_nodes) / PARSE_STRIDE;
    let mut i: i64 = 0;
    while (i < nn) {
        if (nk_kind(i) == (NK::FnDecl as i64)) {
            if (nk_tok(i) == nm_tok) {
                // match the namespace via the member's stamped slot e (the ns
                // name tok) — a top-level fn has slot e < 0.
                let m_ns: i64 = nk_e(i);
                let mut ok: i64 = 0;
                if (ns_tok < 0) { if (m_ns < 0) { ok = 1; } }
                else { if (m_ns == ns_tok) { ok = 1; } }
                if (ok == 1) { return nk_c(i); }
            }
        }
        i = i + 1;
    }
    return -1;
}

// is `name` a declared namespace name? (Tier 1 namespace resolution: Foo::bar
// where Foo is a namespace, not an enum.) Mirrors src/sema.cpp's
// namespace_names.count(...).
fn is_namespace_name(name: string) -> i64 {
    let n: i64 = array_length(g_ns_names);
    let mut i: i64 = 0;
    while (i < n) {
        let tok: i64 = array_get_i64(g_ns_names, i);
        if (tok_name(tok) == name) { return 1; }
        i = i + 1;
    }
    return 0;
}

// fn_param_type(fn_row, i) -> the i-th param's resolved type (0-based).
fn fn_param_type(fn_row: i64, i: i64) -> i64 {
    let first: i64 = array_get_i64(g_fns, fn_row * FN_STRIDE + 2);
    let mut p: i64 = first;
    let mut k: i64 = 0;
    while (p >= 0) {
        if (k == i) { return resolve_type(nk_a(p)); }
        p = nk_next(p);
        k = k + 1;
    }
    return TY_VOID;
}

// fn_ret_type(fn_row) -> the fn's resolved return type.
fn fn_ret_type(fn_row: i64) -> i64 {
    let rt: i64 = array_get_i64(g_fns, fn_row * FN_STRIDE + 1);
    return resolve_type(rt);
}

// fn_param_count(fn_row) -> the recorded param count.
fn fn_param_count(fn_row: i64) -> i64 {
    return array_get_i64(g_fns, fn_row * FN_STRIDE + 3);
}

// -----------------------------------------------------------------------------
// native (host extension) signature table. The self-hosted codegen emits calls
// to these as ABS64_NATIVE relocations (EMBM v1 §7); the host loader resolves
// them against the registered NativeSig table and validates the ABI fingerprint.
// These signatures mirror the host's registered natives
// (extensions/{array,math,map,string,io}/ext_*.cpp) EXACTLY so sema's type check
// + the codegen's fingerprint match what the loader expects.
//
// A `string` is an opaque i64 handle (host bind_handle("string"): prim I64 +
// struct_name "string" -> ABI code 6). Integer args are i64 (code 1); f64/f32
// args are code 2/3; bool is code 4; u8 is code 8; void return is code 0.
// Permission is 0 (none) for array/math/map/string and 1 (PERM_FFI) for io.
//
// NOTE on string_from_slice: the host registers it with a u8-slice param
// (code 5, passed as two words ptr+len). The self-hosted subset has no
// first-class slice value a user can name -- a string literal is typed
// TY_STRING (a handle) here -- so the table records string_from_slice's param
// as TY_STRING so a `string_from_slice("lit")` call type-checks. The codegen
// special-cases that call (StringLit arg) to emit the real slice ABI + the
// code-5 fingerprint; see cg_eval_callexpr. (A non-literal arg is an edge case
// the subset does not support.)
// -----------------------------------------------------------------------------

// add one native row: param_count, up to 4 param type nodes, ret, perm.
// Unused param slots are filled with -1. param_count is the real arity (<= 4
// for every host native in v1). The row ORDER here is the single source of
// truth for native_find's if-chain (names are compared as string==string in
// the chain, since ember keeps `string` handles distinct from `i64`).
fn nat_add(pc: i64, p0: i64, p1: i64, p2: i64, p3: i64, rt: i64, perm: i64) -> i64 {
    array_push_i64(g_natives, pc);
    array_push_i64(g_natives, p0);
    array_push_i64(g_natives, p1);
    array_push_i64(g_natives, p2);
    array_push_i64(g_natives, p3);
    array_push_i64(g_natives, rt);
    array_push_i64(g_natives, perm);
    return 0;
}

// build the full native table. Mirrors the host registrations verbatim. Called
// once from s_init after the canonical TY_* nodes exist. The row ORDER here is
// the single source of truth for native_find's if-chain (1:1 by index).
fn init_natives() -> i64 {
    // Reuse g_natives across init_natives() calls (it is called from s_init,
    // which runs on every sema() entry). array_clear keeps the backing buffer
    // so the slot stops leaking; the first call (g_natives == 0) allocates.
    if (g_natives != 0) { array_clear(g_natives); } else { g_natives = array_new(8, 0); }
    // ---- ARRAY (extensions/array/ext_array.cpp) — all perm 0 ----
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_I64,  0);  // 0 array_new
    nat_add(1, TY_I64, -1, -1, -1, TY_I64,  0);      // 1 array_length
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_VOID, 0);  // 2 array_resize
    nat_add(3, TY_I64, TY_I64, TY_I64, -1, TY_VOID, 0); // 3 array_set_u8
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_U8,   0);  // 4 array_get_u8
    nat_add(3, TY_I64, TY_I64, TY_F32, -1, TY_VOID, 0); // 5 array_set_f32
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_F32,  0);  // 6 array_get_f32
    nat_add(3, TY_I64, TY_I64, TY_I64, -1, TY_VOID, 0); // 7 array_set_i64
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_I64,  0);  // 8 array_get_i64
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_VOID, 0);  // 9 array_push_u8
    nat_add(2, TY_I64, TY_F32, -1, -1, TY_VOID, 0);  // 10 array_push_f32
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_VOID, 0);  // 11 array_push_i64
    nat_add(1, TY_I64, -1, -1, -1, TY_U8,   0);      // 12 array_pop_u8
    nat_add(1, TY_I64, -1, -1, -1, TY_F32,  0);      // 13 array_pop_f32
    nat_add(1, TY_I64, -1, -1, -1, TY_I64,  0);      // 14 array_pop_i64
    nat_add(1, TY_I64, -1, -1, -1, TY_VOID, 0);      // 15 array_clear
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_VOID, 0);  // 16 array_remove
    // ---- MATH (extensions/math/ext_math.cpp) — all perm 0 ----
    nat_add(1, TY_F32, -1, -1, -1, TY_F32, 0);  // 17 sqrt
    nat_add(1, TY_F32, -1, -1, -1, TY_F32, 0);  // 18 sin
    nat_add(1, TY_F32, -1, -1, -1, TY_F32, 0);  // 19 cos
    nat_add(1, TY_F32, -1, -1, -1, TY_F32, 0);  // 20 tan
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 21 sqrt_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 22 sin_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 23 cos_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 24 tan_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 25 floor_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 26 ceil_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 27 abs_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 28 atan_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 29 exp_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 30 log_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 31 log2_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 32 log10_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 33 round_f64
    nat_add(1, TY_F64, -1, -1, -1, TY_F64, 0);  // 34 trunc_f64
    nat_add(2, TY_F64, TY_F64, -1, -1, TY_F64, 0);  // 35 pow_f64
    nat_add(2, TY_F64, TY_F64, -1, -1, TY_F64, 0);  // 36 atan2_f64
    nat_add(2, TY_F64, TY_F64, -1, -1, TY_F64, 0);  // 37 fmod_f64
    nat_add(2, TY_F64, TY_F64, -1, -1, TY_F64, 0);  // 38 min_f64
    nat_add(2, TY_F64, TY_F64, -1, -1, TY_F64, 0);  // 39 max_f64
    nat_add(3, TY_F64, TY_F64, TY_F64, -1, TY_F64, 0); // 40 clamp_f64
    nat_add(1, TY_I64, -1, -1, -1, TY_I64, 0);  // 41 abs_i64
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_I64, 0);  // 42 min_i64
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_I64, 0);  // 43 max_i64
    nat_add(3, TY_I64, TY_I64, TY_I64, -1, TY_I64, 0); // 44 clamp_i64
    nat_add(1, TY_F32, -1, -1, -1, TY_F32, 0);  // 45 atan
    nat_add(2, TY_F32, TY_F32, -1, -1, TY_F32, 0);  // 46 atan2
    nat_add(1, TY_F32, -1, -1, -1, TY_F32, 0);  // 47 exp
    nat_add(1, TY_F32, -1, -1, -1, TY_F32, 0);  // 48 log
    nat_add(1, TY_F32, -1, -1, -1, TY_F32, 0);  // 49 floor
    nat_add(1, TY_F32, -1, -1, -1, TY_F32, 0);  // 50 ceil
    nat_add(1, TY_F32, -1, -1, -1, TY_F32, 0);  // 51 abs
    nat_add(1, TY_F32, -1, -1, -1, TY_F32, 0);  // 52 round
    // ---- MAP (extensions/map/ext_map.cpp) — all perm 0 ----
    nat_add(0, -1, -1, -1, -1, TY_I64,  0);      // 53 map_new
    nat_add(3, TY_I64, TY_I64, TY_I64, -1, TY_VOID, 0); // 54 map_set
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_I64,  0);  // 55 map_get
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_I64,  0);  // 56 map_contains
    nat_add(1, TY_I64, -1, -1, -1, TY_I64,  0);      // 57 map_length
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_VOID, 0);  // 58 map_remove
    nat_add(1, TY_I64, -1, -1, -1, TY_VOID, 0);      // 59 map_clear
    // ---- STRING (extensions/string/ext_string.cpp) — all perm 0 ----
    // string_from_slice's real param is a u8 slice (code 5); recorded here as
    // TY_STRING so a literal arg type-checks (see the NOTE above + codegen).
    nat_add(0, -1, -1, -1, -1, TY_STRING, 0);      // 60 string_new
    nat_add(1, TY_STRING, -1, -1, -1, TY_STRING, 0); // 61 string_from_slice
    nat_add(1, TY_STRING, -1, -1, -1, TY_I64,    0); // 62 string_length
    nat_add(2, TY_STRING, TY_I64, -1, -1, TY_I64,  0); // 63 string_char_at
    nat_add(1, TY_I64, -1, -1, -1, TY_STRING, 0);   // 64 string_from_i64
    nat_add(1, TY_F32, -1, -1, -1, TY_STRING, 0);   // 65 string_from_f32
    nat_add(1, TY_F64, -1, -1, -1, TY_STRING, 0);   // 66 string_from_f64
    nat_add(1, TY_BOOL, -1, -1, -1, TY_STRING, 0);  // 67 string_from_bool
    nat_add(1, TY_STRING, -1, -1, -1, TY_STRING, 0); // 68 string_identity
    nat_add(2, TY_STRING, TY_STRING, -1, -1, TY_I64, 0); // 69 string_find
    nat_add(3, TY_STRING, TY_I64, TY_I64, -1, TY_STRING, 0); // 70 string_substr
    // ---- IO (extensions/io/ext_io.cpp) — all perm 1 (PERM_FFI) ----
    nat_add(1, TY_STRING, -1, -1, -1, TY_VOID, 1);  // 71 print
    nat_add(1, TY_STRING, -1, -1, -1, TY_VOID, 1);  // 72 println
    nat_add(1, TY_I64, -1, -1, -1, TY_VOID, 1);     // 73 print_i64
    nat_add(1, TY_F64, -1, -1, -1, TY_VOID, 1);     // 74 print_f64
    nat_add(0, -1, -1, -1, -1, TY_STRING, 1);       // 75 read_line
    nat_add(1, TY_STRING, -1, -1, -1, TY_I64,  1);  // 76 file_read_bytes
    nat_add(1, TY_STRING, -1, -1, -1, TY_STRING,1); // 77 file_read_text
    nat_add(2, TY_STRING, TY_I64, -1, -1, TY_I64, 1); // 78 file_write_bytes
    nat_add(1, TY_STRING, -1, -1, -1, TY_I64,  1);  // 79 file_exists
    // ---- CONTEXT OFFSETS (extensions/call_raw/ext_call_raw.cpp) — perm 0 ----
    nat_add(0, -1, -1, -1, -1, TY_I64, 0);  // 80 context_off_catch_depth
    nat_add(0, -1, -1, -1, -1, TY_I64, 0);  // 81 context_off_thrown_value
    nat_add(0, -1, -1, -1, -1, TY_I64, 0);  // 82 context_off_catch_bufs
    nat_add(0, -1, -1, -1, -1, TY_I64, 0);  // 83 context_off_catch_saved_depths
    nat_add(0, -1, -1, -1, -1, TY_I64, 0);  // 84 context_catch_buf_stride
    // ---- COROUTINE / DISPATCH / LAMBDA ENV ----
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_I64, 0);  // 85 coroutine_start
    nat_add(1, TY_I64, -1, -1, -1, TY_I64, 0);      // 86 coroutine_next
    nat_add(1, TY_I64, -1, -1, -1, TY_BOOL, 0);     // 87 coroutine_done
    nat_add(1, TY_I64, -1, -1, -1, TY_I64, 0);      // 88 __ember_coro_yield
    nat_add(1, TY_I64, -1, -1, -1, TY_I64, 0);      // 89 __ember_gc_alloc_env
    nat_add(1, TY_I64, -1, -1, -1, TY_I64, 1);      // 90 module_dispatch_base
    nat_add(1, TY_I64, -1, -1, -1, TY_I64, 1);      // 91 module_dispatch_count
    nat_add(2, TY_I64, TY_I64, -1, -1, TY_VOID, 1); // 92 set_coroutine_dispatch
    return 0;
}

// native_find(name) -> row index, or -1 for an unknown name. An if-chain
// comparing name as string==string (ember keeps `string` handles distinct
// from `i64`, so the names cannot live in the i64 signature array). The order
// matches init_natives 1:1 (the trailing comment in each nat_add row).
fn native_find(name: string) -> i64 {
    // ARRAY
    if (name == string_from_slice("array_new"))     { return 0; }
    if (name == string_from_slice("array_length"))  { return 1; }
    if (name == string_from_slice("array_resize"))  { return 2; }
    if (name == string_from_slice("array_set_u8"))  { return 3; }
    if (name == string_from_slice("array_get_u8"))  { return 4; }
    if (name == string_from_slice("array_set_f32")) { return 5; }
    if (name == string_from_slice("array_get_f32")) { return 6; }
    if (name == string_from_slice("array_set_i64")) { return 7; }
    if (name == string_from_slice("array_get_i64")) { return 8; }
    if (name == string_from_slice("array_push_u8")) { return 9; }
    if (name == string_from_slice("array_push_f32")){ return 10; }
    if (name == string_from_slice("array_push_i64")){ return 11; }
    if (name == string_from_slice("array_pop_u8"))  { return 12; }
    if (name == string_from_slice("array_pop_f32")) { return 13; }
    if (name == string_from_slice("array_pop_i64")) { return 14; }
    if (name == string_from_slice("array_clear"))   { return 15; }
    if (name == string_from_slice("array_remove"))  { return 16; }
    // MATH (f32)
    if (name == string_from_slice("sqrt"))    { return 17; }
    if (name == string_from_slice("sin"))     { return 18; }
    if (name == string_from_slice("cos"))     { return 19; }
    if (name == string_from_slice("tan"))     { return 20; }
    // MATH (f64)
    if (name == string_from_slice("sqrt_f64")) { return 21; }
    if (name == string_from_slice("sin_f64"))  { return 22; }
    if (name == string_from_slice("cos_f64"))  { return 23; }
    if (name == string_from_slice("tan_f64"))  { return 24; }
    if (name == string_from_slice("floor_f64")){ return 25; }
    if (name == string_from_slice("ceil_f64")) { return 26; }
    if (name == string_from_slice("abs_f64"))  { return 27; }
    if (name == string_from_slice("atan_f64")) { return 28; }
    if (name == string_from_slice("exp_f64"))  { return 29; }
    if (name == string_from_slice("log_f64"))  { return 30; }
    if (name == string_from_slice("log2_f64")) { return 31; }
    if (name == string_from_slice("log10_f64")){ return 32; }
    if (name == string_from_slice("round_f64")){ return 33; }
    if (name == string_from_slice("trunc_f64")){ return 34; }
    if (name == string_from_slice("pow_f64"))  { return 35; }
    if (name == string_from_slice("atan2_f64")){ return 36; }
    if (name == string_from_slice("fmod_f64")) { return 37; }
    if (name == string_from_slice("min_f64"))  { return 38; }
    if (name == string_from_slice("max_f64"))  { return 39; }
    if (name == string_from_slice("clamp_f64")){ return 40; }
    if (name == string_from_slice("abs_i64"))  { return 41; }
    if (name == string_from_slice("min_i64"))  { return 42; }
    if (name == string_from_slice("max_i64"))  { return 43; }
    if (name == string_from_slice("clamp_i64")){ return 44; }
    if (name == string_from_slice("atan"))     { return 45; }
    if (name == string_from_slice("atan2"))    { return 46; }
    if (name == string_from_slice("exp"))      { return 47; }
    if (name == string_from_slice("log"))      { return 48; }
    if (name == string_from_slice("floor"))    { return 49; }
    if (name == string_from_slice("ceil"))     { return 50; }
    if (name == string_from_slice("abs"))      { return 51; }
    if (name == string_from_slice("round"))    { return 52; }
    // MAP
    if (name == string_from_slice("map_new"))      { return 53; }
    if (name == string_from_slice("map_set"))      { return 54; }
    if (name == string_from_slice("map_get"))      { return 55; }
    if (name == string_from_slice("map_contains")) { return 56; }
    if (name == string_from_slice("map_length"))   { return 57; }
    if (name == string_from_slice("map_remove"))   { return 58; }
    if (name == string_from_slice("map_clear"))    { return 59; }
    // STRING
    if (name == string_from_slice("string_new"))       { return 60; }
    if (name == string_from_slice("string_from_slice")){ return 61; }
    if (name == string_from_slice("string_length"))    { return 62; }
    if (name == string_from_slice("string_char_at"))   { return 63; }
    if (name == string_from_slice("string_from_i64"))  { return 64; }
    if (name == string_from_slice("string_from_f32"))  { return 65; }
    if (name == string_from_slice("string_from_f64"))  { return 66; }
    if (name == string_from_slice("string_from_bool")) { return 67; }
    if (name == string_from_slice("string_identity"))  { return 68; }
    if (name == string_from_slice("string_find"))      { return 69; }
    if (name == string_from_slice("string_substr"))    { return 70; }
    // IO (perm 1)
    if (name == string_from_slice("print"))            { return 71; }
    if (name == string_from_slice("println"))          { return 72; }
    if (name == string_from_slice("print_i64"))        { return 73; }
    if (name == string_from_slice("print_f64"))        { return 74; }
    if (name == string_from_slice("read_line"))        { return 75; }
    if (name == string_from_slice("file_read_bytes"))  { return 76; }
    if (name == string_from_slice("file_read_text"))   { return 77; }
    if (name == string_from_slice("file_write_bytes")) { return 78; }
    if (name == string_from_slice("file_exists"))      { return 79; }
    // CONTEXT OFFSETS
    if (name == string_from_slice("context_off_catch_depth"))        { return 80; }
    if (name == string_from_slice("context_off_thrown_value"))       { return 81; }
    if (name == string_from_slice("context_off_catch_bufs"))         { return 82; }
    if (name == string_from_slice("context_off_catch_saved_depths")) { return 83; }
    if (name == string_from_slice("context_catch_buf_stride"))       { return 84; }
    if (name == string_from_slice("coroutine_start"))                 { return 85; }
    if (name == string_from_slice("coroutine_next"))                  { return 86; }
    if (name == string_from_slice("coroutine_done"))                  { return 87; }
    if (name == string_from_slice("__ember_coro_yield"))              { return 88; }
    if (name == string_from_slice("__ember_gc_alloc_env"))            { return 89; }
    if (name == string_from_slice("module_dispatch_base"))            { return 90; }
    if (name == string_from_slice("module_dispatch_count"))           { return 91; }
    if (name == string_from_slice("set_coroutine_dispatch"))          { return 92; }
    return -1;
}

// native_param_count(name) -> arity, or -1 for an unknown name (so
// check_callexpr falls through to the script-fn path).
fn native_param_count(name: string) -> i64 {
    let row: i64 = native_find(name);
    if (row < 0) { return -1; }
    return array_get_i64(g_natives, row * NAT_STRIDE + 0);
}

// the i-th param's type for a known native. Mirrors the host's registered
// NativeSig params: string args are the opaque handle (TY_STRING), integer
// args are i64 (TY_I64), floats are TY_F32/TY_F64, bool is TY_BOOL, u8 is
// TY_U8. Returns TY_VOID for an out-of-range index (defensive).
fn native_param_type(name: string, i: i64) -> i64 {
    let row: i64 = native_find(name);
    if (row < 0) { return TY_VOID; }
    if (i < 0 || i > 3) { return TY_VOID; }
    let pt: i64 = array_get_i64(g_natives, row * NAT_STRIDE + 1 + i);
    if (pt < 0) { return TY_VOID; }
    return pt;
}

// the return type for a known native.
fn native_ret_type(name: string) -> i64 {
    let row: i64 = native_find(name);
    if (row < 0) { return TY_VOID; }
    return array_get_i64(g_natives, row * NAT_STRIDE + 5);
}

// the permission bits for a known native (0=none, 1=PERM_FFI). The codegen
// bakes this into the ABS64_NATIVE fingerprint so the loader's perm check +
// fingerprint match pass (io natives are perm 1; all others perm 0).
fn native_perm(name: string) -> i64 {
    let row: i64 = native_find(name);
    if (row < 0) { return 0; }
    return array_get_i64(g_natives, row * NAT_STRIDE + 6);
}

// register a fn decl: resolve + record its signature. The body is checked
// separately in check_func_body (after ALL signatures are registered, so a
// forward call from fn A to fn B — A checked first — sees B's sig).
// register a fn decl: resolve + record its signature. The body is checked
// separately in check_func_body (after ALL signatures are registered, so a
// forward call from fn A to fn B — A checked first — sees B's sig). ns_tok is
// the namespace name token (-1 for a top-level fn); a namespaced fn is stored
// with its ns_tok so qualified Ns::fn resolution + intra-namespace bare-call
// resolution can find it (mirrors src/sema.cpp registering Ns::fn under the
// qualified name only).
fn register_fn(fd: i64, ns_tok: i64) -> i64 {
    let nm_tok: i64 = nk_tok(fd);
    let nm: string = tok_name(nm_tok);
    // dedup by qualified identity (same bare name + same namespace).
    let mut ns_name: string = string_from_slice("");
    if (ns_tok >= 0) { ns_name = tok_name(ns_tok); }
    if (find_fn_qualified(nm, ns_name) >= 0) {
        return serr(string_from_slice("duplicate function declaration '") + nm + string_from_slice("'"),
                    node_line(fd), node_col(fd));
    }
    // count params + resolve the return type
    let mut count: i64 = 0;
    let mut p: i64 = nk_a(fd);
    while (p >= 0) {
        count = count + 1;
        p = nk_next(p);
    }
    let rt: i64 = resolve_type(nk_b(fd));
    if (s_err != 0) { return TY_VOID; }
    // The self-hosted call ABI now supports struct by-value params + returns
    // (the hidden-pointer sret return + ceil(size/8)-word arg path, mirroring
    // the native codegen). Slice / fixed-array params + returns are still
    // out-of-subset (no slice/array by-value ABI), so reject those (-310) and
    // let structs through. A struct return type + struct param types are
    // type-checked downstream (check_return / check_callexpr).
    if (ty_is_slice_or_array(rt) == 1) {
        return unsupported(-310, string_from_slice("aggregate return type"), fd);
    }
    let mut pp: i64 = nk_a(fd);
    while (pp >= 0) {
        let pt: i64 = resolve_type(nk_a(pp));
        if (s_err != 0) { return TY_VOID; }
        if (ty_is_slice_or_array(pt) == 1) {
            return unsupported(-310, string_from_slice("aggregate parameter type"), pp);
        }
        pp = nk_next(pp);
    }
    array_push_i64(g_fns, nm_tok);
    array_push_i64(g_fns, nk_b(fd));     // raw ret type node (resolved on read)
    array_push_i64(g_fns, nk_a(fd));     // first param
    array_push_i64(g_fns, count);
    array_push_i64(g_fns, ns_tok);       // namespace name tok (-1 = top-level)
    array_push_i64(g_fns, nk_d(fd));     // FnDecl flags (FD_CEXPR bit etc.)
    return 0;
}

// -----------------------------------------------------------------------------
// global table. find_global(name) -> row, or -1.
//   row layout (GLOBAL_STRIDE = 3): [ name_tok, type, ns_tok ]
// Mirrors src/sema.cpp: a namespaced global is registered under BOTH its bare
// name and its qualified Ns::name, so find_global (bare) matches it AND
// find_global_qualified (Ns::name) matches it. ns_tok is -1 for a top-level
// global.
// -----------------------------------------------------------------------------
fn find_global(name: string) -> i64 {
    let n: i64 = array_length(g_globals) / GLOBAL_STRIDE;
    let mut i: i64 = 0;
    while (i < n) {
        let tok: i64 = array_get_i64(g_globals, i * GLOBAL_STRIDE + 0);
        if (tok_name(tok) == name) { return i; }
        i = i + 1;
    }
    return -1;
}

// find a global by qualified name (Ns::name). ns_name "" matches a top-level
// global; a nonempty ns_name matches a global whose ns_tok names ns_name.
fn find_global_qualified(name: string, ns_name: string) -> i64 {
    let n: i64 = array_length(g_globals) / GLOBAL_STRIDE;
    let mut i: i64 = 0;
    while (i < n) {
        let tok: i64 = array_get_i64(g_globals, i * GLOBAL_STRIDE + 0);
        if (tok_name(tok) == name) {
            let ns_tok: i64 = array_get_i64(g_globals, i * GLOBAL_STRIDE + 2);
            let mut ok: i64 = 0;
            if (ns_tok < 0) {
                if (string_length(ns_name) == 0) { ok = 1; }
            } else {
                if (tok_name(ns_tok) == ns_name) { ok = 1; }
            }
            if (ok == 1) { return i; }
        }
        i = i + 1;
    }
    return -1;
}

// the namespace name token of a global row (-1 for a top-level global).
fn global_ns_tok(row: i64) -> i64 {
    return array_get_i64(g_globals, row * GLOBAL_STRIDE + 2);
}

fn global_type(row: i64) -> i64 {
    return resolve_type(array_get_i64(g_globals, row * GLOBAL_STRIDE + 1));
}

fn register_global(gd: i64, ns_tok: i64) -> i64 {
    let nm_tok: i64 = nk_tok(gd);
    let nm: string = tok_name(nm_tok);
    // dedup by qualified identity (same bare name + same namespace).
    let mut ns_name: string = string_from_slice("");
    if (ns_tok >= 0) { ns_name = tok_name(ns_tok); }
    if (find_global_qualified(nm, ns_name) >= 0) {
        return serr(string_from_slice("duplicate global declaration '") + nm + string_from_slice("'"),
                    node_line(gd), node_col(gd));
    }
    array_push_i64(g_globals, nm_tok);
    array_push_i64(g_globals, nk_a(gd));   // type node (resolved on read)
    array_push_i64(g_globals, ns_tok);     // namespace name tok (-1 = top-level)
    return 0;
}

// is a GlobalDecl a Phase-1-supported constant-initialized i64 global? It must
// have a declared i64 type + a compile-time constant initializer (an IntLit,
// or a unary negation of an IntLit). The codegen evaluates this constant at
// emit time to write the data section's initial bytes (§5). Non-constant /
// non-i64 globals stay out-of-subset (-317) until runtime init is added (§11).
fn global_is_const_i64(gd: i64) -> i64 {
    let gty: i64 = resolve_type(nk_a(gd));
    if (s_err != 0) { return 0; }
    if (ty_is_i64(gty) == 0) { return 0; }   // only i64 globals in Phase 1
    let init: i64 = nk_b(gd);
    if (init < 0) { return 0; }              // must have an initializer
    return expr_is_const_i64(init);
}

// is a GlobalDecl a Phase-1-supported string global? It must have a declared
// `string` type + a constant StringLit initializer (a plain "..." literal,
// not an f-string). The initializer is NOT a compile-time value — it is a
// string literal the codegen materializes at runtime (decode bytes to rodata
// + build a u8 slice + call string_from_slice -> handle) and stores into the
// global's data slot in a module-init function that runs before main (§11).
// check_global_init still type-checks the initializer (StringLit -> TY_STRING)
// against the declared type, so the gate only decides registration.
fn global_is_const_string(gd: i64) -> i64 {
    let gty: i64 = resolve_type(nk_a(gd));
    if (s_err != 0) { return 0; }
    if (ty_is_string(gty) == 0) { return 0; }   // only string globals here
    let init: i64 = nk_b(gd);
    if (init < 0) { return 0; }                  // must have an initializer
    if (nk_kind(init) != (NK::StringLit as i64)) { return 0; }
    if (nk_d(init) != 0) { return 0; }           // plain string, not an f-string
    return 1;
}

// is a GlobalDecl supported by the Phase-1 subset? A constant-initialized i64
// global (compile-time constant, written to the data section at emit time) OR
// a string global with a StringLit initializer (materialized at runtime by the
// module-init function). Non-constant / non-i64 / non-string globals stay
// out-of-subset (-317).
fn global_is_supported(gd: i64) -> i64 {
    if (global_is_const_i64(gd) == 1) { return 1; }
    if (global_is_const_string(gd) == 1) { return 1; }
    return 0;
}

// Is an expression a compile-time i64? Use the bounded constexpr evaluator,
// not just the old literal/-literal gate. This admits constexpr calls nested
// in arithmetic global initializers while retaining the interpreter's limits.
fn expr_is_const_i64(e: i64) -> i64 {
    return try_eval_const_i64(e);
}

// -----------------------------------------------------------------------------
// scope management (local variables). The scope is a flat array of
// (name_tok, type) pairs; g_marks records the logical symbol length at each
// push. Neither backing array can shrink, so s_mark_len and s_scope_len are
// the authoritative live lengths. declare() adds to the current (top) scope;
// lookup_local() scans the whole live stack from innermost to outermost.
// -----------------------------------------------------------------------------
fn push_scope() -> i64 {
    if (array_length(g_marks) < s_mark_len + 1) {
        array_resize(g_marks, s_mark_len + 1);
    }
    array_set_i64(g_marks, s_mark_len, s_scope_len / SCOPE_STRIDE);
    s_mark_len = s_mark_len + 1;
    return 0;
}

fn pop_scope() -> i64 {
    if (s_mark_len == 0) { return 0; }
    s_mark_len = s_mark_len - 1;
    let mark: i64 = array_get_i64(g_marks, s_mark_len);
    s_scope_len = mark * SCOPE_STRIDE;
    return 0;
}

// declare a local in the current (top) scope. Reports a redeclaration error if
// the same name is already in the TOP scope (shadowing an enclosing scope is
// allowed, matching the C++ sema's per-scope dedup).
// declare a local in the current (top) scope. Reports a redeclaration error if
// the same name is already in the TOP scope (shadowing an enclosing scope is
// allowed, matching the C++ sema's per-scope dedup). array_elem_ty is -1 for a
// normal local, or the inferred element Type node for a local minted from
// array_new(esz,n) (the iterable() hook reads it via lookup_local_array_elem_ty).
fn declare_with_elem(name_tok: i64, t: i64, arr_elem_ty: i64) -> i64 {
    let nm: string = tok_name(name_tok);
    // dedup against the current top scope: scan from the last mark to the end.
    let mut top_mark: i64 = 0;
    if (s_mark_len > 0) {
        top_mark = array_get_i64(g_marks, s_mark_len - 1) * SCOPE_STRIDE;
    }
    let mut i: i64 = top_mark;
    while (i < s_scope_len) {
        if (tok_name(array_get_i64(g_scope, i)) == nm) {
            return serr(string_from_slice("redeclaration of '") + nm + string_from_slice("' in the same scope"),
                        node_line_tok(name_tok), node_col_tok(name_tok));
        }
        i = i + SCOPE_STRIDE;
    }
    // append (name_tok, type, array_elem_ty) at s_scope_len. array_set_i64 does
    // NOT grow the array (it silently drops writes past the end), so grow
    // g_scope first when the logical length has reached the physical length.
    // After a pop_scope the physical array is still big enough (we only lower
    // s_scope_len, never shrink), so this resize only fires on the first
    // declare past the high-water mark — and it overwrites any stale slot, so
    // re-pushed scopes see fresh data (not leftover entries from a popped
    // scope).
    if (array_length(g_scope) < s_scope_len + SCOPE_STRIDE) {
        array_resize(g_scope, s_scope_len + SCOPE_STRIDE);
    }
    array_set_i64(g_scope, s_scope_len, name_tok);
    array_set_i64(g_scope, s_scope_len + 1, t);
    array_set_i64(g_scope, s_scope_len + 2, arr_elem_ty);
    s_scope_len = s_scope_len + SCOPE_STRIDE;
    return 0;
}

// convenience: declare a normal local (no array element type tag).
fn declare(name_tok: i64, t: i64) -> i64 {
    return declare_with_elem(name_tok, t, -1);
}

// position helpers that take a raw token index (for declare's error).
fn node_line_tok(t: i64) -> i64 {
    if (t < 0) { return 0; }
    return tok_line(s_toks, t);
}
fn node_col_tok(t: i64) -> i64 {
    if (t < 0) { return 0; }
    return tok_col(s_toks, t);
}

// lookup a local by name. Returns its type, or -1 if not found. Scans from the
// END of the scope stack so the innermost binding wins.
fn lookup_local(name: string) -> i64 {
    let mut i: i64 = s_scope_len - SCOPE_STRIDE;
    while (i >= 0) {
        if (tok_name(array_get_i64(g_scope, i)) == name) {
            return array_get_i64(g_scope, i + 1);
        }
        i = i - SCOPE_STRIDE;
    }
    return -1;
}

// lookup a local's array element-type tag (the iterable() hook). Returns the
// inferred element Type node for a local minted from array_new(esz,n), or -1
// if the local is not an array handle / not found. Mirrors the native
// Var::array_elem_ty read in infer_iterable_array_elem_ty's Ident case.
fn lookup_local_array_elem_ty(name: string) -> i64 {
    let mut i: i64 = s_scope_len - SCOPE_STRIDE;
    while (i >= 0) {
        if (tok_name(array_get_i64(g_scope, i)) == name) {
            return array_get_i64(g_scope, i + 2);
        }
        i = i - SCOPE_STRIDE;
    }
    return -1;
}

// lookup a variable: locals first, then globals. Returns its type or -1.
fn lookup_var(name: string) -> i64 {
    let lt: i64 = lookup_local(name);
    if (lt >= 0) { return lt; }
    let g: i64 = find_global(name);
    if (g >= 0) { return global_type(g); }
    return -1;
}

// -----------------------------------------------------------------------------
// Lambda capture discovery + checking. Captures are scalar locals from the
// enclosing live scope; globals/functions are not captured. Metadata remains
// in flat side tables so the parser's stride-9 AST layout stays unchanged.
// -----------------------------------------------------------------------------
fn lambda_has_capture(le: i64, name: string) -> i64 {
    let n: i64 = array_length(g_lambda_caps) / LAMBDA_CAP_STRIDE;
    let mut i: i64 = 0;
    while (i < n) {
        if (array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE) == le &&
            tok_name(array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 1)) == name) { return 1; }
        i = i + 1;
    }
    return 0;
}
fn lambda_is_ref_capture(le: i64, name: string) -> i64 {
    let mut c: i64 = nk_e(le);
    while (c >= 0) { if (nk_name(c) == name) { return 1; } c = nk_next(c); }
    return 0;
}
fn lambda_add_capture(le: i64, id: i64) -> i64 {
    let name: string = nk_name(id);
    if (lambda_has_capture(le, name) == 1) { return 0; }
    let t: i64 = lookup_local(name);
    if (t < 0) { return 0; }
    if (ty_is_aggregate(t) == 1 || ty_is_fn(t) == 1) {
        serr(string_from_slice("lambda capture '") + name + string_from_slice("' must be scalar"), node_line(id), node_col(id));
        return 0;
    }
    let off: i64 = lambda_capture_count(le) * 8;
    array_push_i64(g_lambda_caps, le); array_push_i64(g_lambda_caps, nk_tok(id));
    array_push_i64(g_lambda_caps, t); array_push_i64(g_lambda_caps, off);
    array_push_i64(g_lambda_caps, lambda_is_ref_capture(le, name));
    return 0;
}
fn lambda_capture_count(le: i64) -> i64 {
    let n: i64 = array_length(g_lambda_caps) / LAMBDA_CAP_STRIDE;
    let mut i: i64 = 0; let mut count: i64 = 0;
    while (i < n) { if (array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE) == le) { count = count + 1; } i = i + 1; }
    return count;
}
fn lambda_collect_expr(le: i64, e: i64) -> i64 {
    if (e < 0) { return 0; }
    let k: i64 = nk_kind(e);
    if (k == (NK::Ident as i64)) { return lambda_add_capture(le, e); }
    if (k == (NK::BinExpr as i64) || k == (NK::AssignExpr as i64) || k == (NK::IndexExpr as i64)) {
        lambda_collect_expr(le, nk_a(e)); lambda_collect_expr(le, nk_b(e)); return 0;
    }
    if (k == (NK::UnaryExpr as i64) || k == (NK::CastExpr as i64) || k == (NK::FieldExpr as i64) || k == (NK::ViewExpr as i64)) {
        return lambda_collect_expr(le, nk_a(e));
    }
    if (k == (NK::TernaryExpr as i64)) {
        lambda_collect_expr(le, nk_a(e)); lambda_collect_expr(le, nk_b(e)); lambda_collect_expr(le, nk_c(e)); return 0;
    }
    if (k == (NK::CallExpr as i64)) {
        if (nk_e(e) >= 0 && string_length(nk_name(e)) == 0) { lambda_collect_expr(le, nk_e(e)); }
        let mut a: i64 = nk_a(e); while (a >= 0) { lambda_collect_expr(le, a); a = nk_next(a); } return 0;
    }
    if (k == (NK::LambdaExpr as i64)) { return lambda_collect_block(le, nk_c(e)); }
    return 0;
}
fn lambda_collect_stmt(le: i64, s: i64) -> i64 {
    let k: i64 = nk_kind(s);
    if (k == (NK::LetStmt as i64)) { lambda_collect_expr(le, nk_b(s)); return 0; }
    if (k == (NK::ExprStmt as i64) || k == (NK::ReturnStmt as i64) || k == (NK::YieldStmt as i64) || k == (NK::ThrowStmt as i64) || k == (NK::DeferStmt as i64)) { return lambda_collect_expr(le, nk_a(s)); }
    if (k == (NK::IfStmt as i64)) { lambda_collect_expr(le, nk_a(s)); lambda_collect_block(le, nk_b(s)); lambda_collect_block(le, nk_c(s)); return 0; }
    if (k == (NK::WhileStmt as i64)) { lambda_collect_expr(le, nk_a(s)); lambda_collect_block(le, nk_b(s)); return 0; }
    if (k == (NK::BlockStmt as i64)) { return lambda_collect_block(le, s); }
    return 0;
}
fn lambda_collect_block(le: i64, b: i64) -> i64 {
    if (b < 0) { return 0; }
    let mut s: i64 = nk_a(b); while (s >= 0) { lambda_collect_stmt(le, s); s = nk_next(s); }
    return 0;
}
fn check_lambda_expr(le: i64) -> i64 {
    let idx: i64 = array_length(g_lambdas);
    array_push_i64(g_lambdas, le);
    lambda_collect_block(le, nk_c(le));
    if (s_err != 0) { return TY_VOID; }
    let slot: i64 = array_length(g_fns) / FN_STRIDE + idx;
    set_d(le, slot);
    let ft: i64 = alloc_node(NK::Type as i64); set_d(ft, Prim::I64 as i64); set_f(ft, 2);
    if (nk_a(le) >= 0) { set_a(ft, nk_a(le)); } set_b(ft, resolve_type(nk_b(le))); set_f(le, ft);
    push_scope();
    let n: i64 = array_length(g_lambda_caps) / LAMBDA_CAP_STRIDE; let mut i: i64 = 0;
    while (i < n) {
        if (array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE) == le) {
            declare(array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 1), array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 2));
        }
        i = i + 1;
    }
    let mut p: i64 = nk_a(le); while (p >= 0) { let pt: i64 = resolve_type(nk_a(p)); declare(nk_tok(p), pt); p = nk_next(p); }
    let saved_ret: i64 = s_cur_ret; s_cur_ret = resolve_type(nk_b(le)); check_block(nk_c(le)); s_cur_ret = saved_ret;
    pop_scope();
    return ft;
}

// -----------------------------------------------------------------------------
// expression type-check. check_expr(e) -> the expression's resolved type (a
// Type node index), or TY_VOID on error (with s_err set). Mirrors the C++
// Checker::check_expr's dispatch on node kind.
//
// v1 subset handles: IntLit, BoolLit, Ident, BinExpr, UnaryExpr, CallExpr.
// Other expression kinds report an "unsupported in v1 sema" error so the test
// sees a clean message if it exercises one.
// -----------------------------------------------------------------------------
fn check_expr(e: i64) -> i64 {
    if (e < 0) { return serr(string_from_slice("missing expression"), 0, 0); }
    let k: i64 = nk_kind(e);

    if (k == (NK::IntLit as i64)) {
        // an integer literal is i64 in the v1 subset (the C++ sema adapts it
        // to a surrounding expected type; v1 keeps literals i64 and checks
        // compatibility at the let/init site, where i64 == i64 trivially).
        return TY_I64;
    }
    if (k == (NK::BoolLit as i64)) {
        return TY_BOOL;
    }
    if (k == (NK::Ident as i64)) {
        let nm: string = nk_name(e);
        let t: i64 = lookup_var(nm);
        if (t < 0) {
            return serr(string_from_slice("undefined name '") + nm + string_from_slice("'"),
                        node_line(e), node_col(e));
        }
        return t;
    }
    if (k == (NK::BinExpr as i64)) {
        return check_binexpr(e);
    }
    if (k == (NK::UnaryExpr as i64)) {
        return check_unaryexpr(e);
    }
    if (k == (NK::CallExpr as i64)) {
        return check_callexpr(e);
    }
    if (k == (NK::AssignExpr as i64)) {
        return check_assignexpr(e);
    }

    if (k == (NK::FloatLit as i64)) {
        // an adapted f32 literal (try_adapt_float_lit annotated slot c) -> f32
        let ann: i64 = nk_c(e);
        if (ann == TY_F32) { return TY_F32; }
        let raw: string = nk_name(e);
        let n: i64 = string_length(raw);
        if (n > 0) {
            let last: i64 = string_char_at(raw, n - 1);
            if (last == 102 || last == 70) { return TY_F32; }
        }
        return TY_F64;
    }
    if (k == (NK::StringLit as i64)) { return TY_STRING; }
    if (k == (NK::ArrayLit as i64)) { return unsupported(-310, string_from_slice("array literal"), e); }
    if (k == (NK::LambdaExpr as i64)) { return check_lambda_expr(e); }
    if (k == (NK::FnHandleExpr as i64)) {
        let row: i64 = find_fn(nk_name(e));
        if (row < 0) { return serr(string_from_slice("unknown function '") + nk_name(e) + string_from_slice("'"), node_line(e), node_col(e)); }
        set_d(e, row);  // top-level function registration order is dispatch-slot order
        return TY_I64;
    }
    if (k == (NK::StructLit as i64)) { return check_structlit(e); }
    if (k == (NK::FieldExpr as i64)) { return check_fieldexpr(e); }
    if (k == (NK::IndexExpr as i64)) { return check_indexexpr(e); }
    if (k == (NK::ViewExpr as i64)) { return check_viewexpr(e); }
    if (k == (NK::EnumAccess as i64)) {
        let ename: string = tok_name(nk_a(e));
        // Tier 1 namespaces: Foo::val where Foo is a namespace (not an enum) is a
        // namespace-global access. Resolve the qualified Ns::global and return
        // its type (mirrors src/sema.cpp's lower_enum_access_expr namespace
        // rewrite to an Ident with the qualified name).
        if (is_namespace_name(ename) == 1) {
            let g: i64 = find_global_qualified(nk_name(e), ename);
            if (g >= 0) { return global_type(g); }
            return serr(string_from_slice("namespace '") + ename + string_from_slice("' has no global '") + nk_name(e) + string_from_slice("'"),
                        node_line(e), node_col(e));
        }
        let row: i64 = find_enum(ename);
        if (row < 0) { return serr(string_from_slice("unknown enum '") + ename + string_from_slice("'"), node_line(e), node_col(e)); }
        if (enum_variant_exists(row, nk_name(e)) == 0) {
            return serr(string_from_slice("unknown enum variant '") + nk_name(e) + string_from_slice("'"), node_line(e), node_col(e));
        }
        // Phase 3b: a typed enum's variant carries the typed-enum type
        // (prim=backing, enum_name set) so `let e: E = E::B` type-checks and
        // `e == E::B` compares two E values. An untyped enum's variant is a
        // plain i64 constant (mirror src/sema.cpp's lower_enum_access_expr:
        // typed -> IntLit with the typed-enum type; untyped -> plain i32/i64).
        if (is_typed_enum_name(ename) == 1) { return typed_enum_type(ename); }
        return TY_I64;
    }
    // Phase 2 Step 2: CastExpr (expr as Type). Mirrors src/sema.cpp's cast matrix:
    //   - same-type: no-op
    //   - int->int (any width/signedness): allowed
    //   - float->float (f32<->f64): allowed
    //   - signed int <-> float: allowed
    //   - unsigned int <-> float: NOT in the v1 matrix (deliberate)
    //   - slice/aggregate/bool/fn-handle: same-type only
    // The result type is the cast's target type.
    if (k == (NK::CastExpr as i64)) {
        let from: i64 = check_expr(nk_a(e));
        if (s_err != 0) { return TY_VOID; }
        let to: i64 = resolve_type(nk_b(e));
        if (s_err != 0) { return TY_VOID; }
        let same: i64 = type_eq(from, to);
        let mut int_to_int: i64 = 0;
        if (ty_is_int(from) == 1 && ty_is_int(to) == 1) { int_to_int = 1; }
        // Phase 3b: explicit typed-enum -> int cast (the explicit spelling of
        // the implicit enum->backing-int widening). int->enum is NOT allowed
        // (mirror src/sema.cpp's enum_to_int guard).
        let mut enum_to_int: i64 = 0;
        if (is_typed_enum_type(from) == 1 && ty_is_int(to) == 1) { enum_to_int = 1; }
        let mut float_to_float: i64 = 0;
        if (ty_is_float(from) == 1 && ty_is_float(to) == 1) { float_to_float = 1; }
        // signed int <-> float (unsigned is deliberately excluded, matching the C++ matrix)
        let mut int_float: i64 = 0;
        if (ty_is_int(from) == 1 && ty_is_uint(from) == 0 && ty_is_float(to) == 1) { int_float = 1; }
        if (ty_is_float(from) == 1 && ty_is_int(to) == 1 && ty_is_uint(to) == 0) { int_float = 1; }
        if (same == 0 && int_to_int == 0 && enum_to_int == 0 && float_to_float == 0 && int_float == 0) {
            return serr(string_from_slice("invalid cast from '") + ty_name(from) + string_from_slice("' to '") + ty_name(to) + string_from_slice("'"),
                        node_line(e), node_col(e));
        }
        return to;
    }
    // Phase 2 Step 4: TernaryExpr (cond ? then : else). Cond must be bool;
    // then/else must have the same type; result = that type. Mirrors
    // src/sema.cpp's TernaryExpr check.
    if (k == (NK::TernaryExpr as i64)) {
        let ct: i64 = check_expr(nk_a(e));
        if (s_err != 0) { return TY_VOID; }
        if (ty_is_bool(ct) == 0) {
            return serr(string_from_slice("ternary condition must be bool"), node_line(e), node_col(e));
        }
        let tt: i64 = check_expr(nk_b(e));
        if (s_err != 0) { return TY_VOID; }
        let et: i64 = check_expr(nk_c(e));
        if (s_err != 0) { return TY_VOID; }
        if (type_eq(tt, et) == 0) {
            return serr(string_from_slice("ternary branches must have same type (got ") + ty_name(tt) + string_from_slice(" and ") + ty_name(et) + string_from_slice(")"),
                        node_line(e), node_col(e));
        }
        return tt;
    }
    // Phase 2 Step 5: SizeofExpr. Result is a compile-time constant of type
    // u64. For primitives, the size is cg_type_size-compatible; for structs/
    // arrays (Phase 3), reject for now. Mirrors src/sema.cpp's SizeofExpr check
    // (which sets resolved = frame_byte_width(...)).
    if (k == (NK::SizeofExpr as i64)) {
        let t: i64 = resolve_type(nk_a(e));
        if (s_err != 0) { return TY_VOID; }
        // Phase 3: any resolved type is sized via the packed memory model
        // (primitives, structs, fixed arrays, slices all have a value_bytes).
        return TY_U64;
    }
    // Phase 3: OffsetofExpr. Result is a compile-time constant of type u64.
    // The type must be a struct (declared) and the field must exist; the
    // offset is the field's packed offset (computed by codegen). For
    // primitives there are no fields (reject). Mirrors src/sema.cpp.
    if (k == (NK::OffsetofExpr as i64)) {
        let t: i64 = resolve_type(nk_a(e));
        if (s_err != 0) { return TY_VOID; }
        if (nk_tok(t) < 0) {
            return serr(string_from_slice("offsetof requires a struct type"), node_line(e), node_col(e));
        }
        let nm: string = tok_name(nk_tok(t));
        if (nm == string_from_slice("string")) {
            return serr(string_from_slice("offsetof requires a struct type"), node_line(e), node_col(e));
        }
        let row: i64 = find_struct(nm);
        if (row < 0) {
            return serr(string_from_slice("offsetof requires a struct type"), node_line(e), node_col(e));
        }
        let fname: string = tok_name(nk_tok(e));
        if (struct_field_type(row, fname) < 0) {
            return serr(string_from_slice("struct '") + nm + string_from_slice("' has no field '") + fname + string_from_slice("'"),
                        node_line(e), node_col(e));
        }
        return TY_U64;
    }
    return unsupported(-313, string_from_slice("expression kind"), e);
}

// check a binary expression. Arithmetic/bitwise require integer operands and
// yield the operand type (i64 in the subset); comparison requires same-type
// operands and yields bool; logical requires bool operands and yields bool.
fn check_binexpr(e: i64) -> i64 {
    let op: i64 = nk_d(e);
    let lhs: i64 = nk_a(e);
    let rhs: i64 = nk_b(e);
    // Float literal adaptation (mirrors src/sema.cpp's FloatLit expected-f32
    // branch + check_binexpr's literal adoption): if one operand is an
    // unsuffixed FloatLit and the other operand is f32, adapt the literal to
    // f32 BEFORE typing so the same-type arithmetic/comparison rule holds
    // (e.g. `f32_var == 60.0` or `f32_var + 1.0`). Check the non-literal side
    // first to learn the target type.
    let mut lhs_is_fl: i64 = 0;
    if (nk_kind(lhs) == (NK::FloatLit as i64)) { lhs_is_fl = 1; }
    let mut rhs_is_fl: i64 = 0;
    if (nk_kind(rhs) == (NK::FloatLit as i64)) { rhs_is_fl = 1; }
    let mut lt: i64 = 0;
    let mut rt: i64 = 0;
    if (lhs_is_fl == 1 && rhs_is_fl == 0) {
        rt = check_expr(rhs); if (s_err != 0) { return TY_VOID; }
        try_adapt_float_lit(lhs, rt);
        lt = check_expr(lhs); if (s_err != 0) { return TY_VOID; }
    } else if (rhs_is_fl == 1 && lhs_is_fl == 0) {
        lt = check_expr(lhs); if (s_err != 0) { return TY_VOID; }
        try_adapt_float_lit(rhs, lt);
        rt = check_expr(rhs); if (s_err != 0) { return TY_VOID; }
    } else {
        lt = check_expr(lhs); if (s_err != 0) { return TY_VOID; }
        rt = check_expr(rhs); if (s_err != 0) { return TY_VOID; }
    }
    // literal adaptation (mirrors src/sema.cpp's check_binexpr): if one operand
    // is an IntLit (always TY_I64 from check_expr), adopt the other operand's
    // integer type so `i32_var + 5` type-checks as i32 + i32 -> i32. The value
    // still fits (sema would error on overflow at the let site); here we only
    // need the TYPE to match for the same-type arithmetic rule.
    let mut elt: i64 = lt;
    let mut ert: i64 = rt;
    if (nk_kind(lhs) == (NK::IntLit as i64) && ty_is_int(rt) == 1) { elt = rt; }
    if (nk_kind(rhs) == (NK::IntLit as i64) && ty_is_int(lt) == 1) { ert = lt; }
    return check_binop_result(op, elt, ert, e);
}

// Validate a binary op's operand types and return its result type (or TY_VOID
// + s_err on a type error). Shared by check_binexpr (a BinExpr) and the
// compound-assign path of check_assignexpr (which only needs the validity
// check; the stored type is the target's). `e` is the originating node for
// error positions (the BinExpr or AssignExpr).
fn check_binop_result(op: i64, lt: i64, rt: i64, e: i64) -> i64 {

    // logical && || : bool operands -> bool
    if (op == (BinOp::LAnd as i64) || op == (BinOp::LOr as i64)) {
        if (ty_is_bool(lt) == 0 || ty_is_bool(rt) == 0) {
            return serr(string_from_slice("logical operator requires bool operands"),
                        node_line(e), node_col(e));
        }
        return TY_BOOL;
    }

    // String concatenation is the string overload of '+'.
    if (op == (BinOp::Add as i64) && ty_is_string(lt) == 1 && ty_is_string(rt) == 1) {
        return TY_STRING;
    }

    // comparison == != < <= > >= : same-type operands -> bool
    let mut is_cmp: i64 = 0;
    if (op == (BinOp::Eq as i64)) { is_cmp = 1; }
    if (op == (BinOp::Neq as i64)) { is_cmp = 1; }
    if (op == (BinOp::Lt as i64)) { is_cmp = 1; }
    if (op == (BinOp::Le as i64)) { is_cmp = 1; }
    if (op == (BinOp::Gt as i64)) { is_cmp = 1; }
    if (op == (BinOp::Ge as i64)) { is_cmp = 1; }
    if (is_cmp == 1) {
        // same-type OR both integer (a typed enum IS an integer, mirroring the
        // native Type::is_int() returning true for a typed enum, so
        // `Color::Red == 0` is accepted as both-integer).
        if (type_eq(lt, rt) == 0) {
            if (ty_is_int_or_typed_enum(lt) == 0 || ty_is_int_or_typed_enum(rt) == 0) {
                return serr(string_from_slice("comparison requires same-type operands (got ")
                            + ty_name(lt) + string_from_slice(" and ") + ty_name(rt) + string_from_slice(")"),
                            node_line(e), node_col(e));
            }
        }
        return TY_BOOL;
    }

    // shift << >> : integer operands -> lhs type
    if (op == (BinOp::Shl as i64) || op == (BinOp::Shr as i64)) {
        if (ty_is_int(lt) == 0 || ty_is_int(rt) == 0) {
            return serr(string_from_slice("shift requires integer operands"),
                        node_line(e), node_col(e));
        }
        return lt;
    }

    // bitwise & | ^ : integer operands -> operand type
    let mut is_bitwise: i64 = 0;
    if (op == (BinOp::And as i64)) { is_bitwise = 1; }
    if (op == (BinOp::Or as i64)) { is_bitwise = 1; }
    if (op == (BinOp::Xor as i64)) { is_bitwise = 1; }
    if (is_bitwise == 1) {
        if (ty_is_int_or_typed_enum(lt) == 0 || ty_is_int_or_typed_enum(rt) == 0) {
            return serr(string_from_slice("bitwise operator requires integer operands"),
                        node_line(e), node_col(e));
        }
        if (type_eq(lt, rt) == 0) {
            return serr(string_from_slice("operator requires same-type operands"),
                        node_line(e), node_col(e));
        }
        return lt;
    }

    // arithmetic + - * / % : numeric operands -> operand type
    if (ty_is_int_or_typed_enum(lt) == 0 && ty_is_float(lt) == 0) {
        return serr(string_from_slice("operator requires numeric operands (got ") + ty_name(lt) + string_from_slice(")"),
                    node_line(e), node_col(e));
    }
    if (ty_is_int_or_typed_enum(rt) == 0 && ty_is_float(rt) == 0) {
        return serr(string_from_slice("operator requires numeric operands (got ") + ty_name(rt) + string_from_slice(")"),
                    node_line(e), node_col(e));
    }
    if (type_eq(lt, rt) == 0) {
        return serr(string_from_slice("operator requires same-type operands (got ")
                    + ty_name(lt) + string_from_slice(" and ") + ty_name(rt) + string_from_slice(")"),
                    node_line(e), node_col(e));
    }
    return lt;
}

// check a unary expression. - and ~ require an integer -> operand type;
// ! requires bool -> bool.
fn check_unaryexpr(e: i64) -> i64 {
    let op: i64 = nk_d(e);
    let ot: i64 = check_expr(nk_a(e));
    if (op == (UnOp::Not as i64)) {
        if (ty_is_bool(ot) == 0) {
            return serr(string_from_slice("'!' requires bool"),
                        node_line(e), node_col(e));
        }
        return TY_BOOL;
    }
    if (op == (UnOp::Neg as i64)) {
        if (ty_is_int(ot) == 0 && ty_is_float(ot) == 0) {
            return serr(string_from_slice("unary '-' requires numeric"),
                        node_line(e), node_col(e));
        }
        return ot;
    }
    // BitNot
    if (ty_is_int(ot) == 0) {
        return serr(string_from_slice("'~' requires integer"),
                    node_line(e), node_col(e));
    }
    return ot;
}

// check a call expression. Look up the fn, check the arg count + each arg's
// type against the fn's param types, and return the fn's return type. v1
// handles direct named calls only (no fn-handle / indirect / cross-module).
fn check_callexpr(e: i64) -> i64 {
    let nm: string = nk_name(e);

    // Indirect closure call. `f(args)` initially looks like a named call; if
    // `f` is a closure local, synthesize its Ident target into slot e.
    let mut indirect: i64 = nk_e(e);
    if (indirect < 0) {
        let local_ft: i64 = lookup_local(nm);
        if (local_ft >= 0 && ty_is_fn(local_ft) == 1) {
            indirect = alloc_node(NK::Ident as i64); set_tok(indirect, nk_tok(e)); set_e(e, indirect);
        }
    }
    if (indirect >= 0 && (string_length(nm) == 0 || ty_is_fn(lookup_local(nm)) == 1)) {
        let ft: i64 = check_expr(indirect);
        if (s_err != 0) { return TY_VOID; }
        if (ty_is_fn(ft) == 0) { return serr(string_from_slice("indirect call target is not callable"), node_line(e), node_col(e)); }
        let mut a: i64 = nk_a(e); let mut p: i64 = nk_a(ft); let mut i: i64 = 0;
        while (a >= 0 && p >= 0) {
            let mut want_node: i64 = p; if (nk_kind(p) == (NK::Param as i64)) { want_node = nk_a(p); }
            let want: i64 = resolve_type(want_node); let got: i64 = check_expr(a);
            if (s_err != 0) { return TY_VOID; }
            if (lit_fits_int_type(a, want) == 0 && types_compatible(want, got) == 0) {
                return serr(string_from_slice("indirect-call argument type mismatch"), node_line(a), node_col(a));
            }
            a = nk_next(a); p = nk_next(p); i = i + 1;
        }
        if (a >= 0 || p >= 0) { return serr(string_from_slice("indirect-call argument count mismatch"), node_line(e), node_col(e)); }
        let rt: i64 = resolve_type(nk_b(ft)); set_c(e, rt); set_d(e, 2); return rt;
    }

    // ---- NATIVE calls (host extensions) ----
    // The self-hosted codegen emits these as ABS64_NATIVE relocations resolved
    // by the EMBM v1 loader against the host's registered NativeSig table. The
    // signatures here mirror the host's registered natives
    // (extensions/string/ext_string.cpp) so sema type-checks the call site the
    // same way the host validates the relocation's ABI fingerprint. A string is
    // an opaque i64 handle (host owns a mutable std::string); string_length /
    // string_char_at / string_substr take a handle + integer(s) and return an
    // integer or a new handle. The call's return type is annotated on the node
    // (slot c) so the codegen can compute the matching ABI fingerprint.
    let npc: i64 = native_param_count(nm);
    if (npc >= 0) {
        // count args (linked via nk_next from the call's `a` slot)
        let mut nargs: i64 = 0;
        let mut a: i64 = nk_a(e);
        while (a >= 0) { nargs = nargs + 1; a = nk_next(a); }
        if (nargs != npc) {
            return serr(string_from_slice("native '") + nm + string_from_slice("' expects ")
                        + int_to_str(npc) + string_from_slice(" args, got ") + int_to_str(nargs),
                        node_line(e), node_col(e));
        }
        // check each arg's type against the native's param type
        let mut ai: i64 = nk_a(e);
        let mut i: i64 = 0;
        while (ai >= 0) {
            let want: i64 = native_param_type(nm, i);
            // adapt an unsuffixed float literal to an f32 param (mirrors the
            // native FloatLit expected-f32 branch) before typing the arg.
            try_adapt_float_lit(ai, want);
            let got: i64 = check_expr(ai);
            if (s_err != 0) { return TY_VOID; }
            if (lit_fits_int_type(ai, want) == 0 && types_compatible(want, got) == 0) {
                return serr(string_from_slice("arg ") + int_to_str(i + 1) + string_from_slice(" of '") + nm
                            + string_from_slice("': expected ") + ty_name(want) + string_from_slice(", got ")
                            + ty_name(got),
                            node_line(ai), node_col(ai));
            }
            ai = nk_next(ai);
            i = i + 1;
        }
        let rt: i64 = native_ret_type(nm);
        // annotate the call's return type on the node (slot c, free for CallExpr)
        // so the codegen can compute the ABI fingerprint + downstream type inference.
        set_c(e, rt);
        return rt;
    }

    // ---- SCRIPT calls ----
    // Tier 1 namespaces: Foo::bar(args) parses as a CallExpr with the base name
    // token in slot e (the module-alias). If that base is a namespace, resolve
    // the qualified Ns::fn. A bare call (slot e < 0) inside a namespace fn
    // first tries the current namespace's Ns::fn (intra-namespace), then the
    // top-level fn. Mirrors src/sema.cpp's namespace_resolved + current_ns path.
    let mut row: i64 = -1;
    let mod_tok: i64 = nk_e(e);
    let mut is_ns_call: i64 = 0;
    if (mod_tok >= 0) {
        let mod_name: string = tok_text_at(mod_tok);
        if (is_namespace_name(mod_name) == 1) {
            is_ns_call = 1;
            row = find_fn_qualified(nm, mod_name);
            if (row < 0) {
                return serr(string_from_slice("namespace '") + mod_name + string_from_slice("' has no function '") + nm + string_from_slice("'"),
                            node_line(e), node_col(e));
            }
        }
    }
    if (is_ns_call == 0) {
        row = find_fn(nm);
        if (row < 0 && s_cur_ns >= 0) {
            // bare call inside a namespace fn: try the sibling Ns::fn first.
            let qrow: i64 = find_fn_qualified(nm, tok_name(s_cur_ns));
            if (qrow >= 0) { row = qrow; }
        }
    }
    if (row < 0) {
        // not a declared fn and not a known native. An unknown name is a type
        // error (the self-hosted subset has no fn-handles / dynamic dispatch).
        return serr(string_from_slice("unknown function '") + nm + string_from_slice("'"),
                    node_line(e), node_col(e));
    }
    // count args (linked via nk_next from the call's `a` slot)
    let mut nargs: i64 = 0;
    let mut a: i64 = nk_a(e);
    while (a >= 0) {
        nargs = nargs + 1;
        a = nk_next(a);
    }
    let nparams: i64 = fn_param_count(row);
    if (nargs != nparams) {
        return serr(string_from_slice("function '") + nm + string_from_slice("' expects ")
                    + int_to_str(nparams) + string_from_slice(" args, got ") + int_to_str(nargs),
                    node_line(e), node_col(e));
    }
    // check each arg's type against the corresponding param type
    let mut ai: i64 = nk_a(e);
    let mut i: i64 = 0;
    while (ai >= 0) {
        let want: i64 = fn_param_type(row, i);
        try_adapt_float_lit(ai, want);
        // A struct-by-value arg slot permits a struct-returning CallExpr of
        // the matching struct (mirrors src/sema.cpp's `expected`-matching
        // gate): set the allowance flag around the arg's check_expr so a
        // nested struct-returning call is not rejected by its own gate. The
        // flag is restored immediately after (the allowance is per-arg-slot,
        // not propagated to siblings).
        let saved_allow: i64 = s_allow_struct_ret_call;
        if (ty_is_struct(want) == 1) { s_allow_struct_ret_call = 1; }
        let got: i64 = check_expr(ai);
        s_allow_struct_ret_call = saved_allow;
        if (s_err != 0) { return TY_VOID; }
        if (lit_fits_int_type(ai, want) == 0 && types_compatible(want, got) == 0) {
            return serr(string_from_slice("arg ") + int_to_str(i + 1) + string_from_slice(" of '") + nm
                        + string_from_slice("': expected ") + ty_name(want) + string_from_slice(", got ")
                        + ty_name(got),
                        node_line(ai), node_col(ai));
        }
        // struct-arg shape gate (mirrors src/sema.cpp's check_struct_arg_shape):
        // a struct-by-value argument must be a bare local Ident, a StructLit of
        // the matching struct, or a CallExpr returning the matching struct.
        // Any other shape (e.g. a field access) has no single source address /
        // concrete destination for the hidden-pointer materialization, so the
        // codegen cannot stash it. The type already matched above; this gate
        // restricts the SHAPE.
        if (ty_is_struct(want) == 1) {
            if (check_struct_arg_shape(ai, want) == 0) {
                return serr(string_from_slice("a struct-by-value argument (type '") + ty_name(want)
                            + string_from_slice("') must be a plain local variable, a struct literal of '")
                            + ty_name(want) + string_from_slice("', or a call returning '") + ty_name(want)
                            + string_from_slice("'"),
                            node_line(ai), node_col(ai));
            }
        }
        ai = nk_next(ai);
        i = i + 1;
    }
    let srt: i64 = fn_ret_type(row);
    // A struct-returning CallExpr is only allowed as a let-init / return value
    // / struct-by-value arg of the matching struct (mirrors src/sema.cpp's
    // allow_struct_ret_call + expected-matching gate). check_let / check_return
    // set s_allow_struct_ret_call=1 around the init/value check_expr; the
    // struct-arg slot above sets it for a matching struct param. In any other
    // position (a discarded expr stmt, a field-access base, a binexpr operand)
    // the flag is 0 and the struct-returning call is rejected — codegen has no
    // register form for a multi-word struct result.
    if (ty_is_struct(srt) == 1 && s_allow_struct_ret_call == 0) {
        return serr(string_from_slice("a call returning struct '") + ty_name(srt)
                    + string_from_slice("' is only allowed as a `let x: ") + ty_name(srt)
                    + string_from_slice(" = ") + nm + string_from_slice("(...);` initializer, a `return ")
                    + nm + string_from_slice("(...);` value, or a struct-by-value argument of type '")
                    + ty_name(srt) + string_from_slice("'"),
                    node_line(e), node_col(e));
    }
    set_c(e, srt);  // annotate return type for the codegen
    // Lower an all-constant constexpr call in every expression context.
    // CallExpr's d/f slots are otherwise unused: d=1 marks the fold and f
    // carries the resulting i64 for codegen.
    if (ty_is_i64(srt) == 1 && fn_is_constexpr(row) == 1) {
        if (ce_fold_constexpr_call(e, 0) == 1) {
            set_d(e, 1);
            set_f(e, ce_int_out);
        }
    }
    return srt;
}

// struct-arg shape gate (mirrors src/sema.cpp's check_struct_arg_shape):
// returns 1 iff `arg` is a permitted struct-by-value call argument for a param
// of struct type `want` — a bare local Ident, a StructLit of the matching
// struct, or a CallExpr whose return type is the matching struct. The type
// match itself is done by types_compatible in check_callexpr; this only
// restricts the expression shape.
fn check_struct_arg_shape(arg: i64, want: i64) -> i64 {
    let k: i64 = nk_kind(arg);
    if (k == (NK::Ident as i64)) { return 1; }
    if (k == (NK::StructLit as i64)) {
        if (ty_struct_name(want) == nk_name(arg)) { return 1; }
        return 0;
    }
    if (k == (NK::CallExpr as i64)) {
        let crt: i64 = nk_c(arg);
        if (ty_is_struct(crt) == 1 && ty_struct_name(crt) == ty_struct_name(want)) { return 1; }
        return 0;
    }
    return 0;
}

fn check_structlit(e: i64) -> i64 {
    let row: i64 = find_struct(nk_name(e));
    if (row < 0) { return serr(string_from_slice("unknown struct '") + nk_name(e) + string_from_slice("'"), node_line(e), node_col(e)); }
    let mut field: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1);
    while (field >= 0) {
        let mut init: i64 = nk_a(e);
        let mut seek: i64 = 1;
        while (init >= 0 && seek == 1) { if (nk_name(init) == nk_name(field)) { seek = 0; } else { init = nk_next(init); } }
        if (init < 0) { return serr(string_from_slice("missing struct field '") + nk_name(field) + string_from_slice("'"), node_line(e), node_col(e)); }
        let want: i64 = resolve_type(nk_a(field));
        let got: i64 = check_expr(nk_a(init));
        // literal adaptation: an IntLit (TY_I64) adapts to a narrower integer
        // field if it fits (mirrors src/sema.cpp's check_value + adapt_int_lit).
        if (lit_fits_int_type(nk_a(init), want) == 0 && types_compatible(want, got) == 0) {
            return serr(string_from_slice("struct field type mismatch"), node_line(init), node_col(init));
        }
        field = nk_next(field);
    }
    let t: i64 = alloc_node(NK::Type as i64);
    set_tok(t, array_get_i64(g_structs, row * STRUCT_STRIDE));
    set_d(t, Prim::Void as i64);
    return t;
}

// check a field access base.field. base must be a struct type; the field must
// exist; the result is the field's type.
fn check_fieldexpr(e: i64) -> i64 {
    let base: i64 = nk_a(e);
    let bt: i64 = check_expr(base);
    if (bt < 0) { return TY_VOID; }
    let sname: string = ty_struct_name(bt);
    if (string_length(sname) == 0) {
        return serr(string_from_slice("field access requires a struct type (got ") + ty_name(bt) + string_from_slice(")"),
                    node_line(e), node_col(e));
    }
    let row: i64 = find_struct(sname);
    if (row < 0) {
        return serr(string_from_slice("unknown struct type '") + sname + string_from_slice("'"),
                    node_line(e), node_col(e));
    }
    let fname: string = nk_name(e);
    let ft: i64 = struct_field_type(row, fname);
    if (ft < 0) {
        return serr(string_from_slice("struct '") + sname + string_from_slice("' has no field '") + fname + string_from_slice("'"),
                    node_line(e), node_col(e));
    }
    return ft;
}

// check an index base[idx]. base must be an array/slice; idx must be an
// integer; the result is the element type. (v1: no bounds folding.)
// try to evaluate an expression as a compile-time i64 constant (an IntLit
// or a unary-negated IntLit). Returns 1 + sets `out_val` (via the global
// s_constval) if it folds, 0 otherwise. Mirrors src/sema.cpp's try_eval_const_
// i64 for the literal-only cases the self-hosted subset needs (IndexExpr
// bounds folding + static_assert folding already use a separate path).
global s_constval : i64 = 0;
fn try_const_i64(e: i64) -> i64 {
    if (e < 0) { return 0; }
    if (nk_kind(e) == (NK::IntLit as i64)) { s_constval = nk_d(e); return 1; }
    if (nk_kind(e) == (NK::UnaryExpr as i64) && nk_d(e) == (UnOp::Neg as i64)) {
        let inner: i64 = nk_a(e);
        if (nk_kind(inner) == (NK::IntLit as i64)) { s_constval = -nk_d(inner); return 1; }
    }
    return 0;
}

fn check_indexexpr(e: i64) -> i64 {
    let base: i64 = nk_a(e);
    let bt: i64 = check_expr(base);
    let it: i64 = check_expr(nk_b(e));
    if (ty_is_int_or_typed_enum(it) == 0) {
        return serr(string_from_slice("array index must be an integer"),
                    node_line(nk_b(e)), node_col(nk_b(e)));
    }
    if (bt < 0) { return TY_VOID; }
    if (ty_is_slice(bt) == 0 && ty_array_len(bt) <= 0) {
        return serr(string_from_slice("indexing requires an array or slice type (got ") + ty_name(bt) + string_from_slice(")"),
                    node_line(e), node_col(e));
    }
    // Compile-time bounds check for a FIXED array + constant index (mirrors
    // src/sema.cpp): the length is known now, so a constant out-of-range index
    // is a compile error. A slice's length is runtime-only, so it always
    // defers to codegen's runtime check (no compile-time check here).
    if (ty_is_slice(bt) == 0 && ty_array_len(bt) > 0) {
        if (try_const_i64(nk_b(e)) == 1) {
            let idx: i64 = s_constval;
            let n: i64 = ty_array_len(bt);
            if (idx < 0 || idx >= n) {
                return serr(string_from_slice("array index ") + int_to_str(idx) + string_from_slice(" out of bounds for array of size ") + int_to_str(n),
                            node_line(nk_b(e)), node_col(nk_b(e)));
            }
        }
    }
    let elem: i64 = ty_elem(bt);
    if (elem < 0) { return TY_I64; }   // fallback
    return resolve_type(elem);
}

// check a view expr arr[..]. base must be a fixed array T[N]; the result is a
// slice T[] of the same element type. Mirrors src/sema.cpp's ViewExpr check.
fn check_viewexpr(e: i64) -> i64 {
    let bt: i64 = check_expr(nk_a(e));
    if (bt < 0) { return TY_VOID; }
    if (ty_array_len(bt) <= 0) {
        return serr(string_from_slice("'[..]' view requires a fixed-size array type (got ") + ty_name(bt) + string_from_slice(")"),
                    node_line(e), node_col(e));
    }
    let elem: i64 = ty_elem(bt);
    if (elem < 0) { return TY_VOID; }
    let sl: i64 = alloc_node(NK::Type as i64);
    set_f(sl, 1);          // is_slice
    set_a(sl, resolve_type(elem));
    return sl;
}

// check an array literal `[ e, e, ... ]` against a declared target type
// `expected` (a fixed array T[N] or a slice T[]). v1 does NOT infer array
// types from elements. For a fixed array, the element count must equal N; for
// a slice, any non-empty count is allowed. Each element is checked against the
// declared element type (with int-literal adaptation). Returns the declared
// type (baked onto the literal so codegen knows the shape). Mirrors
// src/sema.cpp's ArrayLit check.
fn check_arraylit(e: i64, expected: i64) -> i64 {
    let is_sl: i64 = ty_is_slice(expected);
    let n: i64 = ty_array_len(expected);
    if (is_sl == 0 && n <= 0) {
        return serr(string_from_slice("array literal requires a fixed-array or slice target type"),
                    node_line(e), node_col(e));
    }
    let elem_ty: i64 = resolve_type(ty_elem(expected));
    if (s_err != 0) { return TY_VOID; }
    // count elements
    let mut count: i64 = 0;
    let mut el: i64 = nk_a(e);
    while (el >= 0) { count = count + 1; el = nk_next(el); }
    if (count == 0) {
        return serr(string_from_slice("empty array literal needs a declared type and at least one element (v1 does not infer array types)"),
                    node_line(e), node_col(e));
    }
    if (is_sl == 0) {
        // fixed array T[N]: requires EXACTLY N elements
        if (count != n) {
            return serr(string_from_slice("array literal for ") + ty_name(expected) + string_from_slice(" needs ") + int_to_str(n) + string_from_slice(" elements, got ") + int_to_str(count),
                        node_line(e), node_col(e));
        }
    }
    // check each element against the declared element type (with literal adaptation)
    el = nk_a(e);
    while (el >= 0) {
        let got: i64 = check_expr(el);
        if (s_err != 0) { return TY_VOID; }
        if (lit_fits_int_type(el, elem_ty) == 0 && types_compatible(elem_ty, got) == 0) {
            return serr(string_from_slice("array element type mismatch (expected ") + ty_name(elem_ty) + string_from_slice(", got ") + ty_name(got) + string_from_slice(")"),
                        node_line(el), node_col(el));
        }
        el = nk_next(el);
    }
    return expected;
}

// check an assignment target = value (incl. compound += and postfix ++/--).
// The target must be an lvalue (Ident / FieldExpr / IndexExpr in v1); the
// value's type must be compatible with the target's type. For a compound op
// the operand types must satisfy the binary-op rule for that op. Returns the
// target's type (the C++ sema likewise types an assignment at its lhs).
//
// Node layout (parse.ember): a=target, b=value, d=compound op (or -1 for plain
// '='), e=postfix flag (1 for postfix ++/--, where the value is implicit 1).
fn check_assignexpr(e: i64) -> i64 {
    let target: i64 = nk_a(e);
    let value: i64 = nk_b(e);
    let cop: i64 = nk_d(e);
    let postfix: i64 = nk_e(e);

    // the target must be an lvalue. v1 recognizes Ident, FieldExpr, IndexExpr
    // as assignable (matching the C++ is_lvalue). Anything else (a literal, a
    // call, a binary expr) is not.
    let tk: i64 = nk_kind(target);
    let mut is_lval: i64 = 0;
    if (tk == (NK::Ident as i64)) { is_lval = 1; }
    if (tk == (NK::FieldExpr as i64)) { is_lval = 1; }
    if (tk == (NK::IndexExpr as i64)) { is_lval = 1; }
    if (is_lval == 0) {
        return serr(string_from_slice("assignment target is not an lvalue"),
                    node_line(e), node_col(e));
    }

    let lt: i64 = check_expr(target);
    if (s_err != 0) { return TY_VOID; }

    // postfix ++ / -- : the value is an implicit 1; the target must be a
    // numeric integer (only integers support inc/dec in v1). No explicit
    // value node is present (b == -1).
    if (postfix == 1) {
        if (ty_is_int(lt) == 0) {
            return serr(string_from_slice("'++'/'--' requires an integer target"),
                        node_line(e), node_col(e));
        }
        return lt;
    }

    // compound op (+=, -=, ...): the stored value is `target op value`, so the
    // op's binary rule must hold for (lt, rt) and yield lt. Reuse the same
    // operand-type checks as check_binexpr via the shared helper.
    if (cop >= 0) {
        let rt: i64 = check_expr(value);
        if (s_err != 0) { return TY_VOID; }
        let _r: i64 = check_binop_result(cop, lt, rt, e);
        if (s_err != 0) { return TY_VOID; }
        return lt;
    }

    // plain '=' : the value's type must be compatible with the target's.
    // A struct-typed target permits a struct-returning CallExpr value (mirrors
    // src/sema.cpp's AssignExpr `expected`-matching gate: check_value(value,
    // lt) lets a struct-returning call through when lt is the matching struct).
    // Set the allowance flag around the value's check_expr when the target is
    // a struct; the struct-arg-shape gate does not apply to an assignment
    // value (the Ident/StructLit/CallExpr shapes are all stashed the same way
    // as a let-init at codegen).
    let saved_allow: i64 = s_allow_struct_ret_call;
    if (ty_is_struct(lt) == 1) { s_allow_struct_ret_call = 1; }
    let rt: i64 = check_expr(value);
    s_allow_struct_ret_call = saved_allow;
    if (s_err != 0) { return TY_VOID; }
    if (lit_fits_int_type(value, lt) == 0 && types_compatible(lt, rt) == 0) {
        return serr(string_from_slice("assignment type mismatch (") + ty_name(lt) + string_from_slice(" = ")
                    + ty_name(rt) + string_from_slice(")"),
                    node_line(e), node_col(e));
    }
    return lt;
}

// -----------------------------------------------------------------------------
// statement type-check. check_stmt(s) walks a statement node, threading the
// current function's return type (s_cur_ret) for return-stmt checking.
// Mirrors the C++ Checker::check_stmt.
// -----------------------------------------------------------------------------

// check a block: push a scope, check each statement (linked via nk_next from
// the block's `a` slot), pop the scope.
fn check_block(b: i64) -> i64 {
    if (b < 0) { return 0; }
    push_scope();
    let mut s: i64 = nk_a(b);
    while (s >= 0) {
        check_stmt(s);
        if (s_err != 0) { pop_scope(); return 0; }
        s = nk_next(s);
    }
    pop_scope();
    return 0;
}

fn check_stmt(s: i64) -> i64 {
    if (s < 0) { return 0; }
    let k: i64 = nk_kind(s);

    if (k == (NK::LetStmt as i64)) {
        return check_let(s);
    }
    if (k == (NK::IfStmt as i64)) {
        let cond: i64 = nk_a(s);
        let ct: i64 = check_expr(cond);
        if (ty_is_bool(ct) == 0) {
            serr(string_from_slice("if condition must be bool"), node_line(cond), node_col(cond));
            return 0;
        }
        check_block(nk_b(s));        // then
        if (s_err != 0) { return 0; }
        if (nk_c(s) >= 0) {
            check_block(nk_c(s));    // else
        }
        return 0;
    }
    if (k == (NK::WhileStmt as i64)) {
        let cond: i64 = nk_a(s);
        let ct: i64 = check_expr(cond);
        if (ty_is_bool(ct) == 0) {
            serr(string_from_slice("while condition must be bool"), node_line(cond), node_col(cond));
            return 0;
        }
        s_loop_depth = s_loop_depth + 1;
        check_block(nk_b(s));
        s_loop_depth = s_loop_depth - 1;
        return 0;
    }
    if (k == (NK::ReturnStmt as i64)) {
        return check_return(s);
    }
    if (k == (NK::ExprStmt as i64)) {
        if (nk_a(s) >= 0) { check_expr(nk_a(s)); }
        return 0;
    }
    if (k == (NK::BlockStmt as i64)) {
        check_block(s);
        return 0;
    }
    if (k == (NK::BreakStmt as i64)) {
        // break is valid inside a loop OR a switch (mirrors src/sema.cpp:
        // loop_depth>0 || switch_depth>0).
        if (s_loop_depth == 0 && s_switch_depth == 0) {
            serr(string_from_slice("break is only valid inside a loop or switch"), node_line(s), node_col(s));
        }
        return 0;
    }
    if (k == (NK::ContinueStmt as i64)) {
        // continue is valid only inside a loop (a switch does NOT count,
        // mirrors src/sema.cpp: loop_depth>0).
        if (s_loop_depth == 0) {
            serr(string_from_slice("continue is only valid inside a loop"), node_line(s), node_col(s));
        }
        return 0;
    }
    if (k == (NK::ForStmt as i64)) {
        return check_for(s);
    }

    if (k == (NK::ForEachStmt as i64)) { return check_foreach(s); }
    // Phase 3b: do-while. Body runs first, then cond is tested. Like while,
    // the cond must be bool and break/continue are legal inside (loop depth
    // is incremented around the body). Mirrors src/sema.cpp's DoWhileStmt.
    if (k == (NK::DoWhileStmt as i64)) {
        s_loop_depth = s_loop_depth + 1;
        check_block(nk_a(s));
        if (s_err != 0) { s_loop_depth = s_loop_depth - 1; return 0; }
        s_loop_depth = s_loop_depth - 1;
        let cond: i64 = nk_b(s);
        let ct: i64 = check_expr(cond);
        if (ty_is_bool(ct) == 0) {
            serr(string_from_slice("do-while cond must be bool"), node_line(cond), node_col(cond));
            return 0;
        }
        return 0;
    }
    // Phase 3b: switch. Subject must be int/bool; each non-default case value
    // must be a constant matching the subject type; at most one default. Each
    // nonempty case body must end with break/continue/return (no fallthrough).
    // Mirrors src/sema.cpp's SwitchStmt. break/continue are legal inside a
    // case (switch scopes the body like a loop for break purposes).
    if (k == (NK::SwitchStmt as i64)) {
        return check_switch(s);
    }
    if (k == (NK::MatchStmt as i64)) {
        let subject_ty: i64 = check_expr(nk_a(s));
        let mut arm: i64 = nk_b(s);
        while (arm >= 0) {
            // Struct-pattern captures are visible to both the guard and body.
            push_scope();
            if (nk_f(arm) == 1) {
                let pat_name: string = tok_name(nk_tok(arm));
                let row: i64 = find_struct(pat_name);
                if (row < 0 || ty_is_struct(subject_ty) == 0 || (ty_struct_name(subject_ty) == pat_name) == false) {
                    serr(string_from_slice("match struct pattern type mismatch"), node_line(arm), node_col(arm));
                    pop_scope(); return 0;
                }
                let mut fld: i64 = nk_c(arm);
                while (fld >= 0) {
                    let ft: i64 = struct_field_type(row, nk_name(fld));
                    if (ft < 0) {
                        serr(string_from_slice("struct '") + pat_name + string_from_slice("' has no field '") + nk_name(fld) + string_from_slice("'"), node_line(fld), node_col(fld));
                        pop_scope(); return 0;
                    }
                    if (nk_a(fld) < 0) {
                        declare(nk_tok(fld), ft);
                    } else {
                        let pt: i64 = check_expr(nk_a(fld));
                        if (lit_fits_int_type(nk_a(fld), ft) == 0 && types_compatible(ft, pt) == 0) {
                            serr(string_from_slice("match struct field pattern type mismatch"), node_line(fld), node_col(fld));
                            pop_scope(); return 0;
                        }
                    }
                    if (s_err != 0) { pop_scope(); return 0; }
                    fld = nk_next(fld);
                }
            } else if (nk_d(arm) == 0) {
                let pt: i64 = check_expr(nk_a(arm));
                // same type OR both integer (a typed enum IS an integer, so an
                // enum subject + int pattern, or an int subject + enum pattern,
                // is accepted — mirrors src/sema.cpp's match pattern rule).
                if (type_eq(subject_ty, pt) == 0) {
                    if (ty_is_int_or_typed_enum(subject_ty) == 0 || ty_is_int_or_typed_enum(pt) == 0) {
                        serr(string_from_slice("match pattern type mismatch"), node_line(arm), node_col(arm)); pop_scope(); return 0;
                    }
                }
            }
            if (nk_e(arm) >= 0 && ty_is_bool(check_expr(nk_e(arm))) == 0) { serr(string_from_slice("match guard must be bool"), node_line(arm), node_col(arm)); pop_scope(); return 0; }
            check_block(nk_b(arm));
            pop_scope();
            if (s_err != 0) { return 0; }
            arm = nk_next(arm);
        }
        return 0;
    }
    if (k == (NK::ThrowStmt as i64)) {
        let val: i64 = nk_a(s);
        if (val >= 0) { check_expr(val); }
        return 0;
    }
    if (k == (NK::TryCatchStmt as i64)) {
        push_scope();
        let cnametok: i64 = nk_tok(s);
        if (cnametok >= 0) { declare(cnametok, TY_I64); }
        if (s_err != 0) { pop_scope(); return 0; }
        check_block(nk_a(s));
        if (s_err != 0) { pop_scope(); return 0; }
        check_block(nk_b(s));
        pop_scope();
        return 0;
    }
    if (k == (NK::YieldStmt as i64)) {
        let val: i64 = nk_a(s);
        if (val >= 0) {
            let yt: i64 = check_expr(val);
            if (s_err != 0) { return 0; }
            if (ty_is_i64(yt) == 0) { serr(string_from_slice("yield value must be i64"), node_line(s), node_col(s)); }
        }
        return 0;
    }
    // Phase 3b: defer. The deferred expr is checked now (its result is
    // discarded) but runs at scope exit in codegen. Cleanup runs while this
    // lexical block's locals remain live, so ordinary scope lookup suffices.
    // Mirrors src/sema.cpp's DeferStmt.
    if (k == (NK::DeferStmt as i64)) {
        if (nk_a(s) >= 0) { check_expr(nk_a(s)); }
        return 0;
    }
    // Phase 2 Step 6: static_assert(cond, msg). Evaluate cond at compile time.
    // If true, elide (no-op). If false, emit a sema error with the message. If
    // the cond is not a compile-time constant, emit a sema error. Mirrors
    // src/sema.cpp's check_static_assert + try_eval_const_bool.
    if (k == (NK::StaticAssertStmt as i64)) {
        return check_static_assert(s);
    }
    unsupported(-314, string_from_slice("statement kind"), s);
    return 0;
}

// -----------------------------------------------------------------------------
// Phase 2 Step 6: compile-time constant evaluation for static_assert.
// try_eval_const_i64 / try_eval_const_bool mirror src/sema.cpp's同名 fns:
// fold IntLit, UnaryExpr (Neg/BitNot for int, Not for bool), and BinExpr
// (arithmetic/bitwise for int, comparison/logical for bool) over constants.
// Returns 1 + sets `out` on success, 0 on failure (non-constant expr).
// -----------------------------------------------------------------------------

// a two-outcome fold: returns 1 + sets out0 on success, 0 on failure.
// (ember has no tuples/out-params, so the result is returned via globals.)
global ce_int_out  : i64 = 0;
global ce_bool_out : i64 = 0;

fn try_eval_const_i64(e: i64) -> i64 {
    if (e < 0) { return 0; }
    let k: i64 = nk_kind(e);
    if (k == (NK::IntLit as i64)) { ce_int_out = nk_d(e); return 1; }
    if (k == (NK::Ident as i64)) {
        // a constexpr param binding (set by ce_eval_constexpr_fn) or a const
        // i64 global. Mirrors the native ce_eval_expr Ident case.
        if (ce_lookup_param(nk_name(e)) == 1) { return 1; }
        let g: i64 = find_global(nk_name(e));
        if (g >= 0) {
            // a const i64 global's initializer value (global_is_const_i64 gate).
            return 0;   // globals are read via their init expr elsewhere; skip
        }
        return 0;
    }
    if (k == (NK::EnumAccess as i64)) {
        // a typed or untyped enum variant folds to its compile-time integer
        // value (mirrors src/sema.cpp's lower_enum_access_expr -> IntLit).
        let ename: string = tok_name(nk_a(e));
        if (is_namespace_name(ename) == 1) { return 0; }   // a namespace global, not const
        let row: i64 = find_enum(ename);
        if (row < 0) { return 0; }
        if (enum_variant_value(row, nk_name(e)) == 1) { ce_int_out = g_enum_val_out; return 1; }
        return 0;
    }
    if (k == (NK::CallExpr as i64)) {
        // constexpr fn call: fold if the callee is a constexpr fn with all-const
        // i64 args (mirrors src/sema.cpp's lower_constexpr_calls_expr pre-pass).
        return ce_fold_constexpr_call(e, 0);
    }
    if (k == (NK::UnaryExpr as i64)) {
        if (try_eval_const_i64(nk_a(e)) == 0) { return 0; }
        let v: i64 = ce_int_out;
        if (nk_d(e) == (UnOp::Neg as i64)) { ce_int_out = 0 - v; return 1; }
        if (nk_d(e) == (UnOp::BitNot as i64)) { ce_int_out = ~v; return 1; }
        return 0;
    }
    if (k == (NK::BinExpr as i64)) {
        if (try_eval_const_i64(nk_a(e)) == 0) { return 0; }
        let l: i64 = ce_int_out;
        if (try_eval_const_i64(nk_b(e)) == 0) { return 0; }
        let r: i64 = ce_int_out;
        let op: i64 = nk_d(e);
        if (op == (BinOp::Add as i64)) { ce_int_out = l + r; return 1; }
        if (op == (BinOp::Sub as i64)) { ce_int_out = l - r; return 1; }
        if (op == (BinOp::Mul as i64)) { ce_int_out = l * r; return 1; }
        if (op == (BinOp::And as i64)) { ce_int_out = l & r; return 1; }
        if (op == (BinOp::Or  as i64)) { ce_int_out = l | r; return 1; }
        if (op == (BinOp::Xor as i64)) { ce_int_out = l ^ r; return 1; }
        if (op == (BinOp::Shl as i64)) { ce_int_out = l << (r & 63); return 1; }
        if (op == (BinOp::Shr as i64)) { ce_int_out = l >> (r & 63); return 1; }
        return 0;  // Div/Mod excluded (mirrors C++)
    }
    return 0;
}

fn try_eval_const_bool(e: i64) -> i64 {
    if (e < 0) { return 0; }
    let k: i64 = nk_kind(e);
    if (k == (NK::BoolLit as i64)) { ce_bool_out = nk_d(e); return 1; }
    if (k == (NK::UnaryExpr as i64)) {
        if (nk_d(e) != (UnOp::Not as i64)) { return 0; }
        if (try_eval_const_bool(nk_a(e)) == 0) { return 0; }
        let v: i64 = ce_bool_out;
        if (v != 0) { ce_bool_out = 0; } else { ce_bool_out = 1; }
        return 1;
    }
    if (k == (NK::BinExpr as i64)) {
        let op: i64 = nk_d(e);
        // comparison: fold both sides as i64 constants
        if (op == (BinOp::Eq as i64) || op == (BinOp::Neq as i64) ||
            op == (BinOp::Lt as i64) || op == (BinOp::Le as i64) ||
            op == (BinOp::Gt as i64) || op == (BinOp::Ge as i64)) {
            if (try_eval_const_i64(nk_a(e)) == 0) { return 0; }
            let l: i64 = ce_int_out;
            if (try_eval_const_i64(nk_b(e)) == 0) { return 0; }
            let r: i64 = ce_int_out;
            if (op == (BinOp::Eq as i64))  { if (l == r) { ce_bool_out = 1; } else { ce_bool_out = 0; } return 1; }
            if (op == (BinOp::Neq as i64)) { if (l != r) { ce_bool_out = 1; } else { ce_bool_out = 0; } return 1; }
            if (op == (BinOp::Lt as i64))  { if (l <  r) { ce_bool_out = 1; } else { ce_bool_out = 0; } return 1; }
            if (op == (BinOp::Le as i64))  { if (l <= r) { ce_bool_out = 1; } else { ce_bool_out = 0; } return 1; }
            if (op == (BinOp::Gt as i64))  { if (l >  r) { ce_bool_out = 1; } else { ce_bool_out = 0; } return 1; }
            if (op == (BinOp::Ge as i64))  { if (l >= r) { ce_bool_out = 1; } else { ce_bool_out = 0; } return 1; }
            return 0;
        }
        // logical && / ||
        if (op == (BinOp::LAnd as i64) || op == (BinOp::LOr as i64)) {
            if (try_eval_const_bool(nk_a(e)) == 0) { return 0; }
            let l: i64 = ce_bool_out;
            if (try_eval_const_bool(nk_b(e)) == 0) { return 0; }
            let r: i64 = ce_bool_out;
            if (op == (BinOp::LAnd as i64)) {
                if (l != 0 && r != 0) { ce_bool_out = 1; } else { ce_bool_out = 0; }
            } else {
                if (l != 0 || r != 0) { ce_bool_out = 1; } else { ce_bool_out = 0; }
            }
            return 1;
        }
        return 0;
    }
    return 0;
}

// -----------------------------------------------------------------------------
// constexpr fn evaluation (Tier 1): a bounded tree-walking interpreter that
// evaluates a constexpr fn call at sema time to a compile-time i64, so a
// static_assert condition like `square(7) == 49` folds to true. Mirrors
// src/sema.cpp's eval_constexpr_fn + lower_constexpr_calls_expr pre-pass.
// Bound by CE_MAX_DEPTH (recursion) + CE_MAX_ITERS (total loop iterations
// across one eval, the DoS bound). Only i64-returning constexpr fns with
// all-constant i64 args fold; anything else returns 0 (falls back to runtime).
// -----------------------------------------------------------------------------
global CE_MAX_DEPTH : i64 = 256;
global CE_MAX_ITERS : i64 = 100000;
global ce_depth : i64 = 0;
global ce_iters : i64 = 0;
// parameter binding env: a flat array of [name_tok, value] pairs (stride 2),
// with a mark stack so nested calls don't bleed bindings. ce_params_len is the
// logical live length; the backing array grows as needed.
global ce_params : i64 = 0;
global ce_params_len : i64 = 0;
global ce_param_marks : i64 = 0;
global ce_param_mark_len : i64 = 0;
// the result of a successful ce_eval_stmt (a return's value).
global ce_returned : i64 = 0;
global ce_ret_val : i64 = 0;

// fold a CallExpr to a constexpr fn. Returns 1 + sets ce_int_out on success,
// 0 on failure (non-constexpr callee, non-const arg, too-deep, unsupported).
fn ce_fold_constexpr_call(e: i64, depth: i64) -> i64 {
    if (e < 0) { return 0; }
    if (depth > CE_MAX_DEPTH) { return 0; }
    // a namespace-qualified or indirect call is not a constexpr fold target
    // (the constexpr fns in the subset are top-level or namespaced bare calls;
    // resolve via the same path as check_callexpr's script resolution).
    let nm: string = nk_name(e);
    let mut row: i64 = -1;
    let mod_tok: i64 = nk_e(e);
    if (mod_tok >= 0) {
        let mod_name: string = tok_text_at(mod_tok);
        if (is_namespace_name(mod_name) == 1) {
            row = find_fn_qualified(nm, mod_name);
        }
    }
    if (row < 0) {
        row = find_fn(nm);
        if (row < 0 && s_cur_ns >= 0) {
            let qrow: i64 = find_fn_qualified(nm, tok_name(s_cur_ns));
            if (qrow >= 0) { row = qrow; }
        }
    }
    if (row < 0) { return 0; }
    if (fn_is_constexpr(row) == 0) { return 0; }
    // evaluate each arg to a compile-time i64.
    let first_param: i64 = fn_first_param(row);
    let nparams: i64 = fn_param_count(row);
    let arg_vals: i64 = array_new(8, nparams);
    let mut ai: i64 = nk_a(e);
    let mut pi: i64 = first_param;
    let mut i: i64 = 0;
    while (ai >= 0) {
        if (i >= nparams) { return 0; }   // arity mismatch (sema would catch)
        if (try_eval_const_i64(ai) == 0) { return 0; }   // non-const arg
        array_set_i64(arg_vals, i, ce_int_out);
        ai = nk_next(ai);
        pi = nk_next(pi);
        i = i + 1;
    }
    if (i != nparams) { return 0; }       // too few args
    return ce_eval_constexpr_fn(row, arg_vals, depth);
}

// evaluate a constexpr fn body with the given arg values. Returns 1 + sets
// ce_int_out to the return value on success, 0 on failure.
fn ce_eval_constexpr_fn(row: i64, arg_vals: i64, depth: i64) -> i64 {
    if (depth > CE_MAX_DEPTH) { return 0; }
    let body: i64 = fn_body_block(row);
    if (body < 0) { return 0; }
    // bind params: push a mark, append (param_tok, value) for each.
    let saved_mark_len: i64 = ce_param_mark_len;
    if (array_length(ce_param_marks) < ce_param_mark_len + 1) {
        array_resize(ce_param_marks, ce_param_mark_len + 1);
    }
    array_set_i64(ce_param_marks, ce_param_mark_len, ce_params_len);
    ce_param_mark_len = ce_param_mark_len + 1;
    let mut pi: i64 = fn_first_param(row);
    let mut i: i64 = 0;
    while (pi >= 0) {
        if (array_length(ce_params) < ce_params_len + 2) {
            array_resize(ce_params, ce_params_len + 2);
        }
        array_set_i64(ce_params, ce_params_len, nk_tok(pi));
        array_set_i64(ce_params, ce_params_len + 1, array_get_i64(arg_vals, i));
        ce_params_len = ce_params_len + 2;
        pi = nk_next(pi);
        i = i + 1;
    }
    // evaluate the body's stmt list (nk_a(body) = first stmt).
    ce_returned = 0;
    ce_ret_val = 0;
    let saved_depth: i64 = ce_depth;
    ce_depth = depth + 1;
    let mut s: i64 = nk_a(body);
    while (s >= 0) {
        ce_eval_stmt(s);
        if (ce_returned != 0) { s = -1; }
        else { s = nk_next(s); }
        if (ce_iters > CE_MAX_ITERS) { ce_depth = saved_depth; ce_pop_params(saved_mark_len); return 0; }
    }
    ce_depth = saved_depth;
    let mut ok: i64 = 0;
    if (ce_returned != 0) { ce_int_out = ce_ret_val; ok = 1; }
    ce_pop_params(saved_mark_len);
    return ok;
}

// pop parameter bindings back to a saved mark length.
fn ce_pop_params(saved_mark_len: i64) -> i64 {
    if (ce_param_mark_len == 0) { return 0; }
    ce_param_mark_len = saved_mark_len;
    let mark: i64 = array_get_i64(ce_param_marks, saved_mark_len);
    ce_params_len = mark;
    return 0;
}

// look up a parameter binding by name (returns 1 + sets ce_int_out, else 0).
fn ce_lookup_param(name: string) -> i64 {
    let mut i: i64 = ce_params_len - 2;
    while (i >= 0) {
        if (tok_name(array_get_i64(ce_params, i)) == name) {
            ce_int_out = array_get_i64(ce_params, i + 1);
            return 1;
        }
        i = i - 2;
    }
    return 0;
}

// evaluate a statement (only return / let / if / while / block are supported;
// anything else stops the fold with no return). Sets ce_returned + ce_ret_val
// when a return is hit.
fn ce_eval_stmt(s: i64) -> i64 {
    if (s < 0) { return 0; }
    let k: i64 = nk_kind(s);
    if (k == (NK::ReturnStmt as i64)) {
        let val: i64 = nk_a(s);
        if (val >= 0) {
            if (try_eval_const_i64(val) == 1) { ce_ret_val = ce_int_out; }
            else { ce_ret_val = 0; }
        } else { ce_ret_val = 0; }
        ce_returned = 1;
        return 0;
    }
    if (k == (NK::LetStmt as i64)) {
        // bind a local: evaluate the initializer + record (name_tok, value).
        let init: i64 = nk_b(s);
        let mut v: i64 = 0;
        if (init >= 0) {
            if (try_eval_const_i64(init) == 1) { v = ce_int_out; }
            else { return 0; }
        }
        if (array_length(ce_params) < ce_params_len + 2) {
            array_resize(ce_params, ce_params_len + 2);
        }
        array_set_i64(ce_params, ce_params_len, nk_tok(s));
        array_set_i64(ce_params, ce_params_len + 1, v);
        ce_params_len = ce_params_len + 2;
        return 0;
    }
    if (k == (NK::AssignExpr as i64)) {
        // assign to a bound local (Ident target). cop < 0 = plain '='.
        let target: i64 = nk_a(s);
        if (nk_kind(target) == (NK::Ident as i64)) {
            let val: i64 = nk_b(s);
            if (val >= 0 && try_eval_const_i64(val) == 1) {
                let nm: string = nk_name(target);
                let mut i: i64 = ce_params_len - 2;
                while (i >= 0) {
                    if (tok_name(array_get_i64(ce_params, i)) == nm) {
                        array_set_i64(ce_params, i + 1, ce_int_out);
                        return 0;
                    }
                    i = i - 2;
                }
            }
        }
        return 0;
    }
    if (k == (NK::IfStmt as i64)) {
        let cond: i64 = nk_a(s);
        if (try_eval_const_bool(cond) == 1) {
            if (ce_bool_out != 0) { ce_eval_block_stmt(nk_b(s)); }
            else if (nk_c(s) >= 0) { ce_eval_block_stmt(nk_c(s)); }
        }
        return 0;
    }
    if (k == (NK::WhileStmt as i64)) {
        let cond: i64 = nk_a(s);
        while (try_eval_const_bool(cond) == 1 && ce_bool_out != 0) {
            ce_eval_block_stmt(nk_b(s));
            ce_iters = ce_iters + 1;
            if (ce_iters > CE_MAX_ITERS) { return 0; }
            if (ce_returned != 0) { return 0; }
        }
        return 0;
    }
    if (k == (NK::BlockStmt as i64)) { return ce_eval_block_stmt(s); }
    // ExprStmt / other: evaluate for side-effect-free fold (no-op here).
    return 0;
}

// evaluate a BlockStmt's stmt list (nk_a = first stmt).
fn ce_eval_block_stmt(b: i64) -> i64 {
    if (b < 0) { return 0; }
    let mut s: i64 = nk_a(b);
    while (s >= 0) {
        ce_eval_stmt(s);
        if (ce_returned != 0) { return 0; }
        s = nk_next(s);
        if (ce_iters > CE_MAX_ITERS) { return 0; }
    }
    return 0;
}

// check a static_assert(cond, msg): evaluate cond at compile time. If false,
// emit a sema error with the message. If true, no-op (codegen emits nothing).
// If the cond is not a compile-time constant, emit a sema error. Mirrors
// src/sema.cpp's check_static_assert. The message is the StringLit token's text.
fn check_static_assert(s: i64) -> i64 {
    let cond: i64 = nk_a(s);
    let ct: i64 = check_expr(cond);
    if (s_err != 0) { return 0; }
    if (ty_is_bool(ct) == 0) {
        serr(string_from_slice("static_assert condition must be bool"), node_line(s), node_col(s));
        return 0;
    }
    if (try_eval_const_bool(cond) == 1) {
        if (ce_bool_out == 0) {
            // false: emit the message. The message token is a StringLit;
            // its decoded body is the string content (quotes stripped).
            let mut msg: string = string_from_slice("");
            if (nk_tok(s) >= 0) { msg = tok_string_body(nk_tok(s)); }
            serr(string_from_slice("static_assert failed: ") + msg, node_line(s), node_col(s));
            s_errcode = -319;  // dedicated static_assert-failure code
        }
        // true -> elided: no-op
    } else {
        serr(string_from_slice("static_assert condition must be a compile-time constant"), node_line(s), node_col(s));
    }
    return 0;
}

// Does an IntLit expression's value fit in an integer `target` type? Mirrors
// src/sema.cpp's adapt_int_lit: a default-i64 IntLit may adopt any integer
// target whose range contains the literal value. Used at let/return/assign/
// call sites where a typed int target receives an untyped integer literal
// (the C++ sema adapts the literal in check_expr via the `expected` param;
// the self-hosted check_expr has no expected param, so the adaptation gate
// lives at the use site instead).
fn lit_fits_int_type(e: i64, target: i64) -> i64 {
    if (e < 0) { return 0; }
    if (nk_kind(e) != (NK::IntLit as i64)) { return 0; }
    if (ty_is_int(target) == 0) { return 0; }
    let v: i64 = nk_d(e);
    let p: i64 = nk_d(target);
    if (p == (Prim::U8  as i64)) { if (v >= 0 && v <= 0xFF)         { return 1; } return 0; }
    if (p == (Prim::U16 as i64)) { if (v >= 0 && v <= 0xFFFF)      { return 1; } return 0; }
    if (p == (Prim::U32 as i64)) { if (v >= 0 && v <= 0xFFFFFFFF)  { return 1; } return 0; }
    if (p == (Prim::U64 as i64)) { return 1; }   // any 64-bit bit pattern
    if (p == (Prim::I8  as i64)) { if (v >= -128 && v <= 127)      { return 1; } return 0; }
    if (p == (Prim::I16 as i64)) { if (v >= -32768 && v <= 32767)  { return 1; } return 0; }
    if (p == (Prim::I32 as i64)) { if (v >= -2147483648 && v <= 2147483647) { return 1; } return 0; }
    if (p == (Prim::I64 as i64)) { return 1; }
    return 0;
}

// Float literal adaptation (mirrors src/sema.cpp's FloatLit check_expr branch:
// an unsuffixed float literal adapts to an expected f32 context). If `e` is a
// FloatLit WITHOUT an `f`/`F` suffix and `target` is f32, annotate the node's
// slot c with TY_F32 so check_expr returns f32 + the codegen emits it as f32.
// Returns 1 if adapted, 0 otherwise. Idempotent (re-annotating is fine).
fn try_adapt_float_lit(e: i64, target: i64) -> i64 {
    if (e < 0) { return 0; }
    if (nk_kind(e) != (NK::FloatLit as i64)) { return 0; }
    if (ty_is_float(target) == 0) { return 0; }
    if (nk_d(target) == (Prim::F32 as i64)) {
        // already-suffixed f32 literal stays f32 (no change); an unsuffixed
        // f64 literal adapts to f32. Detect the suffix from the raw text.
        let raw: string = nk_name(e);
        let n: i64 = string_length(raw);
        if (n > 0) {
            let last: i64 = string_char_at(raw, n - 1);
            if (last == 102 || last == 70) { return 0; }   // `f`/`F` suffix
        }
        set_c(e, TY_F32);
        return 1;
    }
    return 0;
}

// check a let statement. If it has a declared type, check the initializer's
// type matches it (and declare the var at the declared type). If auto (no
// declared type), infer the var's type from the initializer.
fn check_let(s: i64) -> i64 {
    let nm_tok: i64 = nk_tok(s);
    let nm: string = tok_name(nm_tok);
    let ty_node: i64 = nk_a(s);     // declared type node, or -1 for auto
    let init: i64 = nk_b(s);        // initializer expr, or -1

    let mut decl_ty: i64 = 0;
    if (ty_node >= 0) {
        decl_ty = resolve_type(ty_node);
        if (s_err != 0) { return 0; }
        if (ty_is_void(decl_ty) == 1) {
            serr(string_from_slice("local '") + nm + string_from_slice("' cannot have void type"),
                 node_line(s), node_col(s));
            return 0;
        }
    }

    if (init < 0) {
        // no initializer: declare at the stated type (must have one)
        if (ty_node < 0) {
            serr(string_from_slice("let with no initializer needs a type"), node_line(s), node_col(s));
            return 0;
        }
        declare(nm_tok, decl_ty);
        return 0;
    }

    // Array literal init: requires a declared fixed-array or slice target type
    // (v1 does not infer array types from elements, mirroring src/sema.cpp).
    // check_arraylit validates the element count + each element's type against
    // the declared element type and bakes the declared type onto the literal.
    if (nk_kind(init) == (NK::ArrayLit as i64)) {
        if (ty_node < 0) {
            return serr(string_from_slice("array literal needs an explicit type annotation (v1 does not infer array types from elements)"),
                        node_line(init), node_col(init));
        }
        if (ty_is_aggregate(decl_ty) == 0 || (ty_is_slice(decl_ty) == 0 && ty_array_len(decl_ty) <= 0)) {
            return serr(string_from_slice("array literal requires a fixed-array or slice target type (got ") + ty_name(decl_ty) + string_from_slice(")"),
                        node_line(init), node_col(init));
        }
        let alty: i64 = check_arraylit(init, decl_ty);
        if (s_err != 0) { return 0; }
        declare(nm_tok, alty);
        return 0;
    }

    // iterable() hook: if the initializer is an array_new(esz,n) call, the
    // local is an array<T> handle (an opaque i64). Tag it with the inferred
    // element type so a later `for (x in this_local)` can type the loop
    // variable (mirrors the native Var::array_elem_ty set at declaration).
    let arr_elem: i64 = infer_array_elem_ty_from_call(init);

    // Float literal adaptation: an unsuffixed float literal adapts to a
    // declared f32 type (mirrors src/sema.cpp's FloatLit expected-f32 branch).
    // Annotate BEFORE check_expr so check_expr returns the adapted f32 type.
    if (ty_node >= 0) { try_adapt_float_lit(init, decl_ty); }

    // A let-init is one of the two positions a struct-returning CallExpr is
    // allowed (the local's frame slot is the concrete destination for the
    // callee's hidden return pointer). Set the allowance flag around the
    // init's check_expr, mirroring src/sema.cpp's check_value(..., true).
    let saved_allow: i64 = s_allow_struct_ret_call;
    s_allow_struct_ret_call = 1;
    let init_ty: i64 = check_expr(init);
    s_allow_struct_ret_call = saved_allow;
    if (s_err != 0) { return 0; }

    if (ty_node >= 0) {
        // typed let: init must be compatible with the declared type. An IntLit
        // (always TY_I64 from check_expr) adapts to any integer target whose
        // range contains it (mirrors src/sema.cpp's adapt_int_lit).
        if (lit_fits_int_type(init, decl_ty) == 1) {
            declare_with_elem(nm_tok, decl_ty, arr_elem);
            return 0;
        }
        if (types_compatible(decl_ty, init_ty) == 0) {
            serr(string_from_slice("let type mismatch (") + ty_name(decl_ty) + string_from_slice(" = ")
                 + ty_name(init_ty) + string_from_slice(")"),
                 node_line(s), node_col(s));
            return 0;
        }
        declare_with_elem(nm_tok, decl_ty, arr_elem);
    } else {
        // auto: infer the type from the initializer
        if (ty_is_void(init_ty) == 1) {
            serr(string_from_slice("cannot infer type from a void initializer"), node_line(s), node_col(s));
            return 0;
        }
        declare_with_elem(nm_tok, init_ty, arr_elem);
    }
    return 0;
}

// check a return statement. If it has a value, its type must match the current
// fn's return type; if not, the fn must return void.
fn check_return(s: i64) -> i64 {
    let val: i64 = nk_a(s);
    if (val >= 0) {
        if (s_cur_ret >= 0) { try_adapt_float_lit(val, s_cur_ret); }
        // A return value is one of the two positions a struct-returning
        // CallExpr is allowed (this fn's own incoming hidden return pointer is
        // the concrete destination). Set the allowance flag around the value's
        // check_expr, mirroring src/sema.cpp's check_value(..., true).
        let saved_allow: i64 = s_allow_struct_ret_call;
        s_allow_struct_ret_call = 1;
        let vt: i64 = check_expr(val);
        s_allow_struct_ret_call = saved_allow;
        if (s_err != 0) { return 0; }
        if (s_cur_ret < 0) {
            serr(string_from_slice("return outside a function"), node_line(s), node_col(s));
            return 0;
        }
        if (lit_fits_int_type(val, s_cur_ret) == 1) {
            return 0;
        }
        if (types_compatible(s_cur_ret, vt) == 0) {
            serr(string_from_slice("return type mismatch (got ") + ty_name(vt) + string_from_slice(", fn returns ")
                 + ty_name(s_cur_ret) + string_from_slice(")"),
                 node_line(s), node_col(s));
            return 0;
        }
    } else {
        // bare return; fn must return void
        if (s_cur_ret >= 0 && ty_is_void(s_cur_ret) == 0) {
            serr(string_from_slice("non-void function must return a value"), node_line(s), node_col(s));
            return 0;
        }
    }
    return 0;
}

// check a C-style for (init; cond; step) body. init is a let or expr stmt;
// cond must be bool; step is an expr. The init scope encloses the body, while
// check_block adds the body's nested lexical scope.
fn check_for(s: i64) -> i64 {
    push_scope();
    if (nk_a(s) >= 0) { check_stmt(nk_a(s)); }    // init
    if (s_err != 0) { pop_scope(); return 0; }
    if (nk_b(s) >= 0) {
        let ct: i64 = check_expr(nk_b(s));        // cond
        if (ty_is_bool(ct) == 0) {
            serr(string_from_slice("for cond must be bool"), node_line(nk_b(s)), node_col(nk_b(s)));
            pop_scope();
            return 0;
        }
    }
    if (nk_c(s) >= 0) { check_expr(nk_c(s)); }    // step
    if (s_err != 0) { pop_scope(); return 0; }
    s_loop_depth = s_loop_depth + 1;
    check_block(nk_e(s));                          // body
    s_loop_depth = s_loop_depth - 1;
    pop_scope();
    return 0;
}

// infer the element type of an array_new(esz,n) call from its first arg's
// compile-time-constant elem_size. esz=1 -> u8, esz=4 -> f32, esz=8 -> i64.
// Returns the element Type node, or -1 if the call is not array_new / the
// elem_size is not a compile-time constant / an unsupported size. Mirrors
// src/sema.cpp's infer_array_elem_ty_from_call.
fn infer_array_elem_ty_from_call(c: i64) -> i64 {
    if (c < 0) { return -1; }
    if (nk_kind(c) != (NK::CallExpr as i64)) { return -1; }
    // NOTE: ember's `!=` on strings is handle-identity, NOT content negation,
    // so use the positive `==` guard (mirrors native_find's pattern).
    let mut is_arr_new: i64 = 0;
    if (nk_name(c) == string_from_slice("array_new")) { is_arr_new = 1; }
    if (is_arr_new == 0) { return -1; }
    let a0: i64 = nk_a(c);
    if (a0 < 0) { return -1; }
    if (try_const_i64(a0) == 0) { return -1; }
    let esz: i64 = s_constval;
    if (esz == 1) { return TY_U8; }
    if (esz == 4) { return TY_F32; }
    if (esz == 8) { return TY_I64; }
    return -1;
}

// infer the element type for a for-each iterable expression (the iterable()
// hook, array case). An inline array_new(...) call, or an Ident whose
// declaring `let` initialized from array_new (tracked via the local's
// array_elem_ty tag), is a provable array handle -> return its element type.
// A bare i64 that is NOT from array_new returns -1 so the caller rejects it
// (matches src/sema.cpp's infer_iterable_array_elem_ty + the
// sema_invalid_for_each_not_slice contract).
fn infer_iterable_array_elem_ty(iter: i64) -> i64 {
    if (iter < 0) { return -1; }
    let k: i64 = nk_kind(iter);
    if (k == (NK::CallExpr as i64)) {
        return infer_array_elem_ty_from_call(iter);
    }
    if (k == (NK::Ident as i64)) {
        let et: i64 = lookup_local_array_elem_ty(nk_name(iter));
        if (et >= 0) { return et; }
        return -1;
    }
    return -1;
}

// check a for-each statement: for (x in iter) { body }. Two iterable kinds
// (the iterable() hook, mirroring src/sema.cpp's ForEachStmt check):
//   1. a slice T[]              -> x gets the slice's element type (slice path)
//   2. an array<T> handle (i64) -> x gets the inferred element type (u8/f32/
//      i64 from the array_new elem_size), and the inferred elem type is stored
//      on the node (slot c) so codegen lowers to array_length + array_get_*.
//      A bare i64 that is not a provable array handle is rejected (matches
//      sema_invalid_for_each_not_slice). A fixed array T[N] is rejected
//      (convert it to a slice with [..] first).
fn check_foreach(s: i64) -> i64 {
    let iter: i64 = nk_a(s);
    let it: i64 = check_expr(iter);
    if (s_err != 0) { return 0; }
    let mut elem_ty: i64 = -1;
    let mut is_array_handle: i64 = 0;
    if (ty_is_slice(it) == 1) {
        elem_ty = resolve_type(ty_elem(it));
        if (s_err != 0) { return 0; }
        if (elem_ty < 0) { elem_ty = TY_I64; }
    } else if (ty_is_i64(it) == 1) {
        // array<T> handle path: infer the element type from the handle's
        // creation (an inline array_new or a var tagged at its `let`).
        elem_ty = infer_iterable_array_elem_ty(iter);
        if (elem_ty < 0) {
            serr(string_from_slice("for-each iterable must be a slice or array handle (got ")
                 + ty_name(it) + string_from_slice("); if this is an array handle, declare it from array_new so its element type is known"),
                 node_line(iter), node_col(iter));
            elem_ty = TY_I64;
        } else {
            is_array_handle = 1;
            set_c(s, elem_ty);   // codegen reads slot c for the array branch
        }
    } else {
        serr(string_from_slice("for-each iterable must be a slice or array handle (got ") + ty_name(it) + string_from_slice(")"),
             node_line(iter), node_col(iter));
        elem_ty = TY_I64;
    }
    s_loop_depth = s_loop_depth + 1;
    push_scope();
    declare(nk_tok(s), elem_ty);
    check_block(nk_b(s));
    pop_scope();
    s_loop_depth = s_loop_depth - 1;
    return 0;
}

// Phase 3b: check a switch statement. Subject must be int/bool. Each case is
// either a default (at most one) or a constant value matching the subject
// type. Each nonempty case body must end with break/continue/return (ember
// does NOT support C-style fallthrough). break/continue are legal inside a
// case body (switch increments loop depth for the duration of its cases).
// Mirrors src/sema.cpp's SwitchStmt check.
fn check_switch(s: i64) -> i64 {
    let subj: i64 = nk_a(s);
    let subj_ty: i64 = check_expr(subj);
    if (s_err != 0) { return 0; }
    if (ty_is_int(subj_ty) == 0 && ty_is_bool(subj_ty) == 0) {
        serr(string_from_slice("switch subject must be an integer or bool (got ") + ty_name(subj_ty) + string_from_slice(")"),
             node_line(subj), node_col(subj));
        return 0;
    }
    let mut seen_default: i64 = 0;
    // a switch body allows break (exit the switch) but NOT continue (a
    // switch does not count as a loop for continue). Increment switch_depth
    // only, mirroring src/sema.cpp's ++switch_depth around the cases.
    s_switch_depth = s_switch_depth + 1;
    let mut c: i64 = nk_b(s);
    while (c >= 0) {
        if (nk_d(c) == 1) {
            if (seen_default == 1) {
                serr(string_from_slice("switch has more than one 'default' case"), node_line(c), node_col(c));
                s_switch_depth = s_switch_depth - 1;
                return 0;
            }
            seen_default = 1;
        } else {
            // case value must be a compile-time constant literal. (The C++
            // requires IntLit/BoolLit; enum variants are pre-lowered there.
            // Here an EnumAccess folds to a constant at codegen, but for the
            // type check we accept any int/bool constant expr that matches
            // the subject type — IntLit/BoolLit/EnumAccess/unary-neg literal.)
            let cval: i64 = nk_a(c);
            let vt: i64 = check_expr(cval);
            if (s_err != 0) { s_switch_depth = s_switch_depth - 1; return 0; }
            if (type_eq(subj_ty, vt) == 0 && !(ty_is_int(subj_ty) == 1 && ty_is_int(vt) == 1)) {
                serr(string_from_slice("case value type mismatch (switch on ") + ty_name(subj_ty) + string_from_slice(", case is ") + ty_name(vt) + string_from_slice(")"),
                     node_line(cval), node_col(cval));
                s_switch_depth = s_switch_depth - 1;
                return 0;
            }
        }
        // check the case body in its own scope. The parser stores a case body
        // as a bare linked list of stmts (nk_b(c) = first stmt), NOT a
        // BlockStmt, so iterate the list directly (mirrors src/sema.cpp's
        // check_block over c.body.stmts).
        push_scope();
        let mut bs: i64 = nk_b(c);
        while (bs >= 0) {
            check_stmt(bs);
            if (s_err != 0) { pop_scope(); s_switch_depth = s_switch_depth - 1; return 0; }
            bs = nk_next(bs);
        }
        pop_scope();
        if (s_err != 0) { s_switch_depth = s_switch_depth - 1; return 0; }
        // enforce no-implicit-fallthrough: a nonempty case body must end with
        // break/continue/return (mirrors src/sema.cpp's switch tail check).
        if (case_stmtlist_needs_terminator(nk_b(c)) == 1) {
            serr(string_from_slice("nonempty switch case must end with break, continue, or return; implicit fallthrough is not allowed"),
                 node_line(c), node_col(c));
            s_switch_depth = s_switch_depth - 1;
            return 0;
        }
        c = nk_next(c);
    }
    s_switch_depth = s_switch_depth - 1;
    return 0;
}

// Does a switch case body (a bare linked list of stmts, first = first_stmt)
// need a terminator but lack one? Returns 1 iff the list is nonempty AND its
// last statement is not a break/continue/return (the implicit-fallthrough
// violation). Mirrors src/sema.cpp's
// `!dynamic_cast<BreakStmt*>(last) && !ReturnStmt && !ContinueStmt` check.
fn case_stmtlist_needs_terminator(first_stmt: i64) -> i64 {
    if (first_stmt < 0) { return 0; }   // empty body -> no terminator required
    let mut last: i64 = first_stmt;
    let mut p: i64 = first_stmt;
    while (p >= 0) { last = p; p = nk_next(p); }
    let lk: i64 = nk_kind(last);
    if (lk == (NK::BreakStmt as i64)) { return 0; }
    if (lk == (NK::ContinueStmt as i64)) { return 0; }
    if (lk == (NK::ReturnStmt as i64)) { return 0; }
    return 1;
}

// Does a switch/match case body (a BlockStmt) need a terminator but lack one?
// Returns 1 iff the body is nonempty AND its last statement is not a
// break/continue/return (the implicit-fallthrough violation). A case body that
// is a bare stmt list (no enclosing block) is treated the same: the last stmt
// is the terminator candidate. Mirrors src/sema.cpp's
// `!dynamic_cast<BreakStmt*>(last) && !ReturnStmt && !ContinueStmt` check.
fn case_body_needs_terminator(body: i64) -> i64 {
    if (body < 0) { return 0; }
    // find the last stmt in the body's stmt list (nk_a = first stmt)
    let mut last: i64 = nk_a(body);
    if (last < 0) { return 0; }   // empty body -> no terminator required
    let mut p: i64 = last;
    while (p >= 0) { last = p; p = nk_next(p); }
    let lk: i64 = nk_kind(last);
    if (lk == (NK::BreakStmt as i64)) { return 0; }
    if (lk == (NK::ContinueStmt as i64)) { return 0; }
    if (lk == (NK::ReturnStmt as i64)) { return 0; }
    return 1;
}

// -----------------------------------------------------------------------------
// declaration checking + function-body checking.
// -----------------------------------------------------------------------------

// check a function body: push a scope, declare the params, set s_cur_ret to
// the resolved return type, check the body block, then restore s_cur_ret. The
// "all paths return" check is deferred (v1 keeps it simple; the canonical test
// has an explicit return).
fn check_func_body(fd: i64) -> i64 {
    let nm: string = nk_name(fd);
    push_scope();
    // declare params
    let mut p: i64 = nk_a(fd);
    while (p >= 0) {
        let pt: i64 = resolve_type(nk_a(p));
        if (s_err != 0) { pop_scope(); return 0; }
        if (ty_is_void(pt) == 1) {
            serr(string_from_slice("parameter '") + tok_name(nk_tok(p)) + string_from_slice("' cannot have void type"),
                 node_line(p), node_col(p));
            pop_scope();
            return 0;
        }
        declare(nk_tok(p), pt);
        p = nk_next(p);
    }
    let saved_ret: i64 = s_cur_ret;
    s_cur_ret = resolve_type(nk_b(fd));
    if (s_err != 0) { s_cur_ret = saved_ret; pop_scope(); return 0; }
    check_block(nk_c(fd));
    s_cur_ret = saved_ret;
    pop_scope();
    return 0;
}

// -----------------------------------------------------------------------------
// the top-level sema pass. Walks the program's top-level decls in TWO passes:
//   pass 1 — register every signature (structs, fns, globals) so a forward
//             reference from any fn body sees every other decl's signature.
//   pass 2 — check each fn body + each global's initializer type.
// Returns 0 on success, 1 if s_err was set.
// -----------------------------------------------------------------------------
fn check_program(prog: i64) -> i64 {
    if (prog < 0) { return serr(string_from_slice("no program to check"), 0, 0); }
    if (nk_kind(prog) != (NK::Program as i64)) {
        return serr(string_from_slice("expected a program node"), 0, 0);
    }

    // First collect nominal declarations so function signatures may refer to
    // structs/enums declared anywhere in the file. Descend into NamespaceDecl
    // members (the parser flattens a namespace into a member list linked via
    // nk_next from nk_a(ns), each member tagged with the ns name in slot e).
    let mut d: i64 = nk_a(prog);
    while (d >= 0) {
        if (nk_kind(d) == (NK::NamespaceDecl as i64)) {
            let mut m: i64 = nk_a(d);
            while (m >= 0) {
                if (nk_kind(m) == (NK::StructDecl as i64)) { register_struct(m); }
                else if (nk_kind(m) == (NK::EnumDecl as i64)) { register_enum(m); }
                if (s_err != 0) { return s_errcode; }
                m = nk_next(m);
            }
        } else if (nk_kind(d) == (NK::StructDecl as i64)) { register_struct(d); }
        else if (nk_kind(d) == (NK::EnumDecl as i64)) { register_enum(d); }
        if (s_err != 0) { return s_errcode; }
        d = nk_next(d);
    }

    // Then register callable/value declarations + record namespace names +
    // check top-level static_asserts. Namespaced members are registered with
    // their namespace name token so Ns::fn / Ns::global resolve.
    d = nk_a(prog);
    while (d >= 0) {
        let k: i64 = nk_kind(d);
        if (k == (NK::NamespaceDecl as i64)) {
            // record the namespace name, then register each member.
            array_push_i64(g_ns_names, nk_tok(d));
            let ns_tok: i64 = nk_tok(d);
            let mut m: i64 = nk_a(d);
            while (m >= 0) {
                let mk: i64 = nk_kind(m);
                if (mk == (NK::StructDecl as i64) || mk == (NK::EnumDecl as i64)) {
                    // already collected above
                } else if (mk == (NK::FnDecl as i64)) {
                    register_fn(m, ns_tok);
                } else if (mk == (NK::GlobalDecl as i64)) {
                    if (global_is_supported(m) == 1) {
                        register_global(m, ns_tok);
                    } else {
                        unsupported(-317, string_from_slice("global declaration"), m);
                    }
                } else if (mk == (NK::StaticAssertDecl as i64)) {
                    check_static_assert(m);
                } else {
                    unsupported(-316, string_from_slice("namespace member declaration"), m);
                }
                if (s_err != 0) { return s_errcode; }
                m = nk_next(m);
            }
        } else if (k == (NK::StructDecl as i64) || k == (NK::EnumDecl as i64)) {
            // already collected above
        } else if (k == (NK::FnDecl as i64)) {
            register_fn(d, -1);
        } else if (k == (NK::GlobalDecl as i64)) {
            // Phase 1 supports constant-initialized globals: an i64 global
            // with a compile-time constant initializer (written to the data
            // section at emit time) OR a string global with a StringLit
            // initializer (materialized at runtime by the module-init
            // function). Register those; any other global stays
            // out-of-subset (-317).
            if (global_is_supported(d) == 1) {
                register_global(d, -1);
            } else {
                unsupported(-317, string_from_slice("global declaration"), d);
            }
        } else if (k == (NK::StaticAssertDecl as i64)) {
            // top-level static_assert: same as the in-body check (evaluate the
            // const cond; false = error with the message, true = no-op). Mirrors
            // src/sema.cpp's prog.static_asserts pass calling check_static_assert.
            check_static_assert(d);
        } else {
            unsupported(-316, string_from_slice("top-level declaration"), d);
        }
        if (s_err != 0) { return s_errcode; }
        d = nk_next(d);
    }

    // pass 2: check bodies + global initializers. Namespaced fn bodies are
    // checked with s_cur_ns set to their namespace so bare intra-namespace
    // calls resolve (mirrors src/sema.cpp's current_ns = f.ns).
    d = nk_a(prog);
    while (d >= 0) {
        let k: i64 = nk_kind(d);
        if (k == (NK::NamespaceDecl as i64)) {
            let ns_tok: i64 = nk_tok(d);
            let mut m: i64 = nk_a(d);
            while (m >= 0) {
                let mk: i64 = nk_kind(m);
                if (mk == (NK::FnDecl as i64)) {
                    let saved_ns: i64 = s_cur_ns;
                    s_cur_ns = ns_tok;
                    check_func_body(m);
                    s_cur_ns = saved_ns;
                    if (s_err != 0) { return s_errcode; }
                } else if (mk == (NK::GlobalDecl as i64)) {
                    check_global_init(m);
                    if (s_err != 0) { return s_errcode; }
                }
                m = nk_next(m);
            }
        } else if (k == (NK::FnDecl as i64)) {
            let saved_ns: i64 = s_cur_ns;
            s_cur_ns = -1;
            check_func_body(d);
            s_cur_ns = saved_ns;
            if (s_err != 0) { return s_errcode; }
        } else if (k == (NK::GlobalDecl as i64)) {
            check_global_init(d);
            if (s_err != 0) { return s_errcode; }
        }
        d = nk_next(d);
    }
    if (s_err != 0) { return s_errcode; }
    return 0;
}

// check a global's initializer type against its declared type (shared by the
// top-level + namespace-member paths).
fn check_global_init(d: i64) -> i64 {
    let gty: i64 = resolve_type(nk_a(d));
    if (s_err != 0) { return s_errcode; }
    let init: i64 = nk_b(d);
    if (init >= 0) {
        let ity: i64 = check_expr(init);
        if (s_err != 0) { return s_errcode; }
        if (types_compatible(gty, ity) == 0) {
            serr(string_from_slice("global type mismatch (") + ty_name(gty) + string_from_slice(" = ")
                 + ty_name(ity) + string_from_slice(")"),
                 node_line(d), node_col(d));
            return s_errcode;
        }
    }
    return 0;
}

// -----------------------------------------------------------------------------
// the entry point. Parse `source` (via the parser), then type-check the AST.
// Returns 0 on success, 1 on an ordinary type error, 2 on parse failure, or
// a stable -3xx code when parsed syntax is outside the supported subset. The
// error position + message are available via sema_err_*.
// -----------------------------------------------------------------------------
fn sema(source: string) -> i64 {
    let prog: i64 = parse(source);
    if (parse_failed() != 0) {
        s_err = 1;
        s_errcode = 2;
        s_errline = parse_err_line();
        s_errcol = parse_err_col();
        s_errmsg = string_from_slice("parse error: ") + parse_err_msg();
        return 2;
    }
    s_init();
    let ar: i64 = reject_annotations();
    if (ar != 0) { return ar; }
    return check_program(prog);
}

// whether the sema flagged an error (set by serr() / a parse failure).
fn sema_failed() -> i64 { return s_err; }
fn sema_err_code() -> i64 { return s_errcode; }
fn sema_err_line() -> i64 { return s_errline; }
fn sema_err_col() -> i64 { return s_errcol; }
fn sema_err_msg() -> string { return s_errmsg; }

// -----------------------------------------------------------------------------
// helpers used in error messages. int_to_str renders a small i64 to a string
// (arg counts, etc.). ember has no native int->str in the v1 subset, so this
// is a tiny hand-rolled converter (handles 0 + non-negative values; negative
// values get a leading '-').
// -----------------------------------------------------------------------------
fn int_to_str(v: i64) -> string {
    if (v == 0) { return string_from_slice("0"); }
    let mut neg: i64 = 0;
    let mut n: i64 = v;
    if (n < 0) { neg = 1; n = -n; }
    // collect digits into a temporary (reverse order), then build the string
    let mut digits: i64 = 0;
    let mut buf: i64 = array_new(8, 20);
    let mut pos: i64 = 0;
    while (n > 0) {
        let d: i64 = n % 10;
        array_set_i64(buf, pos, d + 48);   // '0' = 48
        pos = pos + 1;
        n = n / 10;
    }
    // build the result: optional '-' + digits in reverse
    let rlen: i64 = pos + neg;
    let mut r: string = string_from_slice("");
    if (neg == 1) { r = string_from_slice("-"); }
    let mut j: i64 = pos - 1;
    while (j >= 0) {
        let ch: i64 = array_get_i64(buf, j);
        r = r + char_to_str(ch);
        j = j - 1;
    }
    return r;
}

// render a single ASCII byte (0..255) to a one-character string. ember has no
// direct int->char->string, so build via string_char_at on a base string of
// all printable ASCII. (Used only by int_to_str for digit chars 48..57.)
fn char_to_str(ch: i64) -> string {
    // a 0..9 digit -> ch is 48..57. Build the digit string by indexing a
    // constant "0123456789" with ch - 48.
    let digits: string = string_from_slice("0123456789");
    let idx: i64 = ch - 48;
    return string_substr(digits, idx, idx + 1);
}

// self_hosted/codegen.ember — the ember code generator, written IN ember.
//
// Self-hosting Stage 4 (the final stage): prove ember can generate its own
// machine code. This is a port of the CORE x64 emission logic of
// src/codegen.cpp (the C++ reference tree-walking code generator) + the
// byte-level emitter in src/x64_emitter.hpp to ember source. It consumes the
// type-checked AST built by Stage 2's parser (parse.ember) + checked by
// Stage 3's sema (sema.ember) and emits x86-64 machine code bytes into an
// array<u8>.
//
// === v1 subset ===
//
// Stage 4 v1 codegens a SUBSET of ember, matching the task scope:
//   - fn with i64 params + i64/void return
//   - let with i64 (auto or typed)
//   - if / while with bool conditions
//   - return with a value
//   - binary ops on i64: + - * & | ^ << >>
//   - comparison ops: == != < <= > >= -> bool (0/1 in rax)
//   - logical && || -> bool (short-circuit)
//   - unary: - (neg), ! (logical not), ~ (bitwise not)
//   - calls to i64->i64 fns (up to 4 args in Win64 registers rcx/rdx/r8/r9)
//   - int literals -> i64, bool literals -> bool
//   - identifiers: locals + params (loaded from [rbp+offset])
//
// The output is an array<u8> of x64 bytes. The codegen does NOT execute them
// (that requires JIT memory natives not yet exposed to ember scripts); it
// produces the bytes + the test verifies them.
//
// === x64 calling convention (Win64) ===
//
//   - Integer args: rcx, rdx, r8, r9 (first 4), then stack
//   - Return value: rax
//   - Callee-saved: rbx, rbp, rsi, rdi, r12-r15
//   - Shadow space: 32 bytes minimum per call
//   - Stack alignment: 16-byte before `call`
//
// === Frame layout ===
//
//   push rbp                  ; 0x55
//   mov rbp, rsp              ; 48 89 E5
//   sub rsp, frame_size       ; 48 81 EC <imm32>
//   ... params spilled to [rbp-8], [rbp-16], ...
//   ... locals at [rbp-(n*8)], growing downward ...
//   mov rsp, rbp              ; 48 89 EC
//   pop rbp                   ; 0x5D
//   ret                       ; 0xC3
//
// Each local + param gets an 8-byte slot (everything is i64 in v1). The frame
// size is pre-computed from a count of params + locals, rounded up to 16.
//
// === x64 emitter ===
//
// A port of X64Emitter (src/x64_emitter.hpp): a byte buffer (array<u8>) +
// methods that emit bytes. Register encoding numbers (0-15) + REX/ModRM
// helpers match the C++ reference. Labels are rel32 fixups backpatched by
// cg_resolve_fixups() after all labels are bound — identical to the C++.
//
// === Symbol tables ===
//
// ember has no map<string, T> builtin, so every table is a flat i64 array
// (the array extension, elem_size 8) with a fixed stride. Names are stored as
// TOKEN INDICES (into the lexer's token array) — the same trick parse.ember
// and sema.ember use — and compared on demand via tok_name. This is O(n) per
// lookup but n is small.
//
//   cg_locals : stride 2  [ name_tok, rbp_offset ]   (the current fn's locals)
//   cg_labels : stride 2  [ label_id, code_offset ]  (bound label positions)
//   cg_fixups : stride 2  [ code_offset, label_id ]  (pending rel32 patches)
//
// Error handling: a global cg_err flag + message, like sema's s_err.
// codegen(source) returns 0 on success or 1 on error.


// -----------------------------------------------------------------------------
// register encoding numbers (0-15), shared by GP registers. Matches x64_emitter.hpp's Reg enum.
// -----------------------------------------------------------------------------
global RAX : i64 = 0;
global RCX : i64 = 1;
global RDX : i64 = 2;
global RBX : i64 = 3;
global RSP : i64 = 4;
global RBP : i64 = 5;
global RSI : i64 = 6;
global RDI : i64 = 7;
global R8  : i64 = 8;
global R9  : i64 = 9;
global R10 : i64 = 10;
global R11 : i64 = 11;
global R12 : i64 = 12;
global R13 : i64 = 13;
global R14 : i64 = 14;
global R15 : i64 = 15;

global XMM0 : i64 = 0;
global XMM1 : i64 = 1;
global XMM2 : i64 = 2;
global XMM3 : i64 = 3;
global XMM4 : i64 = 4;   // scratch for stack-passed float args (not used yet, reserved)

// condition codes for jcc (low nibble of 0F 8x). Matches x64_emitter.hpp's Cond enum.
global COND_E  : i64 = 0x4;   // equal (ZF=1)
global COND_NE : i64 = 0x5;   // not equal (ZF=0)
global COND_L  : i64 = 0xC;   // less (signed)
global COND_GE : i64 = 0xD;   // greater or equal (signed)
global COND_LE : i64 = 0xE;   // less or equal (signed)
global COND_G  : i64 = 0xF;   // greater (signed)
global COND_B  : i64 = 0x2;   // below (unsigned, CF=1)
global COND_AE : i64 = 0x3;   // above or equal (unsigned, CF=0)
global COND_BE : i64 = 0x6;   // below or equal (unsigned)
global COND_A  : i64 = 0x7;   // above (unsigned)

// -----------------------------------------------------------------------------
// emitter state. Reset per codegen() call.
// -----------------------------------------------------------------------------
global cg_code     : i64 = 0;   // the output byte array (array<u8>, elem_size 1)
global cg_next_label : i64 = 0; // next label id
global cg_labels   : i64 = 0;   // bound labels: stride 2 [ label_id, code_offset ]
global cg_fixups   : i64 = 0;   // pending rel32 fixups: stride 2 [ code_offset, label_id ]

// -----------------------------------------------------------------------------
// EMBM v1 module image buffers (self_hosted/MODULE_IMAGE_FORMAT.md).
// Parallel to cg_code: rodata (read-only literals), data (mutable globals),
// syms (null-terminated native symbol names), relocs (32-byte records). The
// codegen accumulates these during emission; codegen_emit_image() stitches
// them into one array<u8> with an 80-byte header for load_executable_module.
// -----------------------------------------------------------------------------
global cg_rodata : i64 = 0;   // array<u8> — read-only literal bytes
global cg_data   : i64 = 0;   // array<u8> — mutable global initial bytes
global cg_syms   : i64 = 0;   // array<u8> — null-terminated symbol names (bytes)
global cg_relocs : i64 = 0;   // array<u8> — 32-byte relocation records (bytes)

// codegen global table: stride 2 [ name_tok, data_addend ]. Populated by
// cg_compile_globals() from the program's constant-initialized GlobalDecls;
// a global's data addend is its byte offset within cg_data (§5). Reads/writes
// go through a relocated ABS64_DATA pointer.
global cg_globals : i64 = 0;
global cg_globals_len : i64 = 0;

// string-globals table for the module-init function. Stride 3
// [ name_tok, data_addend, init_node ]. Populated by cg_compile_globals() for
// each `string`-typed global with a StringLit initializer; the data slot is
// zero-filled (the handle is materialized at runtime). cg_emit_globals_init()
// walks this table + emits, for each entry, the same literal materialization
// as cg_eval_string_lit (rodata + u8 slice + string_from_slice -> handle in
// rax) followed by a store of rax into the global's [data_base + addend] slot.
// The init function runs BEFORE main (full_pipeline's compile_and_run calls it
// via codegen_globals_init_offset()). i64 globals keep their compile-time
// constant in the data section (no runtime init needed).
global cg_str_globals : i64 = 0;
global cg_str_globals_len : i64 = 0;

// the entry label id of the synthetic __globals_init function (-1 when none
// was emitted, i.e. the program declares no string globals). Bound at the
// init function's prologue offset; codegen_globals_init_offset() returns that
// offset so the pipeline can call it before main.
global cg_globals_init_label : i64 = -1;

// relocation type constants (MODULE_IMAGE_FORMAT.md §7).
global CG_RELOC_RODATA : i64 = 1;   // ABS64_RODATA: addend = rodata byte offset
global CG_RELOC_DATA   : i64 = 2;   // ABS64_DATA:   addend = data byte offset
global CG_RELOC_NATIVE : i64 = 3;   // ABS64_NATIVE: sym_idx = symbol index, addend = fingerprint
global CG_RELOC_DISPATCH : i64 = 4; // DISPATCH_BASE: module function vector

// frame layout for the current function
global cg_locals     : i64 = 0;   // stride 3 [name_tok, rbp_offset, type_node]
global cg_local_len  : i64 = 0;   // logical length of cg_locals (for scope pop)
global cg_scope_marks: i64 = 0;   // scope push marks: stride 1 [ mark ]
global cg_scope_mark_len : i64 = 0;
global cg_next_off   : i64 = 0;   // next local offset (grows downward, negative)
global cg_frame_size : i64 = 0;   // the current fn's frame size

// function-entry labels for direct call_rel32 between fns in the same code
// buffer. Allocated up-front for every FnDecl (name_tok -> label_id); each
// fn's label is bound at its prologue offset, and a call to it is a rel32
// fixup patched after all fns are compiled. This replaces the v1 placeholder
// `mov rax, 0; call rax` (which branched to address 0 under make_executable)
// with a real in-buffer relative call, so multi-fn programs execute.
global cg_fn_labels : i64 = 0;   // array, stride 3 [ name_tok, label_id, ns_tok ]
global cg_current_lambda : i64 = -1;
global cg_lambda_env_off : i64 = 0;
global cg_cap_off : i64 = 0;
global cg_cap_type : i64 = 0;
global cg_cap_by_ref : i64 = 0;

// Reusable scratch array for ABI-fingerprint computation (cg_abi_fingerprint_codes).
// The `codes` locals previously allocated a fresh array_new(8,1|2) on EVERY
// native-call emission (string_from_slice / string_from_i64 / string_add /
// string_eq). The host array extension has no array_free, so each leaked a
// slot; over a large module these accumulate in the trace-callback scan and
// crash the host (bare RUNTIME TRAP / exit 70). This scratch is reused via
// array_clear: set entry 0 (and 1), compute the fingerprint synchronously
// (no recursive emission between set + read), done. Safe because the codes
// are consumed by cg_abi_fingerprint_codes before any nested expression is
// emitted.
global cg_fp_codes : i64 = 0;   // scratch for cg_abi_fingerprint_codes (size 2)

// Reusable scratch array for cg_abi_fingerprint (the type-node variant). The
// `param_types` / `len_pt` / `get_pt` locals previously allocated a fresh
// array_new(8,4) on every native-call / for-each emission. Like cg_fp_codes
// these are consumed synchronously by cg_abi_fingerprint before any nested
// expression is emitted, so a single reused slot is safe.
global cg_fp_types : i64 = 0;   // scratch for cg_abi_fingerprint (size 4)

// Reusable constant scratch holding the 4 Win64 argument registers
// {RCX, RDX, R8, R9} for cg_compile_func's param-spill loop. Previously a
// per-function array_new(8,4) leaked a slot on every function compiled; this
// slot is a pure constant, set + read with no recursive emission between, so a
// single reused slot is safe.
global cg_arg_regs : i64 = 0;   // scratch for Win64 arg registers (size 4)

// error state
global cg_err     : i64 = 0;
global cg_errmsg  : string = "";

// =============================================================================
// x64 emitter — byte-level emission (port of X64Emitter in x64_emitter.hpp).
// =============================================================================

// emit a single byte
fn cg_byte(b: i64) -> i64 {
    array_push_u8(cg_code, b);
    return 0;
}

// emit a little-endian imm32 (4 bytes)
fn cg_imm32(v: i64) -> i64 {
    // emit 4 bytes little-endian. use bitwise ops to extract each byte.
    // (ember i64 is 64-bit; we emit the low 32 bits.)
    cg_byte(v & 0xFF);
    cg_byte((v >> 8) & 0xFF);
    cg_byte((v >> 16) & 0xFF);
    cg_byte((v >> 24) & 0xFF);
    return 0;
}

// emit a little-endian imm64 (8 bytes)
fn cg_imm64(v: i64) -> i64 {
    cg_byte(v & 0xFF);
    cg_byte((v >> 8) & 0xFF);
    cg_byte((v >> 16) & 0xFF);
    cg_byte((v >> 24) & 0xFF);
    cg_byte((v >> 32) & 0xFF);
    cg_byte((v >> 40) & 0xFF);
    cg_byte((v >> 48) & 0xFF);
    cg_byte((v >> 56) & 0xFF);
    return 0;
}

// REX prefix: 0100 W R X B. W=1 for 64-bit operand size.
fn cg_rex(w: i64, r: i64, x: i64, b: i64) -> i64 {
    let mut v: i64 = 0x40;
    if (w != 0) { v = v | 8; }
    if (r != 0) { v = v | 4; }
    if (x != 0) { v = v | 2; }
    if (b != 0) { v = v | 1; }
    return v;
}

// is a register extended (encoding >= 8)?
fn cg_is_extended(r: i64) -> i64 {
    if (r >= 8) { return 1; }
    return 0;
}

// ModRM byte: mod(2) reg(3) rm(3).
fn cg_modrm(mod_: i64, reg: i64, rm: i64) -> i64 {
    return ((mod_ & 3) << 6) | ((reg & 7) << 3) | (rm & 7);
}

// --- instructions ---

// push r64 -> 50+rd (or 41 50+rd for r8-r15)
fn cg_push(r: i64) -> i64 {
    if (cg_is_extended(r) != 0) { cg_byte(0x41); }
    cg_byte(0x50 + (r & 7));
    return 0;
}

// pop r64 -> 58+rd (or 41 58+rd for r8-r15)
fn cg_pop(r: i64) -> i64 {
    if (cg_is_extended(r) != 0) { cg_byte(0x41); }
    cg_byte(0x58 + (r & 7));
    return 0;
}

// mov r64, r64 -> REX.W 89 /r (mod=11, reg=src, rm=dst)
fn cg_mov_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(dst)));
    cg_byte(0x89);
    cg_byte(cg_modrm(3, src, dst));
    return 0;
}

// mov r64, imm64 -> REX.W B8+rd io
fn cg_mov_reg_imm64(dst: i64, imm: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(dst)));
    cg_byte(0xB8 + (dst & 7));
    cg_imm64(imm);
    return 0;
}

// add r64, r64 -> REX.W 01 /r (mod=11, reg=src, rm=dst)
fn cg_add_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(dst)));
    cg_byte(0x01);
    cg_byte(cg_modrm(3, src, dst));
    return 0;
}

// sub r64, r64 -> REX.W 29 /r (mod=11, reg=src, rm=dst)
fn cg_sub_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(dst)));
    cg_byte(0x29);
    cg_byte(cg_modrm(3, src, dst));
    return 0;
}

// sub r64, imm32 -> REX.W 81 /5 id
fn cg_sub_reg_imm32(r: i64, imm: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0x81);
    cg_byte(cg_modrm(3, 5, r));
    cg_imm32(imm);
    return 0;
}

// add r64, imm32 -> REX.W 81 /0 id
fn cg_add_reg_imm32(r: i64, imm: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0x81);
    cg_byte(cg_modrm(3, 0, r));
    cg_imm32(imm);
    return 0;
}

// imul r64, r64 -> REX.W 0F AF /r (dst = dst * src)
fn cg_imul_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(dst), 0, cg_is_extended(src)));
    cg_byte(0x0F);
    cg_byte(0xAF);
    cg_byte(cg_modrm(3, dst, src));
    return 0;
}

// xor r64, r64 -> REX.W 31 /r (mod=11, reg=src, rm=dst)
fn cg_xor_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(dst)));
    cg_byte(0x31);
    cg_byte(cg_modrm(3, src, dst));
    return 0;
}

// and r64, r64 -> REX.W 21 /r
fn cg_and_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(dst)));
    cg_byte(0x21);
    cg_byte(cg_modrm(3, src, dst));
    return 0;
}

// or r64, r64 -> REX.W 09 /r
fn cg_or_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(dst)));
    cg_byte(0x09);
    cg_byte(cg_modrm(3, src, dst));
    return 0;
}

// not r64 -> REX.W F7 /2 (bitwise NOT, one's complement)
fn cg_not_reg(r: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0xF7);
    cg_byte(cg_modrm(3, 2, r));
    return 0;
}

// neg r64 -> REX.W F7 /3 (two's complement negate)
fn cg_neg_reg(r: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0xF7);
    cg_byte(cg_modrm(3, 3, r));
    return 0;
}

// shl r64, cl -> REX.W D3 /4 (shift left by cl)
fn cg_shl_reg_cl(r: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0xD3);
    cg_byte(cg_modrm(3, 4, r));
    return 0;
}

// shr r64, cl -> REX.W D3 /5 (logical shift right by cl)
fn cg_shr_reg_cl(r: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0xD3);
    cg_byte(cg_modrm(3, 5, r));
    return 0;
}

// sar r64, cl -> REX.W D3 /7 (arithmetic shift right by cl)
fn cg_sar_reg_cl(r: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0xD3);
    cg_byte(cg_modrm(3, 7, r));
    return 0;
}
fn cg_shift_right_imm8(r: i64, n: i64) -> i64 { cg_byte(cg_rex(1, 0, 0, cg_is_extended(r))); cg_byte(0xC1); cg_byte(cg_modrm(3, 5, r)); cg_byte(n); return 0; }
fn cg_shift_left_imm8(r: i64, n: i64) -> i64 { cg_byte(cg_rex(1, 0, 0, cg_is_extended(r))); cg_byte(0xC1); cg_byte(cg_modrm(3, 4, r)); cg_byte(n); return 0; }

// cmp r64, r64 -> REX.W 39 /r (mod=11, reg=rhs, rm=lhs)
fn cg_cmp_reg_reg(lhs: i64, rhs: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(rhs), 0, cg_is_extended(lhs)));
    cg_byte(0x39);
    cg_byte(cg_modrm(3, rhs, lhs));
    return 0;
}

// cmp r64, imm32 -> REX.W 81 /7 id
fn cg_cmp_reg_imm32(r: i64, imm: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0x81);
    cg_byte(cg_modrm(3, 7, r));
    cg_imm32(imm);
    return 0;
}

// test r64, r64 -> REX.W 85 /r (sets flags from AND, without storing)
fn cg_test_reg_reg(a: i64, b: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(b), 0, cg_is_extended(a)));
    cg_byte(0x85);
    cg_byte(cg_modrm(3, b, a));
    return 0;
}

// setcc al -> 0F 9x C0 (set al from condition cc)
fn cg_setcc_al(cc: i64) -> i64 {
    cg_byte(0x0F);
    cg_byte(0x90 | cc);
    cg_byte(0xC0);
    return 0;
}

// movzx rax, al -> 48 0F B6 C0 (zero-extend al into rax)
fn cg_movzx_rax_al() -> i64 {
    cg_byte(0x48); cg_byte(0x0F); cg_byte(0xB6); cg_byte(0xC0);
    return 0;
}

// Minimal scalar SSE2 emitter. Float expressions return in xmm0; xmm1 is the
// rhs scratch register. Locals use their native four/eight-byte representation.
fn cg_movq_xmm_rax(x: i64) -> i64 { cg_byte(0x66); cg_byte(0x48); cg_byte(0x0F); cg_byte(0x6E); cg_byte(0xC0 | ((x & 7) << 3)); return 0; }
fn cg_movd_xmm_eax(x: i64) -> i64 { cg_byte(0x66); cg_byte(0x0F); cg_byte(0x6E); cg_byte(0xC0 | ((x & 7) << 3)); return 0; }
fn cg_movq_rax_xmm(x: i64) -> i64 { cg_byte(0x66); cg_byte(0x48); cg_byte(0x0F); cg_byte(0x7E); cg_byte(0xC0 | ((x & 7) << 3)); return 0; }
fn cg_sse_rr(prefix: i64, op: i64, dst: i64, src: i64) -> i64 { cg_byte(prefix); cg_byte(0x0F); cg_byte(op); cg_byte(cg_modrm(3, dst, src)); return 0; }
fn cg_sse_mem(prefix: i64, op: i64, x: i64, disp: i64) -> i64 { cg_byte(prefix); cg_byte(0x0F); cg_byte(op); cg_byte(cg_modrm(2, x, RBP)); cg_imm32(disp); return 0; }
fn cg_load_float(x: i64, disp: i64, is64: i64) -> i64 { if (is64 == 1) { cg_sse_mem(0xF2, 0x10, x, disp); } else { cg_sse_mem(0xF3, 0x10, x, disp); } return 0; }
fn cg_store_float(disp: i64, x: i64, is64: i64) -> i64 { if (is64 == 1) { cg_sse_mem(0xF2, 0x11, x, disp); } else { cg_sse_mem(0xF3, 0x11, x, disp); } return 0; }
fn cg_float_op(op: i64, is64: i64) -> i64 { if (is64 == 1) { cg_sse_rr(0xF2, op, XMM0, XMM1); } else { cg_sse_rr(0xF3, op, XMM0, XMM1); } return 0; }
fn cg_float_cmp(is64: i64) -> i64 { if (is64 == 1) { cg_byte(0x66); } cg_byte(0x0F); cg_byte(0x2E); cg_byte(cg_modrm(3, XMM0, XMM1)); return 0; }
fn cg_i64_to_float(x: i64, r: i64, is64: i64) -> i64 { if (is64 == 1) { cg_byte(0xF2); } else { cg_byte(0xF3); } cg_byte(0x48); cg_byte(0x0F); cg_byte(0x2A); cg_byte(cg_modrm(3, x, r)); return 0; }

// emit an implicit float widening/narrowing so a value of width `from` is
// converted to width `to` in xmm0 before a store/return/arg-pass that expects
// `to`. f32->f64 (cvtss2sd) is the one implicit widening; f64->f32 (cvtsd2ss)
// is narrowing (only reached via an explicit `as` cast, which has its own
// path). Same-width or non-float -> no-op. Mirrors the native sema synthesizing
// a CastExpr for f32->f64 at the use site.
fn cg_convert_float(from: i64, to: i64) -> i64 {
    if (ty_is_float(from) == 0 || ty_is_float(to) == 0) { return 0; }
    if (nk_d(from) == nk_d(to)) { return 0; }   // same width
    if (nk_d(from) == (Prim::F32 as i64) && nk_d(to) == (Prim::F64 as i64)) {
        // cvtss2sd xmm0, xmm0 -> F3 0F 5A C0
        cg_byte(0xF3); cg_byte(0x0F); cg_byte(0x5A); cg_byte(0xC0);
        return 0;
    }
    return 0;
}

fn cg_float_is64_type(t: i64) -> i64 { if (t >= 0 && nk_d(t) == (Prim::F64 as i64)) { return 1; } return 0; }

// -----------------------------------------------------------------------------
// Phase 2: integer width support. Mirrors src/codegen.cpp's int_bits /
// value_bytes / normalize_rax / is_uint. All scalar locals remain 8-byte slots
// (local_width_bytes returns 8 for every scalar); the value is always stored
// as a full 64-bit sign/zero-extended quantity, and normalize_rax re-extends
// on load so a narrower-typed value reads back correctly.
// -----------------------------------------------------------------------------

// the byte size of a primitive type (mirrors src/types.cpp byte_size +
// src/codegen.cpp value_bytes for scalars). Used by sizeof + by width-aware
// load/store helpers.
// the byte size of a primitive SCALAR type (mirrors src/types.cpp byte_size +
// src/codegen.cpp value_bytes for scalars). Aggregates use cg_value_bytes.
fn cg_scalar_bytes(t: i64) -> i64 {
    if (t < 0) { return 8; }
    if (nk_kind(t) != (NK::Type as i64)) { return 8; }
    let p: i64 = nk_d(t);
    if (nk_tok(t) >= 0) { return 8; }   // named/handle type (opaque -> 8)
    if (p == (Prim::Bool as i64) || p == (Prim::I8 as i64) || p == (Prim::U8 as i64)) { return 1; }
    if (p == (Prim::I16 as i64) || p == (Prim::U16 as i64)) { return 2; }
    if (p == (Prim::I32 as i64) || p == (Prim::U32 as i64) || p == (Prim::F32 as i64)) { return 4; }
    return 8;   // i64/u64/f64/ptr + fallback
}

// Phase 3: the byte size of ANY type, mirroring src/codegen.cpp's value_bytes
// EXACTLY (the packed memory model). Aggregates recurse:
//   - slice T[]      -> 16 ({ptr,len})
//   - fixed array T[N]-> N * value_bytes(elem)
//   - struct          -> sum of field value_bytes (packed, declaration order)
//   - scalar/handle   -> cg_scalar_bytes
fn cg_value_bytes(t: i64) -> i64 {
    if (t < 0) { return 8; }
    if (nk_kind(t) != (NK::Type as i64)) { return 8; }
    if (nk_f(t) == 1 || nk_f(t) == 2) { return 16; }       // slice/closure: two words
    if (nk_e(t) > 0) {                                     // fixed array T[N]
        let elem: i64 = nk_a(t);
        if (elem < 0) { return 8; }
        return nk_e(t) * cg_value_bytes(elem);
    }
    if (nk_tok(t) >= 0) {                                  // named type
        let nm: string = tok_name(nk_tok(t));
        if (nm == string_from_slice("string")) { return 8; }   // opaque handle
        let row: i64 = find_struct(nm);
        if (row >= 0) { return cg_struct_value_bytes(row); }
        return 8;
    }
    return cg_scalar_bytes(t);
}

// Phase 3: the local frame byte width, mirroring src/codegen.cpp's
// local_width_bytes. Aggregates use their exact Ember extent; scalars use 8
// (a scalar slot is always one 8-byte word in this codegen).
fn cg_local_width_bytes(t: i64) -> i64 {
    if (t < 0) { return 8; }
    if (nk_kind(t) != (NK::Type as i64)) { return 8; }
    if (nk_f(t) == 1 || nk_f(t) == 2) { return 16; }       // slice/closure
    if (nk_e(t) > 0) { return cg_value_bytes(t); }         // fixed array inline
    if (nk_tok(t) >= 0) {
        let nm: string = tok_name(nk_tok(t));
        if (nm == string_from_slice("string")) { return 8; }
        let row: i64 = find_struct(nm);
        if (row >= 0) { return cg_value_bytes(t); }
        return 8;
    }
    return 8;   // scalar slots are 8 bytes
}

// number of 8-byte stack slots an aggregate local occupies (ceil(extent/8),
// min 1). Scalars are 1 slot. Mirrors src/codegen.cpp's words_for_type for
// structs (ceil(size/8)) and the inline-fixed-array frame sizing.
fn cg_local_slots(t: i64) -> i64 {
    let w: i64 = cg_local_width_bytes(t);
    let mut s: i64 = (w + 7) / 8;
    if (s < 1) { s = 1; }
    return s;
}

// Phase 3: struct layout (packed, declaration order, no padding). Mirrors
// src/sema.cpp build_struct_layouts + src/codegen.cpp value_bytes(struct).
// cg_struct_value_bytes(row) = sum of every field's value_bytes.
// cg_struct_field_offset(row, idx) = sum of value_bytes of preceding fields.
// cg_struct_local_slots(row) = ceil(value_bytes/8) stack slots (min 1).
fn cg_struct_value_bytes(row: i64) -> i64 {
    let mut total: i64 = 0;
    let mut f: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1);
    while (f >= 0) {
        total = total + cg_value_bytes(resolve_type(nk_a(f)));
        f = nk_next(f);
    }
    return total;
}

fn cg_struct_field_offset(row: i64, idx: i64) -> i64 {
    let mut off: i64 = 0;
    let mut f: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1);
    let mut i: i64 = 0;
    while (f >= 0) {
        if (i == idx) { return off; }
        off = off + cg_value_bytes(resolve_type(nk_a(f)));
        i = i + 1;
        f = nk_next(f);
    }
    return off;
}

fn cg_struct_local_slots(row: i64) -> i64 {
    let w: i64 = cg_struct_value_bytes(row);
    let mut s: i64 = (w + 7) / 8;
    if (s < 1) { s = 1; }
    return s;
}

// =============================================================================
// Phase 4: struct by-value call ABI (mirrors src/codegen.cpp's hidden-pointer
// sret return + ceil(size/8)-word arg passing). The self-hosted call ABI is
// self-consistent (caller + callee are both emitted by this codegen) and
// behaviorally matches the native compiler's results (parity is exit-code
// based, not byte-identical). The convention:
//
//   struct RETURN: a fn whose return type is a registered struct gets an
//     implicit word-0 param = the caller-allocated dest pointer (arrives in
//     rcx, the first Win64 int arg reg). The callee spills it to a dedicated
//     frame slot (cg_struct_ret_ptr_off), writes the struct through it at
//     every `return`, and loads it back into rax at the epilogue (the sret
//     ABI requires the dest ptr to be returned in rax). Real params start at
//     word 1.
//
//   struct ARG (script-to-script): a struct arg occupies ceil(size/8)
//     consecutive 8-byte words in the call's arg stash, copied directly from
//     the source (a bare local, a struct literal materialized into a temp, or
//     a struct-returning call materialized into a temp via the hidden ptr).
//     The callee spills those words into the param local's frame slot.
//
//   struct-returning CALL SITE: the caller allocates a dest (a local's frame
//     slot for a let-init / assignment, a temp for an arg, or the fn's own
//     incoming hidden ptr for a `return f(...)` forward), loads its address
//     into rax, then calls cg_eval_struct_returning_call which places the
//     dest at word 0 + the real args from word 1 and calls. The callee writes
//     the struct directly through the dest — no register result.
// =============================================================================

// is this type a REGISTERED struct (mirrors sema's ty_is_struct)?
fn cg_ty_is_struct(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    if (nk_tok(t) < 0) { return 0; }
    let nm: string = tok_name(nk_tok(t));
    if (nm == string_from_slice("string")) { return 0; }
    if (find_struct(nm) >= 0) { return 1; }
    return 0;
}

// number of 8-byte words a call operand/param occupies in ember's private
// ABI: 1 for a scalar/float/handle, 2 for a slice, ceil(size/8) for a
// registered struct (min 1). Mirrors src/codegen.cpp's words_for_type.
fn cg_words_for_type(t: i64) -> i64 {
    if (t < 0) { return 1; }
    if (nk_kind(t) != (NK::Type as i64)) { return 1; }
    if (nk_f(t) == 1 || nk_f(t) == 2) { return 2; }       // slice/closure {word,word}
    if (cg_ty_is_struct(t) == 1) {
        let w: i64 = cg_value_bytes(t);
        let mut s: i64 = (w + 7) / 8;
        if (s < 1) { s = 1; }
        return s;
    }
    return 1;
}

// the callee-side hidden return-pointer frame slot offset (0 = this fn does
// not return a struct by pointer). Set in cg_compile_func when the fn's
// resolved return type is a registered struct; read by the ReturnStmt path +
// the epilogue's rax reload.
global cg_struct_ret_ptr_off : i64 = 0;

// caller-side flag: set to 1 by a context that has loaded a struct-returning
// call's destination address into rax BEFORE calling cg_eval on the call
// (LetStmt init / ReturnStmt value / AssignExpr value / struct-arg stash).
// cg_eval_callexpr checks this to route a struct-returning call to
// cg_eval_struct_returning_call (which consumes rax as the hidden dest). It is
// saved/restored around the eval so a nested non-struct call does not inherit
// it, and cleared after the struct-returning call consumes it.
global cg_struct_ret_dest_ready : i64 = 0;

// hand out a fresh struct temp of `nbytes` from the per-function frame
// pool (shared with user locals via cg_next_off, so temps + locals never
// collide — each gets a distinct downward-growing offset). Returns the
// temp's lowest rbp offset. Mirrors src/codegen.cpp's alloc_struct_temp
// (alloc_local with a synthesized '$' name). The frame is pre-sized by
// cg_count_struct_temps_block to hold these temps.
fn cg_alloc_struct_temp(nbytes: i64) -> i64 {
    let mut slots: i64 = (nbytes + 7) / 8;
    if (slots < 1) { slots = 1; }
    return cg_alloc_local_t(-1, -1, slots);
}

// Copy exactly `nbytes` from [src_base+src_off] to [dst_base+dst_off] via rax,
// in 8/4/2/1-byte chunks (never a blind N-word copy). A struct's byte size is
// frequently NOT a multiple of 8 (e.g. i64+i32+i8 = 13 bytes); a naive
// word-granularity copy overruns past the struct's true extent and can
// corrupt an adjacent saved rbp. Mirrors src/codegen.cpp's copy_bytes.
fn cg_copy_bytes(dst_base: i64, dst_off: i64, src_base: i64, src_off: i64, nbytes: i64) -> i64 {
    let mut done: i64 = 0;
    while (done < nbytes) {
        let remaining: i64 = nbytes - done;
        let chunk: i64 = cg_chunk_for(remaining);
        cg_load_elem_to_rax(src_base, src_off + done, chunk, 0);
        cg_store_rax_elem(dst_base, dst_off + done, chunk);
        done = done + chunk;
    }
    return 0;
}

// Write rax's low `nbytes` to [base+off], chunked, shifting rax right after
// each chunk so the next unwritten bytes come down to the low end. Used when
// a struct word's value is already in rax (moved out of an arg register) and
// must be spilled to a partial last word. Mirrors src/codegen.cpp's
// store_rax_bytes. Clobbers rax.
fn cg_store_rax_bytes(base: i64, off: i64, nbytes: i64) -> i64 {
    let mut done: i64 = 0;
    while (done < nbytes) {
        let chunk: i64 = cg_chunk_for(nbytes - done);
        cg_store_rax_elem(base, off + done, chunk);
        done = done + chunk;
        if (done < nbytes) {
            // shr rax, chunk*8 : REX.W C1 /5 ib  (modrm = 11 101 000 = 0xE8)
            cg_byte(0x48); cg_byte(0xC1); cg_byte(0xE8); cg_byte(chunk * 8);
        }
    }
    return 0;
}

// the byte size of a primitive type (kept for the sizeof/offsetof helpers;
// delegates to the general cg_value_bytes so aggregates are sized correctly).
fn cg_type_size(t: i64) -> i64 { return cg_value_bytes(t); }

// the alignment of a type (same as size for this packed model).
fn cg_type_align(t: i64) -> i64 { return cg_value_bytes(t); }

// is this an UNSIGNED integer type (u8/u16/u32/u64)?
fn cg_type_is_uint(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    let p: i64 = nk_d(t);
    if (nk_tok(t) >= 0) { return 0; }
    if (p == (Prim::U8 as i64) || p == (Prim::U16 as i64) || p == (Prim::U32 as i64) || p == (Prim::U64 as i64)) { return 1; }
    return 0;
}

// is this a plain integer type (any width/signedness)?
fn cg_type_is_int(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    let p: i64 = nk_d(t);
    if (nk_tok(t) >= 0) { return 0; }
    if (p >= (Prim::I8 as i64) && p <= (Prim::U64 as i64)) { return 1; }
    return 0;
}

// the bit width of an integer type (8/16/32/64), mirroring src/sema.cpp's
// int_bits. Non-integer types return 64 (no normalization needed).
fn cg_int_bits(t: i64) -> i64 {
    if (t < 0) { return 64; }
    if (nk_kind(t) != (NK::Type as i64)) { return 64; }
    let p: i64 = nk_d(t);
    if (p == (Prim::I8  as i64) || p == (Prim::U8  as i64)) { return 8; }
    if (p == (Prim::I16 as i64) || p == (Prim::U16 as i64)) { return 16; }
    if (p == (Prim::I32 as i64) || p == (Prim::U32 as i64)) { return 32; }
    return 64;
}

// Normalize rax to the integer type `t`: sign/zero-extend the low N bits into
// the full 64-bit rax. Mirrors src/codegen.cpp's normalize_rax EXACTLY:
//   - 64-bit: no-op
//   - 32-bit unsigned: mov eax,eax (89 C0)        — zero-extends to rax
//   - 32-bit signed:   movsxd rax,eax (48 63 C0)  — sign-extends
//   - 8/16-bit: shl rax,64-bits; then sar (signed) or shr (unsigned) rax,64-bits
// Non-integer / 64-bit types are a no-op. Called after every arithmetic op
// and at every load/store boundary so a narrower-typed value stays canonical.
fn cg_normalize_rax(t: i64) -> i64 {
    if (cg_type_is_int(t) == 0) {
        // Phase 3b: a typed-enum value normalizes to its BACKING integer width
        // (mirror src/codegen.cpp's normalize_rax, where a typed-enum Type
        // has struct_name="" so is_int() is true and it normalizes to the
        // backing prim). The self-hosted cg_type_is_int excludes named types,
        // so handle typed enums explicitly here.
        if (is_typed_enum_type(t) == 0) { return 0; }
        let bits: i64 = typed_enum_width(t);
        if (bits == 64) { return 0; }
        let is_u: i64 = typed_enum_is_uint(t);
        if (bits == 32) {
            if (is_u == 1) { cg_byte(0x89); cg_byte(0xC0); }       // mov eax,eax
            else { cg_byte(0x48); cg_byte(0x63); cg_byte(0xC0); }  // movsxd rax,eax
            return 0;
        }
        cg_byte(0x48); cg_byte(0xC1); cg_byte(0xE0); cg_byte(64 - bits);
        if (is_u == 1) { cg_byte(0x48); cg_byte(0xC1); cg_byte(0xE8); cg_byte(64 - bits); }
        else { cg_byte(0x48); cg_byte(0xC1); cg_byte(0xF8); cg_byte(64 - bits); }
        return 0;
    }
    let bits: i64 = cg_int_bits(t);
    if (bits == 64) { return 0; }
    if (bits == 32) {
        if (cg_type_is_uint(t) == 1) { cg_byte(0x89); cg_byte(0xC0); }       // mov eax,eax
        else { cg_byte(0x48); cg_byte(0x63); cg_byte(0xC0); }                // movsxd rax,eax
        return 0;
    }
    // 8/16-bit: shl rax, (64-bits); then sar/shr rax, (64-bits).
    // shl rax, imm8 -> REX.W C1 /4 ib
    cg_byte(0x48); cg_byte(0xC1); cg_byte(0xE0); cg_byte(64 - bits);
    // sar rax, imm8 (signed) -> REX.W C1 /7 ib ;  shr rax, imm8 (unsigned) -> REX.W C1 /5 ib
    if (cg_type_is_uint(t) == 1) { cg_byte(0x48); cg_byte(0xC1); cg_byte(0xE8); cg_byte(64 - bits); }
    else { cg_byte(0x48); cg_byte(0xC1); cg_byte(0xF8); cg_byte(64 - bits); }
    return 0;
}

fn cg_expr_type(e: i64) -> i64 {
    if (e < 0) { return -1; }
    let k: i64 = nk_kind(e);
    if (k == (NK::FloatLit as i64)) {
        // an adapted f32 literal (sema's try_adapt_float_lit annotated slot c)
        let ann: i64 = nk_c(e);
        if (ann == TY_F32) { return TY_F32; }
        let raw: string = nk_name(e); let n: i64 = string_length(raw);
        if (n > 0 && (string_char_at(raw, n - 1) == 102 || string_char_at(raw, n - 1) == 70)) { return TY_F32; }
        return TY_F64;
    }
    if (k == (NK::StringLit as i64)) { return TY_STRING; }
    if (k == (NK::LambdaExpr as i64)) { return nk_f(e); }
    if (k == (NK::FnHandleExpr as i64)) { return TY_I64; }
    if (k == (NK::IntLit as i64)) { return TY_I64; }
    if (k == (NK::BoolLit as i64)) { return TY_BOOL; }
    // Phase 3b: an EnumAccess's type is the enum's type — TY_I64 for an
    // untyped enum variant, or the typed-enum type for `enum E : T`.
    if (k == (NK::EnumAccess as i64)) {
        let ename: string = tok_name(nk_a(e));
        // a namespace-global access (Foo::val) has the global's type.
        if (is_namespace_name(ename) == 1) {
            let g: i64 = cg_find_global_qualified(nk_name(e), ename);
            if (g >= 0) { return global_type(g); }
            return TY_I64;
        }
        if (is_typed_enum_name(ename) == 1) { return typed_enum_type(ename); }
        return TY_I64;
    }
    if (k == (NK::Ident as i64)) {
        let lt: i64 = cg_lookup_local_type(nk_tok(e));
        if (lt >= 0) { return lt; }
        // not a local: a global's type (sema registered it; Phase 1 globals are i64)
        let g: i64 = cg_find_global(nk_name(e));
        if (g >= 0) { return TY_I64; }
        return -1;
    }
    if (k == (NK::FieldExpr as i64)) {
        let bt: i64 = cg_expr_type(nk_a(e));
        let row: i64 = find_struct(ty_struct_name(bt));
        if (row >= 0) { return struct_field_type(row, nk_name(e)); }
    }
    if (k == (NK::IndexExpr as i64)) {
        // result type = the base's element type (a fixed array / slice elem)
        let bt: i64 = cg_expr_type(nk_a(e));
        if (bt >= 0) { let et: i64 = nk_a(bt); if (et >= 0) { return resolve_type(et); } }
        return -1;
    }
    if (k == (NK::ViewExpr as i64)) {
        // result type = a slice of the base's element type (sema built this)
        let bt: i64 = cg_expr_type(nk_a(e));
        if (bt >= 0) { let et: i64 = nk_a(bt); if (et >= 0) { return resolve_type(et); } }
        return -1;
    }
    if (k == (NK::UnaryExpr as i64)) {
        // Neg/BitNot preserve the operand's (integer) type; Not yields bool.
        // Mirrors sema's check_unaryexpr result. Used by cast dispatch so
        // `(-1) as u8` sees from=i64 (the operand's type).
        let op: i64 = nk_d(e);
        if (op == (UnOp::Not as i64)) { return TY_BOOL; }
        return cg_expr_type(nk_a(e));
    }
    if (k == (NK::BinExpr as i64)) {
        let op: i64 = nk_d(e);
        if (op >= (BinOp::Eq as i64)) { return TY_BOOL; }
        // literal adaptation: if lhs is an IntLit and rhs is a typed int, the
        // result is rhs's type (mirrors sema's check_binexpr adaptation).
        let lt2: i64 = cg_expr_type(nk_a(e));
        let rt2: i64 = cg_expr_type(nk_b(e));
        if (nk_kind(nk_a(e)) == (NK::IntLit as i64) && cg_type_is_int(rt2) == 1) { return rt2; }
        return lt2;
    }
    if (k == (NK::CallExpr as i64)) {
        // sema annotates a call's resolved return type in slot c (free for
        // CallExpr) for both script + native calls. Read it for downstream
        // type inference (e.g. `let s = string_substr(...)`).
        let rt: i64 = nk_c(e);
        if (rt >= 0) { return rt; }
        return -1;
    }
    // Phase 2: CastExpr result type = the cast's target type (nk_b).
    if (k == (NK::CastExpr as i64)) { return resolve_type(nk_b(e)); }
    // Phase 2: TernaryExpr result type = the then-branch's type.
    if (k == (NK::TernaryExpr as i64)) { return cg_expr_type(nk_b(e)); }
    // Phase 2: sizeof/offsetof return u64 (mirrors src/sema.cpp which interns
    // make_prim(Prim::U64)). The self-hosted codegen emits a compile-time
    // constant, so the type is TY_U64.
    if (k == (NK::SizeofExpr as i64)) { return TY_U64; }
    if (k == (NK::OffsetofExpr as i64)) { return TY_U64; }
    return -1;
}

// =============================================================================
// ABI type code + fingerprint (mirrors src/module_abi_fingerprint.hpp EXACTLY).
// The codegen computes a native call's fingerprint from the call's arg types +
// return type (annotated by sema) so the EMBM v1 loader's fingerprint check
// passes. Type -> 6-bit code table (module_abi_fingerprint.hpp):
//   0=void 1=i64 2=f64 3=f32 4=bool 5=slice 6=ptr/opaque(handle)
//   7=i32 8=u8 9=u16 10=u32 11=u64 12=i8 13=i16 14=aggregate
// A `string` is an opaque i64 handle (host bind_handle("string")) -> code 6.
// =============================================================================

// map a sema Type node to its 6-bit ABI code. Mirrors ember::type_code().
fn cg_type_code(t: i64) -> i64 {
    if (t < 0) { return 0; }   // void/missing -> 0
    if (ty_is_string(t) == 1) { return 6; }   // string handle -> opaque ptr
    if (ty_is_slice(t) == 1)  { return 5; }   // slice {ptr,len} (string/slice<u8>)
    if (ty_is_void(t) == 1)  { return 0; }
    if (ty_is_i64(t) == 1)   { return 1; }
    if (ty_is_bool(t) == 1)  { return 4; }
    if (ty_is_float(t) == 1) {
        if (cg_float_is64_type(t) == 1) { return 2; }   // f64
        return 3;                                        // f32
    }
    // other ints (i32/u8/...): read the prim directly
    if (nk_kind(t) == (NK::Type as i64) && nk_tok(t) < 0) {
        let p: i64 = nk_d(t);
        if (p == (Prim::I32 as i64)) { return 7; }
        if (p == (Prim::U8  as i64)) { return 8; }
        if (p == (Prim::U16 as i64)) { return 9; }
        if (p == (Prim::U32 as i64)) { return 10; }
        if (p == (Prim::U64 as i64)) { return 11; }
        if (p == (Prim::I8  as i64)) { return 12; }
        if (p == (Prim::I16 as i64)) { return 13; }
    }
    return 14;  // aggregate / fallback (named struct, fixed array)
}

// compute the u64 ABI fingerprint from a call's arg types + return type +
// permission. Layout (module_abi_fingerprint.hpp §8, LSB-first):
//   bits 0..3   param_count (saturated to 15)
//   bits 4..27  up to 4 param type codes, 6 bits each (param i at 4+6i)
//   bits 28..33 return type code (6 bits)
//   bits 34..37 permission (0=none, 1=FFI)
//   bits 38..63 reserved (zero)
// `arg_types` is an i64 array (elem 8) of sema Type node indices; `argc` is the
// count; `ret_type` is the return Type node; `perm` is the permission bits.
fn cg_abi_fingerprint(arg_types: i64, argc: i64, ret_type: i64, perm: i64) -> i64 {
    let mut pc: i64 = argc;
    if (pc > 15) { pc = 15; }
    let mut fp: i64 = pc & 0xF;
    let mut i: i64 = 0;
    while (i < pc && i < 4) {
        let tc: i64 = cg_type_code(array_get_i64(arg_types, i)) & 0x3F;
        fp = fp | (tc << (4 + 6 * i));
        i = i + 1;
    }
    let rc: i64 = cg_type_code(ret_type) & 0x3F;
    fp = fp | (rc << 28);
    fp = fp | ((perm & 0xF) << 34);
    return fp;
}

// Return the reusable ABI-fingerprint scratch array (cg_fp_codes), ensuring
// it is allocated with capacity 2 (enough for the 1- or 2-entry codes used by
// the internal string_* native emissions). Replaces a per-call array_new that
// leaked a slot on every native-call emission. Callers overwrite index 0 (and
// 1) then call cg_abi_fingerprint_codes with an explicit argc; stale entries
// beyond argc are never read, so no clear is needed between uses.
fn cg_fp_codes_get() -> i64 {
    if (cg_fp_codes == 0) {
        cg_fp_codes = array_new(8, 2);
    } else if (array_length(cg_fp_codes) < 2) {
        array_resize(cg_fp_codes, 2);
    }
    return cg_fp_codes;
}

// Return the reusable type-fingerprint scratch array (cg_fp_types), ensuring
// it is allocated with capacity 4 (enough for the 4-entry param-type arrays
// used by native-call + for-each fingerprinting). Callers overwrite entries
// 0..argc-1 then call cg_abi_fingerprint with an explicit argc; stale entries
// beyond argc are never read, so no clear is needed between uses.
fn cg_fp_types_get() -> i64 {
    if (cg_fp_types == 0) {
        cg_fp_types = array_new(8, 4);
    } else if (array_length(cg_fp_types) < 4) {
        array_resize(cg_fp_types, 4);
    }
    return cg_fp_types;
}

// Return the reusable Win64-arg-register scratch array (cg_arg_regs),
// ensuring it is allocated with capacity 4.
fn cg_arg_regs_get() -> i64 {
    if (cg_arg_regs == 0) {
        cg_arg_regs = array_new(8, 4);
    } else if (array_length(cg_arg_regs) < 4) {
        array_resize(cg_arg_regs, 4);
    }
    return cg_arg_regs;
}

// On-demand native-arg register class for cg_eval_callexpr. Returns 1 if the
// i-th param of native `name` is a float type (so the arg arrives in
// xmm0..xmm3), else 0. Replaces the pre-computed `arg_is_float` array that
// leaked a slot on every call expression (the array was read AFTER recursive
// arg evaluation, so it could not be a simple global). native_param_type is a
// pure table lookup (no codegen recursion), so recomputing on demand is safe.
fn cg_arg_is_float(name: string, i: i64) -> i64 {
    let pt: i64 = native_param_type(name, i);
    if (ty_is_float(pt) == 1) { return 1; }
    return 0;
}

// On-demand native-arg float width for cg_eval_callexpr. Returns 1 if the
// i-th param of native `name` is an f64 (vs f32). Replaces the pre-computed
// `arg_is_f64` array (same re-entrancy reasoning as cg_arg_is_float).
fn cg_arg_is_f64(name: string, i: i64) -> i64 {
    let pt: i64 = native_param_type(name, i);
    if (ty_is_float(pt) == 1) {
        if (cg_float_is64_type(pt) == 1) { return 1; }
    }
    return 0;
}

// the ABI fingerprint for a known native, computed from EXPLICIT type codes
// (used for internal codegen calls like string_from_slice where sema never
// type-checks the call, + for operator-overload natives like string_add whose
// registered params are plain I64, not the handle type sema would infer).
// param_codes is an i64 array of 6-bit codes; perm is the permission.
fn cg_abi_fingerprint_codes(param_codes: i64, argc: i64, ret_code: i64, perm: i64) -> i64 {
    let mut pc: i64 = argc;
    if (pc > 15) { pc = 15; }
    let mut fp: i64 = pc & 0xF;
    let mut i: i64 = 0;
    while (i < pc && i < 4) {
        let tc: i64 = array_get_i64(param_codes, i) & 0x3F;
        fp = fp | (tc << (4 + 6 * i));
        i = i + 1;
    }
    fp = fp | ((ret_code & 0x3F) << 28);
    fp = fp | ((perm & 0xF) << 34);
    return fp;
}

// Convert the decimal token text into mantissa and decimal scale, then emit
// an exact runtime conversion through CVTSI2SS/CVTSI2SD. This avoids needing
// an f64 bitcast primitive in the Ember implementation language.
fn cg_float_mantissa(e: i64) -> i64 {
    let raw: string = nk_name(e); let n: i64 = string_length(raw);
    let mut m: i64 = 0; let mut i: i64 = 0;
    while (i < n) { let ch: i64 = string_char_at(raw, i); if (ch >= 48 && ch <= 57) { m = m * 10 + ch - 48; } if (ch == 101 || ch == 69) { break; } i = i + 1; }
    return m;
}
fn cg_float_scale(e: i64) -> i64 {
    let raw: string = nk_name(e); let n: i64 = string_length(raw);
    let mut frac: i64 = 0; let mut dot: i64 = 0; let mut exp: i64 = 0; let mut esign: i64 = 1; let mut in_exp: i64 = 0; let mut i: i64 = 0;
    while (i < n) { let ch: i64 = string_char_at(raw, i); if (ch == 46) { dot = 1; } else if (ch == 101 || ch == 69) { in_exp = 1; if (i + 1 < n && string_char_at(raw, i + 1) == 45) { esign = -1; i = i + 1; } else if (i + 1 < n && string_char_at(raw, i + 1) == 43) { i = i + 1; } } else if (ch >= 48 && ch <= 57) { if (in_exp == 1) { exp = exp * 10 + ch - 48; } else if (dot == 1) { frac = frac + 1; } } i = i + 1; }
    return frac - esign * exp;
}
fn cg_pow10_i64(n: i64) -> i64 { let mut p: i64 = 1; let mut i: i64 = 0; while (i < n) { p = p * 10; i = i + 1; } return p; }
fn cg_eval_float_lit(e: i64) -> i64 {
    let is64: i64 = cg_float_is64_type(cg_expr_type(e));
    cg_mov_reg_imm64(RAX, cg_float_mantissa(e)); cg_i64_to_float(XMM0, RAX, is64);
    let scale: i64 = cg_float_scale(e);
    if (scale > 0) { cg_mov_reg_imm64(RAX, cg_pow10_i64(scale)); cg_i64_to_float(XMM1, RAX, is64); cg_float_op(0x5E, is64); }
    else if (scale < 0) { cg_mov_reg_imm64(RAX, cg_pow10_i64(0 - scale)); cg_i64_to_float(XMM1, RAX, is64); cg_float_op(0x59, is64); }
    return 0;
}

// mov r64, [r64 + disp32] (load from memory) -> REX.W 8B /r mod=10
fn cg_load_reg_mem(dst: i64, base: i64, disp: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(dst), 0, cg_is_extended(base)));
    cg_byte(0x8B);
    // rsp/r12 (rm=4) need a SIB byte; rbp (rm=5) uses mod=10 (disp32) which
    // is already what we emit, so no special case for rbp here.
    if ((base & 7) == 4) {
        cg_byte(cg_modrm(2, dst, 4));
        cg_byte(0x24);  // SIB: scale=0, index=none(4), base=rsp(4)
    } else {
        cg_byte(cg_modrm(2, dst, base));
    }
    cg_imm32(disp);
    return 0;
}

// mov [r64 + disp32], r64 (store to memory) -> REX.W 89 /r mod=10
fn cg_store_reg_mem(base: i64, disp: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(base)));
    cg_byte(0x89);
    if ((base & 7) == 4) {
        cg_byte(cg_modrm(2, src, 4));
        cg_byte(0x24);
    } else {
        cg_byte(cg_modrm(2, src, base));
    }
    cg_imm32(disp);
    return 0;
}

// load rax's low `width` bytes from [base+disp] with sign/zero extension.
// Mirrors src/x64_emitter.hpp load_elem_to_rax EXACTLY:
//   1 byte: REX.W 0F B6/B7/B7/B7 + modrm(rax,base) + disp32 (zero/sign)
//   2 bytes: REX.W 0F B7/BF + modrm + disp32
//   4 bytes: movsxd rax,[mem] (signed) or mov r32 (unsigned, zero-extends)
//   8 bytes: mov rax,[mem]
// For base rsp/r12 (rm=4) emit a SIB byte (scale=0, index=none, base=base).
fn cg_load_elem_to_rax(base: i64, disp: i64, width: i64, sign_extend: i64) -> i64 {
    if (width >= 8) { cg_load_reg_mem(RAX, base, disp); return 0; }
    if (width == 4) {
        if (sign_extend != 0) {
            cg_byte(cg_rex(1, 0, 0, cg_is_extended(base)));
            cg_byte(0x63);   // movsxd rax, [mem]
        } else {
            if (cg_is_extended(base) != 0) { cg_byte(cg_rex(0, 0, 0, 1)); }
            cg_byte(0x8B);   // mov r32 (zero-extends to rax)
        }
    } else if (width == 2) {
        cg_byte(cg_rex(1, 0, 0, cg_is_extended(base)));
        cg_byte(0x0F); cg_byte(sign_extend != 0 ? 0xBF : 0xB7);
    } else {  // width == 1
        cg_byte(cg_rex(1, 0, 0, cg_is_extended(base)));
        cg_byte(0x0F); cg_byte(sign_extend != 0 ? 0xBE : 0xB6);
    }
    if ((base & 7) == 4) {
        cg_byte(cg_modrm(2, RAX, 4));
        cg_byte(0x24);
    } else {
        cg_byte(cg_modrm(2, RAX, base));
    }
    cg_imm32(disp);
    return 0;
}

// store rax's low `width` bytes to [base+disp]. Mirrors src/x64_emitter.hpp
// store_rax_elem EXACTLY: 1/2/4-byte partial stores (66 prefix for 2 bytes);
// 8 bytes -> full mov [mem], rax.
fn cg_store_rax_elem(base: i64, disp: i64, width: i64) -> i64 {
    if (width >= 8) { cg_store_reg_mem(base, disp, RAX); return 0; }
    if (width == 2) { cg_byte(0x66); }
    if (width <= 4) {
        if (cg_is_extended(base) != 0) { cg_byte(cg_rex(0, 0, 0, 1)); }
        cg_byte(0x88 + (width == 1 ? 0 : 1));   // 88 (1 byte) / 89 (2 or 4 bytes)
    }
    if ((base & 7) == 4) {
        cg_byte(cg_modrm(2, RAX, 4));
        cg_byte(0x24);
    } else {
        cg_byte(cg_modrm(2, RAX, base));
    }
    cg_imm32(disp);
    return 0;
}

// zero-fill `nbytes` bytes starting at [rbp + off] (an aggregate local with no
// initializer), in 8/4/2/1-byte chunks. Mirrors src/codegen.cpp's LetStmt
// no-init zero-fill loop. rax is clobbered (set to 0).
fn cg_zero_fill(off: i64, nbytes: i64) -> i64 {
    let mut remaining: i64 = nbytes;
    let mut cur: i64 = off;
    cg_mov_reg_imm64(RAX, 0);
    while (remaining > 0) {
        let chunk: i64 = cg_chunk_for(remaining);
        cg_store_rax_elem(RBP, cur, chunk);
        cur = cur + chunk;
        remaining = remaining - chunk;
    }
    return 0;
}

// largest power-of-2 chunk <= n up to 8 (for copy/zero chunking).
fn cg_chunk_for(n: i64) -> i64 {
    if (n >= 8) { return 8; }
    if (n >= 4) { return 4; }
    if (n >= 2) { return 2; }
    return 1;
}

// lea r64, [rbp + disp32] -> REX.W 8D /r mod=10. Used for fixed-array / view
// base addresses (the local's frame slot address).
fn cg_lea_r_rbp(dst: i64, disp: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(dst), 0, 0));
    cg_byte(0x8D);
    cg_byte(cg_modrm(2, dst, RBP));
    cg_imm32(disp);
    return 0;
}
fn cg_lea_rax_rbp(disp: i64) -> i64 { return cg_lea_r_rbp(RAX, disp); }
fn cg_lea_r11_rbp(disp: i64) -> i64 { return cg_lea_r_rbp(R11, disp); }
fn cg_lea_scaled8(dst: i64, base: i64, index: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(dst), cg_is_extended(index), cg_is_extended(base)));
    cg_byte(0x8D); cg_byte(cg_modrm(0, dst, 4));
    cg_byte((3 << 6) | ((index & 7) << 3) | (base & 7));
    return 0;
}

// SSE load/store from/to [base + disp32] with an ARBITRARY base register
// (generalizes cg_sse_mem which is rbp-only). prefix=F2(sd)/F3(ss), op=10(load)
// /11(store). REX (if any) is emitted BEFORE the 0F escape, in the right place.
// Used for float array elements addressed through r11.
fn cg_sse_mem_reg(prefix: i64, op: i64, x: i64, base: i64, disp: i64) -> i64 {
    cg_byte(prefix);
    if (cg_is_extended(x) != 0 || cg_is_extended(base) != 0) {
        cg_byte(cg_rex(0, cg_is_extended(x), 0, cg_is_extended(base)));
    }
    cg_byte(0x0F); cg_byte(op);
    if ((base & 7) == 4) {
        cg_byte(cg_modrm(2, x, 4));
        cg_byte(0x24);
    } else {
        cg_byte(cg_modrm(2, x, base));
    }
    cg_imm32(disp);
    return 0;
}

fn cg_load_float_reg(x: i64, base: i64, disp: i64, is64: i64) -> i64 {
    let mut pf: i64 = 0xF3;
    if (is64 == 1) { pf = 0xF2; }
    return cg_sse_mem_reg(pf, 0x10, x, base, disp);
}
fn cg_store_float_reg(base: i64, disp: i64, x: i64, is64: i64) -> i64 {
    let mut pf: i64 = 0xF3;
    if (is64 == 1) { pf = 0xF2; }
    return cg_sse_mem_reg(pf, 0x11, x, base, disp);
}
// load an f32/f64 element from [r11 + 0] into xmm0 (for IndexExpr float path).
fn cg_load_float_disp_r11(is64: i64) -> i64 { return cg_load_float_reg(XMM0, R11, 0, is64); }

// Runtime bounds check: index in rax, len in r9 (a slice). Unsigned compare —
// jb to an in-bounds label, else ud2 (trap). A negative index reinterpreted as
// unsigned is enormous, so one unsigned compare catches both too-large and
// negative. Mirrors src/codegen.cpp's emit_bounds_check_reg.
fn cg_bounds_check_reg_rax_r9() -> i64 {
    cg_mov_reg_reg(RCX, RAX);               // stash index in rcx
    cg_cmp_reg_reg(RCX, R9);
    let ok: i64 = cg_alloc_label();
    cg_jcc(COND_B, ok);                     // idx < len (unsigned) -> ok
    cg_byte(0x0F); cg_byte(0x0B);           // ud2 (raises #UD)
    cg_bind(ok);
    return 0;
}

// Runtime bounds check: index in rax, len = imm (a fixed array's N, non-const
// index). cmp rax, imm32; jb to ok; else ud2.
fn cg_bounds_check_imm_rax(len: i64) -> i64 {
    cg_mov_reg_reg(RCX, RAX);               // stash index in rcx
    cg_cmp_reg_imm32(RCX, len);
    let ok: i64 = cg_alloc_label();
    cg_jcc(COND_B, ok);
    cg_byte(0x0F); cg_byte(0x0B);           // ud2
    cg_bind(ok);
    return 0;
}

// call r64 (indirect) -> FF /2 with mod=11
fn cg_call_reg(r: i64) -> i64 {
    if (cg_is_extended(r) != 0) { cg_byte(cg_rex(0, 0, 0, 1)); }
    cg_byte(0xFF);
    cg_byte(cg_modrm(3, 2, r));
    return 0;
}

// lea dst, [rip + rel32] — rip-relative address of a label (for catch-entry rip).
// REX.W 8D /r mod=00 rm=5 (rip) + rel32 (fixup, backpatched by cg_resolve_fixups).
fn cg_lea_reg_rip(dst: i64, label_id: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(dst), 0, 0));
    cg_byte(0x8D);
    cg_byte(cg_modrm(0, dst, 5));  // mod=00, rm=5 = RIP-relative
    cg_add_fixup(label_id);
    cg_imm32(0);  // placeholder rel32, backpatched by cg_resolve_fixups
    return 0;
}

// jmp r64 — indirect jump to register (FF /4). Used by throw's longjmp to
// jump to the catch-entry rip loaded from catch_bufs.
fn cg_jmp_reg(r: i64) -> i64 {
    if (cg_is_extended(r) != 0) { cg_byte(cg_rex(0, 0, 0, 1)); }
    cg_byte(0xFF);
    cg_byte(cg_modrm(3, 4, r));  // /4 = jmp
    return 0;
}

// call rel32 (direct, in-buffer) -> E8 rel32. The rel32 is a placeholder
// recorded as a fixup for `label_id`; cg_resolve_fixups patches it after all
// labels (including other fns' entry labels) are bound. Used for script-to-
// script calls so a multi-fn program's calls resolve to the callee's real
// entry offset within the same executable page (make_executable copies bytes
// verbatim, so a relative call within the buffer works without host patching).
fn cg_call_rel32(label_id: i64) -> i64 {
    cg_byte(0xE8);
    cg_add_fixup(label_id);
    cg_imm32(0);  // placeholder rel32
    return 0;
}

// ret -> C3
fn cg_ret() -> i64 {
    cg_byte(0xC3);
    return 0;
}

// nop -> 90
fn cg_nop() -> i64 {
    cg_byte(0x90);
    return 0;
}

// =============================================================================
// labels + fixups (port of X64Emitter's label/patch system).
// =============================================================================

// allocate a new label id
fn cg_alloc_label() -> i64 {
    let id: i64 = cg_next_label;
    cg_next_label = cg_next_label + 1;
    return id;
}

// bind a label to the current code offset
fn cg_bind(label_id: i64) -> i64 {
    let off: i64 = array_length(cg_code);  // current byte count = next offset
    array_push_i64(cg_labels, label_id);
    array_push_i64(cg_labels, off);
    return 0;
}

// look up a bound label's code offset. returns -1 if not found.
fn cg_label_offset(label_id: i64) -> i64 {
    let n: i64 = array_length(cg_labels) / 2;
    let mut i: i64 = 0;
    while (i < n) {
        let id: i64 = array_get_i64(cg_labels, i * 2);
        if (id == label_id) { return array_get_i64(cg_labels, i * 2 + 1); }
        i = i + 1;
    }
    return -1;
}

// record a pending rel32 fixup at the current code offset for a label
fn cg_add_fixup(label_id: i64) -> i64 {
    let off: i64 = array_length(cg_code);
    array_push_i64(cg_fixups, off);
    array_push_i64(cg_fixups, label_id);
    return 0;
}

// jmp label -> E9 rel32 (placeholder, backpatched)
fn cg_jmp(label_id: i64) -> i64 {
    cg_byte(0xE9);
    cg_add_fixup(label_id);
    cg_imm32(0);  // placeholder
    return 0;
}

// jcc label -> 0F 8x rel32 (placeholder, backpatched)
fn cg_jcc(cc: i64, label_id: i64) -> i64 {
    cg_byte(0x0F);
    cg_byte(0x80 | cc);
    cg_add_fixup(label_id);
    cg_imm32(0);  // placeholder
    return 0;
}

// resolve all pending rel32 fixups. Must be called after all labels are bound.
// Each fixup's rel32 = target_offset - (fixup_offset + 4).
fn cg_resolve_fixups() -> i64 {
    let n: i64 = array_length(cg_fixups) / 2;
    let mut i: i64 = 0;
    while (i < n) {
        let fix_off: i64 = array_get_i64(cg_fixups, i * 2);
        let label_id: i64 = array_get_i64(cg_fixups, i * 2 + 1);
        let target: i64 = cg_label_offset(label_id);
        if (target < 0) {
            if (cg_err == 0) {
                cg_err = 1;
                cg_errmsg = string_from_slice("codegen: unbound label in fixup");
            }
            i = i + 1;
            continue;
        }
        // rel32 = target - (fix_off + 4)  (the rel32 is relative to the end of the instruction)
        let rel: i64 = target - (fix_off + 4);
        // patch the 4 bytes at fix_off (little-endian)
        array_set_u8(cg_code, fix_off + 0, rel & 0xFF);
        array_set_u8(cg_code, fix_off + 1, (rel >> 8) & 0xFF);
        array_set_u8(cg_code, fix_off + 2, (rel >> 16) & 0xFF);
        array_set_u8(cg_code, fix_off + 3, (rel >> 24) & 0xFF);
        i = i + 1;
    }
    return 0;
}

// =============================================================================
// local variable frame layout.
// =============================================================================

// reset the local table for a new function
fn cg_locals_init() -> i64 {
    // Reuse cg_locals / cg_scope_marks across function compilations instead
    // of allocating fresh arrays each time. This is a HOT PATH: cg_locals_init
    // runs once PER FUNCTION, so compiling a module with N functions leaked
    // 2*N arrays (no array_free in the host extension; slots are never
    // reclaimed). array_clear() resets the logical length to 0 while keeping
    // the backing buffer, so the slot is reused and the store stops growing.
    // The first call (handle == 0) still allocates.
    if (cg_locals != 0) { array_clear(cg_locals); } else { cg_locals = array_new(8, 0); }
    cg_local_len = 0;
    if (cg_scope_marks != 0) { array_clear(cg_scope_marks); } else { cg_scope_marks = array_new(8, 0); }
    cg_scope_mark_len = 0;
    cg_next_off = 0;
    return 0;
}

// push a scope (record the current logical length so pop can truncate)
fn cg_push_scope() -> i64 {
    if (array_length(cg_scope_marks) < cg_scope_mark_len + 1) {
        array_resize(cg_scope_marks, cg_scope_mark_len + 1);
    }
    array_set_i64(cg_scope_marks, cg_scope_mark_len, cg_local_len);
    cg_scope_mark_len = cg_scope_mark_len + 1;
    return 0;
}

// pop a scope (truncate the local table back to the mark)
fn cg_pop_scope() -> i64 {
    if (cg_scope_mark_len == 0) { return 0; }
    cg_scope_mark_len = cg_scope_mark_len - 1;
    let mark: i64 = array_get_i64(cg_scope_marks, cg_scope_mark_len);
    cg_local_len = mark;
    return 0;
}

// Allocate a scalar or aggregate local. `slots` is the number of eight-byte
// words reserved. Returns the rbp offset of the local's LOWEST address (the
// base); aggregate fields/elements live at base + their byte offset (packed,
// ascending), a scalar's value is at base + 0. The region spans
// [base, base + slots*8). Mirrors the C++ codegen's rbp-relative frame slots
// but keeps the base at the lowest address so packed layout addressing is a
// simple base + offset.
fn cg_alloc_local_t(name_tok: i64, type_node: i64, slots: i64) -> i64 {
    let mut nslots: i64 = slots;
    if (nslots < 1) { nslots = 1; }
    cg_next_off = cg_next_off + nslots * 8;
    let off: i64 = -cg_next_off;   // lowest address of the reserved region
    if (array_length(cg_locals) < cg_local_len + 3) { array_resize(cg_locals, cg_local_len + 3); }
    array_set_i64(cg_locals, cg_local_len, name_tok);
    array_set_i64(cg_locals, cg_local_len + 1, off);
    array_set_i64(cg_locals, cg_local_len + 2, type_node);
    cg_local_len = cg_local_len + 3;
    return off;
}

fn cg_alloc_local(name_tok: i64) -> i64 { return cg_alloc_local_t(name_tok, -1, 1); }

// look up a local by name. returns the rbp offset, or 0 if not found.
fn cg_lookup_local(name_tok: i64) -> i64 {
    let nm: string = tok_name(name_tok);
    let n: i64 = cg_local_len / 3;
    let mut i: i64 = n - 1;  // scan from end (innermost scope wins)
    while (i >= 0) {
        let tok: i64 = array_get_i64(cg_locals, i * 3);
        // compare by NAME, not token index: the same variable name at
        // different source positions has different token indices (the let's
        // 'x' and the return's 'x' are distinct tokens). Matches sema's
        // lookup_local, which compares tok_name(...) == name.
        if (tok_name(tok) == nm) { return array_get_i64(cg_locals, i * 3 + 1); }
        i = i - 1;
    }
    return 0;  // 0 = not found (all real offsets are negative)
}

fn cg_lookup_local_type(name_tok: i64) -> i64 {
    let nm: string = tok_name(name_tok);
    let mut i: i64 = cg_local_len / 3 - 1;
    while (i >= 0) {
        if (tok_name(array_get_i64(cg_locals, i * 3)) == nm) { return array_get_i64(cg_locals, i * 3 + 2); }
        i = i - 1;
    }
    return -1;
}

// look up a function's entry label by name. Returns the label id, or -1 if
// the name is not in cg_fn_labels (i.e. the fn was not declared in the
// program). Names are stored as token indices and compared by text via
// tok_name (same trick as cg_lookup_local + sema's tables). This bare lookup
// matches a TOP-LEVEL fn (ns_tok < 0); namespaced fns are found via
// cg_lookup_fn_label_qualified (Ns::fn).
fn cg_lookup_fn_label(name: string) -> i64 {
    let n: i64 = array_length(cg_fn_labels) / 3;
    let mut i: i64 = 0;
    while (i < n) {
        let tok: i64 = array_get_i64(cg_fn_labels, i * 3);
        if (tok_name(tok) == name) {
            if (array_get_i64(cg_fn_labels, i * 3 + 2) < 0) { return array_get_i64(cg_fn_labels, i * 3 + 1); }
        }
        i = i + 1;
    }
    return -1;
}

// look up a function's entry label by qualified name (Ns::fn). ns_name ""
// matches a top-level fn; a nonempty ns_name matches a fn whose ns_tok names
// ns_name. Returns the label id, or -1.
fn cg_lookup_fn_label_qualified(name: string, ns_name: string) -> i64 {
    let n: i64 = array_length(cg_fn_labels) / 3;
    let mut i: i64 = 0;
    while (i < n) {
        let tok: i64 = array_get_i64(cg_fn_labels, i * 3);
        if (tok_name(tok) == name) {
            let ns_tok: i64 = array_get_i64(cg_fn_labels, i * 3 + 2);
            let mut ok: i64 = 0;
            if (ns_tok < 0) {
                if (string_length(ns_name) == 0) { ok = 1; }
            } else {
                if (tok_name(ns_tok) == ns_name) { ok = 1; }
            }
            if (ok == 1) { return array_get_i64(cg_fn_labels, i * 3 + 1); }
        }
        i = i + 1;
    }
    return -1;
}

// =============================================================================
// codegen state init.
// =============================================================================

fn cg_init() -> i64 {
    // Reuse the emitter arrays across cg_init() calls instead of allocating
    // fresh ones each time. The host array extension has no array_free (slots
    // in the process-wide store are never reclaimed until reset()), so a
    // fresh array_new on every codegen() leaks the previous buffer — and the
    // leaked buffers accumulate in the trace-callback scan, eventually
    // crashing the host at scale (a bare RUNTIME TRAP / exit 70).
    // array_clear() resets the logical length to 0 while keeping the backing
    // buffer, so the slot is reused and the store stops growing. The first
    // call (handle == 0) still allocates.
    if (cg_code != 0) { array_clear(cg_code); } else { cg_code = array_new(1, 0); }
    cg_next_label = 0;
    if (cg_labels != 0) { array_clear(cg_labels); } else { cg_labels = array_new(8, 0); }
    if (cg_fixups != 0) { array_clear(cg_fixups); } else { cg_fixups = array_new(8, 0); }
    if (cg_fn_labels != 0) { array_clear(cg_fn_labels); } else { cg_fn_labels = array_new(8, 0); }
    // EMBM v1 image buffers (reset alongside cg_code so every codegen() starts clean).
    if (cg_rodata != 0) { array_clear(cg_rodata); } else { cg_rodata = array_new(1, 0); }
    if (cg_data   != 0) { array_clear(cg_data);   } else { cg_data   = array_new(1, 0); }
    if (cg_syms   != 0) { array_clear(cg_syms);   } else { cg_syms   = array_new(1, 0); }
    if (cg_relocs != 0) { array_clear(cg_relocs); } else { cg_relocs = array_new(1, 0); }
    if (cg_globals != 0) { array_clear(cg_globals); } else { cg_globals = array_new(8, 0); }
    cg_globals_len = 0;
    // string-globals table + init label (reset so each codegen() starts clean;
    // cg_globals_init_label = -1 means "no __globals_init emitted this compile").
    if (cg_str_globals != 0) { array_clear(cg_str_globals); } else { cg_str_globals = array_new(8, 0); }
    cg_str_globals_len = 0;
    cg_globals_init_label = -1;
    // Phase 3b: defer cleanup stack (reset per function in cg_compile_func).
    if (g_defers != 0) { array_clear(g_defers); } else { g_defers = array_new(8, 0); }
    if (g_defer_marks != 0) { array_clear(g_defer_marks); } else { g_defer_marks = array_new(8, 0); }
    g_defer_mark_len = 0;
    cg_cur_ret = -1;
    cg_loop_defer_mark = 0;
    cg_err = 0;
    cg_errmsg = string_from_slice("");
    return 0;
}

// =============================================================================
// EMBM v1 image-buffer helpers (self_hosted/MODULE_IMAGE_FORMAT.md).
// =============================================================================

// append a u64 little-endian (8 bytes) into a byte array (array<u8>).
fn cg_push_u64_le(buf: i64, v: i64) -> i64 {
    array_push_u8(buf, v & 0xFF);
    array_push_u8(buf, (v >> 8) & 0xFF);
    array_push_u8(buf, (v >> 16) & 0xFF);
    array_push_u8(buf, (v >> 24) & 0xFF);
    array_push_u8(buf, (v >> 32) & 0xFF);
    array_push_u8(buf, (v >> 40) & 0xFF);
    array_push_u8(buf, (v >> 48) & 0xFF);
    array_push_u8(buf, (v >> 56) & 0xFF);
    return 0;
}

// append a u32 little-endian (4 bytes) into a byte array (array<u8>).
fn cg_push_u32_le(buf: i64, v: i64) -> i64 {
    array_push_u8(buf, v & 0xFF);
    array_push_u8(buf, (v >> 8) & 0xFF);
    array_push_u8(buf, (v >> 16) & 0xFF);
    array_push_u8(buf, (v >> 24) & 0xFF);
    return 0;
}

// allocate `n` bytes in cg_rodata (the bytes are left zero; the caller writes
// them via array_set_u8 after this returns the addend). Returns the byte
// offset (addend) within rodata where the allocation begins. Used by string
// literals: emit the literal's decoded bytes here, then reference them via an
// ABS64_RODATA reloc whose addend is this offset.
fn cg_rodata_alloc(n: i64) -> i64 {
    let addend: i64 = array_length(cg_rodata);
    let mut i: i64 = 0;
    while (i < n) { array_push_u8(cg_rodata, 0); i = i + 1; }
    return addend;
}

// allocate `n` bytes in cg_data (mutable globals). Returns the byte addend.
// The caller writes the initial bytes via array_set_u8 after this returns.
fn cg_data_alloc(n: i64) -> i64 {
    let addend: i64 = array_length(cg_data);
    let mut i: i64 = 0;
    while (i < n) { array_push_u8(cg_data, 0); i = i + 1; }
    return addend;
}

// find or append a null-terminated symbol name in cg_syms. Returns the 0-based
// symbol index. Scans the accumulated names (each null-terminated) comparing
// byte-for-byte; appends name + '\0' if new. Used by ABS64_NATIVE relocs to
// reference a native by index into the image's symbol-name table (§6).
fn cg_sym_index(name: string) -> i64 {
    let nlen: i64 = string_length(name);
    let syms_len: i64 = array_length(cg_syms);
    let mut idx: i64 = 0;
    let mut i: i64 = 0;
    while (i < syms_len) {
        // read one null-terminated name starting at i
        let mut j: i64 = i;
        let mut match_ok: i64 = 1;
        let mut k: i64 = 0;
        while (k < nlen) {
            let b: i64 = array_get_u8(cg_syms, j) as i64;
            if (b != string_char_at(name, k)) { match_ok = 0; }
            j = j + 1;
            k = k + 1;
            if (j >= syms_len) { match_ok = 0; }
        }
        if (match_ok == 1) {
            // the byte after the name must be the null terminator
            if (j < syms_len && (array_get_u8(cg_syms, j) as i64) == 0) { return idx; }
            match_ok = 0;
        }
        // advance past this null-terminated name to the next
        while (i < syms_len && (array_get_u8(cg_syms, i) as i64) != 0) { i = i + 1; }
        i = i + 1;  // skip the null
        idx = idx + 1;
    }
    // not found: append name + '\0'
    let mut k: i64 = 0;
    while (k < nlen) { array_push_u8(cg_syms, string_char_at(name, k)); k = k + 1; }
    array_push_u8(cg_syms, 0);
    return idx;
}

// record a 32-byte relocation record [type u64][patch_off u64][sym_idx u64][addend u64]
// (all little-endian). patch_off is a byte offset WITHIN the code section of
// the imm64 to patch. For NATIVE, sym_idx is the symbol index + addend is the
// ABI fingerprint; for RODATA/DATA, sym_idx is 0 + addend is the section addend.
fn cg_reloc(reloc_type: i64, patch_off: i64, sym_idx: i64, addend: i64) -> i64 {
    cg_push_u64_le(cg_relocs, reloc_type);
    cg_push_u64_le(cg_relocs, patch_off);
    cg_push_u64_le(cg_relocs, sym_idx);
    cg_push_u64_le(cg_relocs, addend);
    return 0;
}

// emit a `mov reg, <ABS64 imm64>` placeholder (REX.W B8+rd + 8 zero bytes) and
// record a relocation against the imm64's code offset. Returns the code offset
// of the imm64 (for validation). The loader patches the 8 zero bytes with the
// resolved absolute address (rodata_base+addend, data_base+addend, or native fn_ptr).
fn cg_emit_abs64_reloc_reg(reg: i64, reloc_type: i64, sym_idx: i64, addend: i64) -> i64 {
    // mov r64, imm64 -> REX.W B8+rd io
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(reg)));
    cg_byte(0xB8 + (reg & 7));
    let patch_off: i64 = array_length(cg_code);
    cg_imm64(0);  // placeholder; the loader writes the resolved address here
    cg_reloc(reloc_type, patch_off, sym_idx, addend);
    return patch_off;
}

// convenience: `mov rax, <ABS64>` + reloc (the common case for native calls,
// where rax holds the call target before `call rax`).
fn cg_emit_abs64_reloc(reloc_type: i64, sym_idx: i64, addend: i64) -> i64 {
    return cg_emit_abs64_reloc_reg(RAX, reloc_type, sym_idx, addend);
}

// Build EMBM v2: 96-byte header plus function dispatch table.
fn codegen_emit_image() -> i64 {
    let code_len: i64 = array_length(cg_code); let rodata_len: i64 = array_length(cg_rodata);
    let data_len: i64 = array_length(cg_data); let syms_len: i64 = array_length(cg_syms);
    let reloc_count: i64 = array_length(cg_relocs) / 32;
    let fn_count: i64 = array_length(cg_fn_labels) / 3; let fntable_len: i64 = fn_count * 16;
    let header_size: i64 = 96; let code_off: i64 = header_size;
    let rodata_off: i64 = code_off + code_len; let data_off: i64 = rodata_off + rodata_len;
    let syms_off: i64 = data_off + data_len; let fntable_off: i64 = syms_off + syms_len;
    let img: i64 = array_new(1, 0);
    array_push_u8(img, 0x45); array_push_u8(img, 0x4D); array_push_u8(img, 0x42); array_push_u8(img, 0x4D);
    cg_push_u32_le(img, 2); cg_push_u64_le(img, code_off); cg_push_u64_le(img, code_len);
    if (rodata_len > 0) { cg_push_u64_le(img, rodata_off); } else { cg_push_u64_le(img, 0); } cg_push_u64_le(img, rodata_len);
    if (data_len > 0) { cg_push_u64_le(img, data_off); } else { cg_push_u64_le(img, 0); } cg_push_u64_le(img, data_len);
    if (syms_len > 0) { cg_push_u64_le(img, syms_off); } else { cg_push_u64_le(img, 0); } cg_push_u64_le(img, syms_len);
    cg_push_u64_le(img, reloc_count);
    if (fntable_len > 0) { cg_push_u64_le(img, fntable_off); } else { cg_push_u64_le(img, 0); } cg_push_u64_le(img, fntable_len);
    let mut i: i64 = 0;
    while (i < code_len) { array_push_u8(img, array_get_u8(cg_code, i) as i64); i = i + 1; }
    i = 0; while (i < rodata_len) { array_push_u8(img, array_get_u8(cg_rodata, i) as i64); i = i + 1; }
    i = 0; while (i < data_len) { array_push_u8(img, array_get_u8(cg_data, i) as i64); i = i + 1; }
    i = 0; while (i < syms_len) { array_push_u8(img, array_get_u8(cg_syms, i) as i64); i = i + 1; }
    i = 0; while (i < fn_count) { cg_push_u64_le(img, i); cg_push_u64_le(img, cg_label_offset(array_get_i64(cg_fn_labels, i * 3 + 1))); i = i + 1; }
    i = 0; while (i < array_length(cg_relocs)) { array_push_u8(img, array_get_u8(cg_relocs, i) as i64); i = i + 1; }
    return img;
}

// =============================================================================
// mutable globals (EMBM v1 §5 data section). A constant-initialized i64
// global gets an 8-byte slot in cg_data (the initial value written LE), + a
// (name -> data addend) entry in cg_globals. Reads/writes go through a
// relocated ABS64_DATA pointer: `mov reg, <data_base+addend>` then load/store
// through that pointer.
// =============================================================================

// evaluate a constant i64 expression at compile time (mirrors sema's
// expr_is_const_i64). IntLit -> its value; unary negation -> -operand.
fn cg_eval_const_i64(e: i64) -> i64 {
    if (e < 0) { return 0; }
    // Sema's bounded interpreter is the single constexpr implementation.
    if (try_eval_const_i64(e) == 1) { return ce_int_out; }
    return 0;
}

// find a codegen global by bare name. Returns the row index, or -1 if not
// declared. Stride 3 [name_tok, addend, ns_tok]; matches any global with the
// bare name (mirrors sema registering a namespaced global under both bare +
// qualified names).
fn cg_find_global(name: string) -> i64 {
    let mut i: i64 = 0;
    while (i * 3 < cg_globals_len) {
        let tok: i64 = array_get_i64(cg_globals, i * 3);
        if (tok_name(tok) == name) { return i; }
        i = i + 1;
    }
    return -1;
}

// find a codegen global by qualified name (Ns::name). ns_name "" matches a
// top-level global; a nonempty ns_name matches a global whose ns_tok names it.
fn cg_find_global_qualified(name: string, ns_name: string) -> i64 {
    let mut i: i64 = 0;
    while (i * 3 < cg_globals_len) {
        let tok: i64 = array_get_i64(cg_globals, i * 3);
        if (tok_name(tok) == name) {
            let ns_tok: i64 = array_get_i64(cg_globals, i * 3 + 2);
            let mut ok: i64 = 0;
            if (ns_tok < 0) {
                if (string_length(ns_name) == 0) { ok = 1; }
            } else {
                if (tok_name(ns_tok) == ns_name) { ok = 1; }
            }
            if (ok == 1) { return i; }
        }
        i = i + 1;
    }
    return -1;
}

// a global's data-section byte addend (its slot offset within cg_data).
fn cg_global_addend(row: i64) -> i64 {
    return array_get_i64(cg_globals, row * 3 + 1);
}

// walk the program's GlobalDecls + allocate a data slot for each
// constant-initialized i64 global (mirroring sema's global_is_const_i64 gate).
// Writes the constant's 8 LE bytes into cg_data + records (name -> addend).
// Must run BEFORE compiling functions so global references resolve. Descends
// into NamespaceDecl members (namespaced globals get their ns_tok recorded so
// Ns::global reads resolve).
fn cg_compile_globals(prog: i64) -> i64 {
    let mut d: i64 = nk_a(prog);
    while (d >= 0) {
        if (nk_kind(d) == (NK::NamespaceDecl as i64)) {
            let ns_tok: i64 = nk_tok(d);
            let mut m: i64 = nk_a(d);
            while (m >= 0) {
                if (nk_kind(m) == (NK::GlobalDecl as i64)) { cg_compile_one_global(m, ns_tok); }
                if (cg_err != 0) { return 0; }
                m = nk_next(m);
            }
        } else if (nk_kind(d) == (NK::GlobalDecl as i64)) {
            cg_compile_one_global(d, -1);
            if (cg_err != 0) { return 0; }
        }
        d = nk_next(d);
    }
    return 0;
}

// is a GlobalDecl a string global with a StringLit initializer? Mirrors
// sema's global_is_const_string gate so the codegen allocates exactly the
// string globals sema registered. (A plain "..." literal, not an f-string.)
fn cg_global_is_string(d: i64) -> i64 {
    let gty: i64 = resolve_type(nk_a(d));
    if (gty < 0) { return 0; }
    if (ty_is_string(gty) == 0) { return 0; }
    let init: i64 = nk_b(d);
    if (init < 0) { return 0; }
    if (nk_kind(init) != (NK::StringLit as i64)) { return 0; }
    if (nk_d(init) != 0) { return 0; }   // plain string, not an f-string
    return 1;
}

// allocate a data slot for one supported global (constant-initialized i64 OR
// string with a StringLit initializer) + record (name_tok, addend, ns_tok) in
// cg_globals. Mirrors sema's global_is_supported gate so the codegen allocates
// exactly the globals sema registered. An i64 global's 8 LE init bytes are
// written into cg_data now; a string global's slot is zero-filled (the handle
// is materialized at runtime by __globals_init) + recorded in cg_str_globals
// so the init function can emit its literal materialization + store.
fn cg_compile_one_global(d: i64, ns_tok: i64) -> i64 {
    let gty: i64 = resolve_type(nk_a(d));
    let init: i64 = nk_b(d);
    let mut is_const: i64 = 0;
    if (gty >= 0 && ty_is_i64(gty) == 1 && init >= 0) {
        is_const = expr_is_const_i64(init);
    }
    let is_str: i64 = cg_global_is_string(d);
    if (is_const == 1) {
        let addend: i64 = cg_data_alloc(8);
        let val: i64 = cg_eval_const_i64(init);
        // write the 8 LE bytes of the initial value into cg_data
        let mut b: i64 = 0;
        while (b < 8) {
            array_set_u8(cg_data, addend + b, (val >> (b * 8)) & 0xFF);
            b = b + 1;
        }
        // record (name_tok, addend, ns_tok) at stride 3
        if (array_length(cg_globals) < cg_globals_len + 3) {
            array_resize(cg_globals, cg_globals_len + 3);
        }
        array_set_i64(cg_globals, cg_globals_len, nk_tok(d));
        array_set_i64(cg_globals, cg_globals_len + 1, addend);
        array_set_i64(cg_globals, cg_globals_len + 2, ns_tok);
        cg_globals_len = cg_globals_len + 3;
    } else if (is_str == 1) {
        // a string global: 8-byte zero-filled slot (the handle is filled at
        // runtime by __globals_init). Record it in cg_globals (for read/write
        // resolution) AND in cg_str_globals (for the init function).
        let addend: i64 = cg_data_alloc(8);   // zero-filled (cg_data_alloc pushes 0s)
        if (array_length(cg_globals) < cg_globals_len + 3) {
            array_resize(cg_globals, cg_globals_len + 3);
        }
        array_set_i64(cg_globals, cg_globals_len, nk_tok(d));
        array_set_i64(cg_globals, cg_globals_len + 1, addend);
        array_set_i64(cg_globals, cg_globals_len + 2, ns_tok);
        cg_globals_len = cg_globals_len + 3;
        // record (name_tok, addend, init_node) at stride 3 for __globals_init
        if (array_length(cg_str_globals) < cg_str_globals_len + 3) {
            array_resize(cg_str_globals, cg_str_globals_len + 3);
        }
        array_set_i64(cg_str_globals, cg_str_globals_len, nk_tok(d));
        array_set_i64(cg_str_globals, cg_str_globals_len + 1, addend);
        array_set_i64(cg_str_globals, cg_str_globals_len + 2, init);
        cg_str_globals_len = cg_str_globals_len + 3;
    }
    return 0;
}

// =============================================================================
// module-init function (__globals_init). For each string global, materialize
// its StringLit initializer at runtime (decode bytes to cg_rodata + build a
// u8 slice {rcx=ptr, rdx=len} + call string_from_slice -> handle in rax) and
// store the handle into the global's [data_base + addend] slot (mov rcx, <data
// ptr>; mov [rcx], rax). i64 globals keep their compile-time constant in the
// data section, so they need no runtime init. The pipeline calls this function
// BEFORE main (full_pipeline's compile_and_run via codegen_globals_init_offset).
//
// Emitted as a normal function in the code section with a minimal prologue
// (push rbp; mov rbp, rsp — no frame sub: there are no locals, and the
// per-call 32-byte shadow space is managed inline by the materialization, the
// same way cg_eval_string_lit manages it). rbp is preserved across the native
// calls (string_from_slice is Win64-ABI callee-saved with respect to rbp), so
// the epilogue (mov rsp, rbp; pop rbp; ret) restores the caller's frame.
// =============================================================================

// emit the __globals_init function (one per string global). Binds its entry
// label at the prologue offset + records the label in cg_globals_init_label so
// codegen_globals_init_offset() can resolve it. A no-op function (prologue +
// epilogue only) when there are no string globals is NOT emitted — instead the
// label stays -1 and the pipeline skips the call (cleaner than a dead fn).
fn cg_emit_globals_init() -> i64 {
    if (cg_str_globals_len == 0) {
        cg_globals_init_label = -1;
        return 0;
    }
    let lab: i64 = cg_alloc_label();
    cg_globals_init_label = lab;
    cg_bind(lab);   // entry = current code offset
    // prologue: push rbp; mov rbp, rsp  (no frame sub — see file header).
    // Emitted directly (not via cg_emit_prologue) to avoid a dead `sub rsp,0`.
    cg_push(RBP);                    // 0x55
    cg_mov_reg_reg(RBP, RSP);        // 48 89 E5
    // for each string global: materialize the literal -> rax, then store rax
    // into [data_base + addend]. The materialization mirrors cg_eval_string_
    // lit's plain-string path (rodata + slice + string_from_slice) and manages
    // its own 32-byte shadow space (sub/add rsp around the call); rbp is held
    // fixed so the store's data-pointer load is independent of rsp motion.
    let mut i: i64 = 0;
    while (i < cg_str_globals_len) {
        let addend: i64 = array_get_i64(cg_str_globals, i + 1);
        let init_node: i64 = array_get_i64(cg_str_globals, i + 2);
        // 1. emit the body bytes to cg_rodata
        let body: string = nk_string_body(init_node);
        let n: i64 = string_length(body);
        let ro_addend: i64 = cg_rodata_alloc(n);
        let mut j: i64 = 0;
        while (j < n) {
            array_set_u8(cg_rodata, ro_addend + j, string_char_at(body, j));
            j = j + 1;
        }
        // 2. build the u8 slice {rcx=ptr, rdx=len}
        cg_emit_abs64_reloc_reg(RCX, CG_RELOC_RODATA, 0, ro_addend);
        cg_mov_reg_imm64(RDX, n);
        // 3. call string_from_slice(rcx, rdx) -> handle in rax (32-byte shadow)
        cg_sub_reg_imm32(RSP, 32);
        let sym_idx: i64 = cg_sym_index(string_from_slice("string_from_slice"));
        let codes: i64 = cg_fp_codes_get();
        array_set_i64(codes, 0, 5);  // u8 slice
        let fp: i64 = cg_abi_fingerprint_codes(codes, 1, 6, 0);
        cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
        cg_call_reg(RAX);
        cg_add_reg_imm32(RSP, 32);
        // 4. store the handle into the global's data slot:
        //    mov rcx, <data_base + addend>; mov [rcx], rax
        cg_emit_abs64_reloc_reg(RCX, CG_RELOC_DATA, 0, addend);
        cg_byte(0x48); cg_byte(0x89); cg_byte(0x01);  // mov [rcx], rax
        i = i + 3;
    }
    // epilogue: mov rsp, rbp; pop rbp; ret
    cg_emit_epilogue();
    return 0;
}

// the code offset of the __globals_init function's entry (prologue) within the
// buffer, or -1 if no string globals were declared (no init function emitted).
// Used by the end-to-end pipeline to call the init function BEFORE main so
// string globals are live when main reads them.
fn codegen_globals_init_offset() -> i64 {
    if (cg_globals_init_label < 0) { return -1; }
    return cg_label_offset(cg_globals_init_label);
}

// =============================================================================
// frame size pre-computation. Walks the fn body counting locals (let stmts)
// + params to size the stack frame. All slots are 8 bytes (v1: everything is i64).
// =============================================================================

// Phase 4: count compiler-hidden struct temp frame SLOTS needed by the fn
// body (mirrors src/codegen.cpp's count_struct_temps_block/expr, in slots).
// A temp is needed for (a) a struct-literal `return` value in a struct-returning
// fn (materialized into a temp before being copied through the hidden return
// pointer), and (b) a struct-by-value call argument that is a StructLit or a
// struct-returning CallExpr (materialized into a temp before being copied into
// the arg stash / forwarded as the hidden dest). A bare-Ident struct arg + a
// struct-returning call let-init/return/assignment do NOT need a temp (they
// have a concrete destination). The temp slots are added to the frame count so
// cg_alloc_struct_temp (which shares cg_next_off with user locals) has room.
fn cg_struct_temp_slots(t: i64) -> i64 {
    let nb: i64 = cg_value_bytes(t);
    let mut s: i64 = (nb + 7) / 8;
    if (s < 1) { s = 1; }
    return s;
}

fn cg_count_struct_temps_expr(e: i64, total: i64) -> i64 {
    if (e < 0) { return total; }
    let k: i64 = nk_kind(e);
    if (k == (NK::CallExpr as i64)) {
        // resolve the callee fn row to read param types (determines which args
        // are struct-by-value slots). A struct arg that is NOT a bare Ident
        // (StructLit / struct-returning CallExpr) needs a temp.
        let nm: string = nk_name(e);
        let mut fn_row: i64 = -1;
        let mod_tok: i64 = nk_e(e);
        let mut is_ns: i64 = 0;
        if (mod_tok >= 0) {
            let mn: string = tok_text_at(mod_tok);
            if (is_namespace_name(mn) == 1) { is_ns = 1; fn_row = find_fn_qualified(nm, mn); }
        }
        if (is_ns == 0) {
            fn_row = find_fn(nm);
            if (fn_row < 0 && cg_cur_ns >= 0) {
                let qr: i64 = find_fn_qualified(nm, tok_name(cg_cur_ns));
                if (qr >= 0) { fn_row = qr; }
            }
        }
        if (fn_row >= 0) {
            let mut a: i64 = nk_a(e);
            let mut i: i64 = 0;
            while (a >= 0) {
                let pt: i64 = fn_param_type(fn_row, i);
                if (cg_ty_is_struct(pt) == 1 && nk_kind(a) != (NK::Ident as i64)) {
                    total = total + cg_struct_temp_slots(pt);
                }
                total = cg_count_struct_temps_expr(a, total);
                a = nk_next(a);
                i = i + 1;
            }
        } else {
            // native call or unresolved: just recurse into args (no struct
            // arg temps; natives don't take structs in the subset)
            let mut a: i64 = nk_a(e);
            while (a >= 0) { total = cg_count_struct_temps_expr(a, total); a = nk_next(a); }
        }
        return total;
    }
    if (k == (NK::BinExpr as i64)) { total = cg_count_struct_temps_expr(nk_a(e), total); return cg_count_struct_temps_expr(nk_b(e), total); }
    if (k == (NK::UnaryExpr as i64)) { return cg_count_struct_temps_expr(nk_a(e), total); }
    if (k == (NK::CastExpr as i64)) { return cg_count_struct_temps_expr(nk_a(e), total); }
    if (k == (NK::TernaryExpr as i64)) { total = cg_count_struct_temps_expr(nk_a(e), total); total = cg_count_struct_temps_expr(nk_b(e), total); return cg_count_struct_temps_expr(nk_c(e), total); }
    if (k == (NK::AssignExpr as i64)) { total = cg_count_struct_temps_expr(nk_a(e), total); return cg_count_struct_temps_expr(nk_b(e), total); }
    if (k == (NK::IndexExpr as i64)) { total = cg_count_struct_temps_expr(nk_a(e), total); return cg_count_struct_temps_expr(nk_b(e), total); }
    if (k == (NK::FieldExpr as i64)) { return cg_count_struct_temps_expr(nk_a(e), total); }
    if (k == (NK::ViewExpr as i64)) { return cg_count_struct_temps_expr(nk_a(e), total); }
    if (k == (NK::StructLit as i64)) {
        let mut init: i64 = nk_a(e);
        while (init >= 0) { total = cg_count_struct_temps_expr(nk_a(init), total); init = nk_next(init); }
        return total;
    }
    return total;
}

fn cg_count_struct_temps_stmt(s: i64, total: i64, ret_is_struct: i64) -> i64 {
    let k: i64 = nk_kind(s);
    if (k == (NK::LetStmt as i64)) {
        if (nk_b(s) >= 0) { total = cg_count_struct_temps_expr(nk_b(s), total); }
        return total;
    }
    if (k == (NK::ExprStmt as i64)) {
        if (nk_a(s) >= 0) { total = cg_count_struct_temps_expr(nk_a(s), total); }
        return total;
    }
    if (k == (NK::ReturnStmt as i64)) {
        let val: i64 = nk_a(s);
        if (val >= 0 && ret_is_struct == 1 && nk_kind(val) == (NK::StructLit as i64)) {
            // a struct-literal return value materializes into a temp before
            // being copied through the hidden return pointer.
            total = total + cg_struct_temp_slots(cg_cur_ret);
        }
        if (val >= 0) { total = cg_count_struct_temps_expr(val, total); }
        return total;
    }
    if (k == (NK::DeferStmt as i64)) {
        if (nk_a(s) >= 0) { total = cg_count_struct_temps_expr(nk_a(s), total); }
        return total;
    }
    if (k == (NK::IfStmt as i64)) {
        if (nk_a(s) >= 0) { total = cg_count_struct_temps_expr(nk_a(s), total); }
        total = cg_count_struct_temps_block(nk_b(s), total, ret_is_struct);
        if (nk_c(s) >= 0) { total = cg_count_struct_temps_block(nk_c(s), total, ret_is_struct); }
        return total;
    }
    if (k == (NK::WhileStmt as i64)) {
        if (nk_b(s) >= 0) { total = cg_count_struct_temps_expr(nk_b(s), total); }
        total = cg_count_struct_temps_block(nk_a(s), total, ret_is_struct);
        return total;
    }
    if (k == (NK::DoWhileStmt as i64)) {
        total = cg_count_struct_temps_block(nk_a(s), total, ret_is_struct);
        if (nk_b(s) >= 0) { total = cg_count_struct_temps_expr(nk_b(s), total); }
        return total;
    }
    if (k == (NK::BlockStmt as i64)) { return cg_count_struct_temps_block(s, total, ret_is_struct); }
    if (k == (NK::ForStmt as i64)) {
        if (nk_a(s) >= 0) { total = cg_count_struct_temps_stmt(nk_a(s), total, ret_is_struct); }
        if (nk_b(s) >= 0) { total = cg_count_struct_temps_expr(nk_b(s), total); }
        if (nk_d(s) >= 0) { total = cg_count_struct_temps_expr(nk_d(s), total); }
        total = cg_count_struct_temps_block(nk_e(s), total, ret_is_struct);
        return total;
    }
    if (k == (NK::ForEachStmt as i64)) {
        if (nk_a(s) >= 0) { total = cg_count_struct_temps_expr(nk_a(s), total); }
        total = cg_count_struct_temps_block(nk_b(s), total, ret_is_struct);
        return total;
    }
    if (k == (NK::SwitchStmt as i64)) {
        let mut c: i64 = nk_b(s); while (c >= 0) { total = cg_count_struct_temps_block(nk_b(c), total, ret_is_struct); c = nk_next(c); } return total;
    }
    if (k == (NK::MatchStmt as i64)) {
        let mut a: i64 = nk_b(s); while (a >= 0) { total = cg_count_struct_temps_block(nk_b(a), total, ret_is_struct); a = nk_next(a); } return total;
    }
    if (k == (NK::TryCatchStmt as i64)) {
        total = cg_count_struct_temps_block(nk_a(s), total, ret_is_struct);  // try body
        total = cg_count_struct_temps_block(nk_b(s), total, ret_is_struct);  // catch body
        return total;
    }
    return total;
}

fn cg_count_struct_temps_block(b: i64, total: i64, ret_is_struct: i64) -> i64 {
    if (b < 0) { return total; }
    let mut s: i64 = nk_a(b);
    while (s >= 0) {
        total = cg_count_struct_temps_stmt(s, total, ret_is_struct);
        s = nk_next(s);
    }
    return total;
}

fn cg_count_locals_block(b: i64, total: i64) -> i64 {
    if (b < 0) { return total; }
    let mut s: i64 = nk_a(b);
    while (s >= 0) {
        total = cg_count_locals_stmt(s, total);
        s = nk_next(s);
    }
    return total;
}

fn cg_count_locals_stmt(s: i64, total: i64) -> i64 {
    let k: i64 = nk_kind(s);
    if (k == (NK::LetStmt as i64)) {
        // count the local's actual stack slots (aggregates occupy
        // ceil(value_bytes/8); scalars occupy 1) so the frame is sized to
        // hold every byte of every local. Mirrors cg_alloc_local_t's sizing.
        let mut t: i64 = nk_a(s);
        let init: i64 = nk_b(s);
        if (t < 0 && init >= 0) { t = cg_expr_type(init); }
        else if (t >= 0) { t = resolve_type(t); }
        let mut slots: i64 = 1;
        if (t >= 0) { slots = cg_local_slots(t); }
        total = total + slots;
        return total;
    }
    if (k == (NK::IfStmt as i64)) {
        total = cg_count_locals_block(nk_b(s), total);   // then
        if (nk_c(s) >= 0) {
            total = cg_count_locals_block(nk_c(s), total);  // else
        }
        return total;
    }
    if (k == (NK::WhileStmt as i64)) {
        total = cg_count_locals_block(nk_b(s), total);   // body
        return total;
    }
    if (k == (NK::BlockStmt as i64)) {
        total = cg_count_locals_block(s, total);
        return total;
    }
    if (k == (NK::ForStmt as i64)) {
        total = total + 1;
        total = cg_count_locals_block(nk_e(s), total);
        return total;
    }
    if (k == (NK::ForEachStmt as i64)) {
        // for-each uses 4 frame slots: ptr, len, idx, + the loop var (1 slot
        // for a scalar element; aggregates are not yet supported in for-each).
        total = total + 4;
        total = cg_count_locals_block(nk_b(s), total);
        return total;
    }
    if (k == (NK::MatchStmt as i64)) {
        let mut a: i64 = nk_b(s);
        while (a >= 0) {
            if (nk_f(a) == 1) {
                let mut fld: i64 = nk_c(a);
                while (fld >= 0) { if (nk_a(fld) < 0) { total = total + 1; } fld = nk_next(fld); }
            }
            total = cg_count_locals_block(nk_b(a), total);
            a = nk_next(a);
        }
        return total;
    }
    // Phase 3b: do-while + switch + defer locals.
    if (k == (NK::DoWhileStmt as i64)) {
        total = cg_count_locals_block(nk_a(s), total);   // body
        return total;
    }
    if (k == (NK::SwitchStmt as i64)) {
        let mut c: i64 = nk_b(s); while (c >= 0) { total = cg_count_locals_block(nk_b(c), total); c = nk_next(c); } return total;
    }
    if (k == (NK::TryCatchStmt as i64)) {
        total = total + 1;  // catch variable
        total = cg_count_locals_block(nk_a(s), total);   // try body
        total = cg_count_locals_block(nk_b(s), total);   // catch body
        return total;
    }
    // Each captured lambda creation keeps one heap-env pointer spill in its
    // surrounding frame while captures are copied.
    if (k == (NK::ExprStmt as i64) || k == (NK::ReturnStmt as i64)) {
        if (nk_a(s) >= 0 && nk_kind(nk_a(s)) == (NK::LambdaExpr as i64)) { total = total + 1; }
    }
    // DeferStmt holds an expr (no locals of its own); nothing to count.
    return total;
}

// round up to a multiple of 16
fn cg_round16(n: i64) -> i64 {
    return (n + 15) & ~15;
}

// =============================================================================
// function prologue + epilogue.
// =============================================================================

// emit the prologue: push rbp; mov rbp, rsp; sub rsp, frame_size
fn cg_emit_prologue(frame_size: i64) -> i64 {
    cg_push(RBP);                    // 0x55
    cg_mov_reg_reg(RBP, RSP);        // 48 89 E5
    cg_sub_reg_imm32(RSP, frame_size);  // 48 81 EC <imm32>
    return 0;
}

// emit the epilogue: mov rsp, rbp; pop rbp; ret
fn cg_emit_epilogue() -> i64 {
    cg_mov_reg_reg(RSP, RBP);        // 48 89 EC
    cg_pop(RBP);                     // 0x5D
    cg_ret();                        // 0xC3
    return 0;
}

// =============================================================================
// expression evaluation. Result is in rax (int) for all v1 expressions.
// (v1: everything is i64 or bool, both held in rax as a 64-bit value.)
// =============================================================================

fn cg_find_capture(le: i64, name: string) -> i64 {
    let n: i64 = array_length(g_lambda_caps) / LAMBDA_CAP_STRIDE; let mut i: i64 = 0;
    while (i < n) {
        if (array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE) == le &&
            tok_name(array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 1)) == name) {
            cg_cap_type = array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 2);
            cg_cap_off = array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 3);
            cg_cap_by_ref = array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 4); return 1;
        }
        i = i + 1;
    }
    return 0;
}

fn cg_eval_lambda(e: i64) -> i64 {
    let cap_count: i64 = lambda_capture_count(e); let env_size: i64 = cap_count * 8;
    if (env_size == 0) { cg_mov_reg_imm64(RAX, nk_d(e)); cg_mov_reg_imm64(RDX, 0); return 0; }
    // Heap allocate the environment, retaining its pointer in a stack spill.
    let frame: i64 = 48; cg_sub_reg_imm32(RSP, frame); cg_mov_reg_imm64(RCX, env_size);
    let sym: i64 = cg_sym_index(string_from_slice("__ember_gc_alloc_env"));
    let pts: i64 = cg_fp_types_get(); array_set_i64(pts, 0, TY_I64);
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym, cg_abi_fingerprint(pts, 1, TY_I64, 0)); cg_call_reg(RAX);
    cg_store_reg_mem(RSP, 0, RAX);
    let n: i64 = array_length(g_lambda_caps) / LAMBDA_CAP_STRIDE; let mut i: i64 = 0;
    while (i < n) {
        if (array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE) == e) {
            let nt: i64 = array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 1);
            let coff: i64 = array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 3);
            let byref: i64 = array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 4);
            let loff: i64 = cg_lookup_local(nt);
            if (loff != 0) {
                if (byref == 1) { cg_lea_rax_rbp(loff); } else { cg_load_reg_mem(RAX, RBP, loff); }
            } else if (cg_current_lambda >= 0 && cg_find_capture(cg_current_lambda, tok_name(nt)) == 1) {
                cg_load_reg_mem(RAX, RBP, cg_lambda_env_off); cg_load_reg_mem(RAX, RAX, cg_cap_off);
                if (cg_cap_by_ref == 1 && byref == 0) { cg_load_reg_mem(RAX, RAX, 0); }
            } else { cg_mov_reg_imm64(RAX, 0); }
            cg_load_reg_mem(RCX, RSP, 0); cg_store_reg_mem(RCX, coff, RAX);
        }
        i = i + 1;
    }
    cg_load_reg_mem(RDX, RSP, 0); cg_add_reg_imm32(RSP, frame); cg_mov_reg_imm64(RAX, nk_d(e)); return 0;
}

fn cg_eval(e: i64) -> i64 {
    if (e < 0) {
        if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: missing expression"); }
        return 0;
    }
    let k: i64 = nk_kind(e);

    if (k == (NK::IntLit as i64)) {
        // mov rax, imm64
        cg_mov_reg_imm64(RAX, nk_d(e));
        return 0;
    }
    if (k == (NK::BoolLit as i64)) {
        cg_mov_reg_imm64(RAX, nk_d(e));
        return 0;
    }
    if (k == (NK::FloatLit as i64)) { return cg_eval_float_lit(e); }
    if (k == (NK::StringLit as i64)) { return cg_eval_string_lit(e); }
    if (k == (NK::LambdaExpr as i64)) { return cg_eval_lambda(e); }
    if (k == (NK::FnHandleExpr as i64)) { cg_mov_reg_imm64(RAX, nk_d(e)); return 0; }
    if (k == (NK::EnumAccess as i64)) {
        let ename: string = tok_name(nk_a(e));
        // Tier 1 namespaces: Foo::val where Foo is a namespace (not an enum) is
        // a namespace-global read. Emit the same ABS64_DATA load as a global
        // Ident (mirrors src/sema.cpp rewriting Foo::val to an Ident with the
        // qualified name, then codegen's global Ident load).
        if (is_namespace_name(ename) == 1) {
            let g: i64 = cg_find_global_qualified(nk_name(e), ename);
            if (g >= 0) {
                let addend: i64 = cg_global_addend(g);
                cg_emit_abs64_reloc_reg(RAX, CG_RELOC_DATA, 0, addend);  // mov rax, <data ptr>
                cg_byte(0x48); cg_byte(0x8B); cg_byte(0x00);              // mov rax, [rax]
                return 0;
            }
            if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: namespace '") + ename + string_from_slice("' has no global '") + nk_name(e) + string_from_slice("'"); }
            return 0;
        }
        cg_mov_reg_imm64(RAX, cg_enum_value(tok_name(nk_a(e)), nk_name(e)));
        // Phase 3b: a typed-enum variant normalizes to the backing width (a
        // typed enum is a real type; its value is the backing int). An
        // untyped enum variant is a plain i64 constant (no normalize needed).
        if (is_typed_enum_name(ename) == 1) {
            let et: i64 = typed_enum_type(ename);
            if (et >= 0) { cg_normalize_rax(et); }
        }
        return 0;
    }
    if (k == (NK::FieldExpr as i64)) { return cg_eval_fieldexpr(e); }
    if (k == (NK::IndexExpr as i64)) { return cg_eval_indexexpr(e); }
    if (k == (NK::ViewExpr as i64)) { return cg_eval_viewexpr(e); }
    if (k == (NK::ArrayLit as i64)) { return cg_eval_arraylit_rval(e); }
    if (k == (NK::Ident as i64)) {
        if (cg_current_lambda >= 0 && cg_find_capture(cg_current_lambda, nk_name(e)) == 1) {
            cg_load_reg_mem(RAX, RBP, cg_lambda_env_off); cg_load_reg_mem(RAX, RAX, cg_cap_off);
            if (cg_cap_by_ref == 1) { cg_load_reg_mem(RAX, RAX, 0); }
            cg_normalize_rax(cg_cap_type); return 0;
        }
        // look up the local; load from [rbp + offset]
        let off: i64 = cg_lookup_local(nk_tok(e));
        if (off != 0) {
            let t: i64 = cg_lookup_local_type(nk_tok(e));
            if (t >= 0 && nk_kind(t) == (NK::Type as i64) && (nk_f(t) == 1 || nk_f(t) == 2)) {
                // slice/closure local: yield the 2-word ABI {rax=word0, rdx=word1}
                // (mirrors src/codegen.cpp's slice Ident eval). Used by for-each
                // + slice IndexExpr bases + slice args (future).
                cg_load_reg_mem(RAX, RBP, off);
                cg_load_reg_mem(RDX, RBP, off + 8);
                return 0;
            }
            if (ty_is_float(t) == 1) { cg_load_float(XMM0, off, cg_float_is64_type(t)); }
            else { cg_load_reg_mem(RAX, RBP, off); cg_normalize_rax(t); }
            return 0;
        }
        // not a local: try a mutable global. Read through a relocated ABS64_DATA
        // pointer: mov rax, <data_base+addend>; mov rax, [rax]. (Phase 1 globals
        // are i64 only, so no float path here.)
        let g: i64 = cg_find_global(nk_name(e));
        if (g >= 0) {
            let addend: i64 = cg_global_addend(g);
            cg_emit_abs64_reloc_reg(RAX, CG_RELOC_DATA, 0, addend);  // mov rax, <data ptr>
            // mov rax, [rax]  -> 48 8B 00 (load the i64 through the pointer)
            cg_byte(0x48); cg_byte(0x8B); cg_byte(0x00);
            return 0;
        }
        if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unknown local '") + nk_name(e) + string_from_slice("'"); }
        return 0;
    }
    if (k == (NK::BinExpr as i64)) {
        return cg_eval_binexpr(e);
    }
    if (k == (NK::UnaryExpr as i64)) {
        return cg_eval_unaryexpr(e);
    }
    if (k == (NK::CallExpr as i64)) {
        // Sema annotated an all-constant constexpr call in the unused d/f
        // slots. Emit the folded immediate instead of a runtime call.
        if (nk_d(e) == 1) { cg_mov_reg_imm64(RAX, nk_f(e)); return 0; }
        return cg_eval_callexpr(e);
    }
    if (k == (NK::AssignExpr as i64)) {
        return cg_eval_assignexpr(e);
    }
    if (k == (NK::CastExpr as i64)) {
        return cg_eval_castexpr(e);
    }
    if (k == (NK::TernaryExpr as i64)) {
        return cg_eval_ternaryexpr(e);
    }
    if (k == (NK::SizeofExpr as i64)) {
        return cg_eval_sizeofexpr(e);
    }
    if (k == (NK::OffsetofExpr as i64)) {
        return cg_eval_offsetofexpr(e);
    }

    // unsupported in v1
    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: expression kind unsupported in v1"); }
    return 0;
}

fn cg_enum_value(enum_name: string, variant_name: string) -> i64 {
    let row: i64 = find_enum(enum_name); if (row < 0) { return 0; }
    // Delegate to sema's enum_variant_value, which folds constexpr fn calls
    // (e.g. `X = base()`) via try_eval_const_i64, not just plain IntLits.
    if (enum_variant_value(row, variant_name) == 1) { return g_enum_val_out; }
    return 0;
}

// find a struct field's declaration index by name. Returns -1 if not found.
fn cg_struct_field_index(type_node: i64, name: string) -> i64 {
    let row: i64 = find_struct(ty_struct_name(type_node)); if (row < 0) { return -1; }
    let mut f: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1); let mut i: i64 = 0;
    while (f >= 0) { if (nk_name(f) == name) { return i; } i = i + 1; f = nk_next(f); }
    return -1;
}

// the resolved Type node of a struct field by declaration index.
fn cg_struct_field_type_at(row: i64, idx: i64) -> i64 {
    let mut f: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1); let mut i: i64 = 0;
    while (f >= 0) { if (i == idx) { return resolve_type(nk_a(f)); } i = i + 1; f = nk_next(f); }
    return -1;
}

// load a value of type `t` from [base + disp] into rax (int) or xmm0 (float),
// with the correct width + sign/zero extension. Mirrors src/codegen.cpp's
// load_elem_to_rax + the FieldExpr load path. The field's width is
// cg_value_bytes(t); a scalar narrower than 8 is loaded with load_elem_to_rax
// (movsxd/movzx style) and normalized; an 8-byte scalar uses mov rax,[mem].
fn cg_load_typed(RAX_reg: i64, base: i64, disp: i64, t: i64) -> i64 {
    if (ty_is_float(t) == 1) { cg_load_float(XMM0, disp, cg_float_is64_type(t)); return 0; }
    let w: i64 = cg_value_bytes(t);
    if (w >= 8) { cg_load_reg_mem(RAX_reg, base, disp); return 0; }
    // narrow integer load: movzx/movsx via the elem-load helper. For a signed
    // narrow int, sign-extend; for unsigned, zero-extend (load_elem_to_rax's
    // is_signed flag). Then normalize_rax canonicalizes the high bits.
    let mut is_signed: i64 = 0;
    if (cg_type_is_int(t) == 1 && cg_type_is_uint(t) == 0) { is_signed = 1; }
    cg_load_elem_to_rax(base, disp, w, is_signed);
    return 0;
}

// store rax (int) or xmm0 (float) to [base + disp] with the type's width.
// Mirrors src/codegen.cpp's store_rax_elem / store_slot. Narrow ints write only
// their low `w` bytes; the high bits of rax are already canonicalized by the
// caller's normalize_rax so a partial store is correct.
fn cg_store_typed(base: i64, disp: i64, t: i64) -> i64 {
    if (ty_is_float(t) == 1) { cg_store_float(disp, XMM0, cg_float_is64_type(t)); return 0; }
    let w: i64 = cg_value_bytes(t);
    if (w >= 8) { cg_store_reg_mem(base, disp, RAX); return 0; }
    cg_store_rax_elem(base, disp, w);
    return 0;
}

fn cg_eval_fieldexpr(e: i64) -> i64 {
    let base: i64 = nk_a(e);
    if (nk_kind(base) != (NK::Ident as i64)) { cg_err = 1; cg_errmsg = string_from_slice("codegen: field base must be a local"); return 0; }
    let off: i64 = cg_lookup_local(nk_tok(base)); let t: i64 = cg_lookup_local_type(nk_tok(base));
    let row: i64 = find_struct(ty_struct_name(t));
    let idx: i64 = cg_struct_field_index(t, nk_name(e));
    if (idx < 0 || row < 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unknown field"); return 0; }
    let foff: i64 = cg_struct_field_offset(row, idx);
    let ft: i64 = cg_struct_field_type_at(row, idx);
    cg_load_typed(RAX, RBP, off + foff, ft);
    if (ty_is_float(ft) == 0) { cg_normalize_rax(ft); }
    return 0;
}

// Phase 3: load base[index]. base is a bare local Ident of a fixed array T[N]
// (inline, address = its frame slot) or a slice T[] (ptr+len in the slot).
// Mirrors src/codegen.cpp's IndexExpr eval path. Computes the element address
// base + index*elem_sz, applies a runtime bounds check (slice: always; fixed
// array: only for a non-constant index, since sema already checked constant
// indices), and loads the element with its width + sign extension.
fn cg_eval_indexexpr(e: i64) -> i64 {
    let base: i64 = nk_a(e);
    if (nk_kind(base) != (NK::Ident as i64)) { cg_err = 1; cg_errmsg = string_from_slice("codegen: index base must be a local"); return 0; }
    let boff: i64 = cg_lookup_local(nk_tok(base));
    let bt: i64 = cg_lookup_local_type(nk_tok(base));
    let mut is_sl: i64 = 0;
    if (bt >= 0 && nk_kind(bt) == (NK::Type as i64)) { is_sl = nk_f(bt); }
    let elem_ty: i64 = resolve_type(nk_a(bt));
    if (cg_err != 0) { return 0; }
    let elem_sz: i64 = cg_value_bytes(elem_ty);
    let mut arr_len: i64 = 0;
    if (bt >= 0) { arr_len = nk_e(bt); }
    // base address -> r11 (survives index eval). For a fixed array, r11 = rbp +
    // boff (lea). For a slice, load ptr from [rbp+boff] into r11 + len into r9.
    if (is_sl == 1) {
        cg_load_reg_mem(R11, RBP, boff);          // r11 = ptr
        cg_load_reg_mem(R9, RBP, boff + 8);       // r9 = len
    } else {
        cg_lea_r11_rbp(boff);                      // r11 = &arr (rbp + boff)
    }
    // eval index -> rax
    cg_eval(nk_b(e)); if (cg_err != 0) { return 0; }
    // bounds check: slice always (len in r9); fixed array only if the index is
    // not a compile-time constant (sema checked constants). Unsigned compare
    // (jb) catches both too-large and negative indices in one shot.
    if (is_sl == 1) {
        cg_bounds_check_reg_rax_r9();
    } else if (nk_kind(nk_b(e)) != (NK::IntLit as i64)) {
        cg_bounds_check_imm_rax(arr_len);
    }
    // rax = index * elem_sz (imul when sz > 1)
    if (elem_sz > 1) { cg_mov_reg_imm64(RCX, elem_sz); cg_imul_reg_reg(RAX, RCX); }
    // r11 = element address = r11 + rax
    cg_add_reg_reg(R11, RAX);
    // load the element from [r11] with its width
    let mut is_signed: i64 = 0;
    if (cg_type_is_int(elem_ty) == 1 && cg_type_is_uint(elem_ty) == 0) { is_signed = 1; }
    if (ty_is_float(elem_ty) == 1) {
        cg_load_float_disp_r11(cg_float_is64_type(elem_ty));
    } else if (elem_sz >= 8) {
        cg_load_reg_mem(RAX, R11, 0);
        cg_normalize_rax(elem_ty);
    } else {
        cg_load_elem_to_rax(R11, 0, elem_sz, is_signed);
        cg_normalize_rax(elem_ty);
    }
    return 0;
}

// Phase 3: arr[..] -> slice {ptr=&arr, len=N}. base must be a bare local Ident
// of a fixed array. Result is the slice ABI: rax = ptr (lea [rbp+boff]),
// rdx = N. Mirrors src/codegen.cpp's ViewExpr eval path.
fn cg_eval_viewexpr(e: i64) -> i64 {
    let base: i64 = nk_a(e);
    if (nk_kind(base) != (NK::Ident as i64)) { cg_err = 1; cg_errmsg = string_from_slice("codegen: view base must be a local"); return 0; }
    let boff: i64 = cg_lookup_local(nk_tok(base));
    let bt: i64 = cg_lookup_local_type(nk_tok(base));
    let mut n: i64 = 0;
    if (bt >= 0) { n = nk_e(bt); }
    // rax = &arr (lea rax, [rbp+boff]); rdx = N
    cg_lea_rax_rbp(boff);
    cg_mov_reg_imm64(RDX, n);
    return 0;
}

// A bare ArrayLit rvalue (not a let init). sema only lets a SLICE ArrayLit
// reach eval() as an rvalue (a fixed-array ArrayLit is let-init-only). STEP 3
// materializes a slice literal's backing into cg_data + yields {rax=ptr,rdx=len}.
// A fixed-array ArrayLit reaching here is an internal error (sema rejects it).
fn cg_eval_arraylit_rval(e: i64) -> i64 {
    // Determine the baked type (sema stamps the declared type via check_let, but
    // a bare rvalue ArrayLit only reaches here for a slice in an arg/return
    // position the self-hosted subset does not yet support). Defensive trap.
    cg_err = 1; cg_errmsg = string_from_slice("codegen: bare array literal rvalue not supported (use a let binding)");
    return 0;
}

// String literals are materialized as REAL host string handles. A plain
// "ember" literal is compiled to:
//   1. emit the decoded bytes to cg_rodata (cg_rodata_alloc) -> addend
//   2. build a u8 slice {ptr, len}: mov rcx, <rodata_base+addend> via an
//      ABS64_RODATA reloc (ptr in rcx) + mov rdx, len (len in rdx)
//   3. call string_from_slice(rcx=p, rdx=len) via an ABS64_NATIVE reloc ->
//      returns an opaque i64 HANDLE in rax
// That handle IS the string value (host owns a mutable std::string). This
// interoperates with the host string natives (string_length / string_char_at /
// string_substr take handles, not slices). The fingerprint for string_from_slice
// is param0=u8 slice (code 5), ret=string handle (code 6), permission 0.
//
// f-strings (nk_d == 1) keep the legacy length-based representation for now
// (no required test exercises an f-string in the compiled program); the host
// f-string model is deferred.
fn cg_eval_string_lit(e: i64) -> i64 {
    let raw: string = nk_name(e);
    if (nk_d(e) != 1) {
        // plain string literal: real rodata + string_from_slice -> handle in rax
        let body: string = nk_string_body(e);   // decoded body (quotes stripped)
        let n: i64 = string_length(body);
        // 1. emit the body bytes to cg_rodata
        let addend: i64 = cg_rodata_alloc(n);
        let mut i: i64 = 0;
        while (i < n) {
            array_set_u8(cg_rodata, addend + i, string_char_at(body, i));
            i = i + 1;
        }
        // 2. build the u8 slice {ptr in rcx, len in rdx}
        //    mov rcx, <rodata_base + addend>  (ABS64_RODATA reloc patches the ptr)
        cg_emit_abs64_reloc_reg(RCX, CG_RELOC_RODATA, 0, addend);
        //    mov rdx, len
        cg_mov_reg_imm64(RDX, n);
        // 3. call string_from_slice(rcx, rdx) -> handle in rax. Allocate a
        //    32-byte Win64 shadow frame (16-byte aligned: the caller's prologue
        //    leaves rsp 16-aligned at the call site, so sub rsp,32 keeps it
        //    aligned) so the native has scratch space.
        cg_sub_reg_imm32(RSP, 32);
        //    fingerprint: param0 = u8 slice (code 5), ret = string handle (code 6), perm 0
        let sym_idx: i64 = cg_sym_index(string_from_slice("string_from_slice"));
        let codes: i64 = cg_fp_codes_get();
        array_set_i64(codes, 0, 5);  // u8 slice
        let fp: i64 = cg_abi_fingerprint_codes(codes, 1, 6, 0);
        cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
        cg_call_reg(RAX);  // call rax (FF D0)
        cg_add_reg_imm32(RSP, 32);
        return 0;
    }
    // f-string: build a REAL host string handle by concatenating literal
    // segments (string_from_slice) + i64 interpolation segments (string_from_i64)
    // with string_add. The result is a real handle interoperable with the host
    // string natives (string_length etc.). The caller (cg_eval_string_lit) has
    // NOT allocated a frame; cg_eval_fstring_real allocates its own.
    return cg_eval_fstring_real(e);
}

fn cg_lookup_local_name(name: string) -> i64 {
    let mut i: i64 = cg_local_len / 3 - 1;
    while (i >= 0) { if (tok_name(array_get_i64(cg_locals, i * 3)) == name) { return array_get_i64(cg_locals, i * 3 + 1); } i = i - 1; }
    return 0;
}
fn cg_eval_fstring_width(name: string) -> i64 {
    let off: i64 = cg_lookup_local_name(name);
    if (off != 0) { cg_load_reg_mem(RAX, RBP, off); } else {
        let mut v: i64 = 0; let mut i: i64 = 0; while (i < string_length(name)) { let ch: i64 = string_char_at(name, i); if (ch >= 48 && ch <= 57) { v = v * 10 + ch - 48; } i = i + 1; } cg_mov_reg_imm64(RAX, v);
    }
    // Branchless-enough decimal width: start at one and add one for every
    // crossed power of ten. Negative values include a sign byte.
    cg_mov_reg_reg(R11, RAX); cg_mov_reg_imm64(RAX, 1);
    cg_cmp_reg_imm32(R11, 0); let pos: i64 = cg_alloc_label(); cg_jcc(COND_GE, pos); cg_add_reg_imm32(RAX, 1); cg_neg_reg(R11); cg_bind(pos);
    cg_decimal_width_step(10); cg_decimal_width_step(100); cg_decimal_width_step(1000); cg_decimal_width_step(10000); cg_decimal_width_step(100000); cg_decimal_width_step(1000000); cg_decimal_width_step(10000000); cg_decimal_width_step(100000000); cg_decimal_width_step(1000000000);
    return 0;
}
fn cg_decimal_width_step(limit: i64) -> i64 { let skip: i64 = cg_alloc_label(); cg_cmp_reg_imm32(R11, limit); cg_jcc(COND_L, skip); cg_add_reg_imm32(RAX, 1); cg_bind(skip); return 0; }

// -----------------------------------------------------------------------------
// real f-string materialization. Builds a host string handle by concatenating
// literal segments (string_from_slice) + i64 interpolation segments
// (string_from_i64) with string_add. The result handle is in rax.
//
// Frame layout (allocated once, 16-byte aligned at every call):
//   [rsp + 0..31]  shadow space (reused by every segment-build + string_add call)
//   [rsp + 32]     acc  — the accumulator handle (the string built so far)
//   [rsp + 40]     seg  — the current segment handle
// frame = 48 (round16(32 + 8 + 8)).
//
// Segment building emits a native call (string_from_slice / string_from_i64)
// whose shadow space is [rsp+0..31]; acc/seg live above it at [rsp+32/40] so
// they are never clobbered. string_add(acc, seg) reads acc/seg from those slots
// + writes its shadow to [rsp+0..31], returning the new acc in rax.
// -----------------------------------------------------------------------------

// build a literal-segment string handle from `n` bytes already written to
// cg_rodata at `addend`. Emits the u8 slice {rcx=ptr, rdx=len} + a
// string_from_slice native call. Assumes a 32-byte shadow frame is already
// allocated at [rsp+0..31] by the caller. Result handle in rax.
fn cg_build_literal_seg(addend: i64, n: i64) -> i64 {
    // mov rcx, <rodata_base + addend>  (ABS64_RODATA reloc patches the ptr)
    cg_emit_abs64_reloc_reg(RCX, CG_RELOC_RODATA, 0, addend);
    // mov rdx, len
    cg_mov_reg_imm64(RDX, n);
    // call string_from_slice(rcx, rdx) -> handle in rax
    let sym_idx: i64 = cg_sym_index(string_from_slice("string_from_slice"));
    let codes: i64 = cg_fp_codes_get();
    array_set_i64(codes, 0, 5);  // u8 slice
    let fp: i64 = cg_abi_fingerprint_codes(codes, 1, 6, 0);
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
    cg_call_reg(RAX);
    return 0;
}

// build an i64 interpolation segment: load the i64 local `name` -> rax, then
// call string_from_i64(rcx=value) -> handle in rax. Assumes a 32-byte shadow
// frame is already allocated at [rsp+0..31]. Returns 0 on success, 1 if the
// name is not a local (the caller treats that as a literal-integer segment).
fn cg_build_i64_seg(name: string) -> i64 {
    let off: i64 = cg_lookup_local_name(name);
    if (off == 0) { return 1; }  // not a local
    // load the i64 value -> rax; move to rcx (arg1)
    cg_load_reg_mem(RAX, RBP, off);
    cg_mov_reg_reg(RCX, RAX);
    // call string_from_i64(rcx) -> handle in rax
    // fingerprint: param0 = i64 (code 1), ret = string handle (code 6), perm 0
    let sym_idx: i64 = cg_sym_index(string_from_slice("string_from_i64"));
    let codes: i64 = cg_fp_codes_get();
    array_set_i64(codes, 0, 1);  // i64
    let fp: i64 = cg_abi_fingerprint_codes(codes, 1, 6, 0);
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
    cg_call_reg(RAX);
    return 0;
}

// emit string_add(acc, seg): rcx = acc (from [rsp+32]), rdx = seg (from [rsp+40]),
// call string_add -> new acc in rax. Assumes shadow at [rsp+0..31].
fn cg_emit_string_add() -> i64 {
    cg_load_reg_mem(RCX, RSP, 32);  // acc = arg1
    cg_load_reg_mem(RDX, RSP, 40);  // seg = arg2
    // string_add(i64, i64) -> handle. fingerprint: params {1,1}, ret 6, perm 0.
    let sym_idx: i64 = cg_sym_index(string_from_slice("string_add"));
    let codes: i64 = cg_fp_codes_get();
    array_set_i64(codes, 0, 1); array_set_i64(codes, 1, 1);
    let fp: i64 = cg_abi_fingerprint_codes(codes, 2, 6, 0);
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
    cg_call_reg(RAX);
    return 0;
}

// Build a real f-string handle from the StringLit node `e` (nk_d == 1).
// Parses the raw f-string token content (between the outer quotes) into literal
// + {identifier} interpolation segments, builds each as a handle, and
// concatenates them with string_add. Result handle in rax.
fn cg_eval_fstring_real(e: i64) -> i64 {
    let raw: string = nk_name(e);  // raw token text, e.g. f"v={n}"
    let rlen: i64 = string_length(raw);
    // content lies between index 2 (after f") and rlen-1 (before the closing ")
    let start_idx: i64 = 2;
    let end_idx: i64 = rlen - 1;
    if (end_idx <= start_idx) {
        // empty f-string: build an empty handle via string_from_slice("")
        let frame: i64 = 32;
        cg_sub_reg_imm32(RSP, frame);
        cg_build_literal_seg(cg_rodata_alloc(0), 0);
        cg_add_reg_imm32(RSP, frame);
        return 0;
    }
    // allocate the f-string frame: 32 shadow + 8 acc + 8 seg = 48
    let frame: i64 = 48;
    cg_sub_reg_imm32(RSP, frame);

    let mut i: i64 = start_idx;
    let mut have_acc: i64 = 0;  // has the first segment been built into acc?
    // accumulate a literal run's bytes into cg_rodata, then build a segment
    let mut lit_addend: i64 = 0;
    let mut lit_len: i64 = 0;
    let mut lit_started: i64 = 0;
    while (i < end_idx) {
        let ch: i64 = string_char_at(raw, i);
        if (ch == 123) {  // '{'
            if (i + 1 < end_idx && string_char_at(raw, i + 1) == 123) {
                // '{{' -> literal '{'
                if (lit_started == 0) { lit_addend = array_length(cg_rodata); lit_started = 1; }
                array_push_u8(cg_rodata, 123); lit_len = lit_len + 1;
                i = i + 2;
                continue;
            }
            // flush any pending literal run into a segment first
            if (lit_started == 1) {
                cg_build_literal_seg(lit_addend, lit_len);
                cg_store_reg_mem(RSP, 40, RAX);  // seg
                if (have_acc == 0) {
                    cg_store_reg_mem(RSP, 32, RAX); have_acc = 1;  // acc = first seg
                } else {
                    cg_emit_string_add(); cg_store_reg_mem(RSP, 32, RAX);  // acc = acc + seg
                }
                lit_started = 0; lit_len = 0;
            }
            // parse the interpolation {name}
            let expr_start: i64 = i + 1;
            i = i + 1;
            while (i < end_idx && string_char_at(raw, i) != 125) { i = i + 1; }
            let name: string = string_substr(raw, expr_start, i - expr_start);
            // i now at '}' (or end); skip it
            if (i < end_idx) { i = i + 1; }
            // build the interpolation segment. Try i64 local first; if not a
            // local, parse the name as a decimal integer + build it as i64.
            let built: i64 = cg_build_i64_seg(name);
            if (built != 0) {
                // not a local: parse name as a decimal integer literal
                let mut v: i64 = 0; let mut k: i64 = 0;
                while (k < string_length(name)) {
                    let dc: i64 = string_char_at(name, k);
                    if (dc >= 48 && dc <= 57) { v = v * 10 + dc - 48; }
                    k = k + 1;
                }
                cg_mov_reg_imm64(RAX, v);
                cg_mov_reg_reg(RCX, RAX);
                let sym_idx: i64 = cg_sym_index(string_from_slice("string_from_i64"));
                let codes: i64 = cg_fp_codes_get();
                array_set_i64(codes, 0, 1);
                let fp: i64 = cg_abi_fingerprint_codes(codes, 1, 6, 0);
                cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
                cg_call_reg(RAX);
            }
            cg_store_reg_mem(RSP, 40, RAX);  // seg
            if (have_acc == 0) {
                cg_store_reg_mem(RSP, 32, RAX); have_acc = 1;
            } else {
                cg_emit_string_add(); cg_store_reg_mem(RSP, 32, RAX);
            }
            continue;
        }
        if (ch == 125) {  // '}'
            if (i + 1 < end_idx && string_char_at(raw, i + 1) == 125) {
                // '}}' -> literal '}'
                if (lit_started == 0) { lit_addend = array_length(cg_rodata); lit_started = 1; }
                array_push_u8(cg_rodata, 125); lit_len = lit_len + 1;
                i = i + 2;
                continue;
            }
            // unmatched '}' — emit as literal
            if (lit_started == 0) { lit_addend = array_length(cg_rodata); lit_started = 1; }
            array_push_u8(cg_rodata, 125); lit_len = lit_len + 1;
            i = i + 1;
            continue;
        }
        // ordinary literal char
        if (lit_started == 0) { lit_addend = array_length(cg_rodata); lit_started = 1; }
        array_push_u8(cg_rodata, ch); lit_len = lit_len + 1;
        i = i + 1;
    }
    // flush any trailing literal run
    if (lit_started == 1) {
        cg_build_literal_seg(lit_addend, lit_len);
        cg_store_reg_mem(RSP, 40, RAX);
        if (have_acc == 0) {
            cg_store_reg_mem(RSP, 32, RAX); have_acc = 1;
        } else {
            cg_emit_string_add(); cg_store_reg_mem(RSP, 32, RAX);
        }
    }
    // if no segments at all (e.g. empty content), build an empty handle
    if (have_acc == 0) {
        cg_build_literal_seg(cg_rodata_alloc(0), 0);
        cg_store_reg_mem(RSP, 32, RAX); have_acc = 1;
    }
    // result = acc
    cg_load_reg_mem(RAX, RSP, 32);
    cg_add_reg_imm32(RSP, frame);
    return 0;
}

// evaluate a binary expression. lhs -> rax, push; rhs -> rax, mov rcx rax;
// pop rax (lhs); apply op (result in rax).
fn cg_eval_binexpr(e: i64) -> i64 {
    let op: i64 = nk_d(e);
    let lhs: i64 = nk_a(e);
    let rhs: i64 = nk_b(e);

    let et: i64 = cg_expr_type(lhs);
    if (ty_is_float(et) == 1) { return cg_eval_float_binexpr(e, et); }
    if (ty_is_string(et) == 1) { return cg_eval_string_binexpr(e); }

    // short-circuit logical && / ||
    if (op == (BinOp::LAnd as i64)) {
        return cg_eval_logical_and(e);
    }
    if (op == (BinOp::LOr as i64)) {
        return cg_eval_logical_or(e);
    }

    // eval lhs -> rax; push rax (save lhs across rhs eval)
    cg_eval(lhs);
    if (cg_err != 0) { return 0; }
    cg_push(RAX);
    // eval rhs -> rax
    cg_eval(rhs);
    if (cg_err != 0) { return 0; }
    // rcx = rhs (rax)
    cg_mov_reg_reg(RCX, RAX);
    // rax = lhs (pop)
    cg_pop(RAX);

    // apply the op (result in rax)
    // literal adaptation: if lhs is an IntLit (always TY_I64) and rhs is a
    // typed int, the result type is rhs's type (mirrors sema's check_binexpr
    // adaptation + the C++ codegen's normalize_rax(b->lhs->ty) where the
    // literal's ty was adapted to the other operand's type).
    let mut lt: i64 = cg_expr_type(lhs);
    if (nk_kind(lhs) == (NK::IntLit as i64) && cg_type_is_int(cg_expr_type(rhs)) == 1) {
        lt = cg_expr_type(rhs);
    }
    let is_unsigned: i64 = cg_type_is_uint(lt);
    let mut is_cmp: i64 = 0;
    if (op == (BinOp::Eq as i64)) { is_cmp = 1; }
    if (op == (BinOp::Neq as i64)) { is_cmp = 1; }
    if (op == (BinOp::Lt as i64)) { is_cmp = 1; }
    if (op == (BinOp::Le as i64)) { is_cmp = 1; }
    if (op == (BinOp::Gt as i64)) { is_cmp = 1; }
    if (op == (BinOp::Ge as i64)) { is_cmp = 1; }

    if (is_cmp != 0) {
        // cmp rax, rcx; setcc al; movzx rax, al
        cg_cmp_reg_reg(RAX, RCX);
        let mut cc: i64 = 0;
        if (op == (BinOp::Eq as i64))  { cc = COND_E; }
        if (op == (BinOp::Neq as i64)) { cc = COND_NE; }
        if (op == (BinOp::Lt as i64))  { if (is_unsigned == 1) { cc = COND_B; } else { cc = COND_L; } }
        if (op == (BinOp::Le as i64))  { if (is_unsigned == 1) { cc = COND_BE; } else { cc = COND_LE; } }
        if (op == (BinOp::Gt as i64))  { if (is_unsigned == 1) { cc = COND_A; } else { cc = COND_G; } }
        if (op == (BinOp::Ge as i64))  { if (is_unsigned == 1) { cc = COND_AE; } else { cc = COND_GE; } }
        cg_setcc_al(cc);
        cg_movzx_rax_al();
        return 0;
    }

    if (op == (BinOp::Add as i64)) { cg_add_reg_reg(RAX, RCX); cg_normalize_rax(lt); return 0; }
    if (op == (BinOp::Sub as i64)) { cg_sub_reg_reg(RAX, RCX); cg_normalize_rax(lt); return 0; }
    if (op == (BinOp::Mul as i64)) { cg_imul_reg_reg(RAX, RCX); cg_normalize_rax(lt); return 0; }
    if (op == (BinOp::And as i64)) { cg_and_reg_reg(RAX, RCX); cg_normalize_rax(lt); return 0; }
    if (op == (BinOp::Or as i64))  { cg_or_reg_reg(RAX, RCX); cg_normalize_rax(lt); return 0; }
    if (op == (BinOp::Xor as i64)) { cg_xor_reg_reg(RAX, RCX); cg_normalize_rax(lt); return 0; }
    if (op == (BinOp::Shl as i64)) {
        // rcx already holds the shift count; shl rax, cl
        cg_shl_reg_cl(RAX);
        cg_normalize_rax(lt);
        return 0;
    }
    if (op == (BinOp::Shr as i64)) {
        // signed -> arithmetic shift right (sar); unsigned -> logical shift right (shr)
        if (is_unsigned == 1) { cg_shr_reg_cl(RAX); }
        else { cg_sar_reg_cl(RAX); }
        cg_normalize_rax(lt);
        return 0;
    }
    // Div/Mod: signed uses cqo + idiv; unsigned uses xor rdx,rdx + div.
    if (op == (BinOp::Div as i64)) {
        if (is_unsigned == 1) {
            // xor rdx, rdx; div rcx (rax = rax / rcx, unsigned)
            cg_byte(0x48); cg_byte(0x31); cg_byte(0xD2);
            cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF1);
        } else {
            // cqo; idiv rcx (rax = rax / rcx, signed)
            cg_byte(0x48); cg_byte(0x99);
            cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF9);
        }
        cg_normalize_rax(lt);
        return 0;
    }
    if (op == (BinOp::Mod as i64)) {
        if (is_unsigned == 1) {
            // xor rdx, rdx; div rcx; mov rax, rdx (rax = rax % rcx, unsigned)
            cg_byte(0x48); cg_byte(0x31); cg_byte(0xD2);
            cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF1);
        } else {
            // cqo; idiv rcx; mov rax, rdx (rax = rax % rcx, signed)
            cg_byte(0x48); cg_byte(0x99);
            cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF9);
        }
        cg_mov_reg_reg(RAX, RDX);
        cg_normalize_rax(lt);
        return 0;
    }

    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unsupported binary op"); }
    return 0;
}

fn cg_eval_float_binexpr(e: i64, t: i64) -> i64 {
    let op: i64 = nk_d(e); let is64: i64 = cg_float_is64_type(t);
    cg_eval(nk_a(e)); if (cg_err != 0) { return 0; }
    cg_movq_rax_xmm(XMM0); cg_push(RAX);
    cg_eval(nk_b(e)); if (cg_err != 0) { return 0; }
    cg_sse_rr(if64_prefix(is64), 0x10, XMM1, XMM0);
    cg_pop(RAX); if (is64 == 1) { cg_movq_xmm_rax(XMM0); } else { cg_movd_xmm_eax(XMM0); }
    if (op == (BinOp::Add as i64)) { cg_float_op(0x58, is64); return 0; }
    if (op == (BinOp::Sub as i64)) { cg_float_op(0x5C, is64); return 0; }
    if (op == (BinOp::Mul as i64)) { cg_float_op(0x59, is64); return 0; }
    if (op == (BinOp::Div as i64)) { cg_float_op(0x5E, is64); return 0; }
    cg_float_cmp(is64);
    let mut cc: i64 = COND_E;
    if (op == (BinOp::Neq as i64)) { cc = COND_NE; }
    if (op == (BinOp::Lt as i64)) { cc = COND_B; }
    if (op == (BinOp::Le as i64)) { cc = COND_BE; }
    if (op == (BinOp::Gt as i64)) { cc = COND_A; }
    if (op == (BinOp::Ge as i64)) { cc = COND_AE; }
    cg_setcc_al(cc); cg_movzx_rax_al(); return 0;
}
fn if64_prefix(is64: i64) -> i64 { if (is64 == 1) { return 0xF2; } return 0xF3; }

// evaluate a binary expression whose operands are strings (real host handles).
// `string + string` concatenates via the string_add native (an operator
// overload published into the host's native allowlist under name "string_add");
// `==` / `!=` compare content via string_eq. Both take (i64 handle, i64 handle)
// and are emitted as ABS64_NATIVE relocations. The registered overload sigs use
// plain I64 params (code 1) + a handle/bool return, so the fingerprint is
// computed from explicit codes (not the string arg type, which would code 6).
// A proper Win64 call frame (32-byte shadow + 16-byte alignment) is allocated
// so the native has scratch space.
fn cg_eval_string_binexpr(e: i64) -> i64 {
    let op: i64 = nk_d(e);
    // call_frame = round16(2*8 + 32) = 48 (2 arg temps + 32-byte shadow)
    let call_frame: i64 = cg_round16(2 * 8 + 32);
    cg_sub_reg_imm32(RSP, call_frame);
    // eval lhs -> rax; store to [rsp+0]
    cg_eval(nk_a(e)); if (cg_err != 0) { cg_add_reg_imm32(RSP, call_frame); return 0; }
    cg_store_reg_mem(RSP, 0, RAX);
    // eval rhs -> rax; store to [rsp+8]
    cg_eval(nk_b(e)); if (cg_err != 0) { cg_add_reg_imm32(RSP, call_frame); return 0; }
    cg_store_reg_mem(RSP, 8, RAX);
    // load args: rcx = lhs (arg1), rdx = rhs (arg2)
    cg_load_reg_mem(RCX, RSP, 0);
    cg_load_reg_mem(RDX, RSP, 8);
    if (op == (BinOp::Add as i64)) {
        // string_add(i64, i64) -> string handle. fingerprint: params {1,1}, ret 6, perm 0.
        let sym_idx: i64 = cg_sym_index(string_from_slice("string_add"));
        let codes: i64 = cg_fp_codes_get();
        array_set_i64(codes, 0, 1); array_set_i64(codes, 1, 1);  // i64, i64
        let fp: i64 = cg_abi_fingerprint_codes(codes, 2, 6, 0);
        cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
        cg_call_reg(RAX);  // call rax -> handle in rax
        cg_add_reg_imm32(RSP, call_frame);
        return 0;
    }
    // == / != : string_eq(i64, i64) -> bool (0/1). fingerprint: params {1,1}, ret 4 (bool), perm 0.
    let sym_idx: i64 = cg_sym_index(string_from_slice("string_eq"));
    let codes: i64 = cg_fp_codes_get();
    array_set_i64(codes, 0, 1); array_set_i64(codes, 1, 1);  // i64, i64
    let fp: i64 = cg_abi_fingerprint_codes(codes, 2, 4, 0);
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
    cg_call_reg(RAX);  // call rax -> 0/1 in rax
    cg_add_reg_imm32(RSP, call_frame);
    if (op == (BinOp::Neq as i64)) {
        // logical not of the bool result: rax = (rax == 0) ? 1 : 0
        cg_cmp_reg_imm32(RAX, 0); cg_setcc_al(COND_E); cg_movzx_rax_al();
    }
    return 0;
}

// logical && : short-circuit. lhs false -> result 0; else eval rhs.
fn cg_eval_logical_and(e: i64) -> i64 {
    let lhs: i64 = nk_a(e);
    let rhs: i64 = nk_b(e);
    let false_l: i64 = cg_alloc_label();
    let end_l: i64 = cg_alloc_label();

    cg_eval(lhs);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    cg_jcc(COND_E, false_l);       // lhs == 0 -> false
    cg_eval(rhs);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    cg_jcc(COND_NE, end_l);        // rhs != 0 -> true (keep rhs value)
    cg_bind(false_l);
    cg_mov_reg_imm64(RAX, 0);      // result = 0
    cg_bind(end_l);
    // normalize: rax = (rax != 0) ? 1 : 0
    cg_cmp_reg_imm32(RAX, 0);
    let done: i64 = cg_alloc_label();
    cg_mov_reg_imm64(RAX, 0);
    cg_jcc(COND_E, done);
    cg_mov_reg_imm64(RAX, 1);
    cg_bind(done);
    return 0;
}

// logical || : short-circuit. lhs true -> result 1; else eval rhs.
fn cg_eval_logical_or(e: i64) -> i64 {
    let lhs: i64 = nk_a(e);
    let rhs: i64 = nk_b(e);
    let end_l: i64 = cg_alloc_label();

    cg_eval(lhs);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    cg_jcc(COND_NE, end_l);        // lhs != 0 -> true (keep lhs value)
    cg_eval(rhs);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    cg_jcc(COND_NE, end_l);        // rhs != 0 -> true
    cg_mov_reg_imm64(RAX, 0);      // result = 0
    cg_bind(end_l);
    // normalize: rax = (rax != 0) ? 1 : 0
    cg_cmp_reg_imm32(RAX, 0);
    let done: i64 = cg_alloc_label();
    cg_mov_reg_imm64(RAX, 0);
    cg_jcc(COND_E, done);
    cg_mov_reg_imm64(RAX, 1);
    cg_bind(done);
    return 0;
}

// evaluate a unary expression. operand -> rax; apply the op.
fn cg_eval_unaryexpr(e: i64) -> i64 {
    let op: i64 = nk_d(e);
    let operand: i64 = nk_a(e);
    cg_eval(operand);
    if (cg_err != 0) { return 0; }

    if (op == (UnOp::Neg as i64)) {
        // neg rax
        cg_neg_reg(RAX);
        return 0;
    }
    if (op == (UnOp::BitNot as i64)) {
        // not rax
        cg_not_reg(RAX);
        return 0;
    }
    if (op == (UnOp::Not as i64)) {
        // logical not: rax = (rax == 0) ? 1 : 0
        cg_cmp_reg_imm32(RAX, 0);
        cg_setcc_al(COND_E);       // sete al (1 if rax was 0)
        cg_movzx_rax_al();
        return 0;
    }
    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unsupported unary op"); }
    return 0;
}

// evaluate an assignment expression: target = value, target op= value, or
// ++/-- target (prefix/postfix). Mirrors src/codegen.cpp's AssignExpr lowering.
//
// Node layout (parse.ember): a=target, b=value, d=compound op (or -1 for
// plain '='), e=postfix flag (1 for postfix ++/--, where b is absent/-1).
//
//   plain '='      : eval value -> rax; normalize to target type; store.
//                    expression result = the value (in rax).
//   compound op=   : load target -> rax; push; eval value -> rax; rcx=rax;
//                    pop rax (lhs); apply op; normalize to target type; store.
//                    expression result = the new value (in rax).
//   prefix ++/--   : same as compound with value=1 (parser sets b=IntLit(1),
//                    e=-1). expression result = the new value.
//   postfix ++/--  : load target -> rax; push (save old); eval/inc; apply op
//                    with 1; normalize; store; then result = old value
//                    (pop + adjust: for Add, old = new-1; for Sub, old = new+1).
//
// v1: only Ident targets (local or global). The compound/postfix op for
// integers uses the same instruction sequence as cg_eval_binexpr.
fn cg_eval_assignexpr(e: i64) -> i64 {
    let target: i64 = nk_a(e);
    let value: i64 = nk_b(e);
    let cop: i64 = nk_d(e);
    let postfix: i64 = nk_e(e);

    // Phase 3: FieldExpr / IndexExpr assignment targets (p.x = v, a[i] = v).
    // Dispatch to dedicated handlers that compute the lvalue address + type,
    // then perform the plain/compound/postfix store mirroring the Ident path.
    if (nk_kind(target) == (NK::FieldExpr as i64)) { return cg_assign_field(target, value, cop, postfix); }
    if (nk_kind(target) == (NK::IndexExpr as i64)) { return cg_assign_index(target, value, cop, postfix); }

    // v1: only Ident targets (beyond the FieldExpr/IndexExpr cases above)
    if (nk_kind(target) != (NK::Ident as i64)) {
        if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: assignment target must be an identifier in v1"); }
        return 0;
    }

    // Phase 4: if the target is a captured variable inside a lambda, handle
    // the store through the closure env (by-ref: store through the pointer in
    // the env; by-value: store directly into the env slot).
    if (cg_current_lambda >= 0 && cg_find_capture(cg_current_lambda, nk_name(target)) == 1) {
        let cap_type: i64 = cg_cap_type;
        let cap_off: i64 = cg_cap_off;
        let cap_by_ref: i64 = cg_cap_by_ref;
        // plain '=' only for now (compound op= / ++ on captures can be added)
        if (cop < 0 && postfix != 1) {
            cg_eval(value); if (cg_err != 0) { return 0; }
            cg_normalize_rax(cap_type);
            // load env_ptr from [rbp + cg_lambda_env_off]
            cg_load_reg_mem(R11, RBP, cg_lambda_env_off);
            if (cap_by_ref == 1) {
                // by-ref: env slot holds a pointer to the captured var; load
                // it, then store rax through that pointer.
                cg_load_reg_mem(R11, R11, cap_off);  // r11 = ptr to captured var
                cg_store_reg_mem(R11, 0, RAX);       // *ptr = rax
            } else {
                // by-value: store rax directly into the env slot.
                cg_store_reg_mem(R11, cap_off, RAX);
            }
            return 0;
        }
        // compound op= / ++ on captures: load current (capture read), eval rhs,
        // apply op, store back (capture write). Falls through to the generic
        // compound path below by faking a local offset — but captures don't
        // have a frame offset, so handle inline instead.
        // Load current value -> rax (capture read path)
        cg_load_reg_mem(R11, RBP, cg_lambda_env_off);
        cg_load_reg_mem(RAX, R11, cap_off);
        if (cap_by_ref == 1) { cg_load_reg_mem(RAX, RAX, 0); }
        cg_normalize_rax(cap_type);
        // save current value in rdx (or xmm1 for float)
        let is_float: i64 = ty_is_float(cap_type);
        if (is_float == 1) {
            // float compound on capture — save lhs in xmm1, eval rhs in xmm0
            cg_movq_xmm_rax(XMM1);  // hmm, need mov xmm1, rax — use SSE move
            // Actually use the movq approach: xmm1 = rax
            // This is a simplification — full float compound on captures is rare
            if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: float compound assign on capture not yet supported"); }
            return 0;
        }
        cg_mov_reg_reg(RDX, RAX);  // rdx = current value (lhs)
        // eval rhs
        let rhs: i64 = value;
        if (postfix == 1) {
            // ++/-- : rhs is implicit 1; return old value
            cg_mov_reg_imm64(RAX, 1);
        } else {
            cg_eval(rhs); if (cg_err != 0) { return 0; }
            cg_normalize_rax(cap_type);
        }
        // apply op: result = lhs OP rhs (rax = rdx OP rax)
        if (cop == (BinOp::Add as i64)) { cg_add_reg_reg(RDX, RAX); }
        else if (cop == (BinOp::Sub as i64)) { cg_sub_reg_reg(RDX, RAX); }
        else if (cop == (BinOp::Mul as i64)) { cg_imul_reg_reg(RDX, RAX); }
        else if (cop == (BinOp::And as i64)) { cg_and_reg_reg(RDX, RAX); }
        else if (cop == (BinOp::Or as i64)) { cg_or_reg_reg(RDX, RAX); }
        else if (cop == (BinOp::Xor as i64)) { cg_xor_reg_reg(RDX, RAX); }
        else { if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unsupported compound op on capture"); } return 0; }
        // rdx = result; for postfix, return old value (lhs was in rdx before op)
        // Actually after op, rdx = lhs OP rhs. For postfix we need old value.
        // Simpler: for postfix, the return value is the old lhs; the stored
        // value is lhs OP 1. Let's just store the result and return it (non-postfix)
        // or handle postfix separately. For now store result.
        cg_mov_reg_reg(RAX, RDX);  // rax = result
        // store back through capture
        cg_load_reg_mem(R11, RBP, cg_lambda_env_off);
        if (cap_by_ref == 1) {
            cg_load_reg_mem(R11, R11, cap_off);
            cg_store_reg_mem(R11, 0, RAX);
        } else {
            cg_store_reg_mem(R11, cap_off, RAX);
        }
        return 0;
    }

    // resolve the target's offset + type (local or global)
    let off: i64 = cg_lookup_local(nk_tok(target));
    let tt: i64 = cg_lookup_local_type(nk_tok(target));
    let mut is_global: i64 = 0;
    let mut g_addend: i64 = 0;
    if (off == 0) {
        let g: i64 = cg_find_global(nk_name(target));
        if (g >= 0) { is_global = 1; g_addend = cg_global_addend(g); }
        else {
            if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: assignment to unknown local '") + nk_name(target) + string_from_slice("'"); }
            return 0;
        }
    }

    // ---- helper: load the target's current value into rax ----
    // (inlined below for each path)

    // ---- helper: store rax to the target ----
    // (inlined below)

    // ---- plain '=' (cop < 0, not postfix) ----
    if (cop < 0 && postfix != 1) {
        // Phase 4: struct-reassignment `s = mk();` where mk() returns a struct
        // and s is a struct-typed local. The target's frame slot is the
        // concrete destination for the callee's hidden return pointer: lea
        // rax, [rbp+off], then the callee writes the struct directly into the
        // target (no register result). (Struct globals by-value assignment is
        // out of the subset; the local path covers the supported cases.)
        if (ty_is_float(tt) == 0 && cg_ty_is_struct(tt) == 1 && nk_kind(value) == (NK::CallExpr as i64)) {
            if (is_global == 0) {
                cg_lea_rax_rbp(off);
                let saved: i64 = cg_struct_ret_dest_ready; cg_struct_ret_dest_ready = 1;
                cg_eval_struct_returning_call(value);
                cg_struct_ret_dest_ready = saved;
                return 0;
            }
        }
        cg_eval(value);
        if (cg_err != 0) { return 0; }
        if (ty_is_float(tt) == 1) {
            // float value is in XMM0; store with the target's width (movsd f64
            // / movss f32). Mirror the compound float path's store.
            let is64: i64 = cg_float_is64_type(tt);
            if (is_global == 1) {
                // float globals are not in Phase 1; defend anyway via rax.
                if (is64 == 1) { cg_movq_rax_xmm(XMM0); } else { cg_movq_rax_xmm(XMM0); }
                cg_emit_abs64_reloc_reg(RCX, CG_RELOC_DATA, 0, g_addend);
                cg_byte(0x48); cg_byte(0x89); cg_byte(0x01);  // mov [rcx], rax
            } else {
                cg_store_float(off, XMM0, is64);
            }
            return 0;
        }
        cg_normalize_rax(tt);
        if (is_global == 1) {
            cg_emit_abs64_reloc_reg(RCX, CG_RELOC_DATA, 0, g_addend);
            cg_byte(0x48); cg_byte(0x89); cg_byte(0x01);  // mov [rcx], rax
        } else {
            cg_store_reg_mem(RBP, off, RAX);
        }
        return 0;
    }

    // ---- compound op= / prefix ++ / postfix ++ ----
    // For postfix, the value is implicit 1 (b == -1); for prefix/compound, b is the value.
    let is_float: i64 = ty_is_float(tt);

    if (is_float == 1) {
        // float compound: load target (lhs) -> xmm0; save on stack; eval value
        // (rhs) -> xmm0; load lhs -> xmm1; apply op; store. For sub/div the
        // operand order matters (lhs OP rhs), so swap: op xmm1, xmm0; mov xmm0, xmm1.
        let is64: i64 = cg_float_is64_type(tt);
        let prefix: i64 = if64_prefix(is64);
        // load target (lhs) -> xmm0
        if (is_global == 1) {
            cg_emit_abs64_reloc_reg(RAX, CG_RELOC_DATA, 0, g_addend);
            cg_byte(0x48); cg_byte(0x8B); cg_byte(0x00);  // mov rax, [rax]
            if (is64 == 1) { cg_movq_xmm_rax(XMM0); } else { cg_movd_xmm_eax(XMM0); }
        } else {
            cg_load_float(XMM0, off, is64);
        }
        // save lhs (xmm0) on the stack
        cg_sub_reg_imm32(RSP, 8);
        if (is64 == 1) { cg_sse_mem(0xF2, 0x11, XMM0, 0); } else { cg_sse_mem(0xF3, 0x11, XMM0, 0); }
        // eval value (rhs) -> xmm0 (or load 1 for ++/--)
        if (postfix == 1 || value < 0) {
            cg_mov_reg_imm64(RAX, 1);
            cg_i64_to_float(XMM0, RAX, is64);
        } else {
            cg_eval(value); if (cg_err != 0) { return 0; }
            if (is64 == 1) { cg_movq_xmm_rax(XMM0); } else { cg_movd_xmm_eax(XMM0); }
        }
        // xmm1 = lhs (reload from stack)
        if (is64 == 1) { cg_sse_mem(0xF2, 0x10, XMM1, 0); } else { cg_sse_mem(0xF3, 0x10, XMM1, 0); }
        cg_add_reg_imm32(RSP, 8);
        // apply the float op. xmm0=rhs, xmm1=lhs. Result = lhs OP rhs.
        //   add/mul: commutative -> op xmm0, xmm1 (xmm0 = xmm0 + xmm1)
        //   sub/div: non-commutative -> op xmm1, xmm0 (xmm1 = xmm1 - xmm0); mov xmm0, xmm1
        if (cop == (BinOp::Add as i64)) { cg_float_op(0x58, is64); }
        else if (cop == (BinOp::Mul as i64)) { cg_float_op(0x59, is64); }
        else if (cop == (BinOp::Sub as i64)) {
            // subsd/ss xmm1, xmm0 (xmm1 = lhs - rhs); movsd/ss xmm0, xmm1
            cg_sse_rr(prefix, 0x5C, XMM1, XMM0);
            cg_sse_rr(prefix, 0x10, XMM0, XMM1);
        }
        else if (cop == (BinOp::Div as i64)) {
            // divsd/ss xmm1, xmm0 (xmm1 = lhs / rhs); movsd/ss xmm0, xmm1
            cg_sse_rr(prefix, 0x5E, XMM1, XMM0);
            cg_sse_rr(prefix, 0x10, XMM0, XMM1);
        }
        // store xmm0 (the new value) to target
        if (is_global == 1) {
            // unreachable for float globals in Phase 1; defend anyway
            cg_movq_rax_xmm(XMM0);
            cg_emit_abs64_reloc_reg(RCX, CG_RELOC_DATA, 0, g_addend);
            cg_byte(0x48); cg_byte(0x89); cg_byte(0x01);
        } else {
            cg_store_float(off, XMM0, is64);
        }
        // postfix float: result = old value. For ++/-- (Add/Sub with 1),
        // old = new ∓ 1. This is an edge case not in the Phase 2 test set;
        // mirror the C++ derive-from-new approach.
        if (postfix == 1) {
            // xmm0 = new value. old = new - 1 (for Add/++) or new + 1 (for Sub/--).
            // Load 1.0 into xmm1, then sub/add.
            cg_mov_reg_imm64(RAX, 1);
            cg_i64_to_float(XMM1, RAX, is64);
            if (cop == (BinOp::Add as i64)) { cg_sse_rr(prefix, 0x5C, XMM0, XMM1); }
            else { cg_sse_rr(prefix, 0x58, XMM0, XMM1); }
        }
        // result in xmm0 (for float) — but the expression result convention is
        // rax for int / xmm0 for float. The caller that use a float assignment
        // result (let y = (x += 1.0);) read xmm0. Return 0 (no error).
        return 0;
    }

    // integer compound / prefix / postfix
    let is_unsigned: i64 = cg_type_is_uint(tt);

    // load target -> rax
    if (is_global == 1) {
        cg_emit_abs64_reloc_reg(RAX, CG_RELOC_DATA, 0, g_addend);
        cg_byte(0x48); cg_byte(0x8B); cg_byte(0x00);  // mov rax, [rax]
        cg_normalize_rax(tt);
    } else {
        cg_load_reg_mem(RAX, RBP, off);
        cg_normalize_rax(tt);
    }

    // For postfix: save the OLD value (push rax) before computing the new one.
    // The C++ codegen pushes the updated value and derives old = new ± 1, but
    // the simpler correct approach is to save old first, then compute new.
    if (postfix == 1) {
        cg_push(RAX);  // save old value
    }

    // save lhs (rax) across value eval
    cg_push(RAX);
    // eval value -> rax (or load 1 for postfix/prefix ++/--)
    if (postfix == 1 || value < 0) {
        cg_mov_reg_imm64(RAX, 1);
    } else {
        cg_eval(value); if (cg_err != 0) { return 0; }
    }
    // rcx = rhs
    cg_mov_reg_reg(RCX, RAX);
    // rax = lhs (pop)
    cg_pop(RAX);

    // apply the integer op (rax = rax OP rcx), mirroring cg_eval_binexpr
    if (cop == (BinOp::Add as i64)) { cg_add_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Sub as i64)) { cg_sub_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Mul as i64)) { cg_imul_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::And as i64)) { cg_and_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Or as i64))  { cg_or_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Xor as i64)) { cg_xor_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Shl as i64)) { cg_shl_reg_cl(RAX); }
    else if (cop == (BinOp::Shr as i64)) {
        if (is_unsigned == 1) { cg_shr_reg_cl(RAX); } else { cg_sar_reg_cl(RAX); }
    }
    else if (cop == (BinOp::Div as i64)) {
        if (is_unsigned == 1) { cg_byte(0x48); cg_byte(0x31); cg_byte(0xD2); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF1); }
        else { cg_byte(0x48); cg_byte(0x99); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF9); }
    }
    else if (cop == (BinOp::Mod as i64)) {
        if (is_unsigned == 1) { cg_byte(0x48); cg_byte(0x31); cg_byte(0xD2); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF1); }
        else { cg_byte(0x48); cg_byte(0x99); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF9); }
        cg_mov_reg_reg(RAX, RDX);  // mod: result in rdx
    }
    // normalize the new value to the target type
    cg_normalize_rax(tt);

    // store the new value to the target
    if (is_global == 1) {
        // save rax (the new value) before emitting the data pointer (which uses rcx)
        // mov rcx, <data ptr>; mov [rcx], rax
        cg_emit_abs64_reloc_reg(RCX, CG_RELOC_DATA, 0, g_addend);
        cg_byte(0x48); cg_byte(0x89); cg_byte(0x01);  // mov [rcx], rax
    } else {
        cg_store_reg_mem(RBP, off, RAX);
    }

    // postfix: expression result = OLD value (saved on stack before the op)
    if (postfix == 1) {
        cg_pop(RAX);  // restore old value (the expression result)
    }
    // for compound/prefix: expression result = new value (already in rax)
    return 0;
}

// -----------------------------------------------------------------------------
// Phase 3: FieldExpr / IndexExpr assignment targets. The lvalue address +
// element type are resolved, then the plain/compound/postfix store mirrors the
// Ident assignment path but with the field's/element's packed offset + width.
// -----------------------------------------------------------------------------

// resolve a FieldExpr lvalue to (base offset, field offset, field type).
// base must be a bare local Ident of a struct type (v1 scope, mirroring the
// C++ codegen). Returns the field's absolute rbp offset in `out_off` (via the
// global scratch) and the field type via cg_struct_field_type_at.
//
// Computes: base_off = cg_lookup_local(base_tok); field_off = struct field
// offset; addr = base_off + field_off; ft = field type.
// On error sets cg_err. The field type is returned; the address is returned
// via the second result channel (a global, since ember has no multi-return).
global cg_lvalue_addr : i64 = 0;
global cg_lvalue_type : i64 = 0;

fn cg_resolve_field_lvalue(target: i64) -> i64 {
    let base: i64 = nk_a(target);
    if (nk_kind(base) != (NK::Ident as i64)) { cg_err = 1; cg_errmsg = string_from_slice("codegen: field-assign base must be a local"); return -1; }
    let boff: i64 = cg_lookup_local(nk_tok(base));
    let bt: i64 = cg_lookup_local_type(nk_tok(base));
    let row: i64 = find_struct(ty_struct_name(bt));
    let idx: i64 = cg_struct_field_index(bt, nk_name(target));
    if (row < 0 || idx < 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unknown field in assignment"); return -1; }
    let foff: i64 = cg_struct_field_offset(row, idx);
    let ft: i64 = cg_struct_field_type_at(row, idx);
    cg_lvalue_addr = boff + foff;
    cg_lvalue_type = ft;
    return ft;
}

// p.x = value / p.x op= value / p.x++ / ++p.x. The field address + type are
// compile-time-known (no index computation), so this mirrors the Ident path
// with the field's offset + width substituted for the local slot.
fn cg_assign_field(target: i64, value: i64, cop: i64, postfix: i64) -> i64 {
    let ft: i64 = cg_resolve_field_lvalue(target);
    if (cg_err != 0) { return 0; }
    let addr: i64 = cg_lvalue_addr;
    let is_float: i64 = ty_is_float(ft);

    // plain '=' (cop < 0, not postfix)
    if (cop < 0 && postfix != 1) {
        cg_eval(value); if (cg_err != 0) { return 0; }
        if (is_float == 1) { cg_store_float(addr, XMM0, cg_float_is64_type(ft)); }
        else { cg_normalize_rax(ft); cg_store_typed(RBP, addr, ft); }
        return 0;
    }

    // compound op= / prefix ++ / postfix ++ (integer + float paths)
    if (is_float == 1) {
        let is64: i64 = cg_float_is64_type(ft);
        let prefix: i64 = if64_prefix(is64);
        // load field (lhs) -> xmm0
        cg_load_float(XMM0, addr, is64);
        cg_sub_reg_imm32(RSP, 8);
        if (is64 == 1) { cg_sse_mem(0xF2, 0x11, XMM0, 0); } else { cg_sse_mem(0xF3, 0x11, XMM0, 0); }
        if (postfix == 1 || value < 0) { cg_mov_reg_imm64(RAX, 1); cg_i64_to_float(XMM0, RAX, is64); }
        else { cg_eval(value); if (cg_err != 0) { return 0; } if (is64 == 1) { cg_movq_xmm_rax(XMM0); } else { cg_movd_xmm_eax(XMM0); } }
        if (is64 == 1) { cg_sse_mem(0xF2, 0x10, XMM1, 0); } else { cg_sse_mem(0xF3, 0x10, XMM1, 0); }
        cg_add_reg_imm32(RSP, 8);
        if (cop == (BinOp::Add as i64)) { cg_float_op(0x58, is64); }
        else if (cop == (BinOp::Mul as i64)) { cg_float_op(0x59, is64); }
        else if (cop == (BinOp::Sub as i64)) { cg_sse_rr(prefix, 0x5C, XMM1, XMM0); cg_sse_rr(prefix, 0x10, XMM0, XMM1); }
        else if (cop == (BinOp::Div as i64)) { cg_sse_rr(prefix, 0x5E, XMM1, XMM0); cg_sse_rr(prefix, 0x10, XMM0, XMM1); }
        cg_store_float(addr, XMM0, is64);
        if (postfix == 1) { cg_mov_reg_imm64(RAX, 1); cg_i64_to_float(XMM1, RAX, is64); if (cop == (BinOp::Add as i64)) { cg_sse_rr(prefix, 0x5C, XMM0, XMM1); } else { cg_sse_rr(prefix, 0x58, XMM0, XMM1); } }
        return 0;
    }

    // integer compound / prefix / postfix
    let is_unsigned: i64 = cg_type_is_uint(ft);
    // load field -> rax (with width + sign extension)
    cg_load_typed(RAX, RBP, addr, ft);
    cg_normalize_rax(ft);
    if (postfix == 1) { cg_push(RAX); }
    cg_push(RAX);
    if (postfix == 1 || value < 0) { cg_mov_reg_imm64(RAX, 1); }
    else { cg_eval(value); if (cg_err != 0) { return 0; } }
    cg_mov_reg_reg(RCX, RAX);
    cg_pop(RAX);
    if (cop == (BinOp::Add as i64)) { cg_add_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Sub as i64)) { cg_sub_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Mul as i64)) { cg_imul_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::And as i64)) { cg_and_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Or as i64))  { cg_or_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Xor as i64)) { cg_xor_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Shl as i64)) { cg_shl_reg_cl(RAX); }
    else if (cop == (BinOp::Shr as i64)) { if (is_unsigned == 1) { cg_shr_reg_cl(RAX); } else { cg_sar_reg_cl(RAX); } }
    else if (cop == (BinOp::Div as i64)) { if (is_unsigned == 1) { cg_byte(0x48); cg_byte(0x31); cg_byte(0xD2); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF1); } else { cg_byte(0x48); cg_byte(0x99); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF9); } }
    else if (cop == (BinOp::Mod as i64)) { if (is_unsigned == 1) { cg_byte(0x48); cg_byte(0x31); cg_byte(0xD2); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF1); } else { cg_byte(0x48); cg_byte(0x99); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF9); } cg_mov_reg_reg(RAX, RDX); }
    cg_normalize_rax(ft);
    cg_store_typed(RBP, addr, ft);
    if (postfix == 1) { cg_pop(RAX); }
    return 0;
}

// a[i] = value (IndexExpr target). STEP 2 fills this in for fixed arrays +
// STEP 3 for slices. Until then sema rejects IndexExpr targets, so this is
// unreachable; keep a defensive error.
fn cg_assign_index(target: i64, value: i64, cop: i64, postfix: i64) -> i64 {
    return cg_assign_index_impl(target, value, cop, postfix);
}
// a[i] = value / a[i] op= value / a[i]++ (IndexExpr target). Mirrors
// src/codegen.cpp's AssignExpr IndexExpr-target store path. The value is
// eval'd + stashed, the element address is computed (base + index*elem_sz,
// with the same bounds check as the load path), then the value is stored with
// the element width. v1: plain '=' only for index targets (the test set uses
// plain assignment); compound/postfix on an index is a straightforward
// extension but not yet exercised.
fn cg_assign_index_impl(target: i64, value: i64, cop: i64, postfix: i64) -> i64 {
    let base: i64 = nk_a(target);
    if (nk_kind(base) != (NK::Ident as i64)) { cg_err = 1; cg_errmsg = string_from_slice("codegen: index-assign base must be a local"); return 0; }
    let boff: i64 = cg_lookup_local(nk_tok(base));
    let bt: i64 = cg_lookup_local_type(nk_tok(base));
    let mut is_sl: i64 = 0;
    if (bt >= 0 && nk_kind(bt) == (NK::Type as i64)) { is_sl = nk_f(bt); }
    let elem_ty: i64 = resolve_type(nk_a(bt));
    if (cg_err != 0) { return 0; }
    let elem_sz: i64 = cg_value_bytes(elem_ty);
    let mut arr_len: i64 = 0;
    if (bt >= 0) { arr_len = nk_e(bt); }
    // only plain '=' is supported for index targets in v1
    if (cop >= 0 || postfix == 1) { cg_err = 1; cg_errmsg = string_from_slice("codegen: compound/postfix assignment to an index not yet supported"); return 0; }
    // eval value -> rax (int) or xmm0 (float); stash it across address computation
    let is_float: i64 = ty_is_float(elem_ty);
    if (is_float == 1) {
        cg_eval(value); if (cg_err != 0) { return 0; }
        cg_sub_reg_imm32(RSP, 8);
        let is64: i64 = cg_float_is64_type(elem_ty);
        cg_store_float_reg(RSP, 0, XMM0, is64);
    } else {
        cg_eval(value); if (cg_err != 0) { return 0; }
        cg_normalize_rax(elem_ty);
        cg_push(RAX);
    }
    // base address -> r11 (survives index eval). slice: ptr+len; fixed: lea.
    if (is_sl == 1) {
        cg_load_reg_mem(R11, RBP, boff);
        cg_load_reg_mem(R9, RBP, boff + 8);
    } else {
        cg_lea_r11_rbp(boff);
    }
    // eval index -> rax
    cg_eval(nk_b(target)); if (cg_err != 0) { return 0; }
    if (is_sl == 1) {
        cg_bounds_check_reg_rax_r9();
    } else if (nk_kind(nk_b(target)) != (NK::IntLit as i64)) {
        cg_bounds_check_imm_rax(arr_len);
    }
    if (elem_sz > 1) { cg_mov_reg_imm64(RCX, elem_sz); cg_imul_reg_reg(RAX, RCX); }
    cg_add_reg_reg(R11, RAX);   // r11 = element address
    // store the stashed value to [r11] with the element width
    if (is_float == 1) {
        let is64: i64 = cg_float_is64_type(elem_ty);
        cg_load_float_reg(XMM1, RSP, 0, is64);
        cg_add_reg_imm32(RSP, 8);
        cg_store_float_reg(R11, 0, XMM1, is64);
    } else {
        cg_pop(RAX);
        cg_store_rax_elem(R11, 0, elem_sz);
    }
    return 0;
}

// -----------------------------------------------------------------------------
// Phase 2 Step 2: CastExpr (expr as Type). Mirrors src/codegen.cpp's CastExpr
// lowering. The operand is eval'd into rax (int) or xmm0 (float), then
// converted to the target type:
//   - same type: no-op
//   - int->int: normalize_rax(to) (sign/zero-extend or truncate via the
//     shift-then-shift normalize)
//   - f32->f64: cvtss2sd (F3 0F 5A C0)
//   - f64->f32: cvtsd2ss (F2 0F 5A C0)
//   - signed int -> float: normalize_rax(from) + cvtsi2ss/sd (F3/F2 48 0F 2A C0)
//   - float -> signed int: cvttsi2ss/sd (F3/F2 48 0F 2C C0) + normalize_rax(to)
// -----------------------------------------------------------------------------
fn cg_eval_castexpr(e: i64) -> i64 {
    let operand: i64 = nk_a(e);
    let to: i64 = resolve_type(nk_b(e));
    if (cg_err != 0) { return 0; }
    let from: i64 = cg_expr_type(operand);
    // same-type scalar: no-op (just eval the operand)
    if (type_eq(from, to) == 1) { cg_eval(operand); return 0; }
    // int -> int: eval operand, normalize to target width
    if (cg_type_is_int(from) == 1 && cg_type_is_int(to) == 1) {
        cg_eval(operand); if (cg_err != 0) { return 0; }
        cg_normalize_rax(to);
        return 0;
    }
    // Phase 3b: typed-enum -> int cast (the explicit spelling of enum->backing
    // widening). The operand's backing value is already in rax; normalize to
    // the target int width. Mirrors src/codegen.cpp's CastExpr, where a
    // typed-enum `from` has is_int() && struct_name.empty() so it lands in the
    // plain int->int normalize_rax(to) path.
    if (is_typed_enum_type(from) == 1 && cg_type_is_int(to) == 1) {
        cg_eval(operand); if (cg_err != 0) { return 0; }
        cg_normalize_rax(to);
        return 0;
    }
    // float -> float: cvtss2sd (f32->f64) or cvtsd2ss (f64->f32)
    if (ty_is_float(from) == 1 && ty_is_float(to) == 1) {
        cg_eval(operand); if (cg_err != 0) { return 0; }
        if (nk_d(from) == (Prim::F32 as i64) && nk_d(to) == (Prim::F64 as i64)) {
            // cvtss2sd xmm0, xmm0 -> F3 0F 5A C0
            cg_byte(0xF3); cg_byte(0x0F); cg_byte(0x5A); cg_byte(0xC0);
        } else {
            // cvtsd2ss xmm0, xmm0 -> F2 0F 5A C0
            cg_byte(0xF2); cg_byte(0x0F); cg_byte(0x5A); cg_byte(0xC0);
        }
        return 0;
    }
    // signed int -> float: normalize the int, then cvtsi2ss/sd rax -> xmm0
    if (cg_type_is_int(from) == 1 && ty_is_uint(from) == 0 && ty_is_float(to) == 1) {
        cg_eval(operand); if (cg_err != 0) { return 0; }
        cg_normalize_rax(from);
        // cvtsi2sd xmm0, rax (f64) -> F2 48 0F 2A C0
        // cvtsi2ss xmm0, rax (f32) -> F3 48 0F 2A C0
        if (nk_d(to) == (Prim::F64 as i64)) { cg_byte(0xF2); } else { cg_byte(0xF3); }
        cg_byte(0x48); cg_byte(0x0F); cg_byte(0x2A); cg_byte(0xC0);
        return 0;
    }
    // float -> signed int: cvttsi2ss/sd xmm0 -> rax (truncate toward zero),
    // then normalize to the target int width.
    if (ty_is_float(from) == 1 && cg_type_is_int(to) == 1 && ty_is_uint(to) == 0) {
        cg_eval(operand); if (cg_err != 0) { return 0; }
        // cvttsi2si rax, xmm0 (f64->i64) -> F2 48 0F 2C C0
        // cvttsi2si rax, xmm0 (f32->i64) -> F3 48 0F 2C C0
        // (the 64-bit form is used for all int widths; normalize_rax narrows)
        if (nk_d(from) == (Prim::F64 as i64)) { cg_byte(0xF2); } else { cg_byte(0xF3); }
        cg_byte(0x48); cg_byte(0x0F); cg_byte(0x2C); cg_byte(0xC0);
        cg_normalize_rax(to);
        return 0;
    }
    // unreachable: sema's cast matrix rejects anything else
    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: invalid cast from ") + ty_name(from) + string_from_slice(" to ") + ty_name(to); }
    return 0;
}

// -----------------------------------------------------------------------------
// Phase 2 Step 4: TernaryExpr (cond ? then : else). Mirrors src/codegen.cpp:
//   eval cond -> rax; cmp rax, 0; jz else; eval then -> rax; jmp end; else:
//   eval else -> rax; end: Result in rax.
// -----------------------------------------------------------------------------
fn cg_eval_ternaryexpr(e: i64) -> i64 {
    let cond: i64 = nk_a(e);
    let then_e: i64 = nk_b(e);
    let else_e: i64 = nk_c(e);
    cg_eval(cond); if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    let else_l: i64 = cg_alloc_label();
    let end_l: i64 = cg_alloc_label();
    cg_jcc(COND_E, else_l);       // cond == 0 -> else
    cg_eval(then_e); if (cg_err != 0) { return 0; }
    cg_jmp(end_l);
    cg_bind(else_l);
    cg_eval(else_e); if (cg_err != 0) { return 0; }
    cg_bind(end_l);
    return 0;
}

// -----------------------------------------------------------------------------
// Phase 2 Step 5: SizeofExpr + OffsetofExpr. Both are COMPILE-TIME CONSTANTS
// (sema resolved them). The codegen emits `mov rax, <constant>`. For
// primitives, cg_type_size gives the size; offsetof of a primitive field is
// rejected by sema (no fields). Struct sizeof/offsetof complete in Phase 3.
// Mirrors src/codegen.cpp: mov_reg_imm64(Reg::rax, int64_t(s->resolved)).
// -----------------------------------------------------------------------------
fn cg_eval_sizeofexpr(e: i64) -> i64 {
    let t: i64 = resolve_type(nk_a(e));
    if (cg_err != 0) { return 0; }
    let sz: i64 = cg_type_size(t);
    cg_mov_reg_imm64(RAX, sz);
    return 0;
}

fn cg_eval_offsetofexpr(e: i64) -> i64 {
    // Phase 3: offsetof of a struct field = the field's packed offset. For
    // primitives there are no fields (sema rejects). Mirror src/codegen.cpp:
    // mov rax, <field_offset>.
    let t: i64 = resolve_type(nk_a(e));
    if (cg_err != 0) { return 0; }
    let row: i64 = find_struct(ty_struct_name(t));
    if (row < 0) { cg_mov_reg_imm64(RAX, 0); return 0; }
    let idx: i64 = cg_struct_field_index(t, tok_name(nk_tok(e)));
    if (idx < 0) { cg_mov_reg_imm64(RAX, 0); return 0; }
    cg_mov_reg_imm64(RAX, cg_struct_field_offset(row, idx));
    return 0;
}

// evaluate a call expression.
// Two call kinds:
//   - SCRIPT call: find_fn(name) >= 0. Emit a direct `call rel32` to the
//     callee's entry label (patched by cg_resolve_fixups to the callee's
//     prologue offset within the same code section). The loader does NOT touch
//     rel32 — it resolves within the RX code region.
//   - NATIVE call: find_fn(name) < 0 (a host extension native). Eval args into
//     rcx/rdx/r8/r9 (Win64), then emit `mov rax, 0` + an ABS64_NATIVE reloc
//     (sym_idx = cg_sym_index(name), addend = the ABI fingerprint) + `call rax`.
//     The loader resolves the symbol against the host's registered NativeSig
//     table, validates the fingerprint, and patches the imm64 with the native's
//     fn_ptr. The fingerprint is computed from the call's arg types + return
//     type (annotated by sema) using the EXACT type-code table
//     (module_abi_fingerprint.hpp), so it matches the host's registered sig.
//
// Win64: first 4 int args in rcx/rdx/r8/r9. Args are eval'd into stack temps
// first (eval may clobber a placed register), then loaded into registers in
// order — the same stash-then-load pattern the C++ codegen uses.
fn cg_eval_indirect_lambda_call(e: i64) -> i64 {
    let mut argc: i64 = 0; let mut a: i64 = nk_a(e); while (a >= 0) { argc = argc + 1; a = nk_next(a); }
    let frame: i64 = cg_round16((argc + 2) * 8 + 32); cg_sub_reg_imm32(RSP, frame);
    cg_eval(nk_e(e)); if (cg_err != 0) { return 0; }
    cg_store_reg_mem(RSP, 0, RAX); cg_store_reg_mem(RSP, 8, RDX);
    a = nk_a(e); let mut i: i64 = 0;
    while (a >= 0) { cg_eval(a); if (cg_err != 0) { return 0; } cg_store_reg_mem(RSP, 16 + i * 8, RAX); i = i + 1; a = nk_next(a); }
    cg_load_reg_mem(RAX, RSP, 0); cg_load_reg_mem(RCX, RSP, 8);
    if (argc >= 1) { cg_load_reg_mem(RDX, RSP, 16); }
    if (argc >= 2) { cg_load_reg_mem(R8, RSP, 24); }
    if (argc >= 3) { cg_load_reg_mem(R9, RSP, 32); }
    cg_emit_abs64_reloc_reg(R11, CG_RELOC_DISPATCH, 0, 0);
    cg_lea_scaled8(R11, R11, RAX); cg_load_reg_mem(R11, R11, 0); cg_call_reg(R11);
    cg_add_reg_imm32(RSP, frame); return 0;
}

fn cg_eval_callexpr(e: i64) -> i64 {
    let name: string = nk_name(e);
    if (nk_d(e) == 2) { return cg_eval_indirect_lambda_call(e); }

    // ---- string_from_slice(<StringLit>) special case ----
    // The host registers string_from_slice with a u8-slice param (ABI code 5,
    // passed as two words ptr+len). The self-hosted subset types a string
    // literal as TY_STRING (a handle), and cg_eval_string_lit ALREADY
    // materializes a literal by emitting the rodata slice + a real
    // string_from_slice(ptr,len) call -> handle in rax. So a user-written
    // `string_from_slice("lit")` is semantically identical to the bare literal
    // `"lit"` (same handle): evaluate the literal directly. This avoids the
    // generic path's 1-word handle ABI (which would mismatch the slice native)
    // and produces the exact handle the host would. (A non-literal arg is an
    // edge case the subset does not support; it falls through to the generic
    // path, which is best-effort.)
    if (name == string_from_slice("string_from_slice")) {
        let mut a0: i64 = nk_a(e);
        if (a0 >= 0 && nk_kind(a0) == (NK::StringLit as i64) && nk_next(a0) < 0) {
            return cg_eval_string_lit(a0);
        }
    }

    // determine script vs native + the fn row. Tier 1 namespaces: a Foo::bar()
    // call (base name tok in slot e) resolves to the qualified Ns::fn row; a
    // bare call inside a namespaced fn first tries the sibling Ns::fn row.
    let mut fn_row: i64 = -1;
    let mut is_ns_call: i64 = 0;
    let mod_tok: i64 = nk_e(e);
    if (mod_tok >= 0) {
        let mod_name: string = tok_text_at(mod_tok);
        if (is_namespace_name(mod_name) == 1) {
            is_ns_call = 1;
            fn_row = find_fn_qualified(name, mod_name);
        }
    }
    if (is_ns_call == 0) {
        fn_row = find_fn(name);
        if (fn_row < 0 && cg_cur_ns >= 0) {
            let qrow: i64 = find_fn_qualified(name, tok_name(cg_cur_ns));
            if (qrow >= 0) { fn_row = qrow; }
        }
    }
    let mut is_native: i64 = 0;
    if (fn_row < 0) { is_native = 1; }

    // Phase 4: a struct-returning script call uses the hidden-pointer sret
    // ABI. The caller context (LetStmt init / ReturnStmt value / AssignExpr
    // value / a struct-arg stash) has already loaded the destination address
    // into rax. Route to cg_eval_struct_returning_call, which places the dest
    // at word 0 + the real args from word 1 and calls; the callee writes the
    // struct through the dest (no register result). sema guarantees a
    // struct-returning call only appears in those contexts, so reaching here
    // with rax unset is a sema gap (defensive: rax holds garbage, but the
    // callee would write to a garbage address — flag an error instead).
    if (is_native == 0 && cg_ty_is_struct(nk_c(e)) == 1) {
        if (cg_struct_ret_dest_ready == 0) {
            if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: struct-returning call used without a destination"); }
            return 0;
        }
        return cg_eval_struct_returning_call(e);
    }

    // count args (walk the sibling chain via nk_next). The arg node indices
    // are NOT pre-collected into an array — the previous design allocated a
    // fresh `args` array on every call expression and read it AFTER recursively
    // evaluating each arg (cg_eval can recurse into cg_eval_callexpr for nested
    // call args), which both leaked a slot per call (no array_free in the host
    // extension) and made a reused global unsafe. Instead we count now and
    // re-walk the chain during evaluation, so no scratch array is needed.
    let mut argc: i64 = 0;
    {
        let mut a: i64 = nk_a(e);
        while (a >= 0) {
            argc = argc + 1;
            a = nk_next(a);
        }
    }
    // ---- NATIVE call path (no struct args: natives don't take structs in
    // the subset; args are 1 word each, rcx/rdx/r8/r9 + stack) ----
    if (is_native == 1) {
        // call_frame = round16(argc*8 + 32), minimum 32. Args stored at
        // [rsp + i*8]; args 0-3 loaded to regs, args 4+ stay (callee reads at
        // [rbp+48+(i-4)*8] = caller [rsp+32+(i-4)*8] = [rsp+i*8]).
        let mut call_frame: i64 = argc * 8 + 32;
        if (call_frame < 32) { call_frame = 32; }
        call_frame = cg_round16(call_frame);
        cg_sub_reg_imm32(RSP, call_frame);
        // eval each arg -> rax (int/handle) or xmm0 (float); store to [rsp+i*8].
        {
            let mut i2: i64 = 0;
            let mut a: i64 = nk_a(e);
            while (a >= 0) {
                cg_eval(a);
                if (cg_err != 0) { return 0; }
                if (cg_arg_is_float(name, i2) == 1) {
                    let is64: i64 = cg_arg_is_f64(name, i2);
                    cg_store_float_reg(RSP, i2 * 8, XMM0, is64);
                } else {
                    cg_store_reg_mem(RSP, i2 * 8, RAX);
                }
                i2 = i2 + 1;
                a = nk_next(a);
            }
        }
        if (argc >= 1) {
            if (cg_arg_is_float(name, 0) == 1) { cg_load_float_reg(XMM0, RSP, 0,  cg_arg_is_f64(name, 0)); }
            else { cg_load_reg_mem(RCX, RSP, 0); }
        }
        if (argc >= 2) {
            if (cg_arg_is_float(name, 1) == 1) { cg_load_float_reg(XMM1, RSP, 8,  cg_arg_is_f64(name, 1)); }
            else { cg_load_reg_mem(RDX, RSP, 8); }
        }
        if (argc >= 3) {
            if (cg_arg_is_float(name, 2) == 1) { cg_load_float_reg(XMM2, RSP, 16, cg_arg_is_f64(name, 2)); }
            else { cg_load_reg_mem(R8, RSP, 16); }
        }
        if (argc >= 4) {
            if (cg_arg_is_float(name, 3) == 1) { cg_load_float_reg(XMM3, RSP, 24, cg_arg_is_f64(name, 3)); }
            else { cg_load_reg_mem(R9, RSP, 24); }
        }
        let sym_idx: i64 = cg_sym_index(name);
        // build the fingerprint from the native's declared param types (not the
        // call's arg types) so it matches the host's registered sig even when
        // an arg adapts (e.g. an IntLit to an i64 param, f32->f64 widening).
        let param_types: i64 = cg_fp_types_get();
        let mut j: i64 = 0;
        while (j < argc && j < 4) {
            array_set_i64(param_types, j, native_param_type(name, j));
            j = j + 1;
        }
        let ret_type: i64 = native_ret_type(name);
        let perm: i64 = native_perm(name);
        let mut fp: i64 = cg_abi_fingerprint(param_types, argc, ret_type, perm);
        // The host marks coroutine_start's first i64-shaped parameter as a
        // function handle (ABI code 6), even though source-level checking uses
        // i64 slots. Match that registered fingerprint exactly.
        if (name == string_from_slice("coroutine_start")) {
            let codes: i64 = cg_fp_codes_get(); array_set_i64(codes, 0, 6); array_set_i64(codes, 1, 1);
            fp = cg_abi_fingerprint_codes(codes, 2, 1, 0);
        }
        cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
        cg_call_reg(RAX);  // call rax (FF D0)
        cg_add_reg_imm32(RSP, call_frame);
        // result convention: float -> xmm0; int/handle/u8 -> rax (normalize
        // narrow ints); void -> 0. Annotate the call's type on slot c.
        set_c(e, ret_type);
        if (ty_is_float(ret_type) == 1) { return 0; }
        if (ty_is_void(ret_type) == 1) { cg_mov_reg_imm64(RAX, 0); return 0; }
        cg_normalize_rax(ret_type);
        return 0;
    }

    // ---- SCRIPT call path (Phase 4: word-slot-aware for struct args) ----
    // Each operand occupies cg_words_for_type(pt) consecutive 8-byte words:
    // 1 for a scalar/float/handle, 2 for a slice, ceil(size/8) for a struct.
    // A struct arg is copied via cg_stash_struct_arg (a bare Ident copies from
    // its frame slot; a StructLit / struct-returning CallExpr materializes into
    // a fresh temp first). Words 0-3 -> rcx/rdx/r8/r9; words 4+ stay at
    // [rsp+w*8] (callee reads at [rbp+48+(w-4)*8] = caller [rsp+w*8]).
    let mut total_words: i64 = 0;
    {
        let mut i0: i64 = 0;
        while (i0 < argc) { total_words = total_words + cg_words_for_type(fn_param_type(fn_row, i0)); i0 = i0 + 1; }
    }
    let mut call_frame: i64 = total_words * 8 + 32;
    if (call_frame < 32) { call_frame = 32; }
    call_frame = cg_round16(call_frame);
    cg_sub_reg_imm32(RSP, call_frame);

    // stash each arg operand to its cumulative word slot(s). next_slot is the
    // running word index. A struct arg is copied via cg_stash_struct_arg (a
    // bare Ident from its frame slot; a StructLit / struct-returning CallExpr
    // materialized into a fresh temp via cg_alloc_struct_temp); a slice arg
    // stores rax+rdx (2 words); a scalar/float arg evals + stores 1 word.
    let mut next_slot: i64 = 0;
    {
        let mut a: i64 = nk_a(e);
        let mut i2: i64 = 0;
        while (a >= 0) {
            let pt: i64 = fn_param_type(fn_row, i2);
            let off: i64 = next_slot * 8;
            if (cg_ty_is_struct(pt) == 1) {
                cg_stash_struct_arg(a, pt, off);
                if (cg_err != 0) { return 0; }
                next_slot = next_slot + cg_words_for_type(pt);
            } else if (nk_f(pt) == 1 || nk_f(pt) == 2) {
                // slice/closure arg: {rax=word0, rdx=word1} (2 words)
                cg_eval(a); if (cg_err != 0) { return 0; }
                cg_store_reg_mem(RSP, off, RAX);
                cg_store_reg_mem(RSP, off + 8, RDX);
                next_slot = next_slot + 2;
            } else if (ty_is_float(pt) == 1) {
                cg_eval(a); if (cg_err != 0) { return 0; }
                cg_store_float(off, XMM0, cg_float_is64_type(pt));
                next_slot = next_slot + 1;
            } else {
                cg_eval(a); if (cg_err != 0) { return 0; }
                cg_normalize_rax(pt);
                cg_store_reg_mem(RSP, off, RAX);
                next_slot = next_slot + 1;
            }
            a = nk_next(a);
            i2 = i2 + 1;
        }
    }

    // place words 0..3 into the Win64 int registers (struct words are always
    // integer at the word level — a struct's float field lives inside the
    // copied byte blob, not in an xmm arg slot).
    if (total_words >= 1) { cg_load_reg_mem(RCX, RSP, 0); }
    if (total_words >= 2) { cg_load_reg_mem(RDX, RSP, 8); }
    if (total_words >= 3) { cg_load_reg_mem(R8, RSP, 16); }
    if (total_words >= 4) { cg_load_reg_mem(R9, RSP, 24); }

    // SCRIPT call: a direct call rel32 to the callee's entry label.
    // cg_fn_labels maps the callee's name to a label bound at its prologue
    // offset; the rel32 fixup is patched after all fns are compiled.
    let callee_label: i64 = cg_callee_label(e, is_ns_call, mod_tok);
    if (cg_err != 0) { return 0; }
    cg_call_rel32(callee_label);

    // add rsp, call_frame (restore the stack)
    cg_add_reg_imm32(RSP, call_frame);

    // result is in rax; normalize narrow int returns at the call boundary.
    let sret: i64 = nk_c(e);
    cg_normalize_rax(sret);
    return 0;
}

// -----------------------------------------------------------------------------
// Phase 4: struct by-value call ABI helpers.
// -----------------------------------------------------------------------------

// resolve a CallExpr's callee entry label (direct + namespace-qualified +
// intra-namespace bare call). Returns the label id or -1 (sets cg_err).
fn cg_callee_label(e: i64, is_ns_call: i64, mod_tok: i64) -> i64 {
    let name: string = nk_name(e);
    let mut lab: i64 = -1;
    if (is_ns_call == 1) {
        let mod_name: string = tok_text_at(mod_tok);
        lab = cg_lookup_fn_label_qualified(name, mod_name);
    } else {
        lab = cg_lookup_fn_label(name);
        if (lab < 0 && cg_cur_ns >= 0) {
            let qlab: i64 = cg_lookup_fn_label_qualified(name, tok_name(cg_cur_ns));
            if (qlab >= 0) { lab = qlab; }
        }
    }
    if (lab < 0) {
        if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: no entry label for function '") + name + string_from_slice("'"); }
    }
    return lab;
}

// Stash a struct-by-value call argument into the call's arg-stash region at
// [rsp+off]. Mirrors src/codegen.cpp's stash_struct_arg. sema's
// check_struct_arg_shape permits three shapes: a bare local Ident (copy from
// its frame slot), a StructLit of the matching struct (materialize into a
// fresh temp, then copy), or a struct-returning CallExpr of the matching
// struct (lea the temp's address into rax, eval_struct_returning_call writes
// through it into the temp, then copy). A non-Ident arg gets its OWN fresh
// temp via cg_alloc_struct_temp (distinct per call site). Returns 0.
fn cg_stash_struct_arg(arg_e: i64, t: i64, off: i64) -> i64 {
    let k: i64 = nk_kind(arg_e);
    let row: i64 = find_struct(ty_struct_name(t));
    if (row < 0) { if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: struct arg of unknown struct"); } return 0; }
    let nb: i64 = cg_struct_value_bytes(row);
    if (k == (NK::Ident as i64)) {
        let src_off: i64 = cg_lookup_local(nk_tok(arg_e));
        if (src_off == 0) { if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: struct arg local not found"); } return 0; }
        cg_copy_bytes(RSP, off, RBP, src_off, nb);
        return 0;
    }
    if (k == (NK::StructLit as i64)) {
        let temp_off: i64 = cg_alloc_struct_temp(nb);
        cg_store_struct_lit(arg_e, t, temp_off);
        if (cg_err != 0) { return 0; }
        cg_copy_bytes(RSP, off, RBP, temp_off, nb);
        return 0;
    }
    if (k == (NK::CallExpr as i64)) {
        let temp_off: i64 = cg_alloc_struct_temp(nb);
        // lea rax, [rbp+temp_off] (the hidden dest pointer), then the callee
        // writes the struct directly into the temp.
        cg_lea_rax_rbp(temp_off);
        let saved: i64 = cg_struct_ret_dest_ready; cg_struct_ret_dest_ready = 1;
        cg_eval_struct_returning_call(arg_e);
        cg_struct_ret_dest_ready = saved;
        if (cg_err != 0) { return 0; }
        cg_copy_bytes(RSP, off, RBP, temp_off, nb);
        return 0;
    }
    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: struct-by-value arg is not a local/literal/call"); }
    return 0;
}

// Evaluate a struct-returning CallExpr, forwarding the dest pointer (already
// loaded into rax by the caller — a local's frame address via lea for a
// let-init/assignment, a temp's address for a struct arg, or this fn's own
// incoming hidden return pointer for a `return f(...)` forward) as the hidden
// word-0 argument. Mirrors src/codegen.cpp's eval_struct_returning_call: real
// args start at word 1, the dest occupies word 0. The callee writes the struct
// through the dest — no register result is propagated. Returns 0 on success.
fn cg_eval_struct_returning_call(e: i64) -> i64 {
    let name: string = nk_name(e);
    // resolve script fn row + callee label (the subset has no native that
    // returns a struct; a struct-returning call is always a script fn).
    let mut fn_row: i64 = -1;
    let mut is_ns_call: i64 = 0;
    let mod_tok: i64 = nk_e(e);
    if (mod_tok >= 0) {
        let mod_name: string = tok_text_at(mod_tok);
        if (is_namespace_name(mod_name) == 1) { is_ns_call = 1; fn_row = find_fn_qualified(name, mod_name); }
    }
    if (is_ns_call == 0) {
        fn_row = find_fn(name);
        if (fn_row < 0 && cg_cur_ns >= 0) {
            let qrow: i64 = find_fn_qualified(name, tok_name(cg_cur_ns));
            if (qrow >= 0) { fn_row = qrow; }
        }
    }
    if (fn_row < 0) { if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: struct-returning call to unknown function '") + name + string_from_slice("'"); } return 0; }

    // Build the operand list with cumulative word slots. Word 0 is reserved
    // for the hidden dest pointer (already in rax); real args start at word 1.
    // The subset has no native struct-returning calls + no receiver, so the
    // operand list is just the user args. We compute the per-arg word count +
    // slot0 on the fly, mirroring the native add_operand/next_slot scheme.
    let nargs: i64 = fn_param_count(fn_row);
    // total words = 1 (dest) + sum of words_for_type over the params
    let mut total_words: i64 = 1;
    let mut ai0: i64 = 0;
    while (ai0 < nargs) { total_words = total_words + cg_words_for_type(fn_param_type(fn_row, ai0)); ai0 = ai0 + 1; }
    let stash_size: i64 = total_words * 8;
    // Frame = round16(stash_size + 32). Words 0..total_words-1 live at
    // [rsp+w*8] (word 0 = dest ptr); the +32 is the safety margin matching the
    // regular script-call frame (round16(total_words*8 + 32)). Words 4+ stay
    // at [rsp+w*8] = caller [rsp+32+(w-4)*8], where the callee reads them.
    let total: i64 = cg_round16(stash_size + 32);
    cg_sub_reg_imm32(RSP, total);

    // word 0: the hidden dest pointer (already in rax)
    cg_store_reg_mem(RSP, 0, RAX);

    // stash each arg operand to its cumulative word slot(s). next_slot starts
    // at 1 (word 0 = dest). A struct arg is copied via cg_stash_struct_arg
    // (with a fresh temp per non-Ident struct arg); a slice arg stores rax+rdx
    // (2 words); a scalar/float arg evals + stores 1 word.
    let mut next_slot: i64 = 1;
    let mut a: i64 = nk_a(e);
    let mut i: i64 = 0;
    while (a >= 0) {
        let pt: i64 = fn_param_type(fn_row, i);
        let off: i64 = next_slot * 8;
        if (cg_ty_is_struct(pt) == 1) {
            cg_stash_struct_arg(a, pt, off);
            if (cg_err != 0) { return 0; }
            next_slot = next_slot + cg_words_for_type(pt);
        } else if (nk_f(pt) == 1 || nk_f(pt) == 2) {
            // slice/closure arg: cg_eval yields two words in rax/rdx
            cg_eval(a); if (cg_err != 0) { return 0; }
            cg_store_reg_mem(RSP, off, RAX);
            cg_store_reg_mem(RSP, off + 8, RDX);
            next_slot = next_slot + 2;
        } else if (ty_is_float(pt) == 1) {
            cg_eval(a); if (cg_err != 0) { return 0; }
            cg_store_float(off, XMM0, cg_float_is64_type(pt));
            next_slot = next_slot + 1;
        } else {
            cg_eval(a); if (cg_err != 0) { return 0; }
            cg_store_reg_mem(RSP, off, RAX);
            next_slot = next_slot + 1;
        }
        a = nk_next(a);
        i = i + 1;
    }

    // place words 0..3 into rcx/rdx/r8/r9 (word 0 = dest ptr -> rcx). The
    // subset's struct words are always integer (no float struct fields are
    // passed in xmm at the word level — a struct's float field lives inside
    // the copied byte blob), so no per-word float dispatch is needed.
    if (total_words >= 1) { cg_load_reg_mem(RCX, RSP, 0); }
    if (total_words >= 2) { cg_load_reg_mem(RDX, RSP, 8); }
    if (total_words >= 3) { cg_load_reg_mem(R8, RSP, 16); }
    if (total_words >= 4) { cg_load_reg_mem(R9, RSP, 24); }
    // words 4+ stay at [rsp+w*8] (= caller [rsp+32+(w-4)*8]); the callee reads
    // them at [rbp+48+(w-4)*8] = caller [rsp+32+(w-4)*8]. No move needed (the
    // stash loop already placed each word at [rsp+next_slot*8] = [rsp+w*8]).

    let callee_label: i64 = cg_callee_label(e, is_ns_call, mod_tok);
    if (cg_err != 0) { return 0; }
    cg_call_rel32(callee_label);

    cg_add_reg_imm32(RSP, total);
    // no register result to propagate — the callee wrote the struct through
    // the dest pointer. Leave rax as-is (the caller will reload/read the dest).
    return 0;
}

// max(0, n)
fn cg_max0(n: i64) -> i64 { if (n < 0) { return 0; } return n; }

// Spill a single integer arg word `w` (a global word index, 0-based including
// the hidden return ptr at word 0) to [rbp+off]. Words 0-3 come from
// rcx/rdx/r8/r9 (arg_regs); words 4+ come from the caller's outgoing stack
// area at [rbp + 48 + (w-4)*8] (the caller stores words at [rsp+w*8]; words
// 4+ stay there = caller [rsp+32+(w-4)*8] = callee [rbp+48+(w-4)*8]). Used
// by the slice param spill
// (two consecutive words). `arg_regs` is the 4-entry Win64 int-arg-reg array.
fn cg_spill_word(w: i64, off: i64, arg_regs: i64, total_words: i64) -> i64 {
    if (w < 4) {
        let reg: i64 = array_get_i64(arg_regs, w);
        cg_store_reg_mem(RBP, off, reg);
    } else {
        let src_off: i64 = 48 + (w - 4) * 8;
        cg_load_reg_mem(RAX, RBP, src_off);
        cg_store_reg_mem(RBP, off, RAX);
    }
    return 0;
}

// =============================================================================
// statement compilation.
// =============================================================================

fn cg_compile_stmt(s: i64) -> i64 {
    if (s < 0) { return 0; }
    let k: i64 = nk_kind(s);

    if (k == (NK::LetStmt as i64)) {
        let name_tok: i64 = nk_tok(s);
        let init: i64 = nk_b(s);
        let mut t: i64 = nk_a(s); if (t < 0 && init >= 0) { t = cg_expr_type(init); } else if (t >= 0) { t = resolve_type(t); }
        // size the local's stack slots from the type's packed extent (struct:
        // ceil(value_bytes/8); fixed array: ceil(N*elem/8); slice: 2; scalar: 1).
        let mut slots: i64 = 1;
        if (t >= 0) { slots = cg_local_slots(t); }
        let off: i64 = cg_alloc_local_t(name_tok, t, slots);
        if (init >= 0 && nk_kind(init) == (NK::StructLit as i64)) { cg_store_struct_lit(init, t, off); return 0; }
        if (init >= 0 && nk_kind(init) == (NK::ArrayLit as i64)) { return cg_store_arraylit_let(init, t, off); }
        if (init >= 0 && nk_kind(init) == (NK::CallExpr as i64) && cg_ty_is_struct(t) == 1) {
            // Phase 4: struct-returning call init. The local's frame slot is
            // the concrete destination for the callee's hidden return pointer:
            // lea rax, [rbp+off], then the callee writes the struct directly
            // into the local (no register result, no rax store).
            cg_lea_rax_rbp(off);
            let saved: i64 = cg_struct_ret_dest_ready; cg_struct_ret_dest_ready = 1;
            cg_eval_struct_returning_call(init);
            cg_struct_ret_dest_ready = saved;
            return 0;
        }
        if (init >= 0) {
            // slice-typed init (a ViewExpr, a slice Ident, etc.): cg_eval
            // yields the 2-word slice ABI {rax=ptr, rdx=len}; store both words
            // into the 16-byte local (ptr at off, len at off+8).
            let mut is_sl_init: i64 = 0;
            if (t >= 0 && nk_kind(t) == (NK::Type as i64)) { is_sl_init = nk_f(t); }
            if (is_sl_init == 1 || is_sl_init == 2) {
                cg_eval(init); if (cg_err != 0) { return 0; }
                cg_store_reg_mem(RBP, off, RAX);
                cg_store_reg_mem(RBP, off + 8, RDX);
            } else {
                cg_eval(init); if (cg_err != 0) { return 0; }
                if (ty_is_float(t) == 1) {
                    // implicit f32->f64 widening when the init is f32 and the
                    // target is f64 (a same-type or same-width store is a no-op).
                    cg_convert_float(cg_expr_type(init), t);
                    cg_store_float(off, XMM0, cg_float_is64_type(t));
                } else { cg_normalize_rax(t); cg_store_reg_mem(RBP, off, RAX); }
            }
        } else {
            // no initializer: zero-fill an aggregate's whole extent (a fixed
            // array / struct local later populated via indexed / field assigns),
            // mirroring src/codegen.cpp's LetStmt no-init path. Scalars leave
            // their slot as whatever (the value is always written before read).
            if (t >= 0 && cg_local_width_bytes(t) > 8) { cg_zero_fill(off, cg_local_width_bytes(t)); }
        }
        return 0;
    }
    if (k == (NK::ExprStmt as i64)) {
        if (nk_a(s) >= 0) { cg_eval(nk_a(s)); }
        return 0;
    }
    if (k == (NK::ReturnStmt as i64)) {
        let val: i64 = nk_a(s);
        // Phase 4: struct-by-value return (hidden-pointer sret ABI). The fn's
        // incoming hidden return pointer (spilled to cg_struct_ret_ptr_off in
        // the prologue) is the destination; the struct value is copied there.
        // sema guarantees val is a bare Ident, a struct-returning CallExpr, or
        // a struct literal of the return type. There is no register result to
        // stash across defers (the struct is written through the dest ptr),
        // but the dest ptr must be reloaded into rax at the end (the sret ABI
        // requires the dest ptr to be returned in rax).
        if (cg_ty_is_struct(cg_cur_ret) == 1) {
            let rptr: i64 = cg_struct_ret_ptr_off;
            let ret_row: i64 = find_struct(ty_struct_name(cg_cur_ret));
            let ret_bytes: i64 = (ret_row >= 0) ? cg_struct_value_bytes(ret_row) : (cg_words_for_type(cg_cur_ret) * 8);
            if (val >= 0) {
                let vk: i64 = nk_kind(val);
                if (vk == (NK::Ident as i64)) {
                    // copy the local's bytes to [rptr] (via r11 = rptr).
                    let src_off: i64 = cg_lookup_local(nk_tok(val));
                    if (src_off == 0) { if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: return struct local not found"); } return 0; }
                    cg_load_reg_mem(R11, RBP, rptr);
                    cg_copy_bytes(R11, 0, RBP, src_off, ret_bytes);
                } else if (vk == (NK::CallExpr as i64)) {
                    // forward: rax = rptr, the callee writes through it.
                    cg_load_reg_mem(RAX, RBP, rptr);
                    let saved: i64 = cg_struct_ret_dest_ready; cg_struct_ret_dest_ready = 1;
                    cg_eval_struct_returning_call(val);
                    cg_struct_ret_dest_ready = saved;
                    if (cg_err != 0) { return 0; }
                } else if (vk == (NK::StructLit as i64)) {
                    // materialize the literal into a temp, copy to [rptr].
                    let temp_off: i64 = cg_alloc_struct_temp(ret_bytes);
                    cg_store_struct_lit(val, cg_cur_ret, temp_off);
                    if (cg_err != 0) { return 0; }
                    cg_load_reg_mem(R11, RBP, rptr);
                    cg_copy_bytes(R11, 0, RBP, temp_off, ret_bytes);
                } else {
                    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unsupported struct return value shape"); }
                    return 0;
                }
            }
            // emit pending defers (LIFO). No register result to stash (the
            // struct is already at the dest); defers may clobber rax/r11.
            cg_defer_emit_all_nostash();
            if (cg_err != 0) { return 0; }
            // the sret ABI requires the dest pointer to be returned in rax.
            cg_load_reg_mem(RAX, RBP, rptr);
            cg_jmp(cg_epilogue_label);
            return 0;
        }
        // eval the value -> rax (or xmm0 for float, {rax,rdx} for slice)
        if (val >= 0) {
            cg_eval(val);
            if (cg_err != 0) { return 0; }
        } else {
            cg_mov_reg_imm64(RAX, 0);  // void return -> rax = 0
        }
        // Phase 3b: emit all pending defers (LIFO) before exiting, stashing
        // the return value across them (a defer may clobber rax/xmm0/rdx).
        // Mirrors src/codegen.cpp's ReturnStmt emit_cleanups_to(0) + stash.
        cg_defer_emit_all_and_stash();
        if (cg_err != 0) { return 0; }
        // jmp to the function's epilogue label
        cg_jmp(cg_epilogue_label);
        return 0;
    }
    if (k == (NK::IfStmt as i64)) {
        return cg_compile_if(s);
    }
    if (k == (NK::WhileStmt as i64)) {
        return cg_compile_while(s);
    }
    if (k == (NK::BlockStmt as i64)) {
        return cg_compile_block(s);
    }
    if (k == (NK::BreakStmt as i64)) {
        // Phase 3b: clean up defers from scopes opened inside the current
        // loop/switch (down to the saved defer-mark depth), then jmp to the
        // break target. Mirrors src/codegen.cpp's break emit_cleanups_to.
        if (cg_loop_depth > 0) {
            cg_defer_emit_to(cg_loop_defer_mark);
            if (cg_err != 0) { return 0; }
            cg_jmp(cg_loop_break);
        }
        return 0;
    }
    if (k == (NK::ContinueStmt as i64)) {
        // jmp to the current loop's continue label (after cleaning up the
        // scopes opened inside the loop, mirroring src/codegen.cpp's continue).
        if (cg_loop_depth > 0) {
            cg_defer_emit_to(cg_loop_defer_mark);
            if (cg_err != 0) { return 0; }
            cg_jmp(cg_loop_continue);
        }
        return 0;
    }
    if (k == (NK::ForStmt as i64)) { return cg_compile_for(s); }
    if (k == (NK::ForEachStmt as i64)) { return cg_compile_foreach(s); }
    if (k == (NK::DoWhileStmt as i64)) { return cg_compile_dowhile(s); }
    if (k == (NK::SwitchStmt as i64)) { return cg_compile_switch(s); }
    if (k == (NK::MatchStmt as i64)) { return cg_compile_match(s); }
    // Phase 3b: defer. Do NOT emit the expr inline; record it on the defer
    // stack for the current scope so it runs (LIFO) at scope exit. Mirrors
    // src/codegen.cpp's DeferStmt (which sets a per-site activation flag).
    if (k == (NK::DeferStmt as i64)) { return cg_compile_defer(s); }
    // Phase 2 Step 6: static_assert produces NO codegen (sema resolved it:
    // true -> elided, false/non-const -> compile error that never reaches
    // codegen). Skip it before any dispatch, mirroring src/codegen.cpp.
    if (k == (NK::StaticAssertStmt as i64)) { return 0; }

    if (k == (NK::TryCatchStmt as i64)) { return cg_compile_trycatch(s); }
    if (k == (NK::ThrowStmt as i64)) { return cg_compile_throw(s); }
    if (k == (NK::YieldStmt as i64)) {
        if (nk_a(s) >= 0) { cg_eval(nk_a(s)); } else { cg_mov_reg_imm64(RAX, 0); }
        let frame: i64 = 32; cg_sub_reg_imm32(RSP, frame); cg_mov_reg_reg(RCX, RAX);
        let sym: i64 = cg_sym_index(string_from_slice("__ember_coro_yield"));
        let pts: i64 = cg_fp_types_get(); array_set_i64(pts, 0, TY_I64);
        cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym, cg_abi_fingerprint(pts, 1, TY_I64, 0)); cg_call_reg(RAX);
        cg_add_reg_imm32(RSP, frame); return 0;
    }
    // unsupported statement kind in v1
    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: statement kind unsupported in v1"); }
    return 0;
}

fn cg_struct_field_count(row: i64) -> i64 { let mut n: i64 = 0; let mut f: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1); while (f >= 0) { n = n + 1; f = nk_next(f); } if (n < 1) { return 1; } return n; }

// store a struct literal's fields at packed offsets [off + field_offset].
// Mirrors src/codegen.cpp's LetStmt StructLit init path: eval each field
// expression, store it at base + the field's packed offset with the field's
// width. sema guarantees every field is present + types match.
fn cg_store_struct_lit(lit: i64, t: i64, off: i64) -> i64 {
    let row: i64 = find_struct(ty_struct_name(t));
    if (row < 0) { return 0; }
    let mut f: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1);
    let mut idx: i64 = 0;
    while (f >= 0) {
        // find the matching FieldInit by name (sema already verified it exists)
        let mut init: i64 = nk_a(lit);
        while (init >= 0 && (nk_name(init) == nk_name(f)) == false) { init = nk_next(init); }
        if (init >= 0) {
            let ft: i64 = resolve_type(nk_a(f));
            let foff: i64 = cg_struct_field_offset(row, idx);
            cg_eval(nk_a(init)); if (cg_err != 0) { return 0; }
            if (ty_is_float(ft) == 1) {
                cg_store_float(off + foff, XMM0, cg_float_is64_type(ft));
            } else {
                cg_normalize_rax(ft);
                cg_store_typed(RBP, off + foff, ft);
            }
        }
        idx = idx + 1;
        f = nk_next(f);
    }
    return 0;
}

// (Phase 3 Step 2/3 placeholders — implemented below. Forward declarations
// so the LetStmt dispatch compiles before the bodies are filled in.)
fn cg_store_arraylit_let(lit: i64, t: i64, off: i64) -> i64 { return cg_store_arraylit_let_impl(lit, t, off); }
// store an array literal as a let initializer at `off` (the local's base).
// Mirrors src/codegen.cpp's LetStmt ArrayLit init path. Two shapes:
//   (a) fixed array T[N]: elements go directly into the local's inline slot,
//       each at base + i*elem_size via cg_store_typed (handles widths + floats).
//   (b) slice T[]: the local is the 16-byte {ptr,len} pair; the elements go
//       into a separate backing region in cg_data, then ptr=addend (ABS64_DATA)
//       + len=count are stored into the slice slot. (STEP 3.)
fn cg_store_arraylit_let_impl(lit: i64, t: i64, off: i64) -> i64 {
    let mut is_sl: i64 = 0;
    if (t >= 0 && nk_kind(t) == (NK::Type as i64)) { is_sl = nk_f(t); }
    let mut elem_ty: i64 = -1;
    if (t >= 0) { elem_ty = resolve_type(nk_a(t)); }
    if (cg_err != 0) { return 0; }
    let elem_sz: i64 = cg_value_bytes(elem_ty);
    if (is_sl == 1) { return cg_store_slice_arraylit(lit, t, off, elem_ty, elem_sz); }
    // fixed array T[N]: elements inline at base + i*elem_sz
    let mut el: i64 = nk_a(lit);
    let mut i: i64 = 0;
    while (el >= 0) {
        cg_eval(el); if (cg_err != 0) { return 0; }
        if (ty_is_float(elem_ty) == 1) {
            cg_store_float(off + i * elem_sz, XMM0, cg_float_is64_type(elem_ty));
        } else {
            cg_normalize_rax(elem_ty);
            cg_store_typed(RBP, off + i * elem_sz, elem_ty);
        }
        i = i + 1;
        el = nk_next(el);
    }
    return 0;
}

// (STEP 3 slice-array-literal backing.) Materialize the elements into a
// fresh backing region in cg_data, then store the slice {ptr=addend, len=count}
// into the 16-byte local at `off` (ptr at off, len at off+8). The ptr is
// patched at load time via an ABS64_DATA reloc (the data section's base + the
// backing addend). Mirrors src/codegen.cpp's slice-ArrayLit LetStmt path
// (which uses a frame temp; the self-hosted compiler uses the data section as
// the backing region since it has no frame-temp allocator and the literals
// are immutable).
fn cg_store_slice_arraylit(lit: i64, t: i64, off: i64, elem_ty: i64, elem_sz: i64) -> i64 {
    // count elements
    let mut count: i64 = 0;
    let mut el: i64 = nk_a(lit);
    while (el >= 0) { count = count + 1; el = nk_next(el); }
    // allocate count*elem_sz bytes in cg_data + write each element's LE bytes
    let back: i64 = cg_data_alloc(count * elem_sz);
    el = nk_a(lit);
    let mut i: i64 = 0;
    while (el >= 0) {
        // eval the element -> rax (int) or xmm0 (float), then write its LE
        // bytes into cg_data at back + i*elem_sz. We must AVOID emitting
        // runtime stores to cg_data (it's a host-owned byte array built at
        // compile time); instead, fold the element to a compile-time constant
        // + write the bytes directly. v1 slice literals only carry constant
        // integer elements (sema-checked); a non-constant element is rejected.
        let ev: i64 = cg_eval_const_i64(el);
        if (cg_err != 0) { return 0; }
        let mut b: i64 = 0;
        while (b < elem_sz) {
            array_set_u8(cg_data, back + i * elem_sz + b, (ev >> (b * 8)) & 0xFF);
            b = b + 1;
        }
        i = i + 1;
        el = nk_next(el);
    }
    // store ptr = <data_base + back> into [rbp+off] via an ABS64_DATA reloc.
    // mov rax, <data_base+back>; mov [rbp+off], rax
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_DATA, 0, back);
    cg_store_reg_mem(RBP, off, RAX);
    // store len = count into [rbp+off+8]
    cg_mov_reg_imm64(RAX, count);
    cg_store_reg_mem(RBP, off + 8, RAX);
    return 0;
}

// the current function's epilogue label (set in cg_compile_func)
global cg_epilogue_label : i64 = 0;

// loop context for break/continue (v1: single-level, no nesting stack)
global cg_loop_depth   : i64 = 0;
global cg_loop_break   : i64 = 0;
global cg_loop_continue: i64 = 0;

// Phase 3b: lexical defer cleanup. A defer stack (g_defers) holds deferred
// expr node indices in declaration order; a parallel mark stack
// (g_defer_marks) records the g_defers length at each block entry, so a
// block exit can emit + truncate exactly its own defers. break/continue/return
// emit pending defers from the inner scopes outward (LIFO) before jumping,
// mirroring src/codegen.cpp's cleanup-scope emission. cg_loop_defer_mark
// records the defer-mark depth at the current loop/switch entry so break /
// continue clean up only the scopes opened inside that loop/switch.
global g_defers        : i64 = 0;   // array of deferred expr node indices
global g_defer_marks   : i64 = 0;   // array of mark depths (g_defers length)
global g_defer_mark_len: i64 = 0;   // live mark-stack depth
global cg_cur_ret      : i64 = 0;   // current fn's resolved return type (-1 none)
// Tier 1 namespaces: the namespace name token of the fn currently being
// compiled (-1 = top-level). Set in cg_compile_func so a bare call inside a
// namespaced fn resolves to the sibling Ns::fn label (mirrors sema's s_cur_ns).
global cg_cur_ns : i64 = -1;
// per-loop/switch saved defer-mark depth, so break/continue clean up only the
// scopes opened inside the current loop/switch (mirrors src/codegen.cpp's
// cleanup_scopes.size() captured in the LoopFrame).
global cg_loop_defer_mark: i64 = 0;

// push a defer-scope mark: record the current g_defers length as the cleanup
// boundary for the block about to be compiled.
fn cg_defer_push_mark() -> i64 {
    if (array_length(g_defer_marks) < g_defer_mark_len + 1) {
        array_resize(g_defer_marks, g_defer_mark_len + 1);
    }
    array_set_i64(g_defer_marks, g_defer_mark_len, array_length(g_defers));
    g_defer_mark_len = g_defer_mark_len + 1;
    return 0;
}

// pop a defer-scope mark (after the block's defers have been emitted + the
// stack truncated to the mark).
fn cg_defer_pop_mark() -> i64 {
    if (g_defer_mark_len > 0) { g_defer_mark_len = g_defer_mark_len - 1; }
    return 0;
}

// record a deferred expr (the DeferStmt's expr) on the current scope's defer
// stack. Emits NO code inline; the expr is emitted at scope exit. Mirrors
// src/codegen.cpp's DeferStmt (which sets a per-site activation flag instead;
// this stack form is semantically equivalent for the subset).
fn cg_compile_defer(s: i64) -> i64 {
    let expr: i64 = nk_a(s);
    if (expr >= 0) {
        array_push_i64(g_defers, expr);
    }
    return 0;
}

// emit the deferred exprs in the range [lo, hi) in REVERSE order (LIFO). Each
// defer's expr is evaluated for its side effect (result discarded). Mirrors
// src/codegen.cpp's emit_cleanup_scope (rbegin -> rend).
fn cg_emit_defer_range(lo: i64, hi: i64) -> i64 {
    let mut i: i64 = hi - 1;
    while (i >= lo) {
        cg_eval(array_get_i64(g_defers, i));
        if (cg_err != 0) { return 0; }
        i = i - 1;
    }
    return 0;
}

// emit + truncate the current scope's defers (from its mark to the end of the
// defer stack), then pop the mark. Used at a block's normal fallthrough exit.
fn cg_defer_emit_scope() -> i64 {
    if (g_defer_mark_len == 0) { return 0; }
    let mark: i64 = array_get_i64(g_defer_marks, g_defer_mark_len - 1);
    let end: i64 = array_length(g_defers);
    cg_emit_defer_range(mark, end);
    // truncate the defer stack back to the mark (this scope's defers are spent)
    array_resize(g_defers, mark);
    g_defer_mark_len = g_defer_mark_len - 1;
    return 0;
}

// emit all pending defers (the whole stack) in reverse with NO register
// result to stash — used at a struct-by-value return (the struct is already
// written through the hidden dest pointer; there is no rax/xmm0/rdx result
// to preserve). The dest pointer is reloaded into rax by the caller AFTER
// this. A defer's expr may clobber rax/r11/xmm, but none of those hold a
// live struct-return value at this point. Mirrors the struct-return branch
// of src/codegen.cpp's ReturnStmt (which calls emit_cleanups_to(0) with no
// stash, then reloads the dest ptr into rax).
fn cg_defer_emit_all_nostash() -> i64 {
    if (array_length(g_defers) == 0) { return 0; }
    cg_emit_defer_range(0, array_length(g_defers));
    return 0;
}

// emit all pending defers (the whole stack) in reverse — used at a function
// return. Mirrors src/codegen.cpp's emit_cleanups_to(0). The return value(s)
// are already in rax (and rdx for a two-word / xmm0 for a float return); they
// are stashed across the defer exprs (a defer may clobber rax/xmm0/rdx) and
// restored after, matching the C++ stash/restore around emit_cleanups_to(0).
fn cg_defer_emit_all_and_stash() -> i64 {
    if (array_length(g_defers) == 0) { return 0; }
    // stash the return value across the defers. i64 return -> rax; a float
    // return -> xmm0; a slice/two-word return -> {rax, rdx}. Reserve a
    // 16-byte temp on the stack (keeps rsp 16-aligned for any calls the
    // defers make), matching the C++ sub rsp,16 stash.
    let ret_ty: i64 = cg_cur_ret;
    let mut is_float: i64 = 0;
    let mut is_two_word: i64 = 0;
    if (ret_ty >= 0) {
        if (ty_is_float(ret_ty) == 1) { is_float = 1; }
        if (nk_kind(ret_ty) == (NK::Type as i64) && nk_f(ret_ty) == 1) { is_two_word = 1; }
    }
    cg_sub_reg_imm32(RSP, 16);
    if (is_float == 1) {
        cg_store_float(0, XMM0, cg_float_is64_type(ret_ty));
    } else {
        cg_store_reg_mem(RSP, 0, RAX);
        if (is_two_word == 1) { cg_store_reg_mem(RSP, 8, RDX); }
    }
    // emit the whole defer stack in reverse (LIFO), leaving it intact (a
    // return exits the function; the stack is discarded with the frame).
    cg_emit_defer_range(0, array_length(g_defers));
    if (cg_err != 0) { return 0; }
    // restore the return value(s)
    if (is_float == 1) {
        cg_load_float(XMM0, 0, cg_float_is64_type(ret_ty));
    } else {
        cg_load_reg_mem(RAX, RSP, 0);
        if (is_two_word == 1) { cg_load_reg_mem(RDX, RSP, 8); }
    }
    cg_add_reg_imm32(RSP, 16);
    return 0;
}

// emit defers from the current inner scopes down to (but not including) the
// scope at `retain_mark_len`, truncating the stack as each scope's defers run.
// Used by break/continue to clean up the scopes opened inside a loop/switch
// before jumping to the loop's break/continue target. Mirrors src/codegen.cpp's
// emit_cleanups_to(retained_depth).
fn cg_defer_emit_to(retain_mark_len: i64) -> i64 {
    while (g_defer_mark_len > retain_mark_len) {
        let mark: i64 = array_get_i64(g_defer_marks, g_defer_mark_len - 1);
        let end: i64 = array_length(g_defers);
        cg_emit_defer_range(mark, end);
        if (cg_err != 0) { return 0; }
        array_resize(g_defers, mark);
        g_defer_mark_len = g_defer_mark_len - 1;
    }
    return 0;
}

// compile a try/catch/throw statement. Uses raw JIT bytes on context_t::catch_bufs
// via r14 (the context pointer, callee-saved + preserved across call_raw).
// Mirrors src/codegen.cpp / thin_emit.cpp's TryCatch + Throw emission.
//
// catch_bufs[depth] layout (64 bytes): [0]rbx [8]rbp [16]r12 [24]r13 [32]r14
// [40]r15 [48]rsp [56]catch-entry-rip. catch_saved_call_depths[depth] snapshots
// call_depth at try-entry so a cross-frame throw restores the catching frame's
// depth. catch_depth is the 0-based index (incremented AFTER saving).
fn cg_compile_trycatch(s: i64) -> i64 {
    let try_b: i64 = nk_a(s);     // try body (BlockStmt)
    let catch_b: i64 = nk_b(s);   // catch body (BlockStmt)
    let cnametok: i64 = nk_tok(s); // catch variable name token

    // context offsets (compile-time constants from host natives)
    let cd_off: i64 = context_off_catch_depth();
    let cb_off: i64 = context_off_catch_bufs();
    let csd_off: i64 = context_off_catch_saved_depths();

    cg_push_scope();
    let catch_off: i64 = cg_alloc_local_t(cnametok, TY_I64, 1);

    let catch_label: i64 = cg_alloc_label();
    let end_label: i64 = cg_alloc_label();

    // ===== SETJMP: save state into catch_bufs[catch_depth] =====
    // 1. load catch_depth (32-bit, zero-extended) -> rax
    cg_load_elem_to_rax(R14, cd_off, 4, 0);
    // save catch_depth in r10 (for snapshot + increment later)
    cg_mov_reg_reg(R10, RAX);
    // 2. compute catch_bufs[catch_depth] address -> r9
    //    r9 = r14 + cb_off + catch_depth * 64
    cg_shift_left_imm8(RAX, 6);   // rax = catch_depth * 64
    cg_mov_reg_reg(R9, R14);
    cg_add_reg_imm32(R9, cb_off);
    cg_add_reg_reg(R9, RAX);      // r9 = &catch_bufs[catch_depth]
    // 3. save 6 callee-saved regs + rsp
    cg_store_reg_mem(R9, 0, RBX);
    cg_store_reg_mem(R9, 8, RBP);
    cg_store_reg_mem(R9, 16, R12);
    cg_store_reg_mem(R9, 24, R13);
    cg_store_reg_mem(R9, 32, R14);
    cg_store_reg_mem(R9, 40, R15);
    cg_store_reg_mem(R9, 48, RSP);
    // 4. save catch-entry rip (PC-relative lea to catch_label)
    cg_lea_reg_rip(RAX, catch_label);
    cg_store_reg_mem(R9, 56, RAX);
    // 5. save call_depth snapshot into catch_saved_call_depths[catch_depth]
    //    r10 still has catch_depth; r11 = catch_depth * 4
    cg_mov_reg_reg(R11, R10);
    cg_shift_left_imm8(R11, 2);   // r11 = catch_depth * 4
    cg_mov_reg_reg(R8, R14);
    cg_add_reg_imm32(R8, csd_off);
    cg_add_reg_reg(R8, R11);      // r8 = &saved_depths[catch_depth]
    // call_depth is at offset 8 in context_t (catch_depth at offset 20, diff=12)
    let call_depth_off: i64 = cd_off - 12;
    cg_load_elem_to_rax(R14, call_depth_off, 4, 0);
    cg_store_rax_elem(R8, 0, 4);
    // 6. catch_depth++
    cg_add_reg_imm32(R10, 1);
    cg_mov_reg_reg(RAX, R10);
    cg_store_rax_elem(R14, cd_off, 4);

    // ===== TRY BODY =====
    cg_compile_block(try_b);
    if (cg_err != 0) { cg_pop_scope(); return 0; }

    // ===== CATCH CLEANUP: on normal try completion, catch_depth-- =====
    cg_load_elem_to_rax(R14, cd_off, 4, 0);
    cg_sub_reg_imm32(RAX, 1);
    cg_store_rax_elem(R14, cd_off, 4);

    // jump past the catch block
    cg_jmp(end_label);

    // ===== CATCH BLOCK =====
    cg_bind(catch_label);
    // load thrown_value -> rax, store to catch variable frame slot
    let tv_off: i64 = context_off_thrown_value();
    cg_load_reg_mem(RAX, R14, tv_off);
    cg_store_reg_mem(RBP, catch_off, RAX);
    // compile catch body
    cg_compile_block(catch_b);
    if (cg_err != 0) { cg_pop_scope(); return 0; }

    cg_bind(end_label);
    cg_pop_scope();
    return 0;
}

// compile a throw statement: store the thrown value into context_t::thrown_value,
// then longjmp to the most recent catch handler by restoring callee-saved regs
// + rsp from catch_bufs[catch_depth-1] and jumping to the saved catch-entry rip.
fn cg_compile_throw(s: i64) -> i64 {
    // 1. evaluate throw expression -> rax (the thrown value)
    cg_eval(nk_a(s));
    if (cg_err != 0) { return 0; }
    // 2. store thrown value into context_t::thrown_value
    let tv_off: i64 = context_off_thrown_value();
    cg_store_reg_mem(R14, tv_off, RAX);
    // 3. load catch_depth (32-bit) -> rax
    let cd_off: i64 = context_off_catch_depth();
    cg_load_elem_to_rax(R14, cd_off, 4, 0);
    // 4. if catch_depth == 0 -> unhandled throw (trap via ud2)
    cg_cmp_reg_imm32(RAX, 0);
    let no_handler: i64 = cg_alloc_label();
    cg_jcc(COND_E, no_handler);
    // 5. catch_depth-- : rax = catch_depth - 1
    cg_sub_reg_imm32(RAX, 1);
    cg_mov_reg_reg(R10, RAX);   // r10 = catch_depth - 1 (saved for buf ptr)
    // store decremented catch_depth (32-bit)
    cg_store_rax_elem(R14, cd_off, 4);
    // 6. compute catch_bufs[catch_depth-1] address -> r9
    let cb_off: i64 = context_off_catch_bufs();
    cg_shift_left_imm8(RAX, 6);  // rax = (catch_depth-1) * 64
    cg_mov_reg_reg(R9, R14);
    cg_add_reg_imm32(R9, cb_off);
    cg_add_reg_reg(R9, RAX);     // r9 = &catch_bufs[catch_depth-1]
    // 7. load catch-entry rip from [r9+56] -> rax (BEFORE restoring regs)
    cg_load_reg_mem(RAX, R9, 56);
    // 8. restore 6 callee-saved regs + rsp from catch_bufs
    cg_load_reg_mem(RBX, R9, 0);
    cg_load_reg_mem(RBP, R9, 8);
    cg_load_reg_mem(R12, R9, 16);
    cg_load_reg_mem(R13, R9, 24);
    cg_load_reg_mem(R14, R9, 32);
    cg_load_reg_mem(R15, R9, 40);
    cg_load_reg_mem(RSP, R9, 48);  // restore rsp last
    // 9. jmp to catch-entry rip
    cg_jmp_reg(RAX);
    // 10. no handler: ud2 (unhandled throw trap)
    cg_bind(no_handler);
    cg_byte(0x0F); cg_byte(0x0B);  // ud2
    return 0;
}

// compile a block: push scope, compile each stmt, pop scope.
fn cg_compile_block(b: i64) -> i64 {
    if (b < 0) { return 0; }
    cg_push_scope();
    // Phase 3b: this lexical Block owns one defer cleanup scope. Push a mark
    // so defers declared inside run (LIFO) at the block's normal fallthrough
    // exit, mirroring src/codegen.cpp's exec_block cleanup-scope push/pop.
    cg_defer_push_mark();
    let mut s: i64 = nk_a(b);
    while (s >= 0) {
        cg_compile_stmt(s);
        if (cg_err != 0) { cg_defer_pop_mark(); cg_pop_scope(); return 0; }
        s = nk_next(s);
    }
    // normal fallthrough: emit this scope's defers (LIFO) + truncate the stack
    // to the mark, BEFORE popping the local scope (the defer exprs may
    // reference locals whose frame slots are still live at runtime).
    cg_defer_emit_scope();
    cg_pop_scope();
    return 0;
}

// Phase 3b: compile a bare linked list of stmts (a switch case body, which
// the parser stores as nk_b(case) = first stmt, NOT a BlockStmt). Same
// scope + defer-cleanup handling as cg_compile_block.
fn cg_compile_stmtlist(first_stmt: i64) -> i64 {
    cg_push_scope();
    cg_defer_push_mark();
    let mut s: i64 = first_stmt;
    while (s >= 0) {
        cg_compile_stmt(s);
        if (cg_err != 0) { cg_defer_pop_mark(); cg_pop_scope(); return 0; }
        s = nk_next(s);
    }
    cg_defer_emit_scope();
    cg_pop_scope();
    return 0;
}

// compile an if statement:
//   eval cond -> rax; cmp rax, 0; je else_l; <then>; jmp end_l; else_l: <else>; end_l:
fn cg_compile_if(s: i64) -> i64 {
    let cond: i64 = nk_a(s);
    let then_b: i64 = nk_b(s);
    let else_b: i64 = nk_c(s);   // -1 if no else

    cg_eval(cond);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);

    let else_l: i64 = cg_alloc_label();
    let end_l: i64 = cg_alloc_label();
    cg_jcc(COND_E, else_l);       // cond == 0 -> else

    cg_compile_block(then_b);
    if (cg_err != 0) { return 0; }

    if (else_b >= 0) {
        cg_jmp(end_l);
        cg_bind(else_l);
        cg_compile_block(else_b);
        if (cg_err != 0) { return 0; }
        cg_bind(end_l);
    } else {
        cg_bind(else_l);
    }
    return 0;
}

// compile a while statement:
//   top: eval cond -> rax; cmp rax, 0; je end; <body>; jmp top; end:
fn cg_compile_while(s: i64) -> i64 {
    let cond: i64 = nk_a(s);
    let body: i64 = nk_b(s);

    let top: i64 = cg_alloc_label();
    let end: i64 = cg_alloc_label();

    cg_bind(top);
    cg_eval(cond);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    cg_jcc(COND_E, end);          // cond == 0 -> exit loop

    // set up break/continue targets
    let saved_depth: i64 = cg_loop_depth;
    let saved_break: i64 = cg_loop_break;
    let saved_cont: i64 = cg_loop_continue;
    let saved_dmark: i64 = cg_loop_defer_mark;
    cg_loop_depth = 1;
    cg_loop_break = end;
    cg_loop_continue = top;
    cg_loop_defer_mark = g_defer_mark_len;   // break/continue clean up only inner scopes

    cg_compile_block(body);

    // restore loop context
    cg_loop_depth = saved_depth;
    cg_loop_break = saved_break;
    cg_loop_continue = saved_cont;
    cg_loop_defer_mark = saved_dmark;
    if (cg_err != 0) { return 0; }

    cg_jmp(top);                   // back-edge
    cg_bind(end);
    return 0;
}

// compile a for statement (C-style):
//   <init>; top: <cond>; je end; <body>; cont: <step>; jmp top; end:
fn cg_compile_for(s: i64) -> i64 {
    let init: i64 = nk_a(s);    // LetStmt or -1
    let cond: i64 = nk_b(s);    // expr or -1
    let step: i64 = nk_c(s);    // expr or -1
    let body: i64 = nk_e(s);    // BlockStmt

    cg_push_scope();
    // init
    if (init >= 0) {
        cg_compile_stmt(init);
        if (cg_err != 0) { cg_pop_scope(); return 0; }
    }

    let top: i64 = cg_alloc_label();
    let cont: i64 = cg_alloc_label();
    let end: i64 = cg_alloc_label();

    cg_bind(top);
    // cond
    if (cond >= 0) {
        cg_eval(cond);
        if (cg_err != 0) { cg_pop_scope(); return 0; }
        cg_cmp_reg_imm32(RAX, 0);
        cg_jcc(COND_E, end);     // cond == 0 -> exit
    }

    // set up break/continue targets
    let saved_depth: i64 = cg_loop_depth;
    let saved_break: i64 = cg_loop_break;
    let saved_cont: i64 = cg_loop_continue;
    let saved_dmark: i64 = cg_loop_defer_mark;
    cg_loop_depth = 1;
    cg_loop_break = end;
    cg_loop_continue = cont;
    cg_loop_defer_mark = g_defer_mark_len;   // break/continue clean up only inner scopes

    cg_compile_block(body);

    cg_loop_depth = saved_depth;
    cg_loop_break = saved_break;
    cg_loop_continue = saved_cont;
    cg_loop_defer_mark = saved_dmark;
    if (cg_err != 0) { cg_pop_scope(); return 0; }

    cg_bind(cont);
    // step
    if (step >= 0) {
        cg_eval(step);
        if (cg_err != 0) { cg_pop_scope(); return 0; }
    }
    cg_jmp(top);                   // back-edge
    cg_bind(end);
    cg_pop_scope();
    return 0;
}

// compile a for-each statement: for (x in iter) { body }. Two iterable kinds
// (the iterable() hook, mirroring src/codegen.cpp's ForEachStmt):
//   - array<T> handle (sema stored the inferred elem type in slot c)
//     -> len = array_length(h); while i<len { x = array_get_*(h,i); body; i++ }
//   - slice T[] (slot c is -1, the unchanged shipped path)
//        -> eval iter -> {rax=ptr, rdx=len}; stash ptr,len,idx; loop i=0..len,
//           load elem [ptr + i*esz] into the loop var, run the body, i++.
// break -> end, continue -> latch (the i++ step) for both paths.
fn cg_compile_foreach(s: i64) -> i64 {
    let vtok: i64 = nk_tok(s);     // loop var name token
    let iter: i64 = nk_a(s);       // iterable expr
    let body: i64 = nk_b(s);       // body block
    let arr_elem: i64 = nk_c(s);   // inferred array elem type (-1 = slice path)

    if (arr_elem >= 0) {
        return cg_compile_foreach_array(s, vtok, iter, body, arr_elem);
    }
    return cg_compile_foreach_slice(s, vtok, iter, body);
}

// array-handle for-each: len = array_length(h); i = 0;
// while (i < len) { x = array_get_*(h, i); body; i = i + 1; }
// Mirrors src/codegen.cpp's ForEachStmt array branch. The handle is an i64
// opaque value (from array_new); array_length + array_get_* are host natives
// emitted via ABS64_NATIVE. Win64: rcx = handle, rdx = index, 32-byte shadow.
fn cg_compile_foreach_array(s: i64, vtok: i64, iter: i64, body: i64, elem_ty: i64) -> i64 {
    // dispatch the typed get native from the inferred element type
    // (1 -> u8/array_get_u8, 4 -> f32/array_get_f32, 8 -> i64/array_get_i64).
    let mut get_name: string = string_from_slice("array_get_i64");
    if (ty_is_uint(elem_ty) == 1 && cg_value_bytes(elem_ty) == 1) {
        get_name = string_from_slice("array_get_u8");
    } else if (ty_is_float(elem_ty) == 1 && cg_float_is64_type(elem_ty) == 0) {
        get_name = string_from_slice("array_get_f32");
    }

    // hidden frame slots: handle, len, idx (each 8 bytes) + the loop var (1 slot).
    let h_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
    let len_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
    let idx_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
    let var_off: i64 = cg_alloc_local_t(vtok, elem_ty, 1);

    // eval the iterable -> rax = the i64 array handle; stash it.
    cg_eval(iter); if (cg_err != 0) { return 0; }
    cg_store_reg_mem(RBP, h_off, RAX);

    // len = array_length(h).  Win64: rcx = handle, 32-byte shadow, result in rax.
    cg_sub_reg_imm32(RSP, 32);
    cg_load_reg_mem(RCX, RBP, h_off);
    let len_sym: i64 = cg_sym_index(string_from_slice("array_length"));
    let len_pt: i64 = cg_fp_types_get();
    array_set_i64(len_pt, 0, native_param_type(string_from_slice("array_length"), 0));
    let len_fp: i64 = cg_abi_fingerprint(len_pt, 1, native_ret_type(string_from_slice("array_length")), native_perm(string_from_slice("array_length")));
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, len_sym, len_fp);
    cg_call_reg(RAX);
    cg_add_reg_imm32(RSP, 32);
    cg_store_reg_mem(RBP, len_off, RAX);

    // i = 0.
    cg_mov_reg_imm64(RAX, 0);
    cg_store_reg_mem(RBP, idx_off, RAX);

    let top: i64 = cg_alloc_label();
    let latch: i64 = cg_alloc_label();
    let end: i64 = cg_alloc_label();
    cg_bind(top);
    // if (idx >= len) goto end
    cg_load_reg_mem(RAX, RBP, idx_off);
    cg_load_reg_mem(RDX, RBP, len_off);
    cg_cmp_reg_reg(RAX, RDX);
    cg_jcc(COND_GE, end);

    // x = array_get_*(h, i).  rcx = handle, rdx = index, 32-byte shadow.
    // result: rax (u8/i64) or xmm0 (f32).
    cg_sub_reg_imm32(RSP, 32);
    cg_load_reg_mem(RCX, RBP, h_off);
    cg_load_reg_mem(RDX, RBP, idx_off);
    let get_sym: i64 = cg_sym_index(get_name);
    let get_pt: i64 = cg_fp_types_get();
    array_set_i64(get_pt, 0, native_param_type(get_name, 0));
    array_set_i64(get_pt, 1, native_param_type(get_name, 1));
    let get_fp: i64 = cg_abi_fingerprint(get_pt, 2, native_ret_type(get_name), native_perm(get_name));
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, get_sym, get_fp);
    cg_call_reg(RAX);
    cg_add_reg_imm32(RSP, 32);
    // store the element into the loop var slot (int via rax, f32 via xmm0).
    if (ty_is_float(elem_ty) == 1) {
        cg_store_float(var_off, XMM0, cg_float_is64_type(elem_ty));
    } else {
        cg_normalize_rax(elem_ty);
        cg_store_reg_mem(RBP, var_off, RAX);
    }

    // set up break/continue targets + run the body.
    let saved_depth: i64 = cg_loop_depth;
    let saved_break: i64 = cg_loop_break;
    let saved_cont: i64 = cg_loop_continue;
    let saved_dmark: i64 = cg_loop_defer_mark;
    cg_loop_depth = 1;
    cg_loop_break = end;
    cg_loop_continue = latch;
    cg_loop_defer_mark = g_defer_mark_len;
    cg_push_scope();
    cg_compile_block(body);
    cg_pop_scope();
    cg_loop_depth = saved_depth;
    cg_loop_break = saved_break;
    cg_loop_continue = saved_cont;
    cg_loop_defer_mark = saved_dmark;
    if (cg_err != 0) { return 0; }

    // latch: idx = idx + 1; jmp top
    cg_bind(latch);
    cg_load_reg_mem(RAX, RBP, idx_off);
    cg_add_reg_imm32(RAX, 1);
    cg_store_reg_mem(RBP, idx_off, RAX);
    cg_jmp(top);
    cg_bind(end);
    return 0;
}

// slice for-each: eval iter -> {rax=ptr, rdx=len}; stash ptr, len, idx into
// hidden frame slots; loop i=0..len, load elem [ptr + i*esz] into the loop
// var, run the body, i++. break -> end, continue -> latch (the i++ step).
// Mirrors src/codegen.cpp's ForEachStmt slice path (unchanged shipped path).
fn cg_compile_foreach_slice(s: i64, vtok: i64, iter: i64, body: i64) -> i64 {

    // element type + stride from the iter's type (a slice)
    let it: i64 = cg_expr_type(iter);
    let mut elem_ty: i64 = -1;
    if (it >= 0) { elem_ty = resolve_type(nk_a(it)); }
    if (cg_err != 0) { return 0; }
    let esz: i64 = cg_value_bytes(elem_ty);
    let mut esz_use: i64 = esz;
    if (esz_use <= 0) { esz_use = 8; }

    // alloc hidden frame slots: ptr, len, idx (each 8 bytes) + the loop var.
    // The loop var is 1 slot (v1 for-each element is a scalar; aggregate
    // elements are a future enhancement, mirroring the C++ codegen note).
    let ptr_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
    let len_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
    let idx_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
    let var_off: i64 = cg_alloc_local_t(vtok, elem_ty, 1);

    // eval the iterable -> {rax=ptr, rdx=len} (the slice ABI from cg_eval_viewexpr
    // / a slice local load). Stash ptr + len into their slots.
    cg_eval(iter); if (cg_err != 0) { return 0; }
    cg_store_reg_mem(RBP, ptr_off, RAX);
    cg_mov_reg_reg(RAX, RDX);          // rdx (len) -> rax for the store
    cg_store_reg_mem(RBP, len_off, RAX);
    cg_mov_reg_imm64(RAX, 0);
    cg_store_reg_mem(RBP, idx_off, RAX);   // i = 0

    let top: i64 = cg_alloc_label();
    let latch: i64 = cg_alloc_label();
    let end: i64 = cg_alloc_label();

    cg_bind(top);
    // if (idx >= len) goto end
    cg_load_reg_mem(RAX, RBP, idx_off);
    cg_load_reg_mem(RDX, RBP, len_off);
    cg_cmp_reg_reg(RAX, RDX);
    cg_jcc(COND_GE, end);              // idx >= len -> exit

    // load element at [ptr + idx*esz] into the loop var slot.
    cg_load_reg_mem(RAX, RBP, ptr_off);    // rax = ptr
    cg_load_reg_mem(RCX, RBP, idx_off);    // rcx = idx
    if (esz_use == 1 || esz_use == 2 || esz_use == 4 || esz_use == 8) {
        let mut sc: i64 = 0;
        if (esz_use == 2) { sc = 1; }
        else if (esz_use == 4) { sc = 2; }
        else if (esz_use == 8) { sc = 3; }
        cg_lea_rax_rax_rcx_scale(sc);   // rax = ptr + idx*scale
    } else {
        cg_mov_reg_imm64(R11, esz_use);
        cg_imul_reg_reg(RCX, R11);          // rcx = idx*esz
        cg_add_reg_reg(RAX, RCX);           // rax = ptr + idx*esz
    }
    // load the element from [rax] with its width into the var slot.
    let mut is_signed: i64 = 0;
    if (cg_type_is_int(elem_ty) == 1 && cg_type_is_uint(elem_ty) == 0) { is_signed = 1; }
    if (ty_is_float(elem_ty) == 1) {
        cg_load_float_reg(XMM0, RAX, 0, cg_float_is64_type(elem_ty));
        cg_store_float(var_off, XMM0, cg_float_is64_type(elem_ty));
    } else if (esz_use >= 8) {
        cg_load_reg_mem(RAX, RAX, 0);
        cg_normalize_rax(elem_ty);
        cg_store_reg_mem(RBP, var_off, RAX);
    } else {
        cg_load_elem_to_rax(RAX, 0, esz_use, is_signed);
        cg_normalize_rax(elem_ty);
        cg_store_reg_mem(RBP, var_off, RAX);
    }

    // set up break/continue targets + run the body.
    let saved_depth: i64 = cg_loop_depth;
    let saved_break: i64 = cg_loop_break;
    let saved_cont: i64 = cg_loop_continue;
    let saved_dmark: i64 = cg_loop_defer_mark;
    cg_loop_depth = 1;
    cg_loop_break = end;
    cg_loop_continue = latch;
    cg_loop_defer_mark = g_defer_mark_len;   // break/continue clean up only inner scopes
    cg_push_scope();
    cg_compile_block(body);
    cg_pop_scope();
    cg_loop_depth = saved_depth;
    cg_loop_break = saved_break;
    cg_loop_continue = saved_cont;
    cg_loop_defer_mark = saved_dmark;
    if (cg_err != 0) { return 0; }

    // latch: idx = idx + 1; jmp top
    cg_bind(latch);
    cg_load_reg_mem(RAX, RBP, idx_off);
    cg_add_reg_imm32(RAX, 1);
    cg_store_reg_mem(RBP, idx_off, RAX);
    cg_jmp(top);
    cg_bind(end);
    return 0;
}

// lea rax, [rax + rcx*scale] (scale: 0->1, 1->2, 2->4, 3->8). Used by for-each
// to compute the element address with a power-of-2 stride.
fn cg_lea_rax_rax_rcx_scale(scale: i64) -> i64 {
    // lea rax, [rax + rcz*2^scale] -> REX.W 8D /r SIB(scale, rcx, rax)
    // mod=00 (no disp), reg=rax, rm=4 (SIB); SIB = scale<<6 | rcx<<3 | rax
    cg_byte(cg_rex(1, 0, 0, 0));            // REX.W (rax/rcx are not extended)
    cg_byte(0x8D);
    cg_byte(cg_modrm(0, RAX, 4));           // mod=00, reg=rax, rm=4 (SIB)
    cg_byte(((scale & 3) << 6) | (1 << 3) | (0 & 7));   // SIB: scale, index=rcx(1), base=rax(0)
    return 0;
}

fn cg_compile_match(s: i64) -> i64 {
    let subject: i64 = nk_a(s);
    // Recompute from the live codegen local table. Sema runs again at codegen
    // entry, so storing canonical type-node indices on the AST would leave
    // stale indices after the second s_init appends a fresh canonical set.
    let subject_ty: i64 = cg_expr_type(subject);
    let is_struct: i64 = ty_is_struct(subject_ty);
    let mut subject_off: i64 = 0;
    if (is_struct == 1) {
        // Aggregate subjects need an address; supported struct values are
        // frame locals/params and therefore have a stable rbp offset.
        if (nk_kind(subject) != (NK::Ident as i64)) {
            cg_err = 1; cg_errmsg = string_from_slice("codegen: struct match subject must be a local"); return 0;
        }
        subject_off = cg_lookup_local(nk_tok(subject));
        if (subject_off == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unknown struct match subject"); return 0; }
    } else {
        cg_eval(subject); cg_push(RAX);
    }

    let end: i64 = cg_alloc_label(); let mut arm: i64 = nk_b(s);
    while (arm >= 0) {
        let next: i64 = cg_alloc_label();
        cg_push_scope();
        if (nk_f(arm) == 1) {
            let row: i64 = find_struct(tok_name(nk_tok(arm)));
            let mut fld: i64 = nk_c(arm);
            while (fld >= 0) {
                let idx: i64 = cg_struct_field_index(subject_ty, nk_name(fld));
                let ft: i64 = cg_struct_field_type_at(row, idx);
                let foff: i64 = cg_struct_field_offset(row, idx);
                cg_load_typed(RAX, RBP, subject_off + foff, ft);
                if (nk_a(fld) < 0) {
                    let cap_off: i64 = cg_alloc_local_t(nk_tok(fld), ft, 1);
                    if (ty_is_float(ft) == 1) { cg_store_float(cap_off, XMM0, cg_float_is64_type(ft)); }
                    else { cg_store_typed(RBP, cap_off, ft); }
                } else {
                    // Constant sub-pattern: compare the extracted field value.
                    cg_push(RAX);
                    cg_eval(nk_a(fld));
                    cg_mov_reg_reg(RCX, RAX);
                    cg_pop(RAX);
                    cg_cmp_reg_reg(RAX, RCX);
                    cg_jcc(COND_NE, next);
                }
                fld = nk_next(fld);
            }
        } else if (nk_d(arm) == 0) {
            cg_eval(nk_a(arm)); cg_mov_reg_reg(RCX, RAX); cg_load_reg_mem(RAX, RSP, 0); cg_cmp_reg_reg(RAX, RCX); cg_jcc(COND_NE, next);
        }
        if (nk_e(arm) >= 0) { cg_eval(nk_e(arm)); cg_cmp_reg_imm32(RAX, 0); cg_jcc(COND_E, next); }
        cg_compile_block(nk_b(arm)); cg_jmp(end);
        cg_bind(next);
        cg_pop_scope();
        arm = nk_next(arm);
    }
    cg_bind(end); if (is_struct == 0) { cg_pop(RCX); } return 0;
}

// Phase 3b: compile a do-while loop. Body runs first, then the cond is
// tested; if nonzero, jump back to the body. break -> end, continue -> cond
// (the condition is the latch, mirroring src/codegen.cpp's DoWhileStmt which
// sets the continue target to `cond`). Mirrors src/codegen.cpp exactly:
//   body: <body>; cond: eval cond; cmp rax,0; je end; jmp body; end:
fn cg_compile_dowhile(s: i64) -> i64 {
    let body: i64 = nk_a(s);
    let cond: i64 = nk_b(s);

    let body_l: i64 = cg_alloc_label();
    let cond_l: i64 = cg_alloc_label();
    let end: i64 = cg_alloc_label();

    cg_bind(body_l);
    // set up break/continue targets (continue -> cond label, break -> end)
    let saved_depth: i64 = cg_loop_depth;
    let saved_break: i64 = cg_loop_break;
    let saved_cont: i64 = cg_loop_continue;
    let saved_dmark: i64 = cg_loop_defer_mark;
    cg_loop_depth = 1;
    cg_loop_break = end;
    cg_loop_continue = cond_l;
    cg_loop_defer_mark = g_defer_mark_len;   // break/continue clean up only inner scopes

    cg_compile_block(body);

    cg_loop_depth = saved_depth;
    cg_loop_break = saved_break;
    cg_loop_continue = saved_cont;
    cg_loop_defer_mark = saved_dmark;
    if (cg_err != 0) { return 0; }

    cg_bind(cond_l);
    cg_eval(cond);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    cg_jcc(COND_E, end);          // cond == 0 -> exit
    cg_jmp(body_l);               // back-edge
    cg_bind(end);
    return 0;
}

// Phase 3b: compile a switch. Dispatch prologue: eval the subject into rax,
// hold it in a temp stack slot, compare against each non-default case value,
// je to that case's body label. After all compares, jmp to the default's label
// (or past everything). Case bodies are emitted back-to-back; each nonempty
// case ends with break/return/continue (sema enforces no fallthrough), so an
// implicit break-to-end is NOT inserted — the explicit terminator jumps. break
// inside a case jumps to `end` (switch scopes break like a loop). continue
// inside a case continues the ENCLOSING loop (switch does not override
// cg_loop_continue), mirroring src/codegen.cpp's switch loop-frame
// {continue=Label{0}, break=end}. Mirrors src/codegen.cpp's SwitchStmt.
fn cg_compile_switch(s: i64) -> i64 {
    let subj: i64 = nk_a(s);

    // eval subject -> rax; stash in a temp stack slot across the compare chain
    // (case value evals are immediate loads and don't clobber the slot, but a
    // temp slot is robust + matches the C++ r10-volatile approach in spirit).
    cg_eval(subj);
    if (cg_err != 0) { return 0; }
    cg_push(RAX);

    // pre-allocate a body label per case + an end label. The label is stashed
    // on each Case node's `e` slot (unused by parse/sema) instead of a fresh
    // `case_labels` array — the previous array leaked a slot per switch and
    // was read after `cg_eval(case_value)` which can recurse, so a reused
    // global was unsafe. Stashing on the node is re-entrancy-safe (each case
    // owns its label) and allocation-free.
    let end: i64 = cg_alloc_label();
    let mut c: i64 = nk_b(s);
    while (c >= 0) {
        let lab: i64 = cg_alloc_label();
        set_e(c, lab);
        c = nk_next(c);
    }

    // compare chain: for each non-default case, eval the value, cmp with the
    // stashed subject, je to that case's label. Track the default index.
    let mut default_idx: i64 = -1;
    c = nk_b(s);
    let mut ci: i64 = 0;
    while (c >= 0) {
        if (nk_d(c) == 1) {
            default_idx = ci;
        } else {
            cg_eval(nk_a(c));
            if (cg_err != 0) { return 0; }
            cg_mov_reg_reg(RCX, RAX);          // RCX = case value
            cg_load_reg_mem(RAX, RSP, 0);       // RAX = stashed subject
            cg_cmp_reg_reg(RAX, RCX);
            cg_jcc(COND_E, nk_e(c));
        }
        ci = ci + 1;
        c = nk_next(c);
    }
    // no case matched: jump to default (if any) or past the switch
    if (default_idx >= 0) {
        // find the default case's stashed label
        let mut dc: i64 = nk_b(s);
        let mut di: i64 = 0;
        while (dc >= 0) {
            if (di == default_idx) { cg_jmp(nk_e(dc)); break; }
            di = di + 1;
            dc = nk_next(dc);
        }
    } else {
        cg_jmp(end);
    }

    // emit case bodies. Each case gets its own scope (cg_compile_block pushes
    // one). break inside a case jumps to `end`; continue keeps the enclosing
    // loop's continue target (we only set cg_loop_break, not continue).
    c = nk_b(s);
    ci = 0;
    let saved_depth: i64 = cg_loop_depth;
    let saved_break: i64 = cg_loop_break;
    let saved_dmark: i64 = cg_loop_defer_mark;
    cg_loop_depth = 1;
    cg_loop_break = end;
    cg_loop_defer_mark = g_defer_mark_len;   // break cleans up only inner scopes
    while (c >= 0) {
        cg_bind(nk_e(c));
        // The parser stores a case body as a bare linked list of stmts
        // (nk_b(c) = first stmt), NOT a BlockStmt. Compile it as its own
        // scope + defer cleanup scope, mirroring cg_compile_block.
        cg_compile_stmtlist(nk_b(c));
        if (cg_err != 0) { cg_loop_depth = saved_depth; cg_loop_break = saved_break; cg_loop_defer_mark = saved_dmark; return 0; }
        ci = ci + 1;
        c = nk_next(c);
    }
    cg_loop_depth = saved_depth;
    cg_loop_break = saved_break;
    cg_loop_defer_mark = saved_dmark;

    cg_bind(end);
    // pop the stashed subject (restore rsp; discard into RCX)
    cg_pop(RCX);
    return 0;
}

// =============================================================================
// function compilation.
// =============================================================================

fn cg_count_extra_struct_slots(b: i64) -> i64 {
    let mut extra: i64 = 0; if (b < 0) { return 0; } let mut s: i64 = nk_a(b);
    while (s >= 0) { if (nk_kind(s) == (NK::LetStmt as i64) && nk_a(s) >= 0) { let t: i64 = resolve_type(nk_a(s)); let row: i64 = find_struct(ty_struct_name(t)); if (row >= 0) { extra = extra + cg_struct_field_count(row) - 1; } } if (nk_kind(s) == (NK::IfStmt as i64)) { extra = extra + cg_count_extra_struct_slots(nk_b(s)); if (nk_c(s) >= 0) { extra = extra + cg_count_extra_struct_slots(nk_c(s)); } } if (nk_kind(s) == (NK::WhileStmt as i64)) { extra = extra + cg_count_extra_struct_slots(nk_b(s)); } if (nk_kind(s) == (NK::ForStmt as i64)) { extra = extra + cg_count_extra_struct_slots(nk_e(s)); } s = nk_next(s); }
    return extra;
}

// compile a single function: prologue, param spill, body, epilogue, fixups.
fn cg_compile_func(fd: i64, ns_tok: i64) -> i64 {
    cg_cur_ns = ns_tok;
    let is_lambda_fn: i64 = (nk_kind(fd) == (NK::LambdaExpr as i64)) ? 1 : 0;
    // init the local table for this function
    cg_locals_init();
    // Phase 3b: reset the defer cleanup stack for this function (defers are
    // function-scoped) + record the resolved return type so a return can
    // stash the right value across deferred exprs.
    array_resize(g_defers, 0);
    array_resize(g_defer_marks, 0);
    g_defer_mark_len = 0;
    cg_loop_defer_mark = 0;
    let ret_ty_node: i64 = nk_b(fd);
    if (ret_ty_node >= 0) { cg_cur_ret = resolve_type(ret_ty_node); } else { cg_cur_ret = TY_VOID; }
    // Phase 4: a fn whose return type is a registered struct uses the
    // hidden-pointer sret ABI (word 0 = dest ptr, arrives in rcx). Reset the
    // caller-side dest-ready flag for this fn's body.
    let ret_is_struct: i64 = cg_ty_is_struct(cg_cur_ret);
    cg_struct_ret_dest_ready = 0;
    cg_struct_ret_ptr_off = 0;
    cg_current_lambda = -1;
    cg_lambda_env_off = 0;
    if (is_lambda_fn == 1) { cg_current_lambda = fd; }

    // count params (and accumulate each param's word count for the spill map)
    let mut param_count: i64 = 0;
    let mut p: i64 = nk_a(fd);
    while (p >= 0) {
        param_count = param_count + 1;
        p = nk_next(p);
    }
    // total incoming words = (1 if struct return else 0) + sum(words_for_type
    // over params). Used for the stack-arg source offset of words >= 4.
    let mut total_words: i64 = 0;
    if (ret_is_struct == 1) { total_words = 1; }
    if (is_lambda_fn == 1) { total_words = total_words + 1; }
    {
        let mut pp: i64 = nk_a(fd);
        while (pp >= 0) {
            total_words = total_words + cg_words_for_type(resolve_type(nk_a(pp)));
            pp = nk_next(pp);
        }
    }

    // Count scalar locals, then add aggregate expansion words. The ordinary
    // count remains a conservative baseline for nested control-flow locals.
    let body: i64 = nk_c(fd);
    // cg_count_locals_block now counts each let's actual stack slots
    // (ceil(value_bytes/8) for aggregates, 1 for scalars), so the frame is
    // sized to hold every byte of every local. No separate struct-extra pass.
    let local_count: i64 = cg_count_locals_block(body, 0);
    // Phase 4: add compiler-hidden struct temp slots (struct-literal returns +
    // struct-by-value StructLit/CallExpr args) + the hidden return-pointer slot.
    let struct_temp_slots: i64 = cg_count_struct_temps_block(body, 0, ret_is_struct);
    let hidden_ptr_slots: i64 = ((ret_is_struct == 1) ? 1 : 0) + is_lambda_fn;

    // frame size = (params + locals + struct temps + hidden ptr) * 8, rounded
    // to 16, +8 for the return-address alignment (push rbp makes it 16-aligned).
    let frame: i64 = cg_round16((param_count + local_count + struct_temp_slots + hidden_ptr_slots) * 8 + 8);
    cg_frame_size = frame;

    // epilogue label for this function
    cg_epilogue_label = cg_alloc_label();

    // prologue
    cg_emit_prologue(frame);

    // spill the hidden return pointer (word 0, rcx) to a dedicated frame slot
    // BEFORE the real params (which shift to start at word 1). It is not a
    // script-visible variable, so allocate it with a synthesized token (-1)
    // and record its offset in cg_struct_ret_ptr_off for the ReturnStmt path.
    let mut param_word: i64 = 0;
    if (ret_is_struct == 1) {
        let rptr_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
        cg_struct_ret_ptr_off = rptr_off;
        // word 0 arrives in rcx (the first Win64 int arg reg)
        cg_store_reg_mem(RBP, rptr_off, RCX);
        param_word = 1;
    }
    if (is_lambda_fn == 1) {
        let env_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
        cg_lambda_env_off = env_off;
        if (param_word == 0) { cg_store_reg_mem(RBP, env_off, RCX); }
        else { cg_store_reg_mem(RBP, env_off, RDX); }
        param_word = param_word + 1;
    }

    // spill params to frame slots. Each param occupies cg_words_for_type(pt)
    // consecutive words; a struct param's bytes are spilled word-by-word into
    // the param local's frame region (the last word may be partial — store only
    // its real remaining bytes so a non-multiple-of-8 struct does not overrun
    // into the next slot / the saved rbp). Mirrors src/codegen.cpp's prologue.
    let mut arg_regs: i64 = cg_arg_regs_get();
    array_set_i64(arg_regs, 0, RCX);
    array_set_i64(arg_regs, 1, RDX);
    array_set_i64(arg_regs, 2, R8);
    array_set_i64(arg_regs, 3, R9);

    let mut pi: i64 = 0;
    p = nk_a(fd);
    while (p >= 0) {
        let pt: i64 = resolve_type(nk_a(p));
        if (cg_ty_is_struct(pt) == 1) {
            let row: i64 = find_struct(ty_struct_name(pt));
            let struct_bytes: i64 = (row >= 0) ? cg_struct_value_bytes(row) : (cg_words_for_type(pt) * 8);
            let wcount: i64 = cg_words_for_type(pt);
            let off: i64 = cg_alloc_local_t(nk_tok(p), pt, wcount);
            let mut byte_pos: i64 = 0;
            let mut w: i64 = 0;
            while (w < wcount) {
                let word_bytes: i64 = (8 < struct_bytes - byte_pos) ? 8 : (struct_bytes - byte_pos);
                let w_global: i64 = param_word + w;
                if (word_bytes >= 8) {
                    // full word: spill the arg reg (w_global < 4) or load from
                    // the caller's outgoing stack area into the local slot.
                    if (w_global < 4) {
                        let reg: i64 = array_get_i64(arg_regs, w_global);
                        cg_store_reg_mem(RBP, off + byte_pos, reg);
                    } else {
                        let src_off: i64 = 48 + (w_global - 4) * 8;
                        cg_load_reg_mem(RAX, RBP, src_off);
                        cg_store_reg_mem(RBP, off + byte_pos, RAX);
                    }
                } else {
                    // partial last word: get the word's value into rax, then
                    // store only its low `word_bytes` bytes.
                    if (w_global < 4) {
                        cg_mov_reg_reg(RAX, array_get_i64(arg_regs, w_global));
                    } else {
                        let src_off: i64 = 48 + (w_global - 4) * 8;
                        cg_load_reg_mem(RAX, RBP, src_off);
                    }
                    cg_store_rax_bytes(RBP, off + byte_pos, word_bytes);
                }
                byte_pos = byte_pos + word_bytes;
                w = w + 1;
            }
        } else if (nk_f(pt) == 1 || nk_f(pt) == 2) {
            // slice/closure param: 2 consecutive integer words -> the local's 16-byte
            // {ptr,len} slot (word 0 -> off, word 1 -> off+8).
            let off: i64 = cg_alloc_local_t(nk_tok(p), pt, 2);
            cg_spill_word(param_word, off, arg_regs, total_words);
            cg_spill_word(param_word + 1, off + 8, arg_regs, total_words);
        } else if (ty_is_float(pt) == 1) {
            let off: i64 = cg_alloc_local_t(nk_tok(p), pt, 1);
            if (param_word < 4) {
                // float args arrive in xmm0..xmm3 (flt_arg_regs[param_word])
                cg_store_float(off, param_word, cg_float_is64_type(pt));
            } else {
                let src_off: i64 = 48 + (param_word - 4) * 8;
                cg_load_reg_mem(RAX, RBP, src_off);
                cg_store_reg_mem(RBP, off, RAX);
            }
        } else {
            let off: i64 = cg_alloc_local_t(nk_tok(p), pt, 1);
            if (param_word < 4) {
                let reg: i64 = array_get_i64(arg_regs, param_word);
                cg_store_reg_mem(RBP, off, reg);
            } else {
                let src_off: i64 = 48 + (param_word - 4) * 8;
                cg_load_reg_mem(RAX, RBP, src_off);
                cg_store_reg_mem(RBP, off, RAX);
            }
        }
        param_word = param_word + cg_words_for_type(pt);
        pi = pi + 1;
        p = nk_next(p);
    }

    // body
    cg_compile_block(body);
    if (cg_err != 0) { return 0; }

    // implicit void return: rax = 0 (only reached by fallthrough — a fn
    // that falls off the end without an explicit return gets rax = 0).
    // This MUST come before the epilogue label bind: every ReturnStmt evals
    // its value into rax then jumps to cg_epilogue_label, so the label must
    // land at the epilogue itself (mov rsp, rbp; pop rbp; ret) — NOT here —
    // or the implicit zeroing would overwrite the return value. (The C++
    // reference codegen emits emit_epilogue() inline at each return instead
    // of jumping to a shared label; this codegen uses the shared-label form,
    // which is equivalent only if the implicit zero is fallthrough-only.)
    // Phase 4: a struct-returning fn's fallthrough has no struct to return;
    // rax = 0 is harmless (the caller's dest was never written, but sema
    // guarantees a struct-returning fn always has an explicit return).
    cg_mov_reg_imm64(RAX, 0);
    // bind the epilogue label + emit the epilogue (returns jump here, with
    // rax already holding their value)
    cg_bind(cg_epilogue_label);
    cg_emit_epilogue();

    // NOTE: label fixups are NOT resolved here — inter-function call rel32
    // fixups reference other fns' entry labels, which are only bound after
    // every fn is compiled. cg_resolve_fixups() is called once at the end of
    // codegen() after all fns are compiled + all entry labels bound.
    return 0;
}

// =============================================================================
// top-level codegen: find the program node, compile each function.
// =============================================================================

// find the program node in g_nodes by scanning for NK::Program.
// (sema() calls parse() internally + doesn't expose the program node index;
//  the Program node is the one with kind == NK::Program, which is unique.)
fn cg_find_program() -> i64 {
    let n: i64 = array_length(g_nodes) / PARSE_STRIDE;
    let mut i: i64 = 0;
    while (i < n) {
        if (nk_kind(i) == (NK::Program as i64)) { return i; }
        i = i + 1;
    }
    return -1;
}

// codegen(source): lex + parse + sema + emit x64 bytes for every fn.
// Returns the array<u8> handle (the code buffer) on success, or 0 on error.
// cg_failed() / cg_err_msg() expose the error state.
fn codegen(source: string) -> i64 {
    // run sema (which parses + type-checks + builds g_fns / g_globals)
    let r: i64 = sema(source);
    if (r != 0) {
        cg_err = 1;
        if (r == 2) {
            cg_errmsg = string_from_slice("codegen: parse error: ") + parse_err_msg();
        } else {
            cg_errmsg = string_from_slice("codegen: sema error: ") + sema_err_msg();
        }
        return 0;
    }

    // init the emitter
    cg_init();

    // find the program node
    let prog: i64 = cg_find_program();
    if (prog < 0) {
        cg_err = 1;
        cg_errmsg = string_from_slice("codegen: no program node found");
        return 0;
    }

    // Allocate the data-section slots for constant-initialized i64 globals
    // AND string globals (zero-filled slots, handles materialized at runtime)
    // BEFORE compiling functions, so global references in fn bodies resolve
    // to their data addend. Each global gets 8 bytes in cg_data + a
    // (name -> addend) entry in cg_globals (§5). String globals are also
    // recorded in cg_str_globals for the init function below.
    cg_compile_globals(prog);

    // Emit the synthetic __globals_init function (materializes each string
    // global's literal + stores the handle into its data slot) BEFORE the user
    // functions so it lands at offset 0 when present (the pipeline's prologue
    // check still sees 0x55 = push rbp at byte 0). No-op (no fn emitted, label
    // stays -1) when the program declares no string globals. Must run before
    // cg_resolve_fixups so its entry label is bound.
    cg_emit_globals_init();

    // Allocate an entry label for every function up front, so a call to a fn
    // declared later (forward reference) gets a fixup for a label that will be
    // bound when that fn is compiled. Stored in cg_fn_labels stride 3
    // (name_tok, label, ns_tok). Descends into NamespaceDecl members.
    let mut d: i64 = nk_a(prog);
    while (d >= 0) {
        if (nk_kind(d) == (NK::NamespaceDecl as i64)) {
            let ns_tok: i64 = nk_tok(d);
            let mut m: i64 = nk_a(d);
            while (m >= 0) {
                if (nk_kind(m) == (NK::FnDecl as i64)) {
                    let lab: i64 = cg_alloc_label();
                    array_push_i64(cg_fn_labels, nk_tok(m));
                    array_push_i64(cg_fn_labels, lab);
                    array_push_i64(cg_fn_labels, ns_tok);
                }
                m = nk_next(m);
            }
        } else if (nk_kind(d) == (NK::FnDecl as i64)) {
            let lab: i64 = cg_alloc_label();
            array_push_i64(cg_fn_labels, nk_tok(d));
            array_push_i64(cg_fn_labels, lab);
            array_push_i64(cg_fn_labels, -1);
        }
        d = nk_next(d);
    }
    // Synthetic lambdas follow user functions in creation order. This makes
    // sema's baked slot (user-fn count + lambda index) match this table.
    let mut lalloc: i64 = 0;
    while (lalloc < array_length(g_lambdas)) {
        let le: i64 = array_get_i64(g_lambdas, lalloc);
        let lab: i64 = cg_alloc_label();
        array_push_i64(cg_fn_labels, -1); array_push_i64(cg_fn_labels, lab); array_push_i64(cg_fn_labels, -1);
        lalloc = lalloc + 1;
    }

    // compile each function declaration in the program, binding its entry
    // label at its prologue offset (the current code position) first so any
    // call to it — including a self-recursive call inside its own body —
    // resolves to the right entry offset. Namespaced fns bind via the
    // qualified label lookup. A namespace is a sema/scope concern, not a
    // codegen concern: fns have entry labels regardless of namespace.
    d = nk_a(prog);
    while (d >= 0) {
        if (nk_kind(d) == (NK::NamespaceDecl as i64)) {
            let ns_tok: i64 = nk_tok(d);
            let mut m: i64 = nk_a(d);
            while (m >= 0) {
                if (nk_kind(m) == (NK::FnDecl as i64)) {
                    let mut ns_name: string = string_from_slice("");
                    if (ns_tok >= 0) { ns_name = tok_name(ns_tok); }
                    let lab: i64 = cg_lookup_fn_label_qualified(nk_name(m), ns_name);
                    if (lab >= 0) { cg_bind(lab); }   // entry = current code offset
                    cg_compile_func(m, ns_tok);
                    if (cg_err != 0) { return 0; }
                }
                m = nk_next(m);
            }
        } else if (nk_kind(d) == (NK::FnDecl as i64)) {
            let lab: i64 = cg_lookup_fn_label(nk_name(d));
            if (lab >= 0) { cg_bind(lab); }   // entry = current code offset
            cg_compile_func(d, -1);
            if (cg_err != 0) { return 0; }
        }
        d = nk_next(d);
    }

    // Compile synthetic lambda bodies after ordinary functions. Their labels
    // were allocated after user functions, so their indices are dispatch slots.
    let mut li: i64 = 0;
    while (li < array_length(g_lambdas)) {
        let le: i64 = array_get_i64(g_lambdas, li);
        let slot: i64 = (array_length(cg_fn_labels) / 3) - array_length(g_lambdas) + li;
        let llab: i64 = array_get_i64(cg_fn_labels, slot * 3 + 1);
        cg_bind(llab); cg_compile_func(le, -1); if (cg_err != 0) { return 0; }
        li = li + 1;
    }

    // resolve ALL label fixups now that every fn's entry label (and every
    // intra-fn if/while label) is bound. This patches inter-function call
    // rel32 fixups to the callee's real entry offset within the buffer.
    cg_resolve_fixups();
    if (cg_err != 0) { return 0; }

    return cg_code;  // the array<u8> handle
}

// whether the codegen flagged an error.
fn codegen_failed() -> i64 { return cg_err; }
fn codegen_err_msg() -> string { return cg_errmsg; }

// =============================================================================
// convenience: get the length of the code buffer (byte count).
// =============================================================================
fn codegen_byte_count() -> i64 {
    return array_length(cg_code);
}

// read a byte from the code buffer at offset i (for verification).
fn codegen_byte_at(i: i64) -> i64 {
    if (i < 0 || i >= array_length(cg_code)) { return -1; }
    return array_get_u8(cg_code, i) as i64;
}

// the code offset of a named function's entry (prologue) within the buffer.
// Returns -1 if the fn is not in cg_fn_labels or its label was never bound.
// Used by the end-to-end pipeline to call `main` specifically (the codegen
// lays fns out in declaration order, so `main` may not be at offset 0 when
// the program declares helper fns first); call_raw(page_ptr + entry_offset)
// invokes it.
fn codegen_fn_entry_offset(name: string) -> i64 {
    let lab: i64 = cg_lookup_fn_label(name);
    if (lab < 0) { return -1; }
    return cg_label_offset(lab);
}

// self_hosted/full_pipeline.ember — the ember-compiling-ember end-to-end demo.
//
// This is the self-hosting milestone made concrete: a SINGLE ember script
// imports the four self-hosted compiler stages (each written IN ember) +
// chains them into a complete pipeline that takes ember SOURCE as a string,
// compiles it all the way to x64 machine code, and EXECUTES the result via
// the host's call_raw native — returning whatever the compiled program
// returns.
//
//   source string
//     ->  lex.ember      (Stage 1: lex   source -> token array)
//     ->  parse.ember    (Stage 2: parse tokens -> AST)
//     ->  sema.ember     (Stage 3: type-check AST)
//     ->  codegen.ember  (Stage 4: emit AST -> x64 bytes in array<u8>)
//     ->  make_executable(array<u8>) -> fn pointer   (host native: W^X page)
//     ->  call_raw(fn_ptr, arg) -> i64               (host native: execute)
//     ->  the compiled program's return value
//
// The four stage files are imported (import "lex.ember"; import "parse.ember";
// import "sema.ember"; import "codegen.ember";), so this script literally is
// "ember source compiled by the ember-written compiler, then executed" — the
// bootstrapping milestone's proof of concept. The C++ compiler (ember_cli)
// compiles THIS script; this script then compiles + runs a second ember
// program using only ember-written frontend code + the two host execution
// natives.
//
// === Multi-fn programs + in-buffer calls ===
//
// The self-hosted codegen emits script-to-script calls as a direct
// `call rel32` to the callee's entry label. cg_resolve_fixups patches each
// call's rel32 to the callee's real prologue offset within the SAME code
// buffer (every fn is laid out in declaration order in one contiguous
// buffer). make_executable copies the whole buffer to one RX page, so a
// relative call between fns resolves correctly at runtime without any host
// patching — multi-fn programs (helper fns + main, calls, if/else, let mut
// + assignment, comparisons, while loops) execute end-to-end.
//
// Because fns are laid out in declaration order, `main` may not be at
// offset 0 (helper fns declared first are). compile_and_run therefore
// locates `main`'s entry offset by name (codegen_fn_entry_offset) and calls
// page_ptr + main_offset — not the first fn. call_raw casts that to
// int64_t(*)(int64_t); the unused arg is harmless on Win64 (rax holds the
// return).
//
// === Natives used (PERM_FFI-gated; run with --ffi) ===
//
//   make_executable(bytes: i64) -> i64   copy array<u8> to an RX page, return ptr
//   call_raw(fn_ptr: i64, arg: i64) -> i64   invoke the entry, return its result
//   free_executable_ptr(ptr: i64) -> void   release the RX page
//
// Run:
//   ./buildt/ember_cli.exe run self_hosted/full_pipeline.ember --fn main --ffi
// (exit code = the compiled program's return value; for 1 + 2 * 3 that is 7.)


// -----------------------------------------------------------------------------
// compile_and_run(source) — the full pipeline. Takes an ember program as a
// string, runs it through all four self-hosted stages, executes the emitted
// x64 bytes, and returns the compiled program's return value. Returns a
// negative code on a stage failure (so a failure is observable, not a silent
// 0): -1xx = lex, -2xx = parse, -3xx = sema, -4xx = codegen, -5xx = exec.
// -----------------------------------------------------------------------------
fn compile_and_run(source: string) -> i64 {
    // ---- Stage 1: lex source -> token array ----
    // lex() returns an opaque array<u8>-backed token handle + sets the lexer's
    // globals (g_src, g_toks). lex_failed() reports a scan error.
    let toks: i64 = lex(source);
    if (lex_failed() != 0) { return -101; }
    let ntok: i64 = tok_count(toks);
    if (ntok < 2) { return -102; }   // at least one real token + Eof

    // ---- Stage 2: parse tokens -> AST ----
    // parse() takes the source (it re-lexes internally to populate its token
    // cursor — the self-hosted parser's only entry point is parse(source),
    // there is no parse_tokens(toks) variant yet). It returns the Program
    // node index, or -1 on a structural error; parse_failed() / parse_err_*
    // expose the state. parse_tokens() recovers the token array parse built
    // (== toks for the same source).
    let prog: i64 = parse(source);
    if (parse_failed() != 0) { return -201; }
    if (prog < 0) { return -202; }
    // sanity: the program node is an NK::Program
    if (nk_kind(prog) != (NK::Program as i64)) { return -203; }

    // ---- Stage 3: type-check the AST ----
    // sema() takes the source (it calls parse() internally, then runs the
    // type checker over the AST). Returns 0 on success, 1 on a sema error,
    // 2 on a parse error. sema_failed() / sema_err_* expose the state.
    let sr: i64 = sema(source);
    // Stable -3xx values are explicit out-of-subset rejections and must be
    // propagated unchanged. Ordinary sema/parse failures keep the pipeline's
    // historical -302/-303 stage mapping.
    if (sr < 0) { return sr; }
    if (sr != 0) { return -301 - sr; }

    // ---- Stage 4: codegen AST -> x64 bytes ----
    // codegen() takes the source (it calls sema() internally, then emits x64
    // bytes into an array<u8>). Returns the array handle (0 on error).
    // codegen_failed() / codegen_byte_count() / codegen_byte_at() expose state.
    let bytes: i64 = codegen(source);
    if (codegen_failed() != 0) { return -401; }
    let nbytes: i64 = codegen_byte_count();
    if (nbytes <= 0) { return -402; }

    // sanity: the buffer starts with the x64 function prologue
    //   0x55           push rbp
    //   0x48 0x89 0xE5 mov rbp, rsp
    // (the first function's entry is at offset 0 — not necessarily `main`,
    // since the codegen lays fns out in declaration order; the actual entry
    // we invoke is resolved by name below via codegen_fn_entry_offset)
    if (codegen_byte_at(0) != 0x55) { return -403; }
    if (codegen_byte_at(1) != 0x48) { return -404; }
    if (codegen_byte_at(2) != 0x89) { return -405; }
    if (codegen_byte_at(3) != 0xE5) { return -406; }

    // locate `main`'s entry offset within the buffer. The codegen binds an
    // entry label per fn at its prologue offset; codegen_fn_entry_offset
    // returns it by name. For a single-fn program this is 0 (the only fn);
    // for a multi-fn program (helper fns declared before main) it is main's
    // prologue offset, and we call code_base + offset to invoke main.
    let main_off: i64 = codegen_fn_entry_offset(string_from_slice("main"));
    if (main_off < 0) { return -502; }

    // ---- Build the EMBM v1 module image + load it via the host loader ----
    // codegen_emit_image() stitches the 80-byte header + code + rodata + data
    // + symbols + relocations into one array<u8> (replacing the bare code-blob
    // contract). load_executable_module parses it, allocates stable RX/R/RW
    // regions, applies the ABS64 relocations (rodata/data/native calls), and
    // returns an opaque owning handle (0 on any validation failure). This
    // replaces make_executable so the self-hosted compiler can emit real string
    // literals (rodata), mutable globals (data), and native/extension calls.
    let img: i64 = codegen_emit_image();
    let h: i64 = load_executable_module(img);
    if (h == 0) { return -501; }
    // Coroutines resolve the slot passed to coroutine_start through this
    // module's v2 dispatch vector. Register it before any module code runs.
    set_coroutine_dispatch(module_dispatch_base(h), module_dispatch_count(h));

    // module_entry_ptr validates the handle + code_offset and returns
    // code_base + main_off (the executable entry for `main`). 0 on failure.
    let entry: i64 = module_entry_ptr(h, main_off);
    if (entry == 0) { free_executable_module(h); return -502; }

    // ---- Run the module-init function BEFORE main (if present) ----
    // The codegen emits a synthetic __globals_init function when the program
    // declares string globals: it materializes each literal (rodata +
    // string_from_slice -> handle) + stores the handle into the global's data
    // slot, so the globals are live when main reads them. codegen_globals_
    // init_offset returns its entry offset, or -1 when none was emitted (no
    // string globals -> nothing to init). The init result is discarded.
    let init_off: i64 = codegen_globals_init_offset();
    if (init_off >= 0) {
        let init_entry: i64 = module_entry_ptr(h, init_off);
        if (init_entry != 0) {
            let init_res: i64 = call_raw(init_entry, 0);
            // an init failure is non-fatal (string natives returning 0 just
            // leaves the global empty); continue to main regardless.
            if (init_res < 0) { }   // discard
        }
    }

    // call_raw casts the entry to int64_t(*)(int64_t) and calls it. The
    // compiled `main` returns its result in rax, which call_raw reads back.
    // Calls from main to other fns in the same program resolve via in-buffer
    // call rel32 (patched by cg_resolve_fixups to each callee's entry offset);
    // native/extension calls resolve via the loader's ABS64_NATIVE relocs.
    let result: i64 = call_raw(entry, 0);

    // release the loaded module (frees the code/rodata/data regions)
    free_executable_module(h);

    return result;
}

// -----------------------------------------------------------------------------
// run_demo — the end-to-end demo entry. Compiles + executes the canonical
// program
//   fn main() -> i64 { return 1 + 2 * 3; }
// and returns its result (7, since * binds tighter than + : 1 + (2*3) = 7).
// The CLI propagates this as the process exit code (masked to 31 bits), so
//   ./buildt/ember_cli.exe run self_hosted/full_pipeline.ember --fn run_demo --ffi
// exits 7.
//
// (This file deliberately does NOT declare a top-level `main` — it is a
// library, like lex.ember / parse.ember / sema.ember / codegen.ember, so it
// can be imported by full_pipeline_test.ember without a duplicate-`main`
// collision. The test's own `main` is the driver; `run_demo` is this file's
// runnable demo entry.)
// -----------------------------------------------------------------------------
fn run_demo() -> i64 {
    // A multi-fn program exercising the expanded feature set: a helper fn
    // with two i64 params (multi-arg call), `let mut` + assignment, an
    // if/else, and a comparison (<). 1 < 5 is true -> x = add(1, 6) = 7;
    // else x = 0. Returns 7 (so `--fn run_demo --ffi` exits 7).
    let src: string = string_from_slice("fn add(a: i64, b: i64) -> i64 { return a + b; } fn main() -> i64 { let mut x: i64 = 1; if (x < 5) { x = add(x, 6); } else { x = 0; } return x; }");
    return compile_and_run(src);
}

// self_hosted/emberc.ember — bundled self-hosted compiler preview entrypoint.
//
// The preview reads ONE input .ember path from stdin, reads it through the io
// extension, runs the ember-written lex/parse/sema/codegen pipeline, creates a
// W^X executable page, invokes the input program's `main`, and returns that
// result as its process exit code.
//
// Usage after bundling:
//   echo self_hosted/preview_smoke_input.ember | ember_selfhost_preview.exe
//
// Supported source subset:
//   i64/bool/void/f32/f64/string; let/let mut; if/else; while; C-style
//   for; return; arithmetic and comparisons; string concat/equality/length;
//   f-string interpolation of scalar locals; flat struct literals/field reads;
//   enums and variant matching; direct calls of up to four scalar arguments;
//   multiple functions, recursion and forward calls.
// The input must define `fn main() -> i64` and currently must be ASCII text.
// Arrays, slices, switch, try/catch, lambdas, coroutines/yield, for-each,
// defer and other unsupported constructs are rejected before codegen.
//
// The current io extension exposes whole-file bytes rather than a text-read
// native, so this preview performs an explicit checked ASCII byte-to-string
// conversion. This keeps all file access on the io extension boundary.


fn ascii_byte(ch: i64) -> string {
    if (ch == 9) { return "\t"; }
    if (ch == 10) { return "\n"; }
    if (ch == 13) { return "\r"; }
    // Every printable ASCII character, indexed by byte - 32.
    let chars: string = r""" !"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\]^_`abcdefghijklmnopqrstuvwxyz{|}~""";
    return string_substr(chars, ch - 32, 1);
}

fn bytes_to_source(bytes: i64) -> string {
    let mut source: string = "";
    let n: i64 = array_length(bytes);
    let mut i: i64 = 0;
    while (i < n) {
        let ch: i64 = array_get_u8(bytes, i) as i64;
        if (ch != 9 && ch != 10 && ch != 13) {
            if (ch < 32 || ch > 126) { return ""; }
        }
        source = source + ascii_byte(ch);
        i = i + 1;
    }
    return source;
}

fn compile_file_and_run(path: string) -> i64 {
    if (string_length(path) == 0) { return -601; }
    // Read the file as text (UTF-8 preserved verbatim, including non-ASCII)
    // via the host file_read_text native. This replaces the ASCII-only
    // byte-to-string conversion that rejected smart quotes, em-dashes, and
    // other non-ASCII characters (-603), so the self-hosted compiler can
    // now read its own source and the full tests/lang corpus.
    let source: string = file_read_text(path);
    if (string_length(source) == 0) {
        // 0-length result: either a genuine empty file (valid, compiles to
        // no tokens -> -102) or a read failure (return -602). file_read_text
        // returns 0 (a null handle) on read failure, which string_length
        // treats as 0; a real empty file returns an empty-string handle.
        // Distinguish by re-checking the path exists.
        if (file_exists(path) == 0) { return -602; }
    }
    return compile_and_run(source);
}

fn main() -> i64 {
    println("ember self-host preview: enter an ASCII .ember path");
    println("subset: scalar/string ops, f-strings, floats, flat structs, enums/match, calls/recursion");
    let path: string = read_line();
    let result: i64 = compile_file_and_run(path);
    if (result < 0) {
        print("self-host compile failed with code ");
        print_i64(result);
        println("");
    }
    return result;
}

