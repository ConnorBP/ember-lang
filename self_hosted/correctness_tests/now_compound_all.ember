// Self-hosted positive: all compound assignment operators.
// Starts at 42, applies inverse ops to verify each, ends at 42.
// expect: 42
fn main() -> i64 {
    let mut x: i64 = 42;
    x += 8;        // 50
    x -= 8;        // 42
    x *= 2;        // 84
    x /= 2;        // 42
    x |= 64;       // 106
    x &= 0x3F;     // 42
    x ^= 1;        // 43
    x ^= 1;        // 42
    x <<= 1;       // 84
    x >>= 1;       // 42
    return x;
}
