// Differential audit: four-register ABI and nested argument evaluation.
// expect: 100
fn add4(a: i64, b: i64, c: i64, d: i64) -> i64 { return a + b + c + d; }
fn twice(x: i64) -> i64 { return x * 2; }
fn main() -> i64 {
    return add4(twice(5), add4(1, 2, 3, 4), twice(add4(2, 3, 4, 6)), add4(10, 20, 10, 10));
}
