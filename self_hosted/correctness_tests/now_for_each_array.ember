// now_for_each_array — for-each over an array<i64> handle (the iterable() hook,
// array case). array_new(8,3) mints an i64 array handle; set 10,20,30; for x in
// a { sum += x } lowers to len=array_length(a); while i<len { x=array_get_i64;
// ... }.
// expect: 60
fn main() -> i64 {
    let a: i64 = array_new(8, 3);
    array_set_i64(a, 0, 10);
    array_set_i64(a, 1, 20);
    array_set_i64(a, 2, 30);
    let mut sum: i64 = 0;
    for (x in a) {
        sum = sum + x;
    }
    return sum;
}
