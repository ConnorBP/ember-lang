// Differential audit: all six comparison operators, both true and false.
// expect: 63
fn main() -> i64 {
    let mut r: i64 = 0;
    if (2 == 2) { r = r + 1; }
    if (2 != 3) { r = r + 2; }
    if (2 < 3) { r = r + 4; }
    if (2 <= 2) { r = r + 8; }
    if (3 > 2) { r = r + 16; }
    if (3 >= 3) { r = r + 32; }
    if (2 == 3) { r = r + 64; }
    if (2 != 2) { r = r + 128; }
    if (3 < 2) { r = r + 256; }
    if (3 <= 2) { r = r + 512; }
    if (2 > 3) { r = r + 1024; }
    if (2 >= 3) { r = r + 2048; }
    return r;
}
