// Differential audit: nested loops and nested break/continue targets.
// expect: 9
fn main() -> i64 {
    let mut n: i64 = 0;
    let mut i: i64 = 0;
    while (i < 3) {
        let mut j: i64 = 0;
        while (j < 6) {
            j = j + 1;
            if (j == 2) { continue; }
            if (j == 5) { break; }
            n = n + 1;
        }
        i = i + 1;
    }
    return n;
}
