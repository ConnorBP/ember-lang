// Self-hosted positive: for-each over a slice derived from a fixed array view.
// Mirrors tests/lang/valid_for_each.ember (expect 150) for the self-hosted suite.
// expect: 150
fn main() -> i64 {
    let a: i64[5] = [10, 20, 30, 40, 50];
    let s: i64[] = a[..];
    let mut sum: i64 = 0;
    for (x in s) {
        sum = sum + x;
    }
    return sum;
}
