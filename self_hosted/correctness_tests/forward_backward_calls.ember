// Differential audit: declaration order independent call resolution.
// expect: 44
fn first(x: i64) -> i64 { return second(x) + third(x); }
fn main() -> i64 { return first(5) + fourth(2); }
fn second(x: i64) -> i64 { return x * 2; }
fn third(x: i64) -> i64 { return second(x + 1); }
fn fourth(x: i64) -> i64 { return first(x) + 12; }
