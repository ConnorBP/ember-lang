// self_hosted/codegen.ember — the ember code generator, written IN ember.
//
// Self-hosting Stage 4 (the final stage): prove ember can generate its own
// machine code. This is a port of the CORE x64 emission logic of
// src/codegen.cpp (the C++ reference tree-walking code generator) + the
// byte-level emitter in src/x64_emitter.hpp to ember source. It consumes the
// type-checked AST built by Stage 2's parser (parse.ember) + checked by
// Stage 3's sema (sema.ember) and emits x86-64 machine code bytes into an
// array<u8>.
//
// === v1 subset ===
//
// Stage 4 v1 codegens a SUBSET of ember, matching the task scope:
//   - fn with i64 params + i64/void return
//   - let with i64 (auto or typed)
//   - if / while with bool conditions
//   - return with a value
//   - binary ops on i64: + - * & | ^ << >>
//   - comparison ops: == != < <= > >= -> bool (0/1 in rax)
//   - logical && || -> bool (short-circuit)
//   - unary: - (neg), ! (logical not), ~ (bitwise not)
//   - calls to i64->i64 fns (up to 4 args in Win64 registers rcx/rdx/r8/r9)
//   - int literals -> i64, bool literals -> bool
//   - identifiers: locals + params (loaded from [rbp+offset])
//
// The output is an array<u8> of x64 bytes. The codegen does NOT execute them
// (that requires JIT memory natives not yet exposed to ember scripts); it
// produces the bytes + the test verifies them.
//
// === x64 calling convention (Win64) ===
//
//   - Integer args: rcx, rdx, r8, r9 (first 4), then stack
//   - Return value: rax
//   - Callee-saved: rbx, rbp, rsi, rdi, r12-r15
//   - Shadow space: 32 bytes minimum per call
//   - Stack alignment: 16-byte before `call`
//
// === Frame layout ===
//
//   push rbp                  ; 0x55
//   mov rbp, rsp              ; 48 89 E5
//   sub rsp, frame_size       ; 48 81 EC <imm32>
//   ... params spilled to [rbp-8], [rbp-16], ...
//   ... locals at [rbp-(n*8)], growing downward ...
//   mov rsp, rbp              ; 48 89 EC
//   pop rbp                   ; 0x5D
//   ret                       ; 0xC3
//
// Each local + param gets an 8-byte slot (everything is i64 in v1). The frame
// size is pre-computed from a count of params + locals, rounded up to 16.
//
// === x64 emitter ===
//
// A port of X64Emitter (src/x64_emitter.hpp): a byte buffer (array<u8>) +
// methods that emit bytes. Register encoding numbers (0-15) + REX/ModRM
// helpers match the C++ reference. Labels are rel32 fixups backpatched by
// cg_resolve_fixups() after all labels are bound — identical to the C++.
//
// === Symbol tables ===
//
// ember has no map<string, T> builtin, so every table is a flat i64 array
// (the array extension, elem_size 8) with a fixed stride. Names are stored as
// TOKEN INDICES (into the lexer's token array) — the same trick parse.ember
// and sema.ember use — and compared on demand via tok_name. This is O(n) per
// lookup but n is small.
//
//   cg_locals : stride 2  [ name_tok, rbp_offset ]   (the current fn's locals)
//   cg_labels : stride 2  [ label_id, code_offset ]  (bound label positions)
//   cg_fixups : stride 2  [ code_offset, label_id ]  (pending rel32 patches)
//
// Error handling: a global cg_err flag + message, like sema's s_err.
// codegen(source) returns 0 on success or 1 on error.

import "sema.ember";

// -----------------------------------------------------------------------------
// register encoding numbers (0-15), shared by GP registers. Matches x64_emitter.hpp's Reg enum.
// -----------------------------------------------------------------------------
global RAX : i64 = 0;
global RCX : i64 = 1;
global RDX : i64 = 2;
global RBX : i64 = 3;
global RSP : i64 = 4;
global RBP : i64 = 5;
global RSI : i64 = 6;
global RDI : i64 = 7;
global R8  : i64 = 8;
global R9  : i64 = 9;
global R10 : i64 = 10;
global R11 : i64 = 11;
global R12 : i64 = 12;
global R13 : i64 = 13;
global R14 : i64 = 14;
global R15 : i64 = 15;

global XMM0 : i64 = 0;
global XMM1 : i64 = 1;
global XMM2 : i64 = 2;
global XMM3 : i64 = 3;
global XMM4 : i64 = 4;   // scratch for stack-passed float args (not used yet, reserved)

// condition codes for jcc (low nibble of 0F 8x). Matches x64_emitter.hpp's Cond enum.
global COND_E  : i64 = 0x4;   // equal (ZF=1)
global COND_NE : i64 = 0x5;   // not equal (ZF=0)
global COND_L  : i64 = 0xC;   // less (signed)
global COND_GE : i64 = 0xD;   // greater or equal (signed)
global COND_LE : i64 = 0xE;   // less or equal (signed)
global COND_G  : i64 = 0xF;   // greater (signed)
global COND_B  : i64 = 0x2;   // below (unsigned, CF=1)
global COND_AE : i64 = 0x3;   // above or equal (unsigned, CF=0)
global COND_BE : i64 = 0x6;   // below or equal (unsigned)
global COND_A  : i64 = 0x7;   // above (unsigned)

// -----------------------------------------------------------------------------
// emitter state. Reset per codegen() call.
// -----------------------------------------------------------------------------
global cg_code     : i64 = 0;   // the output byte array (array<u8>, elem_size 1)
global cg_next_label : i64 = 0; // next label id
global cg_labels   : i64 = 0;   // bound labels: stride 2 [ label_id, code_offset ]
global cg_fixups   : i64 = 0;   // pending rel32 fixups: stride 2 [ code_offset, label_id ]

// -----------------------------------------------------------------------------
// EMBM v1 module image buffers (self_hosted/MODULE_IMAGE_FORMAT.md).
// Parallel to cg_code: rodata (read-only literals), data (mutable globals),
// syms (null-terminated native symbol names), relocs (32-byte records). The
// codegen accumulates these during emission; codegen_emit_image() stitches
// them into one array<u8> with an 80-byte header for load_executable_module.
// -----------------------------------------------------------------------------
global cg_rodata : i64 = 0;   // array<u8> — read-only literal bytes
global cg_data   : i64 = 0;   // array<u8> — mutable global initial bytes
global cg_syms   : i64 = 0;   // array<u8> — null-terminated symbol names (bytes)
global cg_relocs : i64 = 0;   // array<u8> — 32-byte relocation records (bytes)

// codegen global table: stride 2 [ name_tok, data_addend ]. Populated by
// cg_compile_globals() from the program's constant-initialized GlobalDecls;
// a global's data addend is its byte offset within cg_data (§5). Reads/writes
// go through a relocated ABS64_DATA pointer.
global cg_globals : i64 = 0;
global cg_globals_len : i64 = 0;

// string-globals table for the module-init function. Stride 3
// [ name_tok, data_addend, init_node ]. Populated by cg_compile_globals() for
// each `string`-typed global with a StringLit initializer; the data slot is
// zero-filled (the handle is materialized at runtime). cg_emit_globals_init()
// walks this table + emits, for each entry, the same literal materialization
// as cg_eval_string_lit (rodata + u8 slice + string_from_slice -> handle in
// rax) followed by a store of rax into the global's [data_base + addend] slot.
// The init function runs BEFORE main (full_pipeline's compile_and_run calls it
// via codegen_globals_init_offset()). i64 globals keep their compile-time
// constant in the data section (no runtime init needed).
global cg_str_globals : i64 = 0;
global cg_str_globals_len : i64 = 0;

// the entry label id of the synthetic __globals_init function (-1 when none
// was emitted, i.e. the program declares no string globals). Bound at the
// init function's prologue offset; codegen_globals_init_offset() returns that
// offset so the pipeline can call it before main.
global cg_globals_init_label : i64 = -1;

// relocation type constants (MODULE_IMAGE_FORMAT.md §7).
global CG_RELOC_RODATA : i64 = 1;   // ABS64_RODATA: addend = rodata byte offset
global CG_RELOC_DATA   : i64 = 2;   // ABS64_DATA:   addend = data byte offset
global CG_RELOC_NATIVE : i64 = 3;   // ABS64_NATIVE: sym_idx = symbol index, addend = fingerprint
global CG_RELOC_DISPATCH : i64 = 4; // DISPATCH_BASE: module function vector

// frame layout for the current function
global cg_locals     : i64 = 0;   // stride 3 [name_tok, rbp_offset, type_node]
global cg_local_len  : i64 = 0;   // logical length of cg_locals (for scope pop)
global cg_scope_marks: i64 = 0;   // scope push marks: stride 1 [ mark ]
global cg_scope_mark_len : i64 = 0;
global cg_next_off   : i64 = 0;   // next local offset (grows downward, negative)
global cg_frame_size : i64 = 0;   // the current fn's frame size

// function-entry labels for direct call_rel32 between fns in the same code
// buffer. Allocated up-front for every FnDecl (name_tok -> label_id); each
// fn's label is bound at its prologue offset, and a call to it is a rel32
// fixup patched after all fns are compiled. This replaces the v1 placeholder
// `mov rax, 0; call rax` (which branched to address 0 under make_executable)
// with a real in-buffer relative call, so multi-fn programs execute.
global cg_fn_labels : i64 = 0;   // array, stride 3 [ name_tok, label_id, ns_tok ]
global cg_current_lambda : i64 = -1;
global cg_lambda_env_off : i64 = 0;
global cg_cap_off : i64 = 0;
global cg_cap_type : i64 = 0;
global cg_cap_by_ref : i64 = 0;

// Reusable scratch array for ABI-fingerprint computation (cg_abi_fingerprint_codes).
// The `codes` locals previously allocated a fresh array_new(8,1|2) on EVERY
// native-call emission (string_from_slice / string_from_i64 / string_add /
// string_eq). The host array extension has no array_free, so each leaked a
// slot; over a large module these accumulate in the trace-callback scan and
// crash the host (bare RUNTIME TRAP / exit 70). This scratch is reused via
// array_clear: set entry 0 (and 1), compute the fingerprint synchronously
// (no recursive emission between set + read), done. Safe because the codes
// are consumed by cg_abi_fingerprint_codes before any nested expression is
// emitted.
global cg_fp_codes : i64 = 0;   // scratch for cg_abi_fingerprint_codes (size 2)

// Reusable scratch array for cg_abi_fingerprint (the type-node variant). The
// `param_types` / `len_pt` / `get_pt` locals previously allocated a fresh
// array_new(8,4) on every native-call / for-each emission. Like cg_fp_codes
// these are consumed synchronously by cg_abi_fingerprint before any nested
// expression is emitted, so a single reused slot is safe.
global cg_fp_types : i64 = 0;   // scratch for cg_abi_fingerprint (size 4)

// Reusable constant scratch holding the 4 Win64 argument registers
// {RCX, RDX, R8, R9} for cg_compile_func's param-spill loop. Previously a
// per-function array_new(8,4) leaked a slot on every function compiled; this
// slot is a pure constant, set + read with no recursive emission between, so a
// single reused slot is safe.
global cg_arg_regs : i64 = 0;   // scratch for Win64 arg registers (size 4)

// error state
global cg_err     : i64 = 0;
global cg_errmsg  : string = "";

// =============================================================================
// x64 emitter — byte-level emission (port of X64Emitter in x64_emitter.hpp).
// =============================================================================

// emit a single byte
fn cg_byte(b: i64) -> i64 {
    array_push_u8(cg_code, b);
    return 0;
}

// emit a little-endian imm32 (4 bytes)
fn cg_imm32(v: i64) -> i64 {
    // emit 4 bytes little-endian. use bitwise ops to extract each byte.
    // (ember i64 is 64-bit; we emit the low 32 bits.)
    cg_byte(v & 0xFF);
    cg_byte((v >> 8) & 0xFF);
    cg_byte((v >> 16) & 0xFF);
    cg_byte((v >> 24) & 0xFF);
    return 0;
}

// emit a little-endian imm64 (8 bytes)
fn cg_imm64(v: i64) -> i64 {
    cg_byte(v & 0xFF);
    cg_byte((v >> 8) & 0xFF);
    cg_byte((v >> 16) & 0xFF);
    cg_byte((v >> 24) & 0xFF);
    cg_byte((v >> 32) & 0xFF);
    cg_byte((v >> 40) & 0xFF);
    cg_byte((v >> 48) & 0xFF);
    cg_byte((v >> 56) & 0xFF);
    return 0;
}

// REX prefix: 0100 W R X B. W=1 for 64-bit operand size.
fn cg_rex(w: i64, r: i64, x: i64, b: i64) -> i64 {
    let mut v: i64 = 0x40;
    if (w != 0) { v = v | 8; }
    if (r != 0) { v = v | 4; }
    if (x != 0) { v = v | 2; }
    if (b != 0) { v = v | 1; }
    return v;
}

// is a register extended (encoding >= 8)?
fn cg_is_extended(r: i64) -> i64 {
    if (r >= 8) { return 1; }
    return 0;
}

// ModRM byte: mod(2) reg(3) rm(3).
fn cg_modrm(mod_: i64, reg: i64, rm: i64) -> i64 {
    return ((mod_ & 3) << 6) | ((reg & 7) << 3) | (rm & 7);
}

// --- instructions ---

// push r64 -> 50+rd (or 41 50+rd for r8-r15)
fn cg_push(r: i64) -> i64 {
    if (cg_is_extended(r) != 0) { cg_byte(0x41); }
    cg_byte(0x50 + (r & 7));
    return 0;
}

// pop r64 -> 58+rd (or 41 58+rd for r8-r15)
fn cg_pop(r: i64) -> i64 {
    if (cg_is_extended(r) != 0) { cg_byte(0x41); }
    cg_byte(0x58 + (r & 7));
    return 0;
}

// mov r64, r64 -> REX.W 89 /r (mod=11, reg=src, rm=dst)
fn cg_mov_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(dst)));
    cg_byte(0x89);
    cg_byte(cg_modrm(3, src, dst));
    return 0;
}

// mov r64, imm64 -> REX.W B8+rd io
fn cg_mov_reg_imm64(dst: i64, imm: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(dst)));
    cg_byte(0xB8 + (dst & 7));
    cg_imm64(imm);
    return 0;
}

// add r64, r64 -> REX.W 01 /r (mod=11, reg=src, rm=dst)
fn cg_add_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(dst)));
    cg_byte(0x01);
    cg_byte(cg_modrm(3, src, dst));
    return 0;
}

// sub r64, r64 -> REX.W 29 /r (mod=11, reg=src, rm=dst)
fn cg_sub_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(dst)));
    cg_byte(0x29);
    cg_byte(cg_modrm(3, src, dst));
    return 0;
}

// sub r64, imm32 -> REX.W 81 /5 id
fn cg_sub_reg_imm32(r: i64, imm: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0x81);
    cg_byte(cg_modrm(3, 5, r));
    cg_imm32(imm);
    return 0;
}

// add r64, imm32 -> REX.W 81 /0 id
fn cg_add_reg_imm32(r: i64, imm: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0x81);
    cg_byte(cg_modrm(3, 0, r));
    cg_imm32(imm);
    return 0;
}

// imul r64, r64 -> REX.W 0F AF /r (dst = dst * src)
fn cg_imul_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(dst), 0, cg_is_extended(src)));
    cg_byte(0x0F);
    cg_byte(0xAF);
    cg_byte(cg_modrm(3, dst, src));
    return 0;
}

// xor r64, r64 -> REX.W 31 /r (mod=11, reg=src, rm=dst)
fn cg_xor_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(dst)));
    cg_byte(0x31);
    cg_byte(cg_modrm(3, src, dst));
    return 0;
}

// and r64, r64 -> REX.W 21 /r
fn cg_and_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(dst)));
    cg_byte(0x21);
    cg_byte(cg_modrm(3, src, dst));
    return 0;
}

// or r64, r64 -> REX.W 09 /r
fn cg_or_reg_reg(dst: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(dst)));
    cg_byte(0x09);
    cg_byte(cg_modrm(3, src, dst));
    return 0;
}

// not r64 -> REX.W F7 /2 (bitwise NOT, one's complement)
fn cg_not_reg(r: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0xF7);
    cg_byte(cg_modrm(3, 2, r));
    return 0;
}

// neg r64 -> REX.W F7 /3 (two's complement negate)
fn cg_neg_reg(r: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0xF7);
    cg_byte(cg_modrm(3, 3, r));
    return 0;
}

// shl r64, cl -> REX.W D3 /4 (shift left by cl)
fn cg_shl_reg_cl(r: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0xD3);
    cg_byte(cg_modrm(3, 4, r));
    return 0;
}

// shr r64, cl -> REX.W D3 /5 (logical shift right by cl)
fn cg_shr_reg_cl(r: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0xD3);
    cg_byte(cg_modrm(3, 5, r));
    return 0;
}

// sar r64, cl -> REX.W D3 /7 (arithmetic shift right by cl)
fn cg_sar_reg_cl(r: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0xD3);
    cg_byte(cg_modrm(3, 7, r));
    return 0;
}
fn cg_shift_right_imm8(r: i64, n: i64) -> i64 { cg_byte(cg_rex(1, 0, 0, cg_is_extended(r))); cg_byte(0xC1); cg_byte(cg_modrm(3, 5, r)); cg_byte(n); return 0; }
fn cg_shift_left_imm8(r: i64, n: i64) -> i64 { cg_byte(cg_rex(1, 0, 0, cg_is_extended(r))); cg_byte(0xC1); cg_byte(cg_modrm(3, 4, r)); cg_byte(n); return 0; }

// cmp r64, r64 -> REX.W 39 /r (mod=11, reg=rhs, rm=lhs)
fn cg_cmp_reg_reg(lhs: i64, rhs: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(rhs), 0, cg_is_extended(lhs)));
    cg_byte(0x39);
    cg_byte(cg_modrm(3, rhs, lhs));
    return 0;
}

// cmp r64, imm32 -> REX.W 81 /7 id
fn cg_cmp_reg_imm32(r: i64, imm: i64) -> i64 {
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(r)));
    cg_byte(0x81);
    cg_byte(cg_modrm(3, 7, r));
    cg_imm32(imm);
    return 0;
}

// test r64, r64 -> REX.W 85 /r (sets flags from AND, without storing)
fn cg_test_reg_reg(a: i64, b: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(b), 0, cg_is_extended(a)));
    cg_byte(0x85);
    cg_byte(cg_modrm(3, b, a));
    return 0;
}

// setcc al -> 0F 9x C0 (set al from condition cc)
fn cg_setcc_al(cc: i64) -> i64 {
    cg_byte(0x0F);
    cg_byte(0x90 | cc);
    cg_byte(0xC0);
    return 0;
}

// movzx rax, al -> 48 0F B6 C0 (zero-extend al into rax)
fn cg_movzx_rax_al() -> i64 {
    cg_byte(0x48); cg_byte(0x0F); cg_byte(0xB6); cg_byte(0xC0);
    return 0;
}

// Minimal scalar SSE2 emitter. Float expressions return in xmm0; xmm1 is the
// rhs scratch register. Locals use their native four/eight-byte representation.
fn cg_movq_xmm_rax(x: i64) -> i64 { cg_byte(0x66); cg_byte(0x48); cg_byte(0x0F); cg_byte(0x6E); cg_byte(0xC0 | ((x & 7) << 3)); return 0; }
fn cg_movd_xmm_eax(x: i64) -> i64 { cg_byte(0x66); cg_byte(0x0F); cg_byte(0x6E); cg_byte(0xC0 | ((x & 7) << 3)); return 0; }
fn cg_movq_rax_xmm(x: i64) -> i64 { cg_byte(0x66); cg_byte(0x48); cg_byte(0x0F); cg_byte(0x7E); cg_byte(0xC0 | ((x & 7) << 3)); return 0; }
fn cg_sse_rr(prefix: i64, op: i64, dst: i64, src: i64) -> i64 { cg_byte(prefix); cg_byte(0x0F); cg_byte(op); cg_byte(cg_modrm(3, dst, src)); return 0; }
fn cg_sse_mem(prefix: i64, op: i64, x: i64, disp: i64) -> i64 { cg_byte(prefix); cg_byte(0x0F); cg_byte(op); cg_byte(cg_modrm(2, x, RBP)); cg_imm32(disp); return 0; }
fn cg_load_float(x: i64, disp: i64, is64: i64) -> i64 { if (is64 == 1) { cg_sse_mem(0xF2, 0x10, x, disp); } else { cg_sse_mem(0xF3, 0x10, x, disp); } return 0; }
fn cg_store_float(disp: i64, x: i64, is64: i64) -> i64 { if (is64 == 1) { cg_sse_mem(0xF2, 0x11, x, disp); } else { cg_sse_mem(0xF3, 0x11, x, disp); } return 0; }
fn cg_float_op(op: i64, is64: i64) -> i64 { if (is64 == 1) { cg_sse_rr(0xF2, op, XMM0, XMM1); } else { cg_sse_rr(0xF3, op, XMM0, XMM1); } return 0; }
fn cg_float_cmp(is64: i64) -> i64 { if (is64 == 1) { cg_byte(0x66); } cg_byte(0x0F); cg_byte(0x2E); cg_byte(cg_modrm(3, XMM0, XMM1)); return 0; }
fn cg_i64_to_float(x: i64, r: i64, is64: i64) -> i64 { if (is64 == 1) { cg_byte(0xF2); } else { cg_byte(0xF3); } cg_byte(0x48); cg_byte(0x0F); cg_byte(0x2A); cg_byte(cg_modrm(3, x, r)); return 0; }

// emit an implicit float widening/narrowing so a value of width `from` is
// converted to width `to` in xmm0 before a store/return/arg-pass that expects
// `to`. f32->f64 (cvtss2sd) is the one implicit widening; f64->f32 (cvtsd2ss)
// is narrowing (only reached via an explicit `as` cast, which has its own
// path). Same-width or non-float -> no-op. Mirrors the native sema synthesizing
// a CastExpr for f32->f64 at the use site.
fn cg_convert_float(from: i64, to: i64) -> i64 {
    if (ty_is_float(from) == 0 || ty_is_float(to) == 0) { return 0; }
    if (nk_d(from) == nk_d(to)) { return 0; }   // same width
    if (nk_d(from) == (Prim::F32 as i64) && nk_d(to) == (Prim::F64 as i64)) {
        // cvtss2sd xmm0, xmm0 -> F3 0F 5A C0
        cg_byte(0xF3); cg_byte(0x0F); cg_byte(0x5A); cg_byte(0xC0);
        return 0;
    }
    return 0;
}

fn cg_float_is64_type(t: i64) -> i64 { if (t >= 0 && nk_d(t) == (Prim::F64 as i64)) { return 1; } return 0; }

// -----------------------------------------------------------------------------
// Phase 2: integer width support. Mirrors src/codegen.cpp's int_bits /
// value_bytes / normalize_rax / is_uint. All scalar locals remain 8-byte slots
// (local_width_bytes returns 8 for every scalar); the value is always stored
// as a full 64-bit sign/zero-extended quantity, and normalize_rax re-extends
// on load so a narrower-typed value reads back correctly.
// -----------------------------------------------------------------------------

// the byte size of a primitive type (mirrors src/types.cpp byte_size +
// src/codegen.cpp value_bytes for scalars). Used by sizeof + by width-aware
// load/store helpers.
// the byte size of a primitive SCALAR type (mirrors src/types.cpp byte_size +
// src/codegen.cpp value_bytes for scalars). Aggregates use cg_value_bytes.
fn cg_scalar_bytes(t: i64) -> i64 {
    if (t < 0) { return 8; }
    if (nk_kind(t) != (NK::Type as i64)) { return 8; }
    let p: i64 = nk_d(t);
    if (nk_tok(t) >= 0) { return 8; }   // named/handle type (opaque -> 8)
    if (p == (Prim::Bool as i64) || p == (Prim::I8 as i64) || p == (Prim::U8 as i64)) { return 1; }
    if (p == (Prim::I16 as i64) || p == (Prim::U16 as i64)) { return 2; }
    if (p == (Prim::I32 as i64) || p == (Prim::U32 as i64) || p == (Prim::F32 as i64)) { return 4; }
    return 8;   // i64/u64/f64/ptr + fallback
}

// Phase 3: the byte size of ANY type, mirroring src/codegen.cpp's value_bytes
// EXACTLY (the packed memory model). Aggregates recurse:
//   - slice T[]      -> 16 ({ptr,len})
//   - fixed array T[N]-> N * value_bytes(elem)
//   - struct          -> sum of field value_bytes (packed, declaration order)
//   - scalar/handle   -> cg_scalar_bytes
fn cg_value_bytes(t: i64) -> i64 {
    if (t < 0) { return 8; }
    if (nk_kind(t) != (NK::Type as i64)) { return 8; }
    if (nk_f(t) == 1 || nk_f(t) == 2) { return 16; }       // slice/closure: two words
    if (nk_e(t) > 0) {                                     // fixed array T[N]
        let elem: i64 = nk_a(t);
        if (elem < 0) { return 8; }
        return nk_e(t) * cg_value_bytes(elem);
    }
    if (nk_tok(t) >= 0) {                                  // named type
        let nm: string = tok_name(nk_tok(t));
        if (nm == string_from_slice("string")) { return 8; }   // opaque handle
        let row: i64 = find_struct(nm);
        if (row >= 0) { return cg_struct_value_bytes(row); }
        return 8;
    }
    return cg_scalar_bytes(t);
}

// Phase 3: the local frame byte width, mirroring src/codegen.cpp's
// local_width_bytes. Aggregates use their exact Ember extent; scalars use 8
// (a scalar slot is always one 8-byte word in this codegen).
fn cg_local_width_bytes(t: i64) -> i64 {
    if (t < 0) { return 8; }
    if (nk_kind(t) != (NK::Type as i64)) { return 8; }
    if (nk_f(t) == 1 || nk_f(t) == 2) { return 16; }       // slice/closure
    if (nk_e(t) > 0) { return cg_value_bytes(t); }         // fixed array inline
    if (nk_tok(t) >= 0) {
        let nm: string = tok_name(nk_tok(t));
        if (nm == string_from_slice("string")) { return 8; }
        let row: i64 = find_struct(nm);
        if (row >= 0) { return cg_value_bytes(t); }
        return 8;
    }
    return 8;   // scalar slots are 8 bytes
}

// number of 8-byte stack slots an aggregate local occupies (ceil(extent/8),
// min 1). Scalars are 1 slot. Mirrors src/codegen.cpp's words_for_type for
// structs (ceil(size/8)) and the inline-fixed-array frame sizing.
fn cg_local_slots(t: i64) -> i64 {
    let w: i64 = cg_local_width_bytes(t);
    let mut s: i64 = (w + 7) / 8;
    if (s < 1) { s = 1; }
    return s;
}

// Phase 3: struct layout (packed, declaration order, no padding). Mirrors
// src/sema.cpp build_struct_layouts + src/codegen.cpp value_bytes(struct).
// cg_struct_value_bytes(row) = sum of every field's value_bytes.
// cg_struct_field_offset(row, idx) = sum of value_bytes of preceding fields.
// cg_struct_local_slots(row) = ceil(value_bytes/8) stack slots (min 1).
fn cg_struct_value_bytes(row: i64) -> i64 {
    let mut total: i64 = 0;
    let mut f: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1);
    while (f >= 0) {
        total = total + cg_value_bytes(resolve_type(nk_a(f)));
        f = nk_next(f);
    }
    return total;
}

fn cg_struct_field_offset(row: i64, idx: i64) -> i64 {
    let mut off: i64 = 0;
    let mut f: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1);
    let mut i: i64 = 0;
    while (f >= 0) {
        if (i == idx) { return off; }
        off = off + cg_value_bytes(resolve_type(nk_a(f)));
        i = i + 1;
        f = nk_next(f);
    }
    return off;
}

fn cg_struct_local_slots(row: i64) -> i64 {
    let w: i64 = cg_struct_value_bytes(row);
    let mut s: i64 = (w + 7) / 8;
    if (s < 1) { s = 1; }
    return s;
}

// =============================================================================
// Phase 4: struct by-value call ABI (mirrors src/codegen.cpp's hidden-pointer
// sret return + ceil(size/8)-word arg passing). The self-hosted call ABI is
// self-consistent (caller + callee are both emitted by this codegen) and
// behaviorally matches the native compiler's results (parity is exit-code
// based, not byte-identical). The convention:
//
//   struct RETURN: a fn whose return type is a registered struct gets an
//     implicit word-0 param = the caller-allocated dest pointer (arrives in
//     rcx, the first Win64 int arg reg). The callee spills it to a dedicated
//     frame slot (cg_struct_ret_ptr_off), writes the struct through it at
//     every `return`, and loads it back into rax at the epilogue (the sret
//     ABI requires the dest ptr to be returned in rax). Real params start at
//     word 1.
//
//   struct ARG (script-to-script): a struct arg occupies ceil(size/8)
//     consecutive 8-byte words in the call's arg stash, copied directly from
//     the source (a bare local, a struct literal materialized into a temp, or
//     a struct-returning call materialized into a temp via the hidden ptr).
//     The callee spills those words into the param local's frame slot.
//
//   struct-returning CALL SITE: the caller allocates a dest (a local's frame
//     slot for a let-init / assignment, a temp for an arg, or the fn's own
//     incoming hidden ptr for a `return f(...)` forward), loads its address
//     into rax, then calls cg_eval_struct_returning_call which places the
//     dest at word 0 + the real args from word 1 and calls. The callee writes
//     the struct directly through the dest — no register result.
// =============================================================================

// is this type a REGISTERED struct (mirrors sema's ty_is_struct)?
fn cg_ty_is_struct(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    if (nk_tok(t) < 0) { return 0; }
    let nm: string = tok_name(nk_tok(t));
    if (nm == string_from_slice("string")) { return 0; }
    if (find_struct(nm) >= 0) { return 1; }
    return 0;
}

// number of 8-byte words a call operand/param occupies in ember's private
// ABI: 1 for a scalar/float/handle, 2 for a slice, ceil(size/8) for a
// registered struct (min 1). Mirrors src/codegen.cpp's words_for_type.
fn cg_words_for_type(t: i64) -> i64 {
    if (t < 0) { return 1; }
    if (nk_kind(t) != (NK::Type as i64)) { return 1; }
    if (nk_f(t) == 1 || nk_f(t) == 2) { return 2; }       // slice/closure {word,word}
    if (cg_ty_is_struct(t) == 1) {
        let w: i64 = cg_value_bytes(t);
        let mut s: i64 = (w + 7) / 8;
        if (s < 1) { s = 1; }
        return s;
    }
    return 1;
}

// the callee-side hidden return-pointer frame slot offset (0 = this fn does
// not return a struct by pointer). Set in cg_compile_func when the fn's
// resolved return type is a registered struct; read by the ReturnStmt path +
// the epilogue's rax reload.
global cg_struct_ret_ptr_off : i64 = 0;

// caller-side flag: set to 1 by a context that has loaded a struct-returning
// call's destination address into rax BEFORE calling cg_eval on the call
// (LetStmt init / ReturnStmt value / AssignExpr value / struct-arg stash).
// cg_eval_callexpr checks this to route a struct-returning call to
// cg_eval_struct_returning_call (which consumes rax as the hidden dest). It is
// saved/restored around the eval so a nested non-struct call does not inherit
// it, and cleared after the struct-returning call consumes it.
global cg_struct_ret_dest_ready : i64 = 0;

// hand out a fresh struct temp of `nbytes` from the per-function frame
// pool (shared with user locals via cg_next_off, so temps + locals never
// collide — each gets a distinct downward-growing offset). Returns the
// temp's lowest rbp offset. Mirrors src/codegen.cpp's alloc_struct_temp
// (alloc_local with a synthesized '$' name). The frame is pre-sized by
// cg_count_struct_temps_block to hold these temps.
fn cg_alloc_struct_temp(nbytes: i64) -> i64 {
    let mut slots: i64 = (nbytes + 7) / 8;
    if (slots < 1) { slots = 1; }
    return cg_alloc_local_t(-1, -1, slots);
}

// Copy exactly `nbytes` from [src_base+src_off] to [dst_base+dst_off] via rax,
// in 8/4/2/1-byte chunks (never a blind N-word copy). A struct's byte size is
// frequently NOT a multiple of 8 (e.g. i64+i32+i8 = 13 bytes); a naive
// word-granularity copy overruns past the struct's true extent and can
// corrupt an adjacent saved rbp. Mirrors src/codegen.cpp's copy_bytes.
fn cg_copy_bytes(dst_base: i64, dst_off: i64, src_base: i64, src_off: i64, nbytes: i64) -> i64 {
    let mut done: i64 = 0;
    while (done < nbytes) {
        let remaining: i64 = nbytes - done;
        let chunk: i64 = cg_chunk_for(remaining);
        cg_load_elem_to_rax(src_base, src_off + done, chunk, 0);
        cg_store_rax_elem(dst_base, dst_off + done, chunk);
        done = done + chunk;
    }
    return 0;
}

// Write rax's low `nbytes` to [base+off], chunked, shifting rax right after
// each chunk so the next unwritten bytes come down to the low end. Used when
// a struct word's value is already in rax (moved out of an arg register) and
// must be spilled to a partial last word. Mirrors src/codegen.cpp's
// store_rax_bytes. Clobbers rax.
fn cg_store_rax_bytes(base: i64, off: i64, nbytes: i64) -> i64 {
    let mut done: i64 = 0;
    while (done < nbytes) {
        let chunk: i64 = cg_chunk_for(nbytes - done);
        cg_store_rax_elem(base, off + done, chunk);
        done = done + chunk;
        if (done < nbytes) {
            // shr rax, chunk*8 : REX.W C1 /5 ib  (modrm = 11 101 000 = 0xE8)
            cg_byte(0x48); cg_byte(0xC1); cg_byte(0xE8); cg_byte(chunk * 8);
        }
    }
    return 0;
}

// the byte size of a primitive type (kept for the sizeof/offsetof helpers;
// delegates to the general cg_value_bytes so aggregates are sized correctly).
fn cg_type_size(t: i64) -> i64 { return cg_value_bytes(t); }

// the alignment of a type (same as size for this packed model).
fn cg_type_align(t: i64) -> i64 { return cg_value_bytes(t); }

// is this an UNSIGNED integer type (u8/u16/u32/u64)?
fn cg_type_is_uint(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    let p: i64 = nk_d(t);
    if (nk_tok(t) >= 0) { return 0; }
    if (p == (Prim::U8 as i64) || p == (Prim::U16 as i64) || p == (Prim::U32 as i64) || p == (Prim::U64 as i64)) { return 1; }
    return 0;
}

// is this a plain integer type (any width/signedness)?
fn cg_type_is_int(t: i64) -> i64 {
    if (t < 0) { return 0; }
    if (nk_kind(t) != (NK::Type as i64)) { return 0; }
    let p: i64 = nk_d(t);
    if (nk_tok(t) >= 0) { return 0; }
    if (p >= (Prim::I8 as i64) && p <= (Prim::U64 as i64)) { return 1; }
    return 0;
}

// the bit width of an integer type (8/16/32/64), mirroring src/sema.cpp's
// int_bits. Non-integer types return 64 (no normalization needed).
fn cg_int_bits(t: i64) -> i64 {
    if (t < 0) { return 64; }
    if (nk_kind(t) != (NK::Type as i64)) { return 64; }
    let p: i64 = nk_d(t);
    if (p == (Prim::I8  as i64) || p == (Prim::U8  as i64)) { return 8; }
    if (p == (Prim::I16 as i64) || p == (Prim::U16 as i64)) { return 16; }
    if (p == (Prim::I32 as i64) || p == (Prim::U32 as i64)) { return 32; }
    return 64;
}

// Normalize rax to the integer type `t`: sign/zero-extend the low N bits into
// the full 64-bit rax. Mirrors src/codegen.cpp's normalize_rax EXACTLY:
//   - 64-bit: no-op
//   - 32-bit unsigned: mov eax,eax (89 C0)        — zero-extends to rax
//   - 32-bit signed:   movsxd rax,eax (48 63 C0)  — sign-extends
//   - 8/16-bit: shl rax,64-bits; then sar (signed) or shr (unsigned) rax,64-bits
// Non-integer / 64-bit types are a no-op. Called after every arithmetic op
// and at every load/store boundary so a narrower-typed value stays canonical.
fn cg_normalize_rax(t: i64) -> i64 {
    if (cg_type_is_int(t) == 0) {
        // Phase 3b: a typed-enum value normalizes to its BACKING integer width
        // (mirror src/codegen.cpp's normalize_rax, where a typed-enum Type
        // has struct_name="" so is_int() is true and it normalizes to the
        // backing prim). The self-hosted cg_type_is_int excludes named types,
        // so handle typed enums explicitly here.
        if (is_typed_enum_type(t) == 0) { return 0; }
        let bits: i64 = typed_enum_width(t);
        if (bits == 64) { return 0; }
        let is_u: i64 = typed_enum_is_uint(t);
        if (bits == 32) {
            if (is_u == 1) { cg_byte(0x89); cg_byte(0xC0); }       // mov eax,eax
            else { cg_byte(0x48); cg_byte(0x63); cg_byte(0xC0); }  // movsxd rax,eax
            return 0;
        }
        cg_byte(0x48); cg_byte(0xC1); cg_byte(0xE0); cg_byte(64 - bits);
        if (is_u == 1) { cg_byte(0x48); cg_byte(0xC1); cg_byte(0xE8); cg_byte(64 - bits); }
        else { cg_byte(0x48); cg_byte(0xC1); cg_byte(0xF8); cg_byte(64 - bits); }
        return 0;
    }
    let bits: i64 = cg_int_bits(t);
    if (bits == 64) { return 0; }
    if (bits == 32) {
        if (cg_type_is_uint(t) == 1) { cg_byte(0x89); cg_byte(0xC0); }       // mov eax,eax
        else { cg_byte(0x48); cg_byte(0x63); cg_byte(0xC0); }                // movsxd rax,eax
        return 0;
    }
    // 8/16-bit: shl rax, (64-bits); then sar/shr rax, (64-bits).
    // shl rax, imm8 -> REX.W C1 /4 ib
    cg_byte(0x48); cg_byte(0xC1); cg_byte(0xE0); cg_byte(64 - bits);
    // sar rax, imm8 (signed) -> REX.W C1 /7 ib ;  shr rax, imm8 (unsigned) -> REX.W C1 /5 ib
    if (cg_type_is_uint(t) == 1) { cg_byte(0x48); cg_byte(0xC1); cg_byte(0xE8); cg_byte(64 - bits); }
    else { cg_byte(0x48); cg_byte(0xC1); cg_byte(0xF8); cg_byte(64 - bits); }
    return 0;
}

fn cg_expr_type(e: i64) -> i64 {
    if (e < 0) { return -1; }
    let k: i64 = nk_kind(e);
    if (k == (NK::FloatLit as i64)) {
        // an adapted f32 literal (sema's try_adapt_float_lit annotated slot c)
        let ann: i64 = nk_c(e);
        if (ann == TY_F32) { return TY_F32; }
        let raw: string = nk_name(e); let n: i64 = string_length(raw);
        if (n > 0 && (string_char_at(raw, n - 1) == 102 || string_char_at(raw, n - 1) == 70)) { return TY_F32; }
        return TY_F64;
    }
    if (k == (NK::StringLit as i64)) { return TY_STRING; }
    if (k == (NK::LambdaExpr as i64)) { return nk_f(e); }
    if (k == (NK::FnHandleExpr as i64)) { return TY_I64; }
    if (k == (NK::IntLit as i64)) { return TY_I64; }
    if (k == (NK::BoolLit as i64)) { return TY_BOOL; }
    // Phase 3b: an EnumAccess's type is the enum's type — TY_I64 for an
    // untyped enum variant, or the typed-enum type for `enum E : T`.
    if (k == (NK::EnumAccess as i64)) {
        let ename: string = tok_name(nk_a(e));
        // a namespace-global access (Foo::val) has the global's type.
        if (is_namespace_name(ename) == 1) {
            let g: i64 = cg_find_global_qualified(nk_name(e), ename);
            if (g >= 0) { return global_type(g); }
            return TY_I64;
        }
        if (is_typed_enum_name(ename) == 1) { return typed_enum_type(ename); }
        return TY_I64;
    }
    if (k == (NK::Ident as i64)) {
        let lt: i64 = cg_lookup_local_type(nk_tok(e));
        if (lt >= 0) { return lt; }
        // not a local: a global's type (sema registered it; Phase 1 globals are i64)
        let g: i64 = cg_find_global(nk_name(e));
        if (g >= 0) { return TY_I64; }
        return -1;
    }
    if (k == (NK::FieldExpr as i64)) {
        let bt: i64 = cg_expr_type(nk_a(e));
        let row: i64 = find_struct(ty_struct_name(bt));
        if (row >= 0) { return struct_field_type(row, nk_name(e)); }
    }
    if (k == (NK::IndexExpr as i64)) {
        // result type = the base's element type (a fixed array / slice elem)
        let bt: i64 = cg_expr_type(nk_a(e));
        if (bt >= 0) { let et: i64 = nk_a(bt); if (et >= 0) { return resolve_type(et); } }
        return -1;
    }
    if (k == (NK::ViewExpr as i64)) {
        // result type = a slice of the base's element type (sema built this)
        let bt: i64 = cg_expr_type(nk_a(e));
        if (bt >= 0) { let et: i64 = nk_a(bt); if (et >= 0) { return resolve_type(et); } }
        return -1;
    }
    if (k == (NK::UnaryExpr as i64)) {
        // Neg/BitNot preserve the operand's (integer) type; Not yields bool.
        // Mirrors sema's check_unaryexpr result. Used by cast dispatch so
        // `(-1) as u8` sees from=i64 (the operand's type).
        let op: i64 = nk_d(e);
        if (op == (UnOp::Not as i64)) { return TY_BOOL; }
        return cg_expr_type(nk_a(e));
    }
    if (k == (NK::BinExpr as i64)) {
        let op: i64 = nk_d(e);
        if (op >= (BinOp::Eq as i64)) { return TY_BOOL; }
        // literal adaptation: if lhs is an IntLit and rhs is a typed int, the
        // result is rhs's type (mirrors sema's check_binexpr adaptation).
        let lt2: i64 = cg_expr_type(nk_a(e));
        let rt2: i64 = cg_expr_type(nk_b(e));
        if (nk_kind(nk_a(e)) == (NK::IntLit as i64) && cg_type_is_int(rt2) == 1) { return rt2; }
        return lt2;
    }
    if (k == (NK::CallExpr as i64)) {
        // sema annotates a call's resolved return type in slot c (free for
        // CallExpr) for both script + native calls. Read it for downstream
        // type inference (e.g. `let s = string_substr(...)`).
        let rt: i64 = nk_c(e);
        if (rt >= 0) { return rt; }
        return -1;
    }
    // Phase 2: CastExpr result type = the cast's target type (nk_b).
    if (k == (NK::CastExpr as i64)) { return resolve_type(nk_b(e)); }
    // Phase 2: TernaryExpr result type = the then-branch's type.
    if (k == (NK::TernaryExpr as i64)) { return cg_expr_type(nk_b(e)); }
    // Phase 2: sizeof/offsetof return u64 (mirrors src/sema.cpp which interns
    // make_prim(Prim::U64)). The self-hosted codegen emits a compile-time
    // constant, so the type is TY_U64.
    if (k == (NK::SizeofExpr as i64)) { return TY_U64; }
    if (k == (NK::OffsetofExpr as i64)) { return TY_U64; }
    return -1;
}

// =============================================================================
// ABI type code + fingerprint (mirrors src/module_abi_fingerprint.hpp EXACTLY).
// The codegen computes a native call's fingerprint from the call's arg types +
// return type (annotated by sema) so the EMBM v1 loader's fingerprint check
// passes. Type -> 6-bit code table (module_abi_fingerprint.hpp):
//   0=void 1=i64 2=f64 3=f32 4=bool 5=slice 6=ptr/opaque(handle)
//   7=i32 8=u8 9=u16 10=u32 11=u64 12=i8 13=i16 14=aggregate
// A `string` is an opaque i64 handle (host bind_handle("string")) -> code 6.
// =============================================================================

// map a sema Type node to its 6-bit ABI code. Mirrors ember::type_code().
fn cg_type_code(t: i64) -> i64 {
    if (t < 0) { return 0; }   // void/missing -> 0
    if (ty_is_string(t) == 1) { return 6; }   // string handle -> opaque ptr
    if (ty_is_slice(t) == 1)  { return 5; }   // slice {ptr,len} (string/slice<u8>)
    if (ty_is_void(t) == 1)  { return 0; }
    if (ty_is_i64(t) == 1)   { return 1; }
    if (ty_is_bool(t) == 1)  { return 4; }
    if (ty_is_float(t) == 1) {
        if (cg_float_is64_type(t) == 1) { return 2; }   // f64
        return 3;                                        // f32
    }
    // other ints (i32/u8/...): read the prim directly
    if (nk_kind(t) == (NK::Type as i64) && nk_tok(t) < 0) {
        let p: i64 = nk_d(t);
        if (p == (Prim::I32 as i64)) { return 7; }
        if (p == (Prim::U8  as i64)) { return 8; }
        if (p == (Prim::U16 as i64)) { return 9; }
        if (p == (Prim::U32 as i64)) { return 10; }
        if (p == (Prim::U64 as i64)) { return 11; }
        if (p == (Prim::I8  as i64)) { return 12; }
        if (p == (Prim::I16 as i64)) { return 13; }
    }
    return 14;  // aggregate / fallback (named struct, fixed array)
}

// compute the u64 ABI fingerprint from a call's arg types + return type +
// permission. Layout (module_abi_fingerprint.hpp §8, LSB-first):
//   bits 0..3   param_count (saturated to 15)
//   bits 4..27  up to 4 param type codes, 6 bits each (param i at 4+6i)
//   bits 28..33 return type code (6 bits)
//   bits 34..37 permission (0=none, 1=FFI)
//   bits 38..63 reserved (zero)
// `arg_types` is an i64 array (elem 8) of sema Type node indices; `argc` is the
// count; `ret_type` is the return Type node; `perm` is the permission bits.
fn cg_abi_fingerprint(arg_types: i64, argc: i64, ret_type: i64, perm: i64) -> i64 {
    let mut pc: i64 = argc;
    if (pc > 15) { pc = 15; }
    let mut fp: i64 = pc & 0xF;
    let mut i: i64 = 0;
    while (i < pc && i < 4) {
        let tc: i64 = cg_type_code(array_get_i64(arg_types, i)) & 0x3F;
        fp = fp | (tc << (4 + 6 * i));
        i = i + 1;
    }
    let rc: i64 = cg_type_code(ret_type) & 0x3F;
    fp = fp | (rc << 28);
    fp = fp | ((perm & 0xF) << 34);
    return fp;
}

// Return the reusable ABI-fingerprint scratch array (cg_fp_codes), ensuring
// it is allocated with capacity 2 (enough for the 1- or 2-entry codes used by
// the internal string_* native emissions). Replaces a per-call array_new that
// leaked a slot on every native-call emission. Callers overwrite index 0 (and
// 1) then call cg_abi_fingerprint_codes with an explicit argc; stale entries
// beyond argc are never read, so no clear is needed between uses.
fn cg_fp_codes_get() -> i64 {
    if (cg_fp_codes == 0) {
        cg_fp_codes = array_new(8, 2);
    } else if (array_length(cg_fp_codes) < 2) {
        array_resize(cg_fp_codes, 2);
    }
    return cg_fp_codes;
}

// Return the reusable type-fingerprint scratch array (cg_fp_types), ensuring
// it is allocated with capacity 4 (enough for the 4-entry param-type arrays
// used by native-call + for-each fingerprinting). Callers overwrite entries
// 0..argc-1 then call cg_abi_fingerprint with an explicit argc; stale entries
// beyond argc are never read, so no clear is needed between uses.
fn cg_fp_types_get() -> i64 {
    if (cg_fp_types == 0) {
        cg_fp_types = array_new(8, 4);
    } else if (array_length(cg_fp_types) < 4) {
        array_resize(cg_fp_types, 4);
    }
    return cg_fp_types;
}

// Return the reusable Win64-arg-register scratch array (cg_arg_regs),
// ensuring it is allocated with capacity 4.
fn cg_arg_regs_get() -> i64 {
    if (cg_arg_regs == 0) {
        cg_arg_regs = array_new(8, 4);
    } else if (array_length(cg_arg_regs) < 4) {
        array_resize(cg_arg_regs, 4);
    }
    return cg_arg_regs;
}

// On-demand native-arg register class for cg_eval_callexpr. Returns 1 if the
// i-th param of native `name` is a float type (so the arg arrives in
// xmm0..xmm3), else 0. Replaces the pre-computed `arg_is_float` array that
// leaked a slot on every call expression (the array was read AFTER recursive
// arg evaluation, so it could not be a simple global). native_param_type is a
// pure table lookup (no codegen recursion), so recomputing on demand is safe.
fn cg_arg_is_float(name: string, i: i64) -> i64 {
    let pt: i64 = native_param_type(name, i);
    if (ty_is_float(pt) == 1) { return 1; }
    return 0;
}

// On-demand native-arg float width for cg_eval_callexpr. Returns 1 if the
// i-th param of native `name` is an f64 (vs f32). Replaces the pre-computed
// `arg_is_f64` array (same re-entrancy reasoning as cg_arg_is_float).
fn cg_arg_is_f64(name: string, i: i64) -> i64 {
    let pt: i64 = native_param_type(name, i);
    if (ty_is_float(pt) == 1) {
        if (cg_float_is64_type(pt) == 1) { return 1; }
    }
    return 0;
}

// the ABI fingerprint for a known native, computed from EXPLICIT type codes
// (used for internal codegen calls like string_from_slice where sema never
// type-checks the call, + for operator-overload natives like string_add whose
// registered params are plain I64, not the handle type sema would infer).
// param_codes is an i64 array of 6-bit codes; perm is the permission.
fn cg_abi_fingerprint_codes(param_codes: i64, argc: i64, ret_code: i64, perm: i64) -> i64 {
    let mut pc: i64 = argc;
    if (pc > 15) { pc = 15; }
    let mut fp: i64 = pc & 0xF;
    let mut i: i64 = 0;
    while (i < pc && i < 4) {
        let tc: i64 = array_get_i64(param_codes, i) & 0x3F;
        fp = fp | (tc << (4 + 6 * i));
        i = i + 1;
    }
    fp = fp | ((ret_code & 0x3F) << 28);
    fp = fp | ((perm & 0xF) << 34);
    return fp;
}

// Convert the decimal token text into mantissa and decimal scale, then emit
// an exact runtime conversion through CVTSI2SS/CVTSI2SD. This avoids needing
// an f64 bitcast primitive in the Ember implementation language.
fn cg_float_mantissa(e: i64) -> i64 {
    let raw: string = nk_name(e); let n: i64 = string_length(raw);
    let mut m: i64 = 0; let mut i: i64 = 0;
    while (i < n) { let ch: i64 = string_char_at(raw, i); if (ch >= 48 && ch <= 57) { m = m * 10 + ch - 48; } if (ch == 101 || ch == 69) { break; } i = i + 1; }
    return m;
}
fn cg_float_scale(e: i64) -> i64 {
    let raw: string = nk_name(e); let n: i64 = string_length(raw);
    let mut frac: i64 = 0; let mut dot: i64 = 0; let mut exp: i64 = 0; let mut esign: i64 = 1; let mut in_exp: i64 = 0; let mut i: i64 = 0;
    while (i < n) { let ch: i64 = string_char_at(raw, i); if (ch == 46) { dot = 1; } else if (ch == 101 || ch == 69) { in_exp = 1; if (i + 1 < n && string_char_at(raw, i + 1) == 45) { esign = -1; i = i + 1; } else if (i + 1 < n && string_char_at(raw, i + 1) == 43) { i = i + 1; } } else if (ch >= 48 && ch <= 57) { if (in_exp == 1) { exp = exp * 10 + ch - 48; } else if (dot == 1) { frac = frac + 1; } } i = i + 1; }
    return frac - esign * exp;
}
fn cg_pow10_i64(n: i64) -> i64 { let mut p: i64 = 1; let mut i: i64 = 0; while (i < n) { p = p * 10; i = i + 1; } return p; }
fn cg_eval_float_lit(e: i64) -> i64 {
    let is64: i64 = cg_float_is64_type(cg_expr_type(e));
    cg_mov_reg_imm64(RAX, cg_float_mantissa(e)); cg_i64_to_float(XMM0, RAX, is64);
    let scale: i64 = cg_float_scale(e);
    if (scale > 0) { cg_mov_reg_imm64(RAX, cg_pow10_i64(scale)); cg_i64_to_float(XMM1, RAX, is64); cg_float_op(0x5E, is64); }
    else if (scale < 0) { cg_mov_reg_imm64(RAX, cg_pow10_i64(0 - scale)); cg_i64_to_float(XMM1, RAX, is64); cg_float_op(0x59, is64); }
    return 0;
}

// mov r64, [r64 + disp32] (load from memory) -> REX.W 8B /r mod=10
fn cg_load_reg_mem(dst: i64, base: i64, disp: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(dst), 0, cg_is_extended(base)));
    cg_byte(0x8B);
    // rsp/r12 (rm=4) need a SIB byte; rbp (rm=5) uses mod=10 (disp32) which
    // is already what we emit, so no special case for rbp here.
    if ((base & 7) == 4) {
        cg_byte(cg_modrm(2, dst, 4));
        cg_byte(0x24);  // SIB: scale=0, index=none(4), base=rsp(4)
    } else {
        cg_byte(cg_modrm(2, dst, base));
    }
    cg_imm32(disp);
    return 0;
}

// mov [r64 + disp32], r64 (store to memory) -> REX.W 89 /r mod=10
fn cg_store_reg_mem(base: i64, disp: i64, src: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(src), 0, cg_is_extended(base)));
    cg_byte(0x89);
    if ((base & 7) == 4) {
        cg_byte(cg_modrm(2, src, 4));
        cg_byte(0x24);
    } else {
        cg_byte(cg_modrm(2, src, base));
    }
    cg_imm32(disp);
    return 0;
}

// load rax's low `width` bytes from [base+disp] with sign/zero extension.
// Mirrors src/x64_emitter.hpp load_elem_to_rax EXACTLY:
//   1 byte: REX.W 0F B6/B7/B7/B7 + modrm(rax,base) + disp32 (zero/sign)
//   2 bytes: REX.W 0F B7/BF + modrm + disp32
//   4 bytes: movsxd rax,[mem] (signed) or mov r32 (unsigned, zero-extends)
//   8 bytes: mov rax,[mem]
// For base rsp/r12 (rm=4) emit a SIB byte (scale=0, index=none, base=base).
fn cg_load_elem_to_rax(base: i64, disp: i64, width: i64, sign_extend: i64) -> i64 {
    if (width >= 8) { cg_load_reg_mem(RAX, base, disp); return 0; }
    if (width == 4) {
        if (sign_extend != 0) {
            cg_byte(cg_rex(1, 0, 0, cg_is_extended(base)));
            cg_byte(0x63);   // movsxd rax, [mem]
        } else {
            if (cg_is_extended(base) != 0) { cg_byte(cg_rex(0, 0, 0, 1)); }
            cg_byte(0x8B);   // mov r32 (zero-extends to rax)
        }
    } else if (width == 2) {
        cg_byte(cg_rex(1, 0, 0, cg_is_extended(base)));
        cg_byte(0x0F); cg_byte(sign_extend != 0 ? 0xBF : 0xB7);
    } else {  // width == 1
        cg_byte(cg_rex(1, 0, 0, cg_is_extended(base)));
        cg_byte(0x0F); cg_byte(sign_extend != 0 ? 0xBE : 0xB6);
    }
    if ((base & 7) == 4) {
        cg_byte(cg_modrm(2, RAX, 4));
        cg_byte(0x24);
    } else {
        cg_byte(cg_modrm(2, RAX, base));
    }
    cg_imm32(disp);
    return 0;
}

// store rax's low `width` bytes to [base+disp]. Mirrors src/x64_emitter.hpp
// store_rax_elem EXACTLY: 1/2/4-byte partial stores (66 prefix for 2 bytes);
// 8 bytes -> full mov [mem], rax.
fn cg_store_rax_elem(base: i64, disp: i64, width: i64) -> i64 {
    if (width >= 8) { cg_store_reg_mem(base, disp, RAX); return 0; }
    if (width == 2) { cg_byte(0x66); }
    if (width <= 4) {
        if (cg_is_extended(base) != 0) { cg_byte(cg_rex(0, 0, 0, 1)); }
        cg_byte(0x88 + (width == 1 ? 0 : 1));   // 88 (1 byte) / 89 (2 or 4 bytes)
    }
    if ((base & 7) == 4) {
        cg_byte(cg_modrm(2, RAX, 4));
        cg_byte(0x24);
    } else {
        cg_byte(cg_modrm(2, RAX, base));
    }
    cg_imm32(disp);
    return 0;
}

// zero-fill `nbytes` bytes starting at [rbp + off] (an aggregate local with no
// initializer), in 8/4/2/1-byte chunks. Mirrors src/codegen.cpp's LetStmt
// no-init zero-fill loop. rax is clobbered (set to 0).
fn cg_zero_fill(off: i64, nbytes: i64) -> i64 {
    let mut remaining: i64 = nbytes;
    let mut cur: i64 = off;
    cg_mov_reg_imm64(RAX, 0);
    while (remaining > 0) {
        let chunk: i64 = cg_chunk_for(remaining);
        cg_store_rax_elem(RBP, cur, chunk);
        cur = cur + chunk;
        remaining = remaining - chunk;
    }
    return 0;
}

// largest power-of-2 chunk <= n up to 8 (for copy/zero chunking).
fn cg_chunk_for(n: i64) -> i64 {
    if (n >= 8) { return 8; }
    if (n >= 4) { return 4; }
    if (n >= 2) { return 2; }
    return 1;
}

// lea r64, [rbp + disp32] -> REX.W 8D /r mod=10. Used for fixed-array / view
// base addresses (the local's frame slot address).
fn cg_lea_r_rbp(dst: i64, disp: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(dst), 0, 0));
    cg_byte(0x8D);
    cg_byte(cg_modrm(2, dst, RBP));
    cg_imm32(disp);
    return 0;
}
fn cg_lea_rax_rbp(disp: i64) -> i64 { return cg_lea_r_rbp(RAX, disp); }
fn cg_lea_r11_rbp(disp: i64) -> i64 { return cg_lea_r_rbp(R11, disp); }
fn cg_lea_scaled8(dst: i64, base: i64, index: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(dst), cg_is_extended(index), cg_is_extended(base)));
    cg_byte(0x8D); cg_byte(cg_modrm(0, dst, 4));
    cg_byte((3 << 6) | ((index & 7) << 3) | (base & 7));
    return 0;
}

// SSE load/store from/to [base + disp32] with an ARBITRARY base register
// (generalizes cg_sse_mem which is rbp-only). prefix=F2(sd)/F3(ss), op=10(load)
// /11(store). REX (if any) is emitted BEFORE the 0F escape, in the right place.
// Used for float array elements addressed through r11.
fn cg_sse_mem_reg(prefix: i64, op: i64, x: i64, base: i64, disp: i64) -> i64 {
    cg_byte(prefix);
    if (cg_is_extended(x) != 0 || cg_is_extended(base) != 0) {
        cg_byte(cg_rex(0, cg_is_extended(x), 0, cg_is_extended(base)));
    }
    cg_byte(0x0F); cg_byte(op);
    if ((base & 7) == 4) {
        cg_byte(cg_modrm(2, x, 4));
        cg_byte(0x24);
    } else {
        cg_byte(cg_modrm(2, x, base));
    }
    cg_imm32(disp);
    return 0;
}

fn cg_load_float_reg(x: i64, base: i64, disp: i64, is64: i64) -> i64 {
    let mut pf: i64 = 0xF3;
    if (is64 == 1) { pf = 0xF2; }
    return cg_sse_mem_reg(pf, 0x10, x, base, disp);
}
fn cg_store_float_reg(base: i64, disp: i64, x: i64, is64: i64) -> i64 {
    let mut pf: i64 = 0xF3;
    if (is64 == 1) { pf = 0xF2; }
    return cg_sse_mem_reg(pf, 0x11, x, base, disp);
}
// load an f32/f64 element from [r11 + 0] into xmm0 (for IndexExpr float path).
fn cg_load_float_disp_r11(is64: i64) -> i64 { return cg_load_float_reg(XMM0, R11, 0, is64); }

// Runtime bounds check: index in rax, len in r9 (a slice). Unsigned compare —
// jb to an in-bounds label, else ud2 (trap). A negative index reinterpreted as
// unsigned is enormous, so one unsigned compare catches both too-large and
// negative. Mirrors src/codegen.cpp's emit_bounds_check_reg.
fn cg_bounds_check_reg_rax_r9() -> i64 {
    cg_mov_reg_reg(RCX, RAX);               // stash index in rcx
    cg_cmp_reg_reg(RCX, R9);
    let ok: i64 = cg_alloc_label();
    cg_jcc(COND_B, ok);                     // idx < len (unsigned) -> ok
    cg_byte(0x0F); cg_byte(0x0B);           // ud2 (raises #UD)
    cg_bind(ok);
    return 0;
}

// Runtime bounds check: index in rax, len = imm (a fixed array's N, non-const
// index). cmp rax, imm32; jb to ok; else ud2.
fn cg_bounds_check_imm_rax(len: i64) -> i64 {
    cg_mov_reg_reg(RCX, RAX);               // stash index in rcx
    cg_cmp_reg_imm32(RCX, len);
    let ok: i64 = cg_alloc_label();
    cg_jcc(COND_B, ok);
    cg_byte(0x0F); cg_byte(0x0B);           // ud2
    cg_bind(ok);
    return 0;
}

// call r64 (indirect) -> FF /2 with mod=11
fn cg_call_reg(r: i64) -> i64 {
    if (cg_is_extended(r) != 0) { cg_byte(cg_rex(0, 0, 0, 1)); }
    cg_byte(0xFF);
    cg_byte(cg_modrm(3, 2, r));
    return 0;
}

// lea dst, [rip + rel32] — rip-relative address of a label (for catch-entry rip).
// REX.W 8D /r mod=00 rm=5 (rip) + rel32 (fixup, backpatched by cg_resolve_fixups).
fn cg_lea_reg_rip(dst: i64, label_id: i64) -> i64 {
    cg_byte(cg_rex(1, cg_is_extended(dst), 0, 0));
    cg_byte(0x8D);
    cg_byte(cg_modrm(0, dst, 5));  // mod=00, rm=5 = RIP-relative
    cg_add_fixup(label_id);
    cg_imm32(0);  // placeholder rel32, backpatched by cg_resolve_fixups
    return 0;
}

// jmp r64 — indirect jump to register (FF /4). Used by throw's longjmp to
// jump to the catch-entry rip loaded from catch_bufs.
fn cg_jmp_reg(r: i64) -> i64 {
    if (cg_is_extended(r) != 0) { cg_byte(cg_rex(0, 0, 0, 1)); }
    cg_byte(0xFF);
    cg_byte(cg_modrm(3, 4, r));  // /4 = jmp
    return 0;
}

// call rel32 (direct, in-buffer) -> E8 rel32. The rel32 is a placeholder
// recorded as a fixup for `label_id`; cg_resolve_fixups patches it after all
// labels (including other fns' entry labels) are bound. Used for script-to-
// script calls so a multi-fn program's calls resolve to the callee's real
// entry offset within the same executable page (make_executable copies bytes
// verbatim, so a relative call within the buffer works without host patching).
fn cg_call_rel32(label_id: i64) -> i64 {
    cg_byte(0xE8);
    cg_add_fixup(label_id);
    cg_imm32(0);  // placeholder rel32
    return 0;
}

// ret -> C3
fn cg_ret() -> i64 {
    cg_byte(0xC3);
    return 0;
}

// nop -> 90
fn cg_nop() -> i64 {
    cg_byte(0x90);
    return 0;
}

// =============================================================================
// labels + fixups (port of X64Emitter's label/patch system).
// =============================================================================

// allocate a new label id
fn cg_alloc_label() -> i64 {
    let id: i64 = cg_next_label;
    cg_next_label = cg_next_label + 1;
    return id;
}

// bind a label to the current code offset
fn cg_bind(label_id: i64) -> i64 {
    let off: i64 = array_length(cg_code);  // current byte count = next offset
    array_push_i64(cg_labels, label_id);
    array_push_i64(cg_labels, off);
    return 0;
}

// look up a bound label's code offset. returns -1 if not found.
fn cg_label_offset(label_id: i64) -> i64 {
    let n: i64 = array_length(cg_labels) / 2;
    let mut i: i64 = 0;
    while (i < n) {
        let id: i64 = array_get_i64(cg_labels, i * 2);
        if (id == label_id) { return array_get_i64(cg_labels, i * 2 + 1); }
        i = i + 1;
    }
    return -1;
}

// record a pending rel32 fixup at the current code offset for a label
fn cg_add_fixup(label_id: i64) -> i64 {
    let off: i64 = array_length(cg_code);
    array_push_i64(cg_fixups, off);
    array_push_i64(cg_fixups, label_id);
    return 0;
}

// jmp label -> E9 rel32 (placeholder, backpatched)
fn cg_jmp(label_id: i64) -> i64 {
    cg_byte(0xE9);
    cg_add_fixup(label_id);
    cg_imm32(0);  // placeholder
    return 0;
}

// jcc label -> 0F 8x rel32 (placeholder, backpatched)
fn cg_jcc(cc: i64, label_id: i64) -> i64 {
    cg_byte(0x0F);
    cg_byte(0x80 | cc);
    cg_add_fixup(label_id);
    cg_imm32(0);  // placeholder
    return 0;
}

// resolve all pending rel32 fixups. Must be called after all labels are bound.
// Each fixup's rel32 = target_offset - (fixup_offset + 4).
fn cg_resolve_fixups() -> i64 {
    let n: i64 = array_length(cg_fixups) / 2;
    let mut i: i64 = 0;
    while (i < n) {
        let fix_off: i64 = array_get_i64(cg_fixups, i * 2);
        let label_id: i64 = array_get_i64(cg_fixups, i * 2 + 1);
        let target: i64 = cg_label_offset(label_id);
        if (target < 0) {
            if (cg_err == 0) {
                cg_err = 1;
                cg_errmsg = string_from_slice("codegen: unbound label in fixup");
            }
            i = i + 1;
            continue;
        }
        // rel32 = target - (fix_off + 4)  (the rel32 is relative to the end of the instruction)
        let rel: i64 = target - (fix_off + 4);
        // patch the 4 bytes at fix_off (little-endian)
        array_set_u8(cg_code, fix_off + 0, rel & 0xFF);
        array_set_u8(cg_code, fix_off + 1, (rel >> 8) & 0xFF);
        array_set_u8(cg_code, fix_off + 2, (rel >> 16) & 0xFF);
        array_set_u8(cg_code, fix_off + 3, (rel >> 24) & 0xFF);
        i = i + 1;
    }
    return 0;
}

// =============================================================================
// local variable frame layout.
// =============================================================================

// reset the local table for a new function
fn cg_locals_init() -> i64 {
    // Reuse cg_locals / cg_scope_marks across function compilations instead
    // of allocating fresh arrays each time. This is a HOT PATH: cg_locals_init
    // runs once PER FUNCTION, so compiling a module with N functions leaked
    // 2*N arrays (no array_free in the host extension; slots are never
    // reclaimed). array_clear() resets the logical length to 0 while keeping
    // the backing buffer, so the slot is reused and the store stops growing.
    // The first call (handle == 0) still allocates.
    if (cg_locals != 0) { array_clear(cg_locals); } else { cg_locals = array_new(8, 0); }
    cg_local_len = 0;
    if (cg_scope_marks != 0) { array_clear(cg_scope_marks); } else { cg_scope_marks = array_new(8, 0); }
    cg_scope_mark_len = 0;
    cg_next_off = 0;
    return 0;
}

// push a scope (record the current logical length so pop can truncate)
fn cg_push_scope() -> i64 {
    if (array_length(cg_scope_marks) < cg_scope_mark_len + 1) {
        array_resize(cg_scope_marks, cg_scope_mark_len + 1);
    }
    array_set_i64(cg_scope_marks, cg_scope_mark_len, cg_local_len);
    cg_scope_mark_len = cg_scope_mark_len + 1;
    return 0;
}

// pop a scope (truncate the local table back to the mark)
fn cg_pop_scope() -> i64 {
    if (cg_scope_mark_len == 0) { return 0; }
    cg_scope_mark_len = cg_scope_mark_len - 1;
    let mark: i64 = array_get_i64(cg_scope_marks, cg_scope_mark_len);
    cg_local_len = mark;
    return 0;
}

// Allocate a scalar or aggregate local. `slots` is the number of eight-byte
// words reserved. Returns the rbp offset of the local's LOWEST address (the
// base); aggregate fields/elements live at base + their byte offset (packed,
// ascending), a scalar's value is at base + 0. The region spans
// [base, base + slots*8). Mirrors the C++ codegen's rbp-relative frame slots
// but keeps the base at the lowest address so packed layout addressing is a
// simple base + offset.
fn cg_alloc_local_t(name_tok: i64, type_node: i64, slots: i64) -> i64 {
    let mut nslots: i64 = slots;
    if (nslots < 1) { nslots = 1; }
    cg_next_off = cg_next_off + nslots * 8;
    let off: i64 = -cg_next_off;   // lowest address of the reserved region
    if (array_length(cg_locals) < cg_local_len + 3) { array_resize(cg_locals, cg_local_len + 3); }
    array_set_i64(cg_locals, cg_local_len, name_tok);
    array_set_i64(cg_locals, cg_local_len + 1, off);
    array_set_i64(cg_locals, cg_local_len + 2, type_node);
    cg_local_len = cg_local_len + 3;
    return off;
}

fn cg_alloc_local(name_tok: i64) -> i64 { return cg_alloc_local_t(name_tok, -1, 1); }

// look up a local by name. returns the rbp offset, or 0 if not found.
fn cg_lookup_local(name_tok: i64) -> i64 {
    let nm: string = tok_name(name_tok);
    let n: i64 = cg_local_len / 3;
    let mut i: i64 = n - 1;  // scan from end (innermost scope wins)
    while (i >= 0) {
        let tok: i64 = array_get_i64(cg_locals, i * 3);
        // compare by NAME, not token index: the same variable name at
        // different source positions has different token indices (the let's
        // 'x' and the return's 'x' are distinct tokens). Matches sema's
        // lookup_local, which compares tok_name(...) == name.
        if (tok_name(tok) == nm) { return array_get_i64(cg_locals, i * 3 + 1); }
        i = i - 1;
    }
    return 0;  // 0 = not found (all real offsets are negative)
}

fn cg_lookup_local_type(name_tok: i64) -> i64 {
    let nm: string = tok_name(name_tok);
    let mut i: i64 = cg_local_len / 3 - 1;
    while (i >= 0) {
        if (tok_name(array_get_i64(cg_locals, i * 3)) == nm) { return array_get_i64(cg_locals, i * 3 + 2); }
        i = i - 1;
    }
    return -1;
}

// look up a function's entry label by name. Returns the label id, or -1 if
// the name is not in cg_fn_labels (i.e. the fn was not declared in the
// program). Names are stored as token indices and compared by text via
// tok_name (same trick as cg_lookup_local + sema's tables). This bare lookup
// matches a TOP-LEVEL fn (ns_tok < 0); namespaced fns are found via
// cg_lookup_fn_label_qualified (Ns::fn).
fn cg_lookup_fn_label(name: string) -> i64 {
    let n: i64 = array_length(cg_fn_labels) / 3;
    let mut i: i64 = 0;
    while (i < n) {
        let tok: i64 = array_get_i64(cg_fn_labels, i * 3);
        if (tok_name(tok) == name) {
            if (array_get_i64(cg_fn_labels, i * 3 + 2) < 0) { return array_get_i64(cg_fn_labels, i * 3 + 1); }
        }
        i = i + 1;
    }
    return -1;
}

// look up a function's entry label by qualified name (Ns::fn). ns_name ""
// matches a top-level fn; a nonempty ns_name matches a fn whose ns_tok names
// ns_name. Returns the label id, or -1.
fn cg_lookup_fn_label_qualified(name: string, ns_name: string) -> i64 {
    let n: i64 = array_length(cg_fn_labels) / 3;
    let mut i: i64 = 0;
    while (i < n) {
        let tok: i64 = array_get_i64(cg_fn_labels, i * 3);
        if (tok_name(tok) == name) {
            let ns_tok: i64 = array_get_i64(cg_fn_labels, i * 3 + 2);
            let mut ok: i64 = 0;
            if (ns_tok < 0) {
                if (string_length(ns_name) == 0) { ok = 1; }
            } else {
                if (tok_name(ns_tok) == ns_name) { ok = 1; }
            }
            if (ok == 1) { return array_get_i64(cg_fn_labels, i * 3 + 1); }
        }
        i = i + 1;
    }
    return -1;
}

// =============================================================================
// codegen state init.
// =============================================================================

fn cg_init() -> i64 {
    // Reuse the emitter arrays across cg_init() calls instead of allocating
    // fresh ones each time. The host array extension has no array_free (slots
    // in the process-wide store are never reclaimed until reset()), so a
    // fresh array_new on every codegen() leaks the previous buffer — and the
    // leaked buffers accumulate in the trace-callback scan, eventually
    // crashing the host at scale (a bare RUNTIME TRAP / exit 70).
    // array_clear() resets the logical length to 0 while keeping the backing
    // buffer, so the slot is reused and the store stops growing. The first
    // call (handle == 0) still allocates.
    if (cg_code != 0) { array_clear(cg_code); } else { cg_code = array_new(1, 0); }
    cg_next_label = 0;
    if (cg_labels != 0) { array_clear(cg_labels); } else { cg_labels = array_new(8, 0); }
    if (cg_fixups != 0) { array_clear(cg_fixups); } else { cg_fixups = array_new(8, 0); }
    if (cg_fn_labels != 0) { array_clear(cg_fn_labels); } else { cg_fn_labels = array_new(8, 0); }
    // EMBM v1 image buffers (reset alongside cg_code so every codegen() starts clean).
    if (cg_rodata != 0) { array_clear(cg_rodata); } else { cg_rodata = array_new(1, 0); }
    if (cg_data   != 0) { array_clear(cg_data);   } else { cg_data   = array_new(1, 0); }
    if (cg_syms   != 0) { array_clear(cg_syms);   } else { cg_syms   = array_new(1, 0); }
    if (cg_relocs != 0) { array_clear(cg_relocs); } else { cg_relocs = array_new(1, 0); }
    if (cg_globals != 0) { array_clear(cg_globals); } else { cg_globals = array_new(8, 0); }
    cg_globals_len = 0;
    // string-globals table + init label (reset so each codegen() starts clean;
    // cg_globals_init_label = -1 means "no __globals_init emitted this compile").
    if (cg_str_globals != 0) { array_clear(cg_str_globals); } else { cg_str_globals = array_new(8, 0); }
    cg_str_globals_len = 0;
    cg_globals_init_label = -1;
    // Phase 3b: defer cleanup stack (reset per function in cg_compile_func).
    if (g_defers != 0) { array_clear(g_defers); } else { g_defers = array_new(8, 0); }
    if (g_defer_marks != 0) { array_clear(g_defer_marks); } else { g_defer_marks = array_new(8, 0); }
    g_defer_mark_len = 0;
    cg_cur_ret = -1;
    cg_loop_defer_mark = 0;
    cg_err = 0;
    cg_errmsg = string_from_slice("");
    return 0;
}

// =============================================================================
// EMBM v1 image-buffer helpers (self_hosted/MODULE_IMAGE_FORMAT.md).
// =============================================================================

// append a u64 little-endian (8 bytes) into a byte array (array<u8>).
fn cg_push_u64_le(buf: i64, v: i64) -> i64 {
    array_push_u8(buf, v & 0xFF);
    array_push_u8(buf, (v >> 8) & 0xFF);
    array_push_u8(buf, (v >> 16) & 0xFF);
    array_push_u8(buf, (v >> 24) & 0xFF);
    array_push_u8(buf, (v >> 32) & 0xFF);
    array_push_u8(buf, (v >> 40) & 0xFF);
    array_push_u8(buf, (v >> 48) & 0xFF);
    array_push_u8(buf, (v >> 56) & 0xFF);
    return 0;
}

// append a u32 little-endian (4 bytes) into a byte array (array<u8>).
fn cg_push_u32_le(buf: i64, v: i64) -> i64 {
    array_push_u8(buf, v & 0xFF);
    array_push_u8(buf, (v >> 8) & 0xFF);
    array_push_u8(buf, (v >> 16) & 0xFF);
    array_push_u8(buf, (v >> 24) & 0xFF);
    return 0;
}

// allocate `n` bytes in cg_rodata (the bytes are left zero; the caller writes
// them via array_set_u8 after this returns the addend). Returns the byte
// offset (addend) within rodata where the allocation begins. Used by string
// literals: emit the literal's decoded bytes here, then reference them via an
// ABS64_RODATA reloc whose addend is this offset.
fn cg_rodata_alloc(n: i64) -> i64 {
    let addend: i64 = array_length(cg_rodata);
    let mut i: i64 = 0;
    while (i < n) { array_push_u8(cg_rodata, 0); i = i + 1; }
    return addend;
}

// allocate `n` bytes in cg_data (mutable globals). Returns the byte addend.
// The caller writes the initial bytes via array_set_u8 after this returns.
fn cg_data_alloc(n: i64) -> i64 {
    let addend: i64 = array_length(cg_data);
    let mut i: i64 = 0;
    while (i < n) { array_push_u8(cg_data, 0); i = i + 1; }
    return addend;
}

// find or append a null-terminated symbol name in cg_syms. Returns the 0-based
// symbol index. Scans the accumulated names (each null-terminated) comparing
// byte-for-byte; appends name + '\0' if new. Used by ABS64_NATIVE relocs to
// reference a native by index into the image's symbol-name table (§6).
fn cg_sym_index(name: string) -> i64 {
    let nlen: i64 = string_length(name);
    let syms_len: i64 = array_length(cg_syms);
    let mut idx: i64 = 0;
    let mut i: i64 = 0;
    while (i < syms_len) {
        // read one null-terminated name starting at i
        let mut j: i64 = i;
        let mut match_ok: i64 = 1;
        let mut k: i64 = 0;
        while (k < nlen) {
            let b: i64 = array_get_u8(cg_syms, j) as i64;
            if (b != string_char_at(name, k)) { match_ok = 0; }
            j = j + 1;
            k = k + 1;
            if (j >= syms_len) { match_ok = 0; }
        }
        if (match_ok == 1) {
            // the byte after the name must be the null terminator
            if (j < syms_len && (array_get_u8(cg_syms, j) as i64) == 0) { return idx; }
            match_ok = 0;
        }
        // advance past this null-terminated name to the next
        while (i < syms_len && (array_get_u8(cg_syms, i) as i64) != 0) { i = i + 1; }
        i = i + 1;  // skip the null
        idx = idx + 1;
    }
    // not found: append name + '\0'
    let mut k: i64 = 0;
    while (k < nlen) { array_push_u8(cg_syms, string_char_at(name, k)); k = k + 1; }
    array_push_u8(cg_syms, 0);
    return idx;
}

// record a 32-byte relocation record [type u64][patch_off u64][sym_idx u64][addend u64]
// (all little-endian). patch_off is a byte offset WITHIN the code section of
// the imm64 to patch. For NATIVE, sym_idx is the symbol index + addend is the
// ABI fingerprint; for RODATA/DATA, sym_idx is 0 + addend is the section addend.
fn cg_reloc(reloc_type: i64, patch_off: i64, sym_idx: i64, addend: i64) -> i64 {
    cg_push_u64_le(cg_relocs, reloc_type);
    cg_push_u64_le(cg_relocs, patch_off);
    cg_push_u64_le(cg_relocs, sym_idx);
    cg_push_u64_le(cg_relocs, addend);
    return 0;
}

// emit a `mov reg, <ABS64 imm64>` placeholder (REX.W B8+rd + 8 zero bytes) and
// record a relocation against the imm64's code offset. Returns the code offset
// of the imm64 (for validation). The loader patches the 8 zero bytes with the
// resolved absolute address (rodata_base+addend, data_base+addend, or native fn_ptr).
fn cg_emit_abs64_reloc_reg(reg: i64, reloc_type: i64, sym_idx: i64, addend: i64) -> i64 {
    // mov r64, imm64 -> REX.W B8+rd io
    cg_byte(cg_rex(1, 0, 0, cg_is_extended(reg)));
    cg_byte(0xB8 + (reg & 7));
    let patch_off: i64 = array_length(cg_code);
    cg_imm64(0);  // placeholder; the loader writes the resolved address here
    cg_reloc(reloc_type, patch_off, sym_idx, addend);
    return patch_off;
}

// convenience: `mov rax, <ABS64>` + reloc (the common case for native calls,
// where rax holds the call target before `call rax`).
fn cg_emit_abs64_reloc(reloc_type: i64, sym_idx: i64, addend: i64) -> i64 {
    return cg_emit_abs64_reloc_reg(RAX, reloc_type, sym_idx, addend);
}

// Build EMBM v2: 96-byte header plus function dispatch table.
fn codegen_emit_image() -> i64 {
    let code_len: i64 = array_length(cg_code); let rodata_len: i64 = array_length(cg_rodata);
    let data_len: i64 = array_length(cg_data); let syms_len: i64 = array_length(cg_syms);
    let reloc_count: i64 = array_length(cg_relocs) / 32;
    let fn_count: i64 = array_length(cg_fn_labels) / 3; let fntable_len: i64 = fn_count * 16;
    let header_size: i64 = 96; let code_off: i64 = header_size;
    let rodata_off: i64 = code_off + code_len; let data_off: i64 = rodata_off + rodata_len;
    let syms_off: i64 = data_off + data_len; let fntable_off: i64 = syms_off + syms_len;
    let img: i64 = array_new(1, 0);
    array_push_u8(img, 0x45); array_push_u8(img, 0x4D); array_push_u8(img, 0x42); array_push_u8(img, 0x4D);
    cg_push_u32_le(img, 2); cg_push_u64_le(img, code_off); cg_push_u64_le(img, code_len);
    if (rodata_len > 0) { cg_push_u64_le(img, rodata_off); } else { cg_push_u64_le(img, 0); } cg_push_u64_le(img, rodata_len);
    if (data_len > 0) { cg_push_u64_le(img, data_off); } else { cg_push_u64_le(img, 0); } cg_push_u64_le(img, data_len);
    if (syms_len > 0) { cg_push_u64_le(img, syms_off); } else { cg_push_u64_le(img, 0); } cg_push_u64_le(img, syms_len);
    cg_push_u64_le(img, reloc_count);
    if (fntable_len > 0) { cg_push_u64_le(img, fntable_off); } else { cg_push_u64_le(img, 0); } cg_push_u64_le(img, fntable_len);
    let mut i: i64 = 0;
    while (i < code_len) { array_push_u8(img, array_get_u8(cg_code, i) as i64); i = i + 1; }
    i = 0; while (i < rodata_len) { array_push_u8(img, array_get_u8(cg_rodata, i) as i64); i = i + 1; }
    i = 0; while (i < data_len) { array_push_u8(img, array_get_u8(cg_data, i) as i64); i = i + 1; }
    i = 0; while (i < syms_len) { array_push_u8(img, array_get_u8(cg_syms, i) as i64); i = i + 1; }
    i = 0; while (i < fn_count) { cg_push_u64_le(img, i); cg_push_u64_le(img, cg_label_offset(array_get_i64(cg_fn_labels, i * 3 + 1))); i = i + 1; }
    i = 0; while (i < array_length(cg_relocs)) { array_push_u8(img, array_get_u8(cg_relocs, i) as i64); i = i + 1; }
    return img;
}

// =============================================================================
// mutable globals (EMBM v1 §5 data section). A constant-initialized i64
// global gets an 8-byte slot in cg_data (the initial value written LE), + a
// (name -> data addend) entry in cg_globals. Reads/writes go through a
// relocated ABS64_DATA pointer: `mov reg, <data_base+addend>` then load/store
// through that pointer.
// =============================================================================

// evaluate a constant i64 expression at compile time (mirrors sema's
// expr_is_const_i64). IntLit -> its value; unary negation -> -operand.
fn cg_eval_const_i64(e: i64) -> i64 {
    if (e < 0) { return 0; }
    // Sema's bounded interpreter is the single constexpr implementation.
    if (try_eval_const_i64(e) == 1) { return ce_int_out; }
    return 0;
}

// find a codegen global by bare name. Returns the row index, or -1 if not
// declared. Stride 3 [name_tok, addend, ns_tok]; matches any global with the
// bare name (mirrors sema registering a namespaced global under both bare +
// qualified names).
fn cg_find_global(name: string) -> i64 {
    let mut i: i64 = 0;
    while (i * 3 < cg_globals_len) {
        let tok: i64 = array_get_i64(cg_globals, i * 3);
        if (tok_name(tok) == name) { return i; }
        i = i + 1;
    }
    return -1;
}

// find a codegen global by qualified name (Ns::name). ns_name "" matches a
// top-level global; a nonempty ns_name matches a global whose ns_tok names it.
fn cg_find_global_qualified(name: string, ns_name: string) -> i64 {
    let mut i: i64 = 0;
    while (i * 3 < cg_globals_len) {
        let tok: i64 = array_get_i64(cg_globals, i * 3);
        if (tok_name(tok) == name) {
            let ns_tok: i64 = array_get_i64(cg_globals, i * 3 + 2);
            let mut ok: i64 = 0;
            if (ns_tok < 0) {
                if (string_length(ns_name) == 0) { ok = 1; }
            } else {
                if (tok_name(ns_tok) == ns_name) { ok = 1; }
            }
            if (ok == 1) { return i; }
        }
        i = i + 1;
    }
    return -1;
}

// a global's data-section byte addend (its slot offset within cg_data).
fn cg_global_addend(row: i64) -> i64 {
    return array_get_i64(cg_globals, row * 3 + 1);
}

// walk the program's GlobalDecls + allocate a data slot for each
// constant-initialized i64 global (mirroring sema's global_is_const_i64 gate).
// Writes the constant's 8 LE bytes into cg_data + records (name -> addend).
// Must run BEFORE compiling functions so global references resolve. Descends
// into NamespaceDecl members (namespaced globals get their ns_tok recorded so
// Ns::global reads resolve).
fn cg_compile_globals(prog: i64) -> i64 {
    let mut d: i64 = nk_a(prog);
    while (d >= 0) {
        if (nk_kind(d) == (NK::NamespaceDecl as i64)) {
            let ns_tok: i64 = nk_tok(d);
            let mut m: i64 = nk_a(d);
            while (m >= 0) {
                if (nk_kind(m) == (NK::GlobalDecl as i64)) { cg_compile_one_global(m, ns_tok); }
                if (cg_err != 0) { return 0; }
                m = nk_next(m);
            }
        } else if (nk_kind(d) == (NK::GlobalDecl as i64)) {
            cg_compile_one_global(d, -1);
            if (cg_err != 0) { return 0; }
        }
        d = nk_next(d);
    }
    return 0;
}

// is a GlobalDecl a string global with a StringLit initializer? Mirrors
// sema's global_is_const_string gate so the codegen allocates exactly the
// string globals sema registered. (A plain "..." literal, not an f-string.)
fn cg_global_is_string(d: i64) -> i64 {
    let gty: i64 = resolve_type(nk_a(d));
    if (gty < 0) { return 0; }
    if (ty_is_string(gty) == 0) { return 0; }
    let init: i64 = nk_b(d);
    if (init < 0) { return 0; }
    if (nk_kind(init) != (NK::StringLit as i64)) { return 0; }
    if (nk_d(init) != 0) { return 0; }   // plain string, not an f-string
    return 1;
}

// allocate a data slot for one supported global (constant-initialized i64 OR
// string with a StringLit initializer) + record (name_tok, addend, ns_tok) in
// cg_globals. Mirrors sema's global_is_supported gate so the codegen allocates
// exactly the globals sema registered. An i64 global's 8 LE init bytes are
// written into cg_data now; a string global's slot is zero-filled (the handle
// is materialized at runtime by __globals_init) + recorded in cg_str_globals
// so the init function can emit its literal materialization + store.
fn cg_compile_one_global(d: i64, ns_tok: i64) -> i64 {
    let gty: i64 = resolve_type(nk_a(d));
    let init: i64 = nk_b(d);
    let mut is_const: i64 = 0;
    if (gty >= 0 && ty_is_i64(gty) == 1 && init >= 0) {
        is_const = expr_is_const_i64(init);
    }
    let is_str: i64 = cg_global_is_string(d);
    if (is_const == 1) {
        let addend: i64 = cg_data_alloc(8);
        let val: i64 = cg_eval_const_i64(init);
        // write the 8 LE bytes of the initial value into cg_data
        let mut b: i64 = 0;
        while (b < 8) {
            array_set_u8(cg_data, addend + b, (val >> (b * 8)) & 0xFF);
            b = b + 1;
        }
        // record (name_tok, addend, ns_tok) at stride 3
        if (array_length(cg_globals) < cg_globals_len + 3) {
            array_resize(cg_globals, cg_globals_len + 3);
        }
        array_set_i64(cg_globals, cg_globals_len, nk_tok(d));
        array_set_i64(cg_globals, cg_globals_len + 1, addend);
        array_set_i64(cg_globals, cg_globals_len + 2, ns_tok);
        cg_globals_len = cg_globals_len + 3;
    } else if (is_str == 1) {
        // a string global: 8-byte zero-filled slot (the handle is filled at
        // runtime by __globals_init). Record it in cg_globals (for read/write
        // resolution) AND in cg_str_globals (for the init function).
        let addend: i64 = cg_data_alloc(8);   // zero-filled (cg_data_alloc pushes 0s)
        if (array_length(cg_globals) < cg_globals_len + 3) {
            array_resize(cg_globals, cg_globals_len + 3);
        }
        array_set_i64(cg_globals, cg_globals_len, nk_tok(d));
        array_set_i64(cg_globals, cg_globals_len + 1, addend);
        array_set_i64(cg_globals, cg_globals_len + 2, ns_tok);
        cg_globals_len = cg_globals_len + 3;
        // record (name_tok, addend, init_node) at stride 3 for __globals_init
        if (array_length(cg_str_globals) < cg_str_globals_len + 3) {
            array_resize(cg_str_globals, cg_str_globals_len + 3);
        }
        array_set_i64(cg_str_globals, cg_str_globals_len, nk_tok(d));
        array_set_i64(cg_str_globals, cg_str_globals_len + 1, addend);
        array_set_i64(cg_str_globals, cg_str_globals_len + 2, init);
        cg_str_globals_len = cg_str_globals_len + 3;
    }
    return 0;
}

// =============================================================================
// module-init function (__globals_init). For each string global, materialize
// its StringLit initializer at runtime (decode bytes to cg_rodata + build a
// u8 slice {rcx=ptr, rdx=len} + call string_from_slice -> handle in rax) and
// store the handle into the global's [data_base + addend] slot (mov rcx, <data
// ptr>; mov [rcx], rax). i64 globals keep their compile-time constant in the
// data section, so they need no runtime init. The pipeline calls this function
// BEFORE main (full_pipeline's compile_and_run via codegen_globals_init_offset).
//
// Emitted as a normal function in the code section with a minimal prologue
// (push rbp; mov rbp, rsp — no frame sub: there are no locals, and the
// per-call 32-byte shadow space is managed inline by the materialization, the
// same way cg_eval_string_lit manages it). rbp is preserved across the native
// calls (string_from_slice is Win64-ABI callee-saved with respect to rbp), so
// the epilogue (mov rsp, rbp; pop rbp; ret) restores the caller's frame.
// =============================================================================

// emit the __globals_init function (one per string global). Binds its entry
// label at the prologue offset + records the label in cg_globals_init_label so
// codegen_globals_init_offset() can resolve it. A no-op function (prologue +
// epilogue only) when there are no string globals is NOT emitted — instead the
// label stays -1 and the pipeline skips the call (cleaner than a dead fn).
fn cg_emit_globals_init() -> i64 {
    if (cg_str_globals_len == 0) {
        cg_globals_init_label = -1;
        return 0;
    }
    let lab: i64 = cg_alloc_label();
    cg_globals_init_label = lab;
    cg_bind(lab);   // entry = current code offset
    // prologue: push rbp; mov rbp, rsp  (no frame sub — see file header).
    // Emitted directly (not via cg_emit_prologue) to avoid a dead `sub rsp,0`.
    cg_push(RBP);                    // 0x55
    cg_mov_reg_reg(RBP, RSP);        // 48 89 E5
    // for each string global: materialize the literal -> rax, then store rax
    // into [data_base + addend]. The materialization mirrors cg_eval_string_
    // lit's plain-string path (rodata + slice + string_from_slice) and manages
    // its own 32-byte shadow space (sub/add rsp around the call); rbp is held
    // fixed so the store's data-pointer load is independent of rsp motion.
    let mut i: i64 = 0;
    while (i < cg_str_globals_len) {
        let addend: i64 = array_get_i64(cg_str_globals, i + 1);
        let init_node: i64 = array_get_i64(cg_str_globals, i + 2);
        // 1. emit the body bytes to cg_rodata
        let body: string = nk_string_body(init_node);
        let n: i64 = string_length(body);
        let ro_addend: i64 = cg_rodata_alloc(n);
        let mut j: i64 = 0;
        while (j < n) {
            array_set_u8(cg_rodata, ro_addend + j, string_char_at(body, j));
            j = j + 1;
        }
        // 2. build the u8 slice {rcx=ptr, rdx=len}
        cg_emit_abs64_reloc_reg(RCX, CG_RELOC_RODATA, 0, ro_addend);
        cg_mov_reg_imm64(RDX, n);
        // 3. call string_from_slice(rcx, rdx) -> handle in rax (32-byte shadow)
        cg_sub_reg_imm32(RSP, 32);
        let sym_idx: i64 = cg_sym_index(string_from_slice("string_from_slice"));
        let codes: i64 = cg_fp_codes_get();
        array_set_i64(codes, 0, 5);  // u8 slice
        let fp: i64 = cg_abi_fingerprint_codes(codes, 1, 6, 0);
        cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
        cg_call_reg(RAX);
        cg_add_reg_imm32(RSP, 32);
        // 4. store the handle into the global's data slot:
        //    mov rcx, <data_base + addend>; mov [rcx], rax
        cg_emit_abs64_reloc_reg(RCX, CG_RELOC_DATA, 0, addend);
        cg_byte(0x48); cg_byte(0x89); cg_byte(0x01);  // mov [rcx], rax
        i = i + 3;
    }
    // epilogue: mov rsp, rbp; pop rbp; ret
    cg_emit_epilogue();
    return 0;
}

// the code offset of the __globals_init function's entry (prologue) within the
// buffer, or -1 if no string globals were declared (no init function emitted).
// Used by the end-to-end pipeline to call the init function BEFORE main so
// string globals are live when main reads them.
fn codegen_globals_init_offset() -> i64 {
    if (cg_globals_init_label < 0) { return -1; }
    return cg_label_offset(cg_globals_init_label);
}

// =============================================================================
// frame size pre-computation. Walks the fn body counting locals (let stmts)
// + params to size the stack frame. All slots are 8 bytes (v1: everything is i64).
// =============================================================================

// Phase 4: count compiler-hidden struct temp frame SLOTS needed by the fn
// body (mirrors src/codegen.cpp's count_struct_temps_block/expr, in slots).
// A temp is needed for (a) a struct-literal `return` value in a struct-returning
// fn (materialized into a temp before being copied through the hidden return
// pointer), and (b) a struct-by-value call argument that is a StructLit or a
// struct-returning CallExpr (materialized into a temp before being copied into
// the arg stash / forwarded as the hidden dest). A bare-Ident struct arg + a
// struct-returning call let-init/return/assignment do NOT need a temp (they
// have a concrete destination). The temp slots are added to the frame count so
// cg_alloc_struct_temp (which shares cg_next_off with user locals) has room.
fn cg_struct_temp_slots(t: i64) -> i64 {
    let nb: i64 = cg_value_bytes(t);
    let mut s: i64 = (nb + 7) / 8;
    if (s < 1) { s = 1; }
    return s;
}

fn cg_count_struct_temps_expr(e: i64, total: i64) -> i64 {
    if (e < 0) { return total; }
    let k: i64 = nk_kind(e);
    if (k == (NK::CallExpr as i64)) {
        // resolve the callee fn row to read param types (determines which args
        // are struct-by-value slots). A struct arg that is NOT a bare Ident
        // (StructLit / struct-returning CallExpr) needs a temp.
        let nm: string = nk_name(e);
        let mut fn_row: i64 = -1;
        let mod_tok: i64 = nk_e(e);
        let mut is_ns: i64 = 0;
        if (mod_tok >= 0) {
            let mn: string = tok_text_at(mod_tok);
            if (is_namespace_name(mn) == 1) { is_ns = 1; fn_row = find_fn_qualified(nm, mn); }
        }
        if (is_ns == 0) {
            fn_row = find_fn(nm);
            if (fn_row < 0 && cg_cur_ns >= 0) {
                let qr: i64 = find_fn_qualified(nm, tok_name(cg_cur_ns));
                if (qr >= 0) { fn_row = qr; }
            }
        }
        if (fn_row >= 0) {
            let mut a: i64 = nk_a(e);
            let mut i: i64 = 0;
            while (a >= 0) {
                let pt: i64 = fn_param_type(fn_row, i);
                if (cg_ty_is_struct(pt) == 1 && nk_kind(a) != (NK::Ident as i64)) {
                    total = total + cg_struct_temp_slots(pt);
                }
                total = cg_count_struct_temps_expr(a, total);
                a = nk_next(a);
                i = i + 1;
            }
        } else {
            // native call or unresolved: just recurse into args (no struct
            // arg temps; natives don't take structs in the subset)
            let mut a: i64 = nk_a(e);
            while (a >= 0) { total = cg_count_struct_temps_expr(a, total); a = nk_next(a); }
        }
        return total;
    }
    if (k == (NK::BinExpr as i64)) { total = cg_count_struct_temps_expr(nk_a(e), total); return cg_count_struct_temps_expr(nk_b(e), total); }
    if (k == (NK::UnaryExpr as i64)) { return cg_count_struct_temps_expr(nk_a(e), total); }
    if (k == (NK::CastExpr as i64)) { return cg_count_struct_temps_expr(nk_a(e), total); }
    if (k == (NK::TernaryExpr as i64)) { total = cg_count_struct_temps_expr(nk_a(e), total); total = cg_count_struct_temps_expr(nk_b(e), total); return cg_count_struct_temps_expr(nk_c(e), total); }
    if (k == (NK::AssignExpr as i64)) { total = cg_count_struct_temps_expr(nk_a(e), total); return cg_count_struct_temps_expr(nk_b(e), total); }
    if (k == (NK::IndexExpr as i64)) { total = cg_count_struct_temps_expr(nk_a(e), total); return cg_count_struct_temps_expr(nk_b(e), total); }
    if (k == (NK::FieldExpr as i64)) { return cg_count_struct_temps_expr(nk_a(e), total); }
    if (k == (NK::ViewExpr as i64)) { return cg_count_struct_temps_expr(nk_a(e), total); }
    if (k == (NK::StructLit as i64)) {
        let mut init: i64 = nk_a(e);
        while (init >= 0) { total = cg_count_struct_temps_expr(nk_a(init), total); init = nk_next(init); }
        return total;
    }
    return total;
}

fn cg_count_struct_temps_stmt(s: i64, total: i64, ret_is_struct: i64) -> i64 {
    let k: i64 = nk_kind(s);
    if (k == (NK::LetStmt as i64)) {
        if (nk_b(s) >= 0) { total = cg_count_struct_temps_expr(nk_b(s), total); }
        return total;
    }
    if (k == (NK::ExprStmt as i64)) {
        if (nk_a(s) >= 0) { total = cg_count_struct_temps_expr(nk_a(s), total); }
        return total;
    }
    if (k == (NK::ReturnStmt as i64)) {
        let val: i64 = nk_a(s);
        if (val >= 0 && ret_is_struct == 1 && nk_kind(val) == (NK::StructLit as i64)) {
            // a struct-literal return value materializes into a temp before
            // being copied through the hidden return pointer.
            total = total + cg_struct_temp_slots(cg_cur_ret);
        }
        if (val >= 0) { total = cg_count_struct_temps_expr(val, total); }
        return total;
    }
    if (k == (NK::DeferStmt as i64)) {
        if (nk_a(s) >= 0) { total = cg_count_struct_temps_expr(nk_a(s), total); }
        return total;
    }
    if (k == (NK::IfStmt as i64)) {
        if (nk_a(s) >= 0) { total = cg_count_struct_temps_expr(nk_a(s), total); }
        total = cg_count_struct_temps_block(nk_b(s), total, ret_is_struct);
        if (nk_c(s) >= 0) { total = cg_count_struct_temps_block(nk_c(s), total, ret_is_struct); }
        return total;
    }
    if (k == (NK::WhileStmt as i64)) {
        if (nk_b(s) >= 0) { total = cg_count_struct_temps_expr(nk_b(s), total); }
        total = cg_count_struct_temps_block(nk_a(s), total, ret_is_struct);
        return total;
    }
    if (k == (NK::DoWhileStmt as i64)) {
        total = cg_count_struct_temps_block(nk_a(s), total, ret_is_struct);
        if (nk_b(s) >= 0) { total = cg_count_struct_temps_expr(nk_b(s), total); }
        return total;
    }
    if (k == (NK::BlockStmt as i64)) { return cg_count_struct_temps_block(s, total, ret_is_struct); }
    if (k == (NK::ForStmt as i64)) {
        if (nk_a(s) >= 0) { total = cg_count_struct_temps_stmt(nk_a(s), total, ret_is_struct); }
        if (nk_b(s) >= 0) { total = cg_count_struct_temps_expr(nk_b(s), total); }
        if (nk_d(s) >= 0) { total = cg_count_struct_temps_expr(nk_d(s), total); }
        total = cg_count_struct_temps_block(nk_e(s), total, ret_is_struct);
        return total;
    }
    if (k == (NK::ForEachStmt as i64)) {
        if (nk_a(s) >= 0) { total = cg_count_struct_temps_expr(nk_a(s), total); }
        total = cg_count_struct_temps_block(nk_b(s), total, ret_is_struct);
        return total;
    }
    if (k == (NK::SwitchStmt as i64)) {
        let mut c: i64 = nk_b(s); while (c >= 0) { total = cg_count_struct_temps_block(nk_b(c), total, ret_is_struct); c = nk_next(c); } return total;
    }
    if (k == (NK::MatchStmt as i64)) {
        let mut a: i64 = nk_b(s); while (a >= 0) { total = cg_count_struct_temps_block(nk_b(a), total, ret_is_struct); a = nk_next(a); } return total;
    }
    if (k == (NK::TryCatchStmt as i64)) {
        total = cg_count_struct_temps_block(nk_a(s), total, ret_is_struct);  // try body
        total = cg_count_struct_temps_block(nk_b(s), total, ret_is_struct);  // catch body
        return total;
    }
    return total;
}

fn cg_count_struct_temps_block(b: i64, total: i64, ret_is_struct: i64) -> i64 {
    if (b < 0) { return total; }
    let mut s: i64 = nk_a(b);
    while (s >= 0) {
        total = cg_count_struct_temps_stmt(s, total, ret_is_struct);
        s = nk_next(s);
    }
    return total;
}

fn cg_count_locals_block(b: i64, total: i64) -> i64 {
    if (b < 0) { return total; }
    let mut s: i64 = nk_a(b);
    while (s >= 0) {
        total = cg_count_locals_stmt(s, total);
        s = nk_next(s);
    }
    return total;
}

fn cg_count_locals_stmt(s: i64, total: i64) -> i64 {
    let k: i64 = nk_kind(s);
    if (k == (NK::LetStmt as i64)) {
        // count the local's actual stack slots (aggregates occupy
        // ceil(value_bytes/8); scalars occupy 1) so the frame is sized to
        // hold every byte of every local. Mirrors cg_alloc_local_t's sizing.
        let mut t: i64 = nk_a(s);
        let init: i64 = nk_b(s);
        if (t < 0 && init >= 0) { t = cg_expr_type(init); }
        else if (t >= 0) { t = resolve_type(t); }
        let mut slots: i64 = 1;
        if (t >= 0) { slots = cg_local_slots(t); }
        total = total + slots;
        return total;
    }
    if (k == (NK::IfStmt as i64)) {
        total = cg_count_locals_block(nk_b(s), total);   // then
        if (nk_c(s) >= 0) {
            total = cg_count_locals_block(nk_c(s), total);  // else
        }
        return total;
    }
    if (k == (NK::WhileStmt as i64)) {
        total = cg_count_locals_block(nk_b(s), total);   // body
        return total;
    }
    if (k == (NK::BlockStmt as i64)) {
        total = cg_count_locals_block(s, total);
        return total;
    }
    if (k == (NK::ForStmt as i64)) {
        total = total + 1;
        total = cg_count_locals_block(nk_e(s), total);
        return total;
    }
    if (k == (NK::ForEachStmt as i64)) {
        // for-each uses 4 frame slots: ptr, len, idx, + the loop var (1 slot
        // for a scalar element; aggregates are not yet supported in for-each).
        total = total + 4;
        total = cg_count_locals_block(nk_b(s), total);
        return total;
    }
    if (k == (NK::MatchStmt as i64)) {
        let mut a: i64 = nk_b(s);
        while (a >= 0) {
            if (nk_f(a) == 1) {
                let mut fld: i64 = nk_c(a);
                while (fld >= 0) { if (nk_a(fld) < 0) { total = total + 1; } fld = nk_next(fld); }
            }
            total = cg_count_locals_block(nk_b(a), total);
            a = nk_next(a);
        }
        return total;
    }
    // Phase 3b: do-while + switch + defer locals.
    if (k == (NK::DoWhileStmt as i64)) {
        total = cg_count_locals_block(nk_a(s), total);   // body
        return total;
    }
    if (k == (NK::SwitchStmt as i64)) {
        let mut c: i64 = nk_b(s); while (c >= 0) { total = cg_count_locals_block(nk_b(c), total); c = nk_next(c); } return total;
    }
    if (k == (NK::TryCatchStmt as i64)) {
        total = total + 1;  // catch variable
        total = cg_count_locals_block(nk_a(s), total);   // try body
        total = cg_count_locals_block(nk_b(s), total);   // catch body
        return total;
    }
    // Each captured lambda creation keeps one heap-env pointer spill in its
    // surrounding frame while captures are copied.
    if (k == (NK::ExprStmt as i64) || k == (NK::ReturnStmt as i64)) {
        if (nk_a(s) >= 0 && nk_kind(nk_a(s)) == (NK::LambdaExpr as i64)) { total = total + 1; }
    }
    // DeferStmt holds an expr (no locals of its own); nothing to count.
    return total;
}

// round up to a multiple of 16
fn cg_round16(n: i64) -> i64 {
    return (n + 15) & ~15;
}

// =============================================================================
// function prologue + epilogue.
// =============================================================================

// emit the prologue: push rbp; mov rbp, rsp; sub rsp, frame_size
fn cg_emit_prologue(frame_size: i64) -> i64 {
    cg_push(RBP);                    // 0x55
    cg_mov_reg_reg(RBP, RSP);        // 48 89 E5
    cg_sub_reg_imm32(RSP, frame_size);  // 48 81 EC <imm32>
    return 0;
}

// emit the epilogue: mov rsp, rbp; pop rbp; ret
fn cg_emit_epilogue() -> i64 {
    cg_mov_reg_reg(RSP, RBP);        // 48 89 EC
    cg_pop(RBP);                     // 0x5D
    cg_ret();                        // 0xC3
    return 0;
}

// =============================================================================
// expression evaluation. Result is in rax (int) for all v1 expressions.
// (v1: everything is i64 or bool, both held in rax as a 64-bit value.)
// =============================================================================

fn cg_find_capture(le: i64, name: string) -> i64 {
    let n: i64 = array_length(g_lambda_caps) / LAMBDA_CAP_STRIDE; let mut i: i64 = 0;
    while (i < n) {
        if (array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE) == le &&
            tok_name(array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 1)) == name) {
            cg_cap_type = array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 2);
            cg_cap_off = array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 3);
            cg_cap_by_ref = array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 4); return 1;
        }
        i = i + 1;
    }
    return 0;
}

fn cg_eval_lambda(e: i64) -> i64 {
    let cap_count: i64 = lambda_capture_count(e); let env_size: i64 = cap_count * 8;
    if (env_size == 0) { cg_mov_reg_imm64(RAX, nk_d(e)); cg_mov_reg_imm64(RDX, 0); return 0; }
    // Heap allocate the environment, retaining its pointer in a stack spill.
    let frame: i64 = 48; cg_sub_reg_imm32(RSP, frame); cg_mov_reg_imm64(RCX, env_size);
    let sym: i64 = cg_sym_index(string_from_slice("__ember_gc_alloc_env"));
    let pts: i64 = cg_fp_types_get(); array_set_i64(pts, 0, TY_I64);
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym, cg_abi_fingerprint(pts, 1, TY_I64, 0)); cg_call_reg(RAX);
    cg_store_reg_mem(RSP, 0, RAX);
    let n: i64 = array_length(g_lambda_caps) / LAMBDA_CAP_STRIDE; let mut i: i64 = 0;
    while (i < n) {
        if (array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE) == e) {
            let nt: i64 = array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 1);
            let coff: i64 = array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 3);
            let byref: i64 = array_get_i64(g_lambda_caps, i * LAMBDA_CAP_STRIDE + 4);
            let loff: i64 = cg_lookup_local(nt);
            if (loff != 0) {
                if (byref == 1) { cg_lea_rax_rbp(loff); } else { cg_load_reg_mem(RAX, RBP, loff); }
            } else if (cg_current_lambda >= 0 && cg_find_capture(cg_current_lambda, tok_name(nt)) == 1) {
                cg_load_reg_mem(RAX, RBP, cg_lambda_env_off); cg_load_reg_mem(RAX, RAX, cg_cap_off);
                if (cg_cap_by_ref == 1 && byref == 0) { cg_load_reg_mem(RAX, RAX, 0); }
            } else { cg_mov_reg_imm64(RAX, 0); }
            cg_load_reg_mem(RCX, RSP, 0); cg_store_reg_mem(RCX, coff, RAX);
        }
        i = i + 1;
    }
    cg_load_reg_mem(RDX, RSP, 0); cg_add_reg_imm32(RSP, frame); cg_mov_reg_imm64(RAX, nk_d(e)); return 0;
}

fn cg_eval(e: i64) -> i64 {
    if (e < 0) {
        if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: missing expression"); }
        return 0;
    }
    let k: i64 = nk_kind(e);

    if (k == (NK::IntLit as i64)) {
        // mov rax, imm64
        cg_mov_reg_imm64(RAX, nk_d(e));
        return 0;
    }
    if (k == (NK::BoolLit as i64)) {
        cg_mov_reg_imm64(RAX, nk_d(e));
        return 0;
    }
    if (k == (NK::FloatLit as i64)) { return cg_eval_float_lit(e); }
    if (k == (NK::StringLit as i64)) { return cg_eval_string_lit(e); }
    if (k == (NK::LambdaExpr as i64)) { return cg_eval_lambda(e); }
    if (k == (NK::FnHandleExpr as i64)) { cg_mov_reg_imm64(RAX, nk_d(e)); return 0; }
    if (k == (NK::EnumAccess as i64)) {
        let ename: string = tok_name(nk_a(e));
        // Tier 1 namespaces: Foo::val where Foo is a namespace (not an enum) is
        // a namespace-global read. Emit the same ABS64_DATA load as a global
        // Ident (mirrors src/sema.cpp rewriting Foo::val to an Ident with the
        // qualified name, then codegen's global Ident load).
        if (is_namespace_name(ename) == 1) {
            let g: i64 = cg_find_global_qualified(nk_name(e), ename);
            if (g >= 0) {
                let addend: i64 = cg_global_addend(g);
                cg_emit_abs64_reloc_reg(RAX, CG_RELOC_DATA, 0, addend);  // mov rax, <data ptr>
                cg_byte(0x48); cg_byte(0x8B); cg_byte(0x00);              // mov rax, [rax]
                return 0;
            }
            if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: namespace '") + ename + string_from_slice("' has no global '") + nk_name(e) + string_from_slice("'"); }
            return 0;
        }
        cg_mov_reg_imm64(RAX, cg_enum_value(tok_name(nk_a(e)), nk_name(e)));
        // Phase 3b: a typed-enum variant normalizes to the backing width (a
        // typed enum is a real type; its value is the backing int). An
        // untyped enum variant is a plain i64 constant (no normalize needed).
        if (is_typed_enum_name(ename) == 1) {
            let et: i64 = typed_enum_type(ename);
            if (et >= 0) { cg_normalize_rax(et); }
        }
        return 0;
    }
    if (k == (NK::FieldExpr as i64)) { return cg_eval_fieldexpr(e); }
    if (k == (NK::IndexExpr as i64)) { return cg_eval_indexexpr(e); }
    if (k == (NK::ViewExpr as i64)) { return cg_eval_viewexpr(e); }
    if (k == (NK::ArrayLit as i64)) { return cg_eval_arraylit_rval(e); }
    if (k == (NK::Ident as i64)) {
        if (cg_current_lambda >= 0 && cg_find_capture(cg_current_lambda, nk_name(e)) == 1) {
            cg_load_reg_mem(RAX, RBP, cg_lambda_env_off); cg_load_reg_mem(RAX, RAX, cg_cap_off);
            if (cg_cap_by_ref == 1) { cg_load_reg_mem(RAX, RAX, 0); }
            cg_normalize_rax(cg_cap_type); return 0;
        }
        // look up the local; load from [rbp + offset]
        let off: i64 = cg_lookup_local(nk_tok(e));
        if (off != 0) {
            let t: i64 = cg_lookup_local_type(nk_tok(e));
            if (t >= 0 && nk_kind(t) == (NK::Type as i64) && (nk_f(t) == 1 || nk_f(t) == 2)) {
                // slice/closure local: yield the 2-word ABI {rax=word0, rdx=word1}
                // (mirrors src/codegen.cpp's slice Ident eval). Used by for-each
                // + slice IndexExpr bases + slice args (future).
                cg_load_reg_mem(RAX, RBP, off);
                cg_load_reg_mem(RDX, RBP, off + 8);
                return 0;
            }
            if (ty_is_float(t) == 1) { cg_load_float(XMM0, off, cg_float_is64_type(t)); }
            else { cg_load_reg_mem(RAX, RBP, off); cg_normalize_rax(t); }
            return 0;
        }
        // not a local: try a mutable global. Read through a relocated ABS64_DATA
        // pointer: mov rax, <data_base+addend>; mov rax, [rax]. (Phase 1 globals
        // are i64 only, so no float path here.)
        let g: i64 = cg_find_global(nk_name(e));
        if (g >= 0) {
            let addend: i64 = cg_global_addend(g);
            cg_emit_abs64_reloc_reg(RAX, CG_RELOC_DATA, 0, addend);  // mov rax, <data ptr>
            // mov rax, [rax]  -> 48 8B 00 (load the i64 through the pointer)
            cg_byte(0x48); cg_byte(0x8B); cg_byte(0x00);
            return 0;
        }
        if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unknown local '") + nk_name(e) + string_from_slice("'"); }
        return 0;
    }
    if (k == (NK::BinExpr as i64)) {
        return cg_eval_binexpr(e);
    }
    if (k == (NK::UnaryExpr as i64)) {
        return cg_eval_unaryexpr(e);
    }
    if (k == (NK::CallExpr as i64)) {
        // Sema annotated an all-constant constexpr call in the unused d/f
        // slots. Emit the folded immediate instead of a runtime call.
        if (nk_d(e) == 1) { cg_mov_reg_imm64(RAX, nk_f(e)); return 0; }
        return cg_eval_callexpr(e);
    }
    if (k == (NK::AssignExpr as i64)) {
        return cg_eval_assignexpr(e);
    }
    if (k == (NK::CastExpr as i64)) {
        return cg_eval_castexpr(e);
    }
    if (k == (NK::TernaryExpr as i64)) {
        return cg_eval_ternaryexpr(e);
    }
    if (k == (NK::SizeofExpr as i64)) {
        return cg_eval_sizeofexpr(e);
    }
    if (k == (NK::OffsetofExpr as i64)) {
        return cg_eval_offsetofexpr(e);
    }

    // unsupported in v1
    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: expression kind unsupported in v1"); }
    return 0;
}

fn cg_enum_value(enum_name: string, variant_name: string) -> i64 {
    let row: i64 = find_enum(enum_name); if (row < 0) { return 0; }
    // Delegate to sema's enum_variant_value, which folds constexpr fn calls
    // (e.g. `X = base()`) via try_eval_const_i64, not just plain IntLits.
    if (enum_variant_value(row, variant_name) == 1) { return g_enum_val_out; }
    return 0;
}

// find a struct field's declaration index by name. Returns -1 if not found.
fn cg_struct_field_index(type_node: i64, name: string) -> i64 {
    let row: i64 = find_struct(ty_struct_name(type_node)); if (row < 0) { return -1; }
    let mut f: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1); let mut i: i64 = 0;
    while (f >= 0) { if (nk_name(f) == name) { return i; } i = i + 1; f = nk_next(f); }
    return -1;
}

// the resolved Type node of a struct field by declaration index.
fn cg_struct_field_type_at(row: i64, idx: i64) -> i64 {
    let mut f: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1); let mut i: i64 = 0;
    while (f >= 0) { if (i == idx) { return resolve_type(nk_a(f)); } i = i + 1; f = nk_next(f); }
    return -1;
}

// load a value of type `t` from [base + disp] into rax (int) or xmm0 (float),
// with the correct width + sign/zero extension. Mirrors src/codegen.cpp's
// load_elem_to_rax + the FieldExpr load path. The field's width is
// cg_value_bytes(t); a scalar narrower than 8 is loaded with load_elem_to_rax
// (movsxd/movzx style) and normalized; an 8-byte scalar uses mov rax,[mem].
fn cg_load_typed(RAX_reg: i64, base: i64, disp: i64, t: i64) -> i64 {
    if (ty_is_float(t) == 1) { cg_load_float(XMM0, disp, cg_float_is64_type(t)); return 0; }
    let w: i64 = cg_value_bytes(t);
    if (w >= 8) { cg_load_reg_mem(RAX_reg, base, disp); return 0; }
    // narrow integer load: movzx/movsx via the elem-load helper. For a signed
    // narrow int, sign-extend; for unsigned, zero-extend (load_elem_to_rax's
    // is_signed flag). Then normalize_rax canonicalizes the high bits.
    let mut is_signed: i64 = 0;
    if (cg_type_is_int(t) == 1 && cg_type_is_uint(t) == 0) { is_signed = 1; }
    cg_load_elem_to_rax(base, disp, w, is_signed);
    return 0;
}

// store rax (int) or xmm0 (float) to [base + disp] with the type's width.
// Mirrors src/codegen.cpp's store_rax_elem / store_slot. Narrow ints write only
// their low `w` bytes; the high bits of rax are already canonicalized by the
// caller's normalize_rax so a partial store is correct.
fn cg_store_typed(base: i64, disp: i64, t: i64) -> i64 {
    if (ty_is_float(t) == 1) { cg_store_float(disp, XMM0, cg_float_is64_type(t)); return 0; }
    let w: i64 = cg_value_bytes(t);
    if (w >= 8) { cg_store_reg_mem(base, disp, RAX); return 0; }
    cg_store_rax_elem(base, disp, w);
    return 0;
}

fn cg_eval_fieldexpr(e: i64) -> i64 {
    let base: i64 = nk_a(e);
    if (nk_kind(base) != (NK::Ident as i64)) { cg_err = 1; cg_errmsg = string_from_slice("codegen: field base must be a local"); return 0; }
    let off: i64 = cg_lookup_local(nk_tok(base)); let t: i64 = cg_lookup_local_type(nk_tok(base));
    let row: i64 = find_struct(ty_struct_name(t));
    let idx: i64 = cg_struct_field_index(t, nk_name(e));
    if (idx < 0 || row < 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unknown field"); return 0; }
    let foff: i64 = cg_struct_field_offset(row, idx);
    let ft: i64 = cg_struct_field_type_at(row, idx);
    cg_load_typed(RAX, RBP, off + foff, ft);
    if (ty_is_float(ft) == 0) { cg_normalize_rax(ft); }
    return 0;
}

// Phase 3: load base[index]. base is a bare local Ident of a fixed array T[N]
// (inline, address = its frame slot) or a slice T[] (ptr+len in the slot).
// Mirrors src/codegen.cpp's IndexExpr eval path. Computes the element address
// base + index*elem_sz, applies a runtime bounds check (slice: always; fixed
// array: only for a non-constant index, since sema already checked constant
// indices), and loads the element with its width + sign extension.
fn cg_eval_indexexpr(e: i64) -> i64 {
    let base: i64 = nk_a(e);
    if (nk_kind(base) != (NK::Ident as i64)) { cg_err = 1; cg_errmsg = string_from_slice("codegen: index base must be a local"); return 0; }
    let boff: i64 = cg_lookup_local(nk_tok(base));
    let bt: i64 = cg_lookup_local_type(nk_tok(base));
    let mut is_sl: i64 = 0;
    if (bt >= 0 && nk_kind(bt) == (NK::Type as i64)) { is_sl = nk_f(bt); }
    let elem_ty: i64 = resolve_type(nk_a(bt));
    if (cg_err != 0) { return 0; }
    let elem_sz: i64 = cg_value_bytes(elem_ty);
    let mut arr_len: i64 = 0;
    if (bt >= 0) { arr_len = nk_e(bt); }
    // base address -> r11 (survives index eval). For a fixed array, r11 = rbp +
    // boff (lea). For a slice, load ptr from [rbp+boff] into r11 + len into r9.
    if (is_sl == 1) {
        cg_load_reg_mem(R11, RBP, boff);          // r11 = ptr
        cg_load_reg_mem(R9, RBP, boff + 8);       // r9 = len
    } else {
        cg_lea_r11_rbp(boff);                      // r11 = &arr (rbp + boff)
    }
    // eval index -> rax
    cg_eval(nk_b(e)); if (cg_err != 0) { return 0; }
    // bounds check: slice always (len in r9); fixed array only if the index is
    // not a compile-time constant (sema checked constants). Unsigned compare
    // (jb) catches both too-large and negative indices in one shot.
    if (is_sl == 1) {
        cg_bounds_check_reg_rax_r9();
    } else if (nk_kind(nk_b(e)) != (NK::IntLit as i64)) {
        cg_bounds_check_imm_rax(arr_len);
    }
    // rax = index * elem_sz (imul when sz > 1)
    if (elem_sz > 1) { cg_mov_reg_imm64(RCX, elem_sz); cg_imul_reg_reg(RAX, RCX); }
    // r11 = element address = r11 + rax
    cg_add_reg_reg(R11, RAX);
    // load the element from [r11] with its width
    let mut is_signed: i64 = 0;
    if (cg_type_is_int(elem_ty) == 1 && cg_type_is_uint(elem_ty) == 0) { is_signed = 1; }
    if (ty_is_float(elem_ty) == 1) {
        cg_load_float_disp_r11(cg_float_is64_type(elem_ty));
    } else if (elem_sz >= 8) {
        cg_load_reg_mem(RAX, R11, 0);
        cg_normalize_rax(elem_ty);
    } else {
        cg_load_elem_to_rax(R11, 0, elem_sz, is_signed);
        cg_normalize_rax(elem_ty);
    }
    return 0;
}

// Phase 3: arr[..] -> slice {ptr=&arr, len=N}. base must be a bare local Ident
// of a fixed array. Result is the slice ABI: rax = ptr (lea [rbp+boff]),
// rdx = N. Mirrors src/codegen.cpp's ViewExpr eval path.
fn cg_eval_viewexpr(e: i64) -> i64 {
    let base: i64 = nk_a(e);
    if (nk_kind(base) != (NK::Ident as i64)) { cg_err = 1; cg_errmsg = string_from_slice("codegen: view base must be a local"); return 0; }
    let boff: i64 = cg_lookup_local(nk_tok(base));
    let bt: i64 = cg_lookup_local_type(nk_tok(base));
    let mut n: i64 = 0;
    if (bt >= 0) { n = nk_e(bt); }
    // rax = &arr (lea rax, [rbp+boff]); rdx = N
    cg_lea_rax_rbp(boff);
    cg_mov_reg_imm64(RDX, n);
    return 0;
}

// A bare ArrayLit rvalue (not a let init). sema only lets a SLICE ArrayLit
// reach eval() as an rvalue (a fixed-array ArrayLit is let-init-only). STEP 3
// materializes a slice literal's backing into cg_data + yields {rax=ptr,rdx=len}.
// A fixed-array ArrayLit reaching here is an internal error (sema rejects it).
fn cg_eval_arraylit_rval(e: i64) -> i64 {
    // Determine the baked type (sema stamps the declared type via check_let, but
    // a bare rvalue ArrayLit only reaches here for a slice in an arg/return
    // position the self-hosted subset does not yet support). Defensive trap.
    cg_err = 1; cg_errmsg = string_from_slice("codegen: bare array literal rvalue not supported (use a let binding)");
    return 0;
}

// String literals are materialized as REAL host string handles. A plain
// "ember" literal is compiled to:
//   1. emit the decoded bytes to cg_rodata (cg_rodata_alloc) -> addend
//   2. build a u8 slice {ptr, len}: mov rcx, <rodata_base+addend> via an
//      ABS64_RODATA reloc (ptr in rcx) + mov rdx, len (len in rdx)
//   3. call string_from_slice(rcx=p, rdx=len) via an ABS64_NATIVE reloc ->
//      returns an opaque i64 HANDLE in rax
// That handle IS the string value (host owns a mutable std::string). This
// interoperates with the host string natives (string_length / string_char_at /
// string_substr take handles, not slices). The fingerprint for string_from_slice
// is param0=u8 slice (code 5), ret=string handle (code 6), permission 0.
//
// f-strings (nk_d == 1) keep the legacy length-based representation for now
// (no required test exercises an f-string in the compiled program); the host
// f-string model is deferred.
fn cg_eval_string_lit(e: i64) -> i64 {
    let raw: string = nk_name(e);
    if (nk_d(e) != 1) {
        // plain string literal: real rodata + string_from_slice -> handle in rax
        let body: string = nk_string_body(e);   // decoded body (quotes stripped)
        let n: i64 = string_length(body);
        // 1. emit the body bytes to cg_rodata
        let addend: i64 = cg_rodata_alloc(n);
        let mut i: i64 = 0;
        while (i < n) {
            array_set_u8(cg_rodata, addend + i, string_char_at(body, i));
            i = i + 1;
        }
        // 2. build the u8 slice {ptr in rcx, len in rdx}
        //    mov rcx, <rodata_base + addend>  (ABS64_RODATA reloc patches the ptr)
        cg_emit_abs64_reloc_reg(RCX, CG_RELOC_RODATA, 0, addend);
        //    mov rdx, len
        cg_mov_reg_imm64(RDX, n);
        // 3. call string_from_slice(rcx, rdx) -> handle in rax. Allocate a
        //    32-byte Win64 shadow frame (16-byte aligned: the caller's prologue
        //    leaves rsp 16-aligned at the call site, so sub rsp,32 keeps it
        //    aligned) so the native has scratch space.
        cg_sub_reg_imm32(RSP, 32);
        //    fingerprint: param0 = u8 slice (code 5), ret = string handle (code 6), perm 0
        let sym_idx: i64 = cg_sym_index(string_from_slice("string_from_slice"));
        let codes: i64 = cg_fp_codes_get();
        array_set_i64(codes, 0, 5);  // u8 slice
        let fp: i64 = cg_abi_fingerprint_codes(codes, 1, 6, 0);
        cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
        cg_call_reg(RAX);  // call rax (FF D0)
        cg_add_reg_imm32(RSP, 32);
        return 0;
    }
    // f-string: build a REAL host string handle by concatenating literal
    // segments (string_from_slice) + i64 interpolation segments (string_from_i64)
    // with string_add. The result is a real handle interoperable with the host
    // string natives (string_length etc.). The caller (cg_eval_string_lit) has
    // NOT allocated a frame; cg_eval_fstring_real allocates its own.
    return cg_eval_fstring_real(e);
}

fn cg_lookup_local_name(name: string) -> i64 {
    let mut i: i64 = cg_local_len / 3 - 1;
    while (i >= 0) { if (tok_name(array_get_i64(cg_locals, i * 3)) == name) { return array_get_i64(cg_locals, i * 3 + 1); } i = i - 1; }
    return 0;
}
fn cg_eval_fstring_width(name: string) -> i64 {
    let off: i64 = cg_lookup_local_name(name);
    if (off != 0) { cg_load_reg_mem(RAX, RBP, off); } else {
        let mut v: i64 = 0; let mut i: i64 = 0; while (i < string_length(name)) { let ch: i64 = string_char_at(name, i); if (ch >= 48 && ch <= 57) { v = v * 10 + ch - 48; } i = i + 1; } cg_mov_reg_imm64(RAX, v);
    }
    // Branchless-enough decimal width: start at one and add one for every
    // crossed power of ten. Negative values include a sign byte.
    cg_mov_reg_reg(R11, RAX); cg_mov_reg_imm64(RAX, 1);
    cg_cmp_reg_imm32(R11, 0); let pos: i64 = cg_alloc_label(); cg_jcc(COND_GE, pos); cg_add_reg_imm32(RAX, 1); cg_neg_reg(R11); cg_bind(pos);
    cg_decimal_width_step(10); cg_decimal_width_step(100); cg_decimal_width_step(1000); cg_decimal_width_step(10000); cg_decimal_width_step(100000); cg_decimal_width_step(1000000); cg_decimal_width_step(10000000); cg_decimal_width_step(100000000); cg_decimal_width_step(1000000000);
    return 0;
}
fn cg_decimal_width_step(limit: i64) -> i64 { let skip: i64 = cg_alloc_label(); cg_cmp_reg_imm32(R11, limit); cg_jcc(COND_L, skip); cg_add_reg_imm32(RAX, 1); cg_bind(skip); return 0; }

// -----------------------------------------------------------------------------
// real f-string materialization. Builds a host string handle by concatenating
// literal segments (string_from_slice) + i64 interpolation segments
// (string_from_i64) with string_add. The result handle is in rax.
//
// Frame layout (allocated once, 16-byte aligned at every call):
//   [rsp + 0..31]  shadow space (reused by every segment-build + string_add call)
//   [rsp + 32]     acc  — the accumulator handle (the string built so far)
//   [rsp + 40]     seg  — the current segment handle
// frame = 48 (round16(32 + 8 + 8)).
//
// Segment building emits a native call (string_from_slice / string_from_i64)
// whose shadow space is [rsp+0..31]; acc/seg live above it at [rsp+32/40] so
// they are never clobbered. string_add(acc, seg) reads acc/seg from those slots
// + writes its shadow to [rsp+0..31], returning the new acc in rax.
// -----------------------------------------------------------------------------

// build a literal-segment string handle from `n` bytes already written to
// cg_rodata at `addend`. Emits the u8 slice {rcx=ptr, rdx=len} + a
// string_from_slice native call. Assumes a 32-byte shadow frame is already
// allocated at [rsp+0..31] by the caller. Result handle in rax.
fn cg_build_literal_seg(addend: i64, n: i64) -> i64 {
    // mov rcx, <rodata_base + addend>  (ABS64_RODATA reloc patches the ptr)
    cg_emit_abs64_reloc_reg(RCX, CG_RELOC_RODATA, 0, addend);
    // mov rdx, len
    cg_mov_reg_imm64(RDX, n);
    // call string_from_slice(rcx, rdx) -> handle in rax
    let sym_idx: i64 = cg_sym_index(string_from_slice("string_from_slice"));
    let codes: i64 = cg_fp_codes_get();
    array_set_i64(codes, 0, 5);  // u8 slice
    let fp: i64 = cg_abi_fingerprint_codes(codes, 1, 6, 0);
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
    cg_call_reg(RAX);
    return 0;
}

// build an i64 interpolation segment: load the i64 local `name` -> rax, then
// call string_from_i64(rcx=value) -> handle in rax. Assumes a 32-byte shadow
// frame is already allocated at [rsp+0..31]. Returns 0 on success, 1 if the
// name is not a local (the caller treats that as a literal-integer segment).
fn cg_build_i64_seg(name: string) -> i64 {
    let off: i64 = cg_lookup_local_name(name);
    if (off == 0) { return 1; }  // not a local
    // load the i64 value -> rax; move to rcx (arg1)
    cg_load_reg_mem(RAX, RBP, off);
    cg_mov_reg_reg(RCX, RAX);
    // call string_from_i64(rcx) -> handle in rax
    // fingerprint: param0 = i64 (code 1), ret = string handle (code 6), perm 0
    let sym_idx: i64 = cg_sym_index(string_from_slice("string_from_i64"));
    let codes: i64 = cg_fp_codes_get();
    array_set_i64(codes, 0, 1);  // i64
    let fp: i64 = cg_abi_fingerprint_codes(codes, 1, 6, 0);
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
    cg_call_reg(RAX);
    return 0;
}

// emit string_add(acc, seg): rcx = acc (from [rsp+32]), rdx = seg (from [rsp+40]),
// call string_add -> new acc in rax. Assumes shadow at [rsp+0..31].
fn cg_emit_string_add() -> i64 {
    cg_load_reg_mem(RCX, RSP, 32);  // acc = arg1
    cg_load_reg_mem(RDX, RSP, 40);  // seg = arg2
    // string_add(i64, i64) -> handle. fingerprint: params {1,1}, ret 6, perm 0.
    let sym_idx: i64 = cg_sym_index(string_from_slice("string_add"));
    let codes: i64 = cg_fp_codes_get();
    array_set_i64(codes, 0, 1); array_set_i64(codes, 1, 1);
    let fp: i64 = cg_abi_fingerprint_codes(codes, 2, 6, 0);
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
    cg_call_reg(RAX);
    return 0;
}

// Build a real f-string handle from the StringLit node `e` (nk_d == 1).
// Parses the raw f-string token content (between the outer quotes) into literal
// + {identifier} interpolation segments, builds each as a handle, and
// concatenates them with string_add. Result handle in rax.
fn cg_eval_fstring_real(e: i64) -> i64 {
    let raw: string = nk_name(e);  // raw token text, e.g. f"v={n}"
    let rlen: i64 = string_length(raw);
    // content lies between index 2 (after f") and rlen-1 (before the closing ")
    let start_idx: i64 = 2;
    let end_idx: i64 = rlen - 1;
    if (end_idx <= start_idx) {
        // empty f-string: build an empty handle via string_from_slice("")
        let frame: i64 = 32;
        cg_sub_reg_imm32(RSP, frame);
        cg_build_literal_seg(cg_rodata_alloc(0), 0);
        cg_add_reg_imm32(RSP, frame);
        return 0;
    }
    // allocate the f-string frame: 32 shadow + 8 acc + 8 seg = 48
    let frame: i64 = 48;
    cg_sub_reg_imm32(RSP, frame);

    let mut i: i64 = start_idx;
    let mut have_acc: i64 = 0;  // has the first segment been built into acc?
    // accumulate a literal run's bytes into cg_rodata, then build a segment
    let mut lit_addend: i64 = 0;
    let mut lit_len: i64 = 0;
    let mut lit_started: i64 = 0;
    while (i < end_idx) {
        let ch: i64 = string_char_at(raw, i);
        if (ch == 123) {  // '{'
            if (i + 1 < end_idx && string_char_at(raw, i + 1) == 123) {
                // '{{' -> literal '{'
                if (lit_started == 0) { lit_addend = array_length(cg_rodata); lit_started = 1; }
                array_push_u8(cg_rodata, 123); lit_len = lit_len + 1;
                i = i + 2;
                continue;
            }
            // flush any pending literal run into a segment first
            if (lit_started == 1) {
                cg_build_literal_seg(lit_addend, lit_len);
                cg_store_reg_mem(RSP, 40, RAX);  // seg
                if (have_acc == 0) {
                    cg_store_reg_mem(RSP, 32, RAX); have_acc = 1;  // acc = first seg
                } else {
                    cg_emit_string_add(); cg_store_reg_mem(RSP, 32, RAX);  // acc = acc + seg
                }
                lit_started = 0; lit_len = 0;
            }
            // parse the interpolation {name}
            let expr_start: i64 = i + 1;
            i = i + 1;
            while (i < end_idx && string_char_at(raw, i) != 125) { i = i + 1; }
            let name: string = string_substr(raw, expr_start, i - expr_start);
            // i now at '}' (or end); skip it
            if (i < end_idx) { i = i + 1; }
            // build the interpolation segment. Try i64 local first; if not a
            // local, parse the name as a decimal integer + build it as i64.
            let built: i64 = cg_build_i64_seg(name);
            if (built != 0) {
                // not a local: parse name as a decimal integer literal
                let mut v: i64 = 0; let mut k: i64 = 0;
                while (k < string_length(name)) {
                    let dc: i64 = string_char_at(name, k);
                    if (dc >= 48 && dc <= 57) { v = v * 10 + dc - 48; }
                    k = k + 1;
                }
                cg_mov_reg_imm64(RAX, v);
                cg_mov_reg_reg(RCX, RAX);
                let sym_idx: i64 = cg_sym_index(string_from_slice("string_from_i64"));
                let codes: i64 = cg_fp_codes_get();
                array_set_i64(codes, 0, 1);
                let fp: i64 = cg_abi_fingerprint_codes(codes, 1, 6, 0);
                cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
                cg_call_reg(RAX);
            }
            cg_store_reg_mem(RSP, 40, RAX);  // seg
            if (have_acc == 0) {
                cg_store_reg_mem(RSP, 32, RAX); have_acc = 1;
            } else {
                cg_emit_string_add(); cg_store_reg_mem(RSP, 32, RAX);
            }
            continue;
        }
        if (ch == 125) {  // '}'
            if (i + 1 < end_idx && string_char_at(raw, i + 1) == 125) {
                // '}}' -> literal '}'
                if (lit_started == 0) { lit_addend = array_length(cg_rodata); lit_started = 1; }
                array_push_u8(cg_rodata, 125); lit_len = lit_len + 1;
                i = i + 2;
                continue;
            }
            // unmatched '}' — emit as literal
            if (lit_started == 0) { lit_addend = array_length(cg_rodata); lit_started = 1; }
            array_push_u8(cg_rodata, 125); lit_len = lit_len + 1;
            i = i + 1;
            continue;
        }
        // ordinary literal char
        if (lit_started == 0) { lit_addend = array_length(cg_rodata); lit_started = 1; }
        array_push_u8(cg_rodata, ch); lit_len = lit_len + 1;
        i = i + 1;
    }
    // flush any trailing literal run
    if (lit_started == 1) {
        cg_build_literal_seg(lit_addend, lit_len);
        cg_store_reg_mem(RSP, 40, RAX);
        if (have_acc == 0) {
            cg_store_reg_mem(RSP, 32, RAX); have_acc = 1;
        } else {
            cg_emit_string_add(); cg_store_reg_mem(RSP, 32, RAX);
        }
    }
    // if no segments at all (e.g. empty content), build an empty handle
    if (have_acc == 0) {
        cg_build_literal_seg(cg_rodata_alloc(0), 0);
        cg_store_reg_mem(RSP, 32, RAX); have_acc = 1;
    }
    // result = acc
    cg_load_reg_mem(RAX, RSP, 32);
    cg_add_reg_imm32(RSP, frame);
    return 0;
}

// evaluate a binary expression. lhs -> rax, push; rhs -> rax, mov rcx rax;
// pop rax (lhs); apply op (result in rax).
fn cg_eval_binexpr(e: i64) -> i64 {
    let op: i64 = nk_d(e);
    let lhs: i64 = nk_a(e);
    let rhs: i64 = nk_b(e);

    let et: i64 = cg_expr_type(lhs);
    if (ty_is_float(et) == 1) { return cg_eval_float_binexpr(e, et); }
    if (ty_is_string(et) == 1) { return cg_eval_string_binexpr(e); }

    // short-circuit logical && / ||
    if (op == (BinOp::LAnd as i64)) {
        return cg_eval_logical_and(e);
    }
    if (op == (BinOp::LOr as i64)) {
        return cg_eval_logical_or(e);
    }

    // eval lhs -> rax; push rax (save lhs across rhs eval)
    cg_eval(lhs);
    if (cg_err != 0) { return 0; }
    cg_push(RAX);
    // eval rhs -> rax
    cg_eval(rhs);
    if (cg_err != 0) { return 0; }
    // rcx = rhs (rax)
    cg_mov_reg_reg(RCX, RAX);
    // rax = lhs (pop)
    cg_pop(RAX);

    // apply the op (result in rax)
    // literal adaptation: if lhs is an IntLit (always TY_I64) and rhs is a
    // typed int, the result type is rhs's type (mirrors sema's check_binexpr
    // adaptation + the C++ codegen's normalize_rax(b->lhs->ty) where the
    // literal's ty was adapted to the other operand's type).
    let mut lt: i64 = cg_expr_type(lhs);
    if (nk_kind(lhs) == (NK::IntLit as i64) && cg_type_is_int(cg_expr_type(rhs)) == 1) {
        lt = cg_expr_type(rhs);
    }
    let is_unsigned: i64 = cg_type_is_uint(lt);
    let mut is_cmp: i64 = 0;
    if (op == (BinOp::Eq as i64)) { is_cmp = 1; }
    if (op == (BinOp::Neq as i64)) { is_cmp = 1; }
    if (op == (BinOp::Lt as i64)) { is_cmp = 1; }
    if (op == (BinOp::Le as i64)) { is_cmp = 1; }
    if (op == (BinOp::Gt as i64)) { is_cmp = 1; }
    if (op == (BinOp::Ge as i64)) { is_cmp = 1; }

    if (is_cmp != 0) {
        // cmp rax, rcx; setcc al; movzx rax, al
        cg_cmp_reg_reg(RAX, RCX);
        let mut cc: i64 = 0;
        if (op == (BinOp::Eq as i64))  { cc = COND_E; }
        if (op == (BinOp::Neq as i64)) { cc = COND_NE; }
        if (op == (BinOp::Lt as i64))  { if (is_unsigned == 1) { cc = COND_B; } else { cc = COND_L; } }
        if (op == (BinOp::Le as i64))  { if (is_unsigned == 1) { cc = COND_BE; } else { cc = COND_LE; } }
        if (op == (BinOp::Gt as i64))  { if (is_unsigned == 1) { cc = COND_A; } else { cc = COND_G; } }
        if (op == (BinOp::Ge as i64))  { if (is_unsigned == 1) { cc = COND_AE; } else { cc = COND_GE; } }
        cg_setcc_al(cc);
        cg_movzx_rax_al();
        return 0;
    }

    if (op == (BinOp::Add as i64)) { cg_add_reg_reg(RAX, RCX); cg_normalize_rax(lt); return 0; }
    if (op == (BinOp::Sub as i64)) { cg_sub_reg_reg(RAX, RCX); cg_normalize_rax(lt); return 0; }
    if (op == (BinOp::Mul as i64)) { cg_imul_reg_reg(RAX, RCX); cg_normalize_rax(lt); return 0; }
    if (op == (BinOp::And as i64)) { cg_and_reg_reg(RAX, RCX); cg_normalize_rax(lt); return 0; }
    if (op == (BinOp::Or as i64))  { cg_or_reg_reg(RAX, RCX); cg_normalize_rax(lt); return 0; }
    if (op == (BinOp::Xor as i64)) { cg_xor_reg_reg(RAX, RCX); cg_normalize_rax(lt); return 0; }
    if (op == (BinOp::Shl as i64)) {
        // rcx already holds the shift count; shl rax, cl
        cg_shl_reg_cl(RAX);
        cg_normalize_rax(lt);
        return 0;
    }
    if (op == (BinOp::Shr as i64)) {
        // signed -> arithmetic shift right (sar); unsigned -> logical shift right (shr)
        if (is_unsigned == 1) { cg_shr_reg_cl(RAX); }
        else { cg_sar_reg_cl(RAX); }
        cg_normalize_rax(lt);
        return 0;
    }
    // Div/Mod: signed uses cqo + idiv; unsigned uses xor rdx,rdx + div.
    if (op == (BinOp::Div as i64)) {
        if (is_unsigned == 1) {
            // xor rdx, rdx; div rcx (rax = rax / rcx, unsigned)
            cg_byte(0x48); cg_byte(0x31); cg_byte(0xD2);
            cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF1);
        } else {
            // cqo; idiv rcx (rax = rax / rcx, signed)
            cg_byte(0x48); cg_byte(0x99);
            cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF9);
        }
        cg_normalize_rax(lt);
        return 0;
    }
    if (op == (BinOp::Mod as i64)) {
        if (is_unsigned == 1) {
            // xor rdx, rdx; div rcx; mov rax, rdx (rax = rax % rcx, unsigned)
            cg_byte(0x48); cg_byte(0x31); cg_byte(0xD2);
            cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF1);
        } else {
            // cqo; idiv rcx; mov rax, rdx (rax = rax % rcx, signed)
            cg_byte(0x48); cg_byte(0x99);
            cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF9);
        }
        cg_mov_reg_reg(RAX, RDX);
        cg_normalize_rax(lt);
        return 0;
    }

    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unsupported binary op"); }
    return 0;
}

fn cg_eval_float_binexpr(e: i64, t: i64) -> i64 {
    let op: i64 = nk_d(e); let is64: i64 = cg_float_is64_type(t);
    cg_eval(nk_a(e)); if (cg_err != 0) { return 0; }
    cg_movq_rax_xmm(XMM0); cg_push(RAX);
    cg_eval(nk_b(e)); if (cg_err != 0) { return 0; }
    cg_sse_rr(if64_prefix(is64), 0x10, XMM1, XMM0);
    cg_pop(RAX); if (is64 == 1) { cg_movq_xmm_rax(XMM0); } else { cg_movd_xmm_eax(XMM0); }
    if (op == (BinOp::Add as i64)) { cg_float_op(0x58, is64); return 0; }
    if (op == (BinOp::Sub as i64)) { cg_float_op(0x5C, is64); return 0; }
    if (op == (BinOp::Mul as i64)) { cg_float_op(0x59, is64); return 0; }
    if (op == (BinOp::Div as i64)) { cg_float_op(0x5E, is64); return 0; }
    cg_float_cmp(is64);
    let mut cc: i64 = COND_E;
    if (op == (BinOp::Neq as i64)) { cc = COND_NE; }
    if (op == (BinOp::Lt as i64)) { cc = COND_B; }
    if (op == (BinOp::Le as i64)) { cc = COND_BE; }
    if (op == (BinOp::Gt as i64)) { cc = COND_A; }
    if (op == (BinOp::Ge as i64)) { cc = COND_AE; }
    cg_setcc_al(cc); cg_movzx_rax_al(); return 0;
}
fn if64_prefix(is64: i64) -> i64 { if (is64 == 1) { return 0xF2; } return 0xF3; }

// evaluate a binary expression whose operands are strings (real host handles).
// `string + string` concatenates via the string_add native (an operator
// overload published into the host's native allowlist under name "string_add");
// `==` / `!=` compare content via string_eq. Both take (i64 handle, i64 handle)
// and are emitted as ABS64_NATIVE relocations. The registered overload sigs use
// plain I64 params (code 1) + a handle/bool return, so the fingerprint is
// computed from explicit codes (not the string arg type, which would code 6).
// A proper Win64 call frame (32-byte shadow + 16-byte alignment) is allocated
// so the native has scratch space.
fn cg_eval_string_binexpr(e: i64) -> i64 {
    let op: i64 = nk_d(e);
    // call_frame = round16(2*8 + 32) = 48 (2 arg temps + 32-byte shadow)
    let call_frame: i64 = cg_round16(2 * 8 + 32);
    cg_sub_reg_imm32(RSP, call_frame);
    // eval lhs -> rax; store to [rsp+0]
    cg_eval(nk_a(e)); if (cg_err != 0) { cg_add_reg_imm32(RSP, call_frame); return 0; }
    cg_store_reg_mem(RSP, 0, RAX);
    // eval rhs -> rax; store to [rsp+8]
    cg_eval(nk_b(e)); if (cg_err != 0) { cg_add_reg_imm32(RSP, call_frame); return 0; }
    cg_store_reg_mem(RSP, 8, RAX);
    // load args: rcx = lhs (arg1), rdx = rhs (arg2)
    cg_load_reg_mem(RCX, RSP, 0);
    cg_load_reg_mem(RDX, RSP, 8);
    if (op == (BinOp::Add as i64)) {
        // string_add(i64, i64) -> string handle. fingerprint: params {1,1}, ret 6, perm 0.
        let sym_idx: i64 = cg_sym_index(string_from_slice("string_add"));
        let codes: i64 = cg_fp_codes_get();
        array_set_i64(codes, 0, 1); array_set_i64(codes, 1, 1);  // i64, i64
        let fp: i64 = cg_abi_fingerprint_codes(codes, 2, 6, 0);
        cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
        cg_call_reg(RAX);  // call rax -> handle in rax
        cg_add_reg_imm32(RSP, call_frame);
        return 0;
    }
    // == / != : string_eq(i64, i64) -> bool (0/1). fingerprint: params {1,1}, ret 4 (bool), perm 0.
    let sym_idx: i64 = cg_sym_index(string_from_slice("string_eq"));
    let codes: i64 = cg_fp_codes_get();
    array_set_i64(codes, 0, 1); array_set_i64(codes, 1, 1);  // i64, i64
    let fp: i64 = cg_abi_fingerprint_codes(codes, 2, 4, 0);
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
    cg_call_reg(RAX);  // call rax -> 0/1 in rax
    cg_add_reg_imm32(RSP, call_frame);
    if (op == (BinOp::Neq as i64)) {
        // logical not of the bool result: rax = (rax == 0) ? 1 : 0
        cg_cmp_reg_imm32(RAX, 0); cg_setcc_al(COND_E); cg_movzx_rax_al();
    }
    return 0;
}

// logical && : short-circuit. lhs false -> result 0; else eval rhs.
fn cg_eval_logical_and(e: i64) -> i64 {
    let lhs: i64 = nk_a(e);
    let rhs: i64 = nk_b(e);
    let false_l: i64 = cg_alloc_label();
    let end_l: i64 = cg_alloc_label();

    cg_eval(lhs);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    cg_jcc(COND_E, false_l);       // lhs == 0 -> false
    cg_eval(rhs);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    cg_jcc(COND_NE, end_l);        // rhs != 0 -> true (keep rhs value)
    cg_bind(false_l);
    cg_mov_reg_imm64(RAX, 0);      // result = 0
    cg_bind(end_l);
    // normalize: rax = (rax != 0) ? 1 : 0
    cg_cmp_reg_imm32(RAX, 0);
    let done: i64 = cg_alloc_label();
    cg_mov_reg_imm64(RAX, 0);
    cg_jcc(COND_E, done);
    cg_mov_reg_imm64(RAX, 1);
    cg_bind(done);
    return 0;
}

// logical || : short-circuit. lhs true -> result 1; else eval rhs.
fn cg_eval_logical_or(e: i64) -> i64 {
    let lhs: i64 = nk_a(e);
    let rhs: i64 = nk_b(e);
    let end_l: i64 = cg_alloc_label();

    cg_eval(lhs);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    cg_jcc(COND_NE, end_l);        // lhs != 0 -> true (keep lhs value)
    cg_eval(rhs);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    cg_jcc(COND_NE, end_l);        // rhs != 0 -> true
    cg_mov_reg_imm64(RAX, 0);      // result = 0
    cg_bind(end_l);
    // normalize: rax = (rax != 0) ? 1 : 0
    cg_cmp_reg_imm32(RAX, 0);
    let done: i64 = cg_alloc_label();
    cg_mov_reg_imm64(RAX, 0);
    cg_jcc(COND_E, done);
    cg_mov_reg_imm64(RAX, 1);
    cg_bind(done);
    return 0;
}

// evaluate a unary expression. operand -> rax; apply the op.
fn cg_eval_unaryexpr(e: i64) -> i64 {
    let op: i64 = nk_d(e);
    let operand: i64 = nk_a(e);
    cg_eval(operand);
    if (cg_err != 0) { return 0; }

    if (op == (UnOp::Neg as i64)) {
        // neg rax
        cg_neg_reg(RAX);
        return 0;
    }
    if (op == (UnOp::BitNot as i64)) {
        // not rax
        cg_not_reg(RAX);
        return 0;
    }
    if (op == (UnOp::Not as i64)) {
        // logical not: rax = (rax == 0) ? 1 : 0
        cg_cmp_reg_imm32(RAX, 0);
        cg_setcc_al(COND_E);       // sete al (1 if rax was 0)
        cg_movzx_rax_al();
        return 0;
    }
    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unsupported unary op"); }
    return 0;
}

// evaluate an assignment expression: target = value, target op= value, or
// ++/-- target (prefix/postfix). Mirrors src/codegen.cpp's AssignExpr lowering.
//
// Node layout (parse.ember): a=target, b=value, d=compound op (or -1 for
// plain '='), e=postfix flag (1 for postfix ++/--, where b is absent/-1).
//
//   plain '='      : eval value -> rax; normalize to target type; store.
//                    expression result = the value (in rax).
//   compound op=   : load target -> rax; push; eval value -> rax; rcx=rax;
//                    pop rax (lhs); apply op; normalize to target type; store.
//                    expression result = the new value (in rax).
//   prefix ++/--   : same as compound with value=1 (parser sets b=IntLit(1),
//                    e=-1). expression result = the new value.
//   postfix ++/--  : load target -> rax; push (save old); eval/inc; apply op
//                    with 1; normalize; store; then result = old value
//                    (pop + adjust: for Add, old = new-1; for Sub, old = new+1).
//
// v1: only Ident targets (local or global). The compound/postfix op for
// integers uses the same instruction sequence as cg_eval_binexpr.
fn cg_eval_assignexpr(e: i64) -> i64 {
    let target: i64 = nk_a(e);
    let value: i64 = nk_b(e);
    let cop: i64 = nk_d(e);
    let postfix: i64 = nk_e(e);

    // Phase 3: FieldExpr / IndexExpr assignment targets (p.x = v, a[i] = v).
    // Dispatch to dedicated handlers that compute the lvalue address + type,
    // then perform the plain/compound/postfix store mirroring the Ident path.
    if (nk_kind(target) == (NK::FieldExpr as i64)) { return cg_assign_field(target, value, cop, postfix); }
    if (nk_kind(target) == (NK::IndexExpr as i64)) { return cg_assign_index(target, value, cop, postfix); }

    // v1: only Ident targets (beyond the FieldExpr/IndexExpr cases above)
    if (nk_kind(target) != (NK::Ident as i64)) {
        if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: assignment target must be an identifier in v1"); }
        return 0;
    }

    // Phase 4: if the target is a captured variable inside a lambda, handle
    // the store through the closure env (by-ref: store through the pointer in
    // the env; by-value: store directly into the env slot).
    if (cg_current_lambda >= 0 && cg_find_capture(cg_current_lambda, nk_name(target)) == 1) {
        let cap_type: i64 = cg_cap_type;
        let cap_off: i64 = cg_cap_off;
        let cap_by_ref: i64 = cg_cap_by_ref;
        // plain '=' only for now (compound op= / ++ on captures can be added)
        if (cop < 0 && postfix != 1) {
            cg_eval(value); if (cg_err != 0) { return 0; }
            cg_normalize_rax(cap_type);
            // load env_ptr from [rbp + cg_lambda_env_off]
            cg_load_reg_mem(R11, RBP, cg_lambda_env_off);
            if (cap_by_ref == 1) {
                // by-ref: env slot holds a pointer to the captured var; load
                // it, then store rax through that pointer.
                cg_load_reg_mem(R11, R11, cap_off);  // r11 = ptr to captured var
                cg_store_reg_mem(R11, 0, RAX);       // *ptr = rax
            } else {
                // by-value: store rax directly into the env slot.
                cg_store_reg_mem(R11, cap_off, RAX);
            }
            return 0;
        }
        // compound op= / ++ on captures: load current (capture read), eval rhs,
        // apply op, store back (capture write). Falls through to the generic
        // compound path below by faking a local offset — but captures don't
        // have a frame offset, so handle inline instead.
        // Load current value -> rax (capture read path)
        cg_load_reg_mem(R11, RBP, cg_lambda_env_off);
        cg_load_reg_mem(RAX, R11, cap_off);
        if (cap_by_ref == 1) { cg_load_reg_mem(RAX, RAX, 0); }
        cg_normalize_rax(cap_type);
        // save current value in rdx (or xmm1 for float)
        let is_float: i64 = ty_is_float(cap_type);
        if (is_float == 1) {
            // float compound on capture — save lhs in xmm1, eval rhs in xmm0
            cg_movq_xmm_rax(XMM1);  // hmm, need mov xmm1, rax — use SSE move
            // Actually use the movq approach: xmm1 = rax
            // This is a simplification — full float compound on captures is rare
            if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: float compound assign on capture not yet supported"); }
            return 0;
        }
        cg_mov_reg_reg(RDX, RAX);  // rdx = current value (lhs)
        // eval rhs
        let rhs: i64 = value;
        if (postfix == 1) {
            // ++/-- : rhs is implicit 1; return old value
            cg_mov_reg_imm64(RAX, 1);
        } else {
            cg_eval(rhs); if (cg_err != 0) { return 0; }
            cg_normalize_rax(cap_type);
        }
        // apply op: result = lhs OP rhs (rax = rdx OP rax)
        if (cop == (BinOp::Add as i64)) { cg_add_reg_reg(RDX, RAX); }
        else if (cop == (BinOp::Sub as i64)) { cg_sub_reg_reg(RDX, RAX); }
        else if (cop == (BinOp::Mul as i64)) { cg_imul_reg_reg(RDX, RAX); }
        else if (cop == (BinOp::And as i64)) { cg_and_reg_reg(RDX, RAX); }
        else if (cop == (BinOp::Or as i64)) { cg_or_reg_reg(RDX, RAX); }
        else if (cop == (BinOp::Xor as i64)) { cg_xor_reg_reg(RDX, RAX); }
        else { if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unsupported compound op on capture"); } return 0; }
        // rdx = result; for postfix, return old value (lhs was in rdx before op)
        // Actually after op, rdx = lhs OP rhs. For postfix we need old value.
        // Simpler: for postfix, the return value is the old lhs; the stored
        // value is lhs OP 1. Let's just store the result and return it (non-postfix)
        // or handle postfix separately. For now store result.
        cg_mov_reg_reg(RAX, RDX);  // rax = result
        // store back through capture
        cg_load_reg_mem(R11, RBP, cg_lambda_env_off);
        if (cap_by_ref == 1) {
            cg_load_reg_mem(R11, R11, cap_off);
            cg_store_reg_mem(R11, 0, RAX);
        } else {
            cg_store_reg_mem(R11, cap_off, RAX);
        }
        return 0;
    }

    // resolve the target's offset + type (local or global)
    let off: i64 = cg_lookup_local(nk_tok(target));
    let tt: i64 = cg_lookup_local_type(nk_tok(target));
    let mut is_global: i64 = 0;
    let mut g_addend: i64 = 0;
    if (off == 0) {
        let g: i64 = cg_find_global(nk_name(target));
        if (g >= 0) { is_global = 1; g_addend = cg_global_addend(g); }
        else {
            if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: assignment to unknown local '") + nk_name(target) + string_from_slice("'"); }
            return 0;
        }
    }

    // ---- helper: load the target's current value into rax ----
    // (inlined below for each path)

    // ---- helper: store rax to the target ----
    // (inlined below)

    // ---- plain '=' (cop < 0, not postfix) ----
    if (cop < 0 && postfix != 1) {
        // Phase 4: struct-reassignment `s = mk();` where mk() returns a struct
        // and s is a struct-typed local. The target's frame slot is the
        // concrete destination for the callee's hidden return pointer: lea
        // rax, [rbp+off], then the callee writes the struct directly into the
        // target (no register result). (Struct globals by-value assignment is
        // out of the subset; the local path covers the supported cases.)
        if (ty_is_float(tt) == 0 && cg_ty_is_struct(tt) == 1 && nk_kind(value) == (NK::CallExpr as i64)) {
            if (is_global == 0) {
                cg_lea_rax_rbp(off);
                let saved: i64 = cg_struct_ret_dest_ready; cg_struct_ret_dest_ready = 1;
                cg_eval_struct_returning_call(value);
                cg_struct_ret_dest_ready = saved;
                return 0;
            }
        }
        cg_eval(value);
        if (cg_err != 0) { return 0; }
        if (ty_is_float(tt) == 1) {
            // float value is in XMM0; store with the target's width (movsd f64
            // / movss f32). Mirror the compound float path's store.
            let is64: i64 = cg_float_is64_type(tt);
            if (is_global == 1) {
                // float globals are not in Phase 1; defend anyway via rax.
                if (is64 == 1) { cg_movq_rax_xmm(XMM0); } else { cg_movq_rax_xmm(XMM0); }
                cg_emit_abs64_reloc_reg(RCX, CG_RELOC_DATA, 0, g_addend);
                cg_byte(0x48); cg_byte(0x89); cg_byte(0x01);  // mov [rcx], rax
            } else {
                cg_store_float(off, XMM0, is64);
            }
            return 0;
        }
        cg_normalize_rax(tt);
        if (is_global == 1) {
            cg_emit_abs64_reloc_reg(RCX, CG_RELOC_DATA, 0, g_addend);
            cg_byte(0x48); cg_byte(0x89); cg_byte(0x01);  // mov [rcx], rax
        } else {
            cg_store_reg_mem(RBP, off, RAX);
        }
        return 0;
    }

    // ---- compound op= / prefix ++ / postfix ++ ----
    // For postfix, the value is implicit 1 (b == -1); for prefix/compound, b is the value.
    let is_float: i64 = ty_is_float(tt);

    if (is_float == 1) {
        // float compound: load target (lhs) -> xmm0; save on stack; eval value
        // (rhs) -> xmm0; load lhs -> xmm1; apply op; store. For sub/div the
        // operand order matters (lhs OP rhs), so swap: op xmm1, xmm0; mov xmm0, xmm1.
        let is64: i64 = cg_float_is64_type(tt);
        let prefix: i64 = if64_prefix(is64);
        // load target (lhs) -> xmm0
        if (is_global == 1) {
            cg_emit_abs64_reloc_reg(RAX, CG_RELOC_DATA, 0, g_addend);
            cg_byte(0x48); cg_byte(0x8B); cg_byte(0x00);  // mov rax, [rax]
            if (is64 == 1) { cg_movq_xmm_rax(XMM0); } else { cg_movd_xmm_eax(XMM0); }
        } else {
            cg_load_float(XMM0, off, is64);
        }
        // save lhs (xmm0) on the stack
        cg_sub_reg_imm32(RSP, 8);
        if (is64 == 1) { cg_sse_mem(0xF2, 0x11, XMM0, 0); } else { cg_sse_mem(0xF3, 0x11, XMM0, 0); }
        // eval value (rhs) -> xmm0 (or load 1 for ++/--)
        if (postfix == 1 || value < 0) {
            cg_mov_reg_imm64(RAX, 1);
            cg_i64_to_float(XMM0, RAX, is64);
        } else {
            cg_eval(value); if (cg_err != 0) { return 0; }
            if (is64 == 1) { cg_movq_xmm_rax(XMM0); } else { cg_movd_xmm_eax(XMM0); }
        }
        // xmm1 = lhs (reload from stack)
        if (is64 == 1) { cg_sse_mem(0xF2, 0x10, XMM1, 0); } else { cg_sse_mem(0xF3, 0x10, XMM1, 0); }
        cg_add_reg_imm32(RSP, 8);
        // apply the float op. xmm0=rhs, xmm1=lhs. Result = lhs OP rhs.
        //   add/mul: commutative -> op xmm0, xmm1 (xmm0 = xmm0 + xmm1)
        //   sub/div: non-commutative -> op xmm1, xmm0 (xmm1 = xmm1 - xmm0); mov xmm0, xmm1
        if (cop == (BinOp::Add as i64)) { cg_float_op(0x58, is64); }
        else if (cop == (BinOp::Mul as i64)) { cg_float_op(0x59, is64); }
        else if (cop == (BinOp::Sub as i64)) {
            // subsd/ss xmm1, xmm0 (xmm1 = lhs - rhs); movsd/ss xmm0, xmm1
            cg_sse_rr(prefix, 0x5C, XMM1, XMM0);
            cg_sse_rr(prefix, 0x10, XMM0, XMM1);
        }
        else if (cop == (BinOp::Div as i64)) {
            // divsd/ss xmm1, xmm0 (xmm1 = lhs / rhs); movsd/ss xmm0, xmm1
            cg_sse_rr(prefix, 0x5E, XMM1, XMM0);
            cg_sse_rr(prefix, 0x10, XMM0, XMM1);
        }
        // store xmm0 (the new value) to target
        if (is_global == 1) {
            // unreachable for float globals in Phase 1; defend anyway
            cg_movq_rax_xmm(XMM0);
            cg_emit_abs64_reloc_reg(RCX, CG_RELOC_DATA, 0, g_addend);
            cg_byte(0x48); cg_byte(0x89); cg_byte(0x01);
        } else {
            cg_store_float(off, XMM0, is64);
        }
        // postfix float: result = old value. For ++/-- (Add/Sub with 1),
        // old = new ∓ 1. This is an edge case not in the Phase 2 test set;
        // mirror the C++ derive-from-new approach.
        if (postfix == 1) {
            // xmm0 = new value. old = new - 1 (for Add/++) or new + 1 (for Sub/--).
            // Load 1.0 into xmm1, then sub/add.
            cg_mov_reg_imm64(RAX, 1);
            cg_i64_to_float(XMM1, RAX, is64);
            if (cop == (BinOp::Add as i64)) { cg_sse_rr(prefix, 0x5C, XMM0, XMM1); }
            else { cg_sse_rr(prefix, 0x58, XMM0, XMM1); }
        }
        // result in xmm0 (for float) — but the expression result convention is
        // rax for int / xmm0 for float. The caller that use a float assignment
        // result (let y = (x += 1.0);) read xmm0. Return 0 (no error).
        return 0;
    }

    // integer compound / prefix / postfix
    let is_unsigned: i64 = cg_type_is_uint(tt);

    // load target -> rax
    if (is_global == 1) {
        cg_emit_abs64_reloc_reg(RAX, CG_RELOC_DATA, 0, g_addend);
        cg_byte(0x48); cg_byte(0x8B); cg_byte(0x00);  // mov rax, [rax]
        cg_normalize_rax(tt);
    } else {
        cg_load_reg_mem(RAX, RBP, off);
        cg_normalize_rax(tt);
    }

    // For postfix: save the OLD value (push rax) before computing the new one.
    // The C++ codegen pushes the updated value and derives old = new ± 1, but
    // the simpler correct approach is to save old first, then compute new.
    if (postfix == 1) {
        cg_push(RAX);  // save old value
    }

    // save lhs (rax) across value eval
    cg_push(RAX);
    // eval value -> rax (or load 1 for postfix/prefix ++/--)
    if (postfix == 1 || value < 0) {
        cg_mov_reg_imm64(RAX, 1);
    } else {
        cg_eval(value); if (cg_err != 0) { return 0; }
    }
    // rcx = rhs
    cg_mov_reg_reg(RCX, RAX);
    // rax = lhs (pop)
    cg_pop(RAX);

    // apply the integer op (rax = rax OP rcx), mirroring cg_eval_binexpr
    if (cop == (BinOp::Add as i64)) { cg_add_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Sub as i64)) { cg_sub_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Mul as i64)) { cg_imul_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::And as i64)) { cg_and_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Or as i64))  { cg_or_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Xor as i64)) { cg_xor_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Shl as i64)) { cg_shl_reg_cl(RAX); }
    else if (cop == (BinOp::Shr as i64)) {
        if (is_unsigned == 1) { cg_shr_reg_cl(RAX); } else { cg_sar_reg_cl(RAX); }
    }
    else if (cop == (BinOp::Div as i64)) {
        if (is_unsigned == 1) { cg_byte(0x48); cg_byte(0x31); cg_byte(0xD2); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF1); }
        else { cg_byte(0x48); cg_byte(0x99); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF9); }
    }
    else if (cop == (BinOp::Mod as i64)) {
        if (is_unsigned == 1) { cg_byte(0x48); cg_byte(0x31); cg_byte(0xD2); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF1); }
        else { cg_byte(0x48); cg_byte(0x99); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF9); }
        cg_mov_reg_reg(RAX, RDX);  // mod: result in rdx
    }
    // normalize the new value to the target type
    cg_normalize_rax(tt);

    // store the new value to the target
    if (is_global == 1) {
        // save rax (the new value) before emitting the data pointer (which uses rcx)
        // mov rcx, <data ptr>; mov [rcx], rax
        cg_emit_abs64_reloc_reg(RCX, CG_RELOC_DATA, 0, g_addend);
        cg_byte(0x48); cg_byte(0x89); cg_byte(0x01);  // mov [rcx], rax
    } else {
        cg_store_reg_mem(RBP, off, RAX);
    }

    // postfix: expression result = OLD value (saved on stack before the op)
    if (postfix == 1) {
        cg_pop(RAX);  // restore old value (the expression result)
    }
    // for compound/prefix: expression result = new value (already in rax)
    return 0;
}

// -----------------------------------------------------------------------------
// Phase 3: FieldExpr / IndexExpr assignment targets. The lvalue address +
// element type are resolved, then the plain/compound/postfix store mirrors the
// Ident assignment path but with the field's/element's packed offset + width.
// -----------------------------------------------------------------------------

// resolve a FieldExpr lvalue to (base offset, field offset, field type).
// base must be a bare local Ident of a struct type (v1 scope, mirroring the
// C++ codegen). Returns the field's absolute rbp offset in `out_off` (via the
// global scratch) and the field type via cg_struct_field_type_at.
//
// Computes: base_off = cg_lookup_local(base_tok); field_off = struct field
// offset; addr = base_off + field_off; ft = field type.
// On error sets cg_err. The field type is returned; the address is returned
// via the second result channel (a global, since ember has no multi-return).
global cg_lvalue_addr : i64 = 0;
global cg_lvalue_type : i64 = 0;

fn cg_resolve_field_lvalue(target: i64) -> i64 {
    let base: i64 = nk_a(target);
    if (nk_kind(base) != (NK::Ident as i64)) { cg_err = 1; cg_errmsg = string_from_slice("codegen: field-assign base must be a local"); return -1; }
    let boff: i64 = cg_lookup_local(nk_tok(base));
    let bt: i64 = cg_lookup_local_type(nk_tok(base));
    let row: i64 = find_struct(ty_struct_name(bt));
    let idx: i64 = cg_struct_field_index(bt, nk_name(target));
    if (row < 0 || idx < 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unknown field in assignment"); return -1; }
    let foff: i64 = cg_struct_field_offset(row, idx);
    let ft: i64 = cg_struct_field_type_at(row, idx);
    cg_lvalue_addr = boff + foff;
    cg_lvalue_type = ft;
    return ft;
}

// p.x = value / p.x op= value / p.x++ / ++p.x. The field address + type are
// compile-time-known (no index computation), so this mirrors the Ident path
// with the field's offset + width substituted for the local slot.
fn cg_assign_field(target: i64, value: i64, cop: i64, postfix: i64) -> i64 {
    let ft: i64 = cg_resolve_field_lvalue(target);
    if (cg_err != 0) { return 0; }
    let addr: i64 = cg_lvalue_addr;
    let is_float: i64 = ty_is_float(ft);

    // plain '=' (cop < 0, not postfix)
    if (cop < 0 && postfix != 1) {
        cg_eval(value); if (cg_err != 0) { return 0; }
        if (is_float == 1) { cg_store_float(addr, XMM0, cg_float_is64_type(ft)); }
        else { cg_normalize_rax(ft); cg_store_typed(RBP, addr, ft); }
        return 0;
    }

    // compound op= / prefix ++ / postfix ++ (integer + float paths)
    if (is_float == 1) {
        let is64: i64 = cg_float_is64_type(ft);
        let prefix: i64 = if64_prefix(is64);
        // load field (lhs) -> xmm0
        cg_load_float(XMM0, addr, is64);
        cg_sub_reg_imm32(RSP, 8);
        if (is64 == 1) { cg_sse_mem(0xF2, 0x11, XMM0, 0); } else { cg_sse_mem(0xF3, 0x11, XMM0, 0); }
        if (postfix == 1 || value < 0) { cg_mov_reg_imm64(RAX, 1); cg_i64_to_float(XMM0, RAX, is64); }
        else { cg_eval(value); if (cg_err != 0) { return 0; } if (is64 == 1) { cg_movq_xmm_rax(XMM0); } else { cg_movd_xmm_eax(XMM0); } }
        if (is64 == 1) { cg_sse_mem(0xF2, 0x10, XMM1, 0); } else { cg_sse_mem(0xF3, 0x10, XMM1, 0); }
        cg_add_reg_imm32(RSP, 8);
        if (cop == (BinOp::Add as i64)) { cg_float_op(0x58, is64); }
        else if (cop == (BinOp::Mul as i64)) { cg_float_op(0x59, is64); }
        else if (cop == (BinOp::Sub as i64)) { cg_sse_rr(prefix, 0x5C, XMM1, XMM0); cg_sse_rr(prefix, 0x10, XMM0, XMM1); }
        else if (cop == (BinOp::Div as i64)) { cg_sse_rr(prefix, 0x5E, XMM1, XMM0); cg_sse_rr(prefix, 0x10, XMM0, XMM1); }
        cg_store_float(addr, XMM0, is64);
        if (postfix == 1) { cg_mov_reg_imm64(RAX, 1); cg_i64_to_float(XMM1, RAX, is64); if (cop == (BinOp::Add as i64)) { cg_sse_rr(prefix, 0x5C, XMM0, XMM1); } else { cg_sse_rr(prefix, 0x58, XMM0, XMM1); } }
        return 0;
    }

    // integer compound / prefix / postfix
    let is_unsigned: i64 = cg_type_is_uint(ft);
    // load field -> rax (with width + sign extension)
    cg_load_typed(RAX, RBP, addr, ft);
    cg_normalize_rax(ft);
    if (postfix == 1) { cg_push(RAX); }
    cg_push(RAX);
    if (postfix == 1 || value < 0) { cg_mov_reg_imm64(RAX, 1); }
    else { cg_eval(value); if (cg_err != 0) { return 0; } }
    cg_mov_reg_reg(RCX, RAX);
    cg_pop(RAX);
    if (cop == (BinOp::Add as i64)) { cg_add_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Sub as i64)) { cg_sub_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Mul as i64)) { cg_imul_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::And as i64)) { cg_and_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Or as i64))  { cg_or_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Xor as i64)) { cg_xor_reg_reg(RAX, RCX); }
    else if (cop == (BinOp::Shl as i64)) { cg_shl_reg_cl(RAX); }
    else if (cop == (BinOp::Shr as i64)) { if (is_unsigned == 1) { cg_shr_reg_cl(RAX); } else { cg_sar_reg_cl(RAX); } }
    else if (cop == (BinOp::Div as i64)) { if (is_unsigned == 1) { cg_byte(0x48); cg_byte(0x31); cg_byte(0xD2); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF1); } else { cg_byte(0x48); cg_byte(0x99); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF9); } }
    else if (cop == (BinOp::Mod as i64)) { if (is_unsigned == 1) { cg_byte(0x48); cg_byte(0x31); cg_byte(0xD2); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF1); } else { cg_byte(0x48); cg_byte(0x99); cg_byte(0x48); cg_byte(0xF7); cg_byte(0xF9); } cg_mov_reg_reg(RAX, RDX); }
    cg_normalize_rax(ft);
    cg_store_typed(RBP, addr, ft);
    if (postfix == 1) { cg_pop(RAX); }
    return 0;
}

// a[i] = value (IndexExpr target). STEP 2 fills this in for fixed arrays +
// STEP 3 for slices. Until then sema rejects IndexExpr targets, so this is
// unreachable; keep a defensive error.
fn cg_assign_index(target: i64, value: i64, cop: i64, postfix: i64) -> i64 {
    return cg_assign_index_impl(target, value, cop, postfix);
}
// a[i] = value / a[i] op= value / a[i]++ (IndexExpr target). Mirrors
// src/codegen.cpp's AssignExpr IndexExpr-target store path. The value is
// eval'd + stashed, the element address is computed (base + index*elem_sz,
// with the same bounds check as the load path), then the value is stored with
// the element width. v1: plain '=' only for index targets (the test set uses
// plain assignment); compound/postfix on an index is a straightforward
// extension but not yet exercised.
fn cg_assign_index_impl(target: i64, value: i64, cop: i64, postfix: i64) -> i64 {
    let base: i64 = nk_a(target);
    if (nk_kind(base) != (NK::Ident as i64)) { cg_err = 1; cg_errmsg = string_from_slice("codegen: index-assign base must be a local"); return 0; }
    let boff: i64 = cg_lookup_local(nk_tok(base));
    let bt: i64 = cg_lookup_local_type(nk_tok(base));
    let mut is_sl: i64 = 0;
    if (bt >= 0 && nk_kind(bt) == (NK::Type as i64)) { is_sl = nk_f(bt); }
    let elem_ty: i64 = resolve_type(nk_a(bt));
    if (cg_err != 0) { return 0; }
    let elem_sz: i64 = cg_value_bytes(elem_ty);
    let mut arr_len: i64 = 0;
    if (bt >= 0) { arr_len = nk_e(bt); }
    // only plain '=' is supported for index targets in v1
    if (cop >= 0 || postfix == 1) { cg_err = 1; cg_errmsg = string_from_slice("codegen: compound/postfix assignment to an index not yet supported"); return 0; }
    // eval value -> rax (int) or xmm0 (float); stash it across address computation
    let is_float: i64 = ty_is_float(elem_ty);
    if (is_float == 1) {
        cg_eval(value); if (cg_err != 0) { return 0; }
        cg_sub_reg_imm32(RSP, 8);
        let is64: i64 = cg_float_is64_type(elem_ty);
        cg_store_float_reg(RSP, 0, XMM0, is64);
    } else {
        cg_eval(value); if (cg_err != 0) { return 0; }
        cg_normalize_rax(elem_ty);
        cg_push(RAX);
    }
    // base address -> r11 (survives index eval). slice: ptr+len; fixed: lea.
    if (is_sl == 1) {
        cg_load_reg_mem(R11, RBP, boff);
        cg_load_reg_mem(R9, RBP, boff + 8);
    } else {
        cg_lea_r11_rbp(boff);
    }
    // eval index -> rax
    cg_eval(nk_b(target)); if (cg_err != 0) { return 0; }
    if (is_sl == 1) {
        cg_bounds_check_reg_rax_r9();
    } else if (nk_kind(nk_b(target)) != (NK::IntLit as i64)) {
        cg_bounds_check_imm_rax(arr_len);
    }
    if (elem_sz > 1) { cg_mov_reg_imm64(RCX, elem_sz); cg_imul_reg_reg(RAX, RCX); }
    cg_add_reg_reg(R11, RAX);   // r11 = element address
    // store the stashed value to [r11] with the element width
    if (is_float == 1) {
        let is64: i64 = cg_float_is64_type(elem_ty);
        cg_load_float_reg(XMM1, RSP, 0, is64);
        cg_add_reg_imm32(RSP, 8);
        cg_store_float_reg(R11, 0, XMM1, is64);
    } else {
        cg_pop(RAX);
        cg_store_rax_elem(R11, 0, elem_sz);
    }
    return 0;
}

// -----------------------------------------------------------------------------
// Phase 2 Step 2: CastExpr (expr as Type). Mirrors src/codegen.cpp's CastExpr
// lowering. The operand is eval'd into rax (int) or xmm0 (float), then
// converted to the target type:
//   - same type: no-op
//   - int->int: normalize_rax(to) (sign/zero-extend or truncate via the
//     shift-then-shift normalize)
//   - f32->f64: cvtss2sd (F3 0F 5A C0)
//   - f64->f32: cvtsd2ss (F2 0F 5A C0)
//   - signed int -> float: normalize_rax(from) + cvtsi2ss/sd (F3/F2 48 0F 2A C0)
//   - float -> signed int: cvttsi2ss/sd (F3/F2 48 0F 2C C0) + normalize_rax(to)
// -----------------------------------------------------------------------------
fn cg_eval_castexpr(e: i64) -> i64 {
    let operand: i64 = nk_a(e);
    let to: i64 = resolve_type(nk_b(e));
    if (cg_err != 0) { return 0; }
    let from: i64 = cg_expr_type(operand);
    // same-type scalar: no-op (just eval the operand)
    if (type_eq(from, to) == 1) { cg_eval(operand); return 0; }
    // int -> int: eval operand, normalize to target width
    if (cg_type_is_int(from) == 1 && cg_type_is_int(to) == 1) {
        cg_eval(operand); if (cg_err != 0) { return 0; }
        cg_normalize_rax(to);
        return 0;
    }
    // Phase 3b: typed-enum -> int cast (the explicit spelling of enum->backing
    // widening). The operand's backing value is already in rax; normalize to
    // the target int width. Mirrors src/codegen.cpp's CastExpr, where a
    // typed-enum `from` has is_int() && struct_name.empty() so it lands in the
    // plain int->int normalize_rax(to) path.
    if (is_typed_enum_type(from) == 1 && cg_type_is_int(to) == 1) {
        cg_eval(operand); if (cg_err != 0) { return 0; }
        cg_normalize_rax(to);
        return 0;
    }
    // float -> float: cvtss2sd (f32->f64) or cvtsd2ss (f64->f32)
    if (ty_is_float(from) == 1 && ty_is_float(to) == 1) {
        cg_eval(operand); if (cg_err != 0) { return 0; }
        if (nk_d(from) == (Prim::F32 as i64) && nk_d(to) == (Prim::F64 as i64)) {
            // cvtss2sd xmm0, xmm0 -> F3 0F 5A C0
            cg_byte(0xF3); cg_byte(0x0F); cg_byte(0x5A); cg_byte(0xC0);
        } else {
            // cvtsd2ss xmm0, xmm0 -> F2 0F 5A C0
            cg_byte(0xF2); cg_byte(0x0F); cg_byte(0x5A); cg_byte(0xC0);
        }
        return 0;
    }
    // signed int -> float: normalize the int, then cvtsi2ss/sd rax -> xmm0
    if (cg_type_is_int(from) == 1 && ty_is_uint(from) == 0 && ty_is_float(to) == 1) {
        cg_eval(operand); if (cg_err != 0) { return 0; }
        cg_normalize_rax(from);
        // cvtsi2sd xmm0, rax (f64) -> F2 48 0F 2A C0
        // cvtsi2ss xmm0, rax (f32) -> F3 48 0F 2A C0
        if (nk_d(to) == (Prim::F64 as i64)) { cg_byte(0xF2); } else { cg_byte(0xF3); }
        cg_byte(0x48); cg_byte(0x0F); cg_byte(0x2A); cg_byte(0xC0);
        return 0;
    }
    // float -> signed int: cvttsi2ss/sd xmm0 -> rax (truncate toward zero),
    // then normalize to the target int width.
    if (ty_is_float(from) == 1 && cg_type_is_int(to) == 1 && ty_is_uint(to) == 0) {
        cg_eval(operand); if (cg_err != 0) { return 0; }
        // cvttsi2si rax, xmm0 (f64->i64) -> F2 48 0F 2C C0
        // cvttsi2si rax, xmm0 (f32->i64) -> F3 48 0F 2C C0
        // (the 64-bit form is used for all int widths; normalize_rax narrows)
        if (nk_d(from) == (Prim::F64 as i64)) { cg_byte(0xF2); } else { cg_byte(0xF3); }
        cg_byte(0x48); cg_byte(0x0F); cg_byte(0x2C); cg_byte(0xC0);
        cg_normalize_rax(to);
        return 0;
    }
    // unreachable: sema's cast matrix rejects anything else
    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: invalid cast from ") + ty_name(from) + string_from_slice(" to ") + ty_name(to); }
    return 0;
}

// -----------------------------------------------------------------------------
// Phase 2 Step 4: TernaryExpr (cond ? then : else). Mirrors src/codegen.cpp:
//   eval cond -> rax; cmp rax, 0; jz else; eval then -> rax; jmp end; else:
//   eval else -> rax; end: Result in rax.
// -----------------------------------------------------------------------------
fn cg_eval_ternaryexpr(e: i64) -> i64 {
    let cond: i64 = nk_a(e);
    let then_e: i64 = nk_b(e);
    let else_e: i64 = nk_c(e);
    cg_eval(cond); if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    let else_l: i64 = cg_alloc_label();
    let end_l: i64 = cg_alloc_label();
    cg_jcc(COND_E, else_l);       // cond == 0 -> else
    cg_eval(then_e); if (cg_err != 0) { return 0; }
    cg_jmp(end_l);
    cg_bind(else_l);
    cg_eval(else_e); if (cg_err != 0) { return 0; }
    cg_bind(end_l);
    return 0;
}

// -----------------------------------------------------------------------------
// Phase 2 Step 5: SizeofExpr + OffsetofExpr. Both are COMPILE-TIME CONSTANTS
// (sema resolved them). The codegen emits `mov rax, <constant>`. For
// primitives, cg_type_size gives the size; offsetof of a primitive field is
// rejected by sema (no fields). Struct sizeof/offsetof complete in Phase 3.
// Mirrors src/codegen.cpp: mov_reg_imm64(Reg::rax, int64_t(s->resolved)).
// -----------------------------------------------------------------------------
fn cg_eval_sizeofexpr(e: i64) -> i64 {
    let t: i64 = resolve_type(nk_a(e));
    if (cg_err != 0) { return 0; }
    let sz: i64 = cg_type_size(t);
    cg_mov_reg_imm64(RAX, sz);
    return 0;
}

fn cg_eval_offsetofexpr(e: i64) -> i64 {
    // Phase 3: offsetof of a struct field = the field's packed offset. For
    // primitives there are no fields (sema rejects). Mirror src/codegen.cpp:
    // mov rax, <field_offset>.
    let t: i64 = resolve_type(nk_a(e));
    if (cg_err != 0) { return 0; }
    let row: i64 = find_struct(ty_struct_name(t));
    if (row < 0) { cg_mov_reg_imm64(RAX, 0); return 0; }
    let idx: i64 = cg_struct_field_index(t, tok_name(nk_tok(e)));
    if (idx < 0) { cg_mov_reg_imm64(RAX, 0); return 0; }
    cg_mov_reg_imm64(RAX, cg_struct_field_offset(row, idx));
    return 0;
}

// evaluate a call expression.
// Two call kinds:
//   - SCRIPT call: find_fn(name) >= 0. Emit a direct `call rel32` to the
//     callee's entry label (patched by cg_resolve_fixups to the callee's
//     prologue offset within the same code section). The loader does NOT touch
//     rel32 — it resolves within the RX code region.
//   - NATIVE call: find_fn(name) < 0 (a host extension native). Eval args into
//     rcx/rdx/r8/r9 (Win64), then emit `mov rax, 0` + an ABS64_NATIVE reloc
//     (sym_idx = cg_sym_index(name), addend = the ABI fingerprint) + `call rax`.
//     The loader resolves the symbol against the host's registered NativeSig
//     table, validates the fingerprint, and patches the imm64 with the native's
//     fn_ptr. The fingerprint is computed from the call's arg types + return
//     type (annotated by sema) using the EXACT type-code table
//     (module_abi_fingerprint.hpp), so it matches the host's registered sig.
//
// Win64: first 4 int args in rcx/rdx/r8/r9. Args are eval'd into stack temps
// first (eval may clobber a placed register), then loaded into registers in
// order — the same stash-then-load pattern the C++ codegen uses.
fn cg_eval_indirect_lambda_call(e: i64) -> i64 {
    let mut argc: i64 = 0; let mut a: i64 = nk_a(e); while (a >= 0) { argc = argc + 1; a = nk_next(a); }
    let frame: i64 = cg_round16((argc + 2) * 8 + 32); cg_sub_reg_imm32(RSP, frame);
    cg_eval(nk_e(e)); if (cg_err != 0) { return 0; }
    cg_store_reg_mem(RSP, 0, RAX); cg_store_reg_mem(RSP, 8, RDX);
    a = nk_a(e); let mut i: i64 = 0;
    while (a >= 0) { cg_eval(a); if (cg_err != 0) { return 0; } cg_store_reg_mem(RSP, 16 + i * 8, RAX); i = i + 1; a = nk_next(a); }
    cg_load_reg_mem(RAX, RSP, 0); cg_load_reg_mem(RCX, RSP, 8);
    if (argc >= 1) { cg_load_reg_mem(RDX, RSP, 16); }
    if (argc >= 2) { cg_load_reg_mem(R8, RSP, 24); }
    if (argc >= 3) { cg_load_reg_mem(R9, RSP, 32); }
    cg_emit_abs64_reloc_reg(R11, CG_RELOC_DISPATCH, 0, 0);
    cg_lea_scaled8(R11, R11, RAX); cg_load_reg_mem(R11, R11, 0); cg_call_reg(R11);
    cg_add_reg_imm32(RSP, frame); return 0;
}

fn cg_eval_callexpr(e: i64) -> i64 {
    let name: string = nk_name(e);
    if (nk_d(e) == 2) { return cg_eval_indirect_lambda_call(e); }

    // ---- string_from_slice(<StringLit>) special case ----
    // The host registers string_from_slice with a u8-slice param (ABI code 5,
    // passed as two words ptr+len). The self-hosted subset types a string
    // literal as TY_STRING (a handle), and cg_eval_string_lit ALREADY
    // materializes a literal by emitting the rodata slice + a real
    // string_from_slice(ptr,len) call -> handle in rax. So a user-written
    // `string_from_slice("lit")` is semantically identical to the bare literal
    // `"lit"` (same handle): evaluate the literal directly. This avoids the
    // generic path's 1-word handle ABI (which would mismatch the slice native)
    // and produces the exact handle the host would. (A non-literal arg is an
    // edge case the subset does not support; it falls through to the generic
    // path, which is best-effort.)
    if (name == string_from_slice("string_from_slice")) {
        let mut a0: i64 = nk_a(e);
        if (a0 >= 0 && nk_kind(a0) == (NK::StringLit as i64) && nk_next(a0) < 0) {
            return cg_eval_string_lit(a0);
        }
    }

    // determine script vs native + the fn row. Tier 1 namespaces: a Foo::bar()
    // call (base name tok in slot e) resolves to the qualified Ns::fn row; a
    // bare call inside a namespaced fn first tries the sibling Ns::fn row.
    let mut fn_row: i64 = -1;
    let mut is_ns_call: i64 = 0;
    let mod_tok: i64 = nk_e(e);
    if (mod_tok >= 0) {
        let mod_name: string = tok_text_at(mod_tok);
        if (is_namespace_name(mod_name) == 1) {
            is_ns_call = 1;
            fn_row = find_fn_qualified(name, mod_name);
        }
    }
    if (is_ns_call == 0) {
        fn_row = find_fn(name);
        if (fn_row < 0 && cg_cur_ns >= 0) {
            let qrow: i64 = find_fn_qualified(name, tok_name(cg_cur_ns));
            if (qrow >= 0) { fn_row = qrow; }
        }
    }
    let mut is_native: i64 = 0;
    if (fn_row < 0) { is_native = 1; }

    // Phase 4: a struct-returning script call uses the hidden-pointer sret
    // ABI. The caller context (LetStmt init / ReturnStmt value / AssignExpr
    // value / a struct-arg stash) has already loaded the destination address
    // into rax. Route to cg_eval_struct_returning_call, which places the dest
    // at word 0 + the real args from word 1 and calls; the callee writes the
    // struct through the dest (no register result). sema guarantees a
    // struct-returning call only appears in those contexts, so reaching here
    // with rax unset is a sema gap (defensive: rax holds garbage, but the
    // callee would write to a garbage address — flag an error instead).
    if (is_native == 0 && cg_ty_is_struct(nk_c(e)) == 1) {
        if (cg_struct_ret_dest_ready == 0) {
            if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: struct-returning call used without a destination"); }
            return 0;
        }
        return cg_eval_struct_returning_call(e);
    }

    // count args (walk the sibling chain via nk_next). The arg node indices
    // are NOT pre-collected into an array — the previous design allocated a
    // fresh `args` array on every call expression and read it AFTER recursively
    // evaluating each arg (cg_eval can recurse into cg_eval_callexpr for nested
    // call args), which both leaked a slot per call (no array_free in the host
    // extension) and made a reused global unsafe. Instead we count now and
    // re-walk the chain during evaluation, so no scratch array is needed.
    let mut argc: i64 = 0;
    {
        let mut a: i64 = nk_a(e);
        while (a >= 0) {
            argc = argc + 1;
            a = nk_next(a);
        }
    }
    // ---- NATIVE call path (no struct args: natives don't take structs in
    // the subset; args are 1 word each, rcx/rdx/r8/r9 + stack) ----
    if (is_native == 1) {
        // call_frame = round16(argc*8 + 32), minimum 32. Args stored at
        // [rsp + i*8]; args 0-3 loaded to regs, args 4+ stay (callee reads at
        // [rbp+48+(i-4)*8] = caller [rsp+32+(i-4)*8] = [rsp+i*8]).
        let mut call_frame: i64 = argc * 8 + 32;
        if (call_frame < 32) { call_frame = 32; }
        call_frame = cg_round16(call_frame);
        cg_sub_reg_imm32(RSP, call_frame);
        // eval each arg -> rax (int/handle) or xmm0 (float); store to [rsp+i*8].
        {
            let mut i2: i64 = 0;
            let mut a: i64 = nk_a(e);
            while (a >= 0) {
                cg_eval(a);
                if (cg_err != 0) { return 0; }
                if (cg_arg_is_float(name, i2) == 1) {
                    let is64: i64 = cg_arg_is_f64(name, i2);
                    cg_store_float_reg(RSP, i2 * 8, XMM0, is64);
                } else {
                    cg_store_reg_mem(RSP, i2 * 8, RAX);
                }
                i2 = i2 + 1;
                a = nk_next(a);
            }
        }
        if (argc >= 1) {
            if (cg_arg_is_float(name, 0) == 1) { cg_load_float_reg(XMM0, RSP, 0,  cg_arg_is_f64(name, 0)); }
            else { cg_load_reg_mem(RCX, RSP, 0); }
        }
        if (argc >= 2) {
            if (cg_arg_is_float(name, 1) == 1) { cg_load_float_reg(XMM1, RSP, 8,  cg_arg_is_f64(name, 1)); }
            else { cg_load_reg_mem(RDX, RSP, 8); }
        }
        if (argc >= 3) {
            if (cg_arg_is_float(name, 2) == 1) { cg_load_float_reg(XMM2, RSP, 16, cg_arg_is_f64(name, 2)); }
            else { cg_load_reg_mem(R8, RSP, 16); }
        }
        if (argc >= 4) {
            if (cg_arg_is_float(name, 3) == 1) { cg_load_float_reg(XMM3, RSP, 24, cg_arg_is_f64(name, 3)); }
            else { cg_load_reg_mem(R9, RSP, 24); }
        }
        let sym_idx: i64 = cg_sym_index(name);
        // build the fingerprint from the native's declared param types (not the
        // call's arg types) so it matches the host's registered sig even when
        // an arg adapts (e.g. an IntLit to an i64 param, f32->f64 widening).
        let param_types: i64 = cg_fp_types_get();
        let mut j: i64 = 0;
        while (j < argc && j < 4) {
            array_set_i64(param_types, j, native_param_type(name, j));
            j = j + 1;
        }
        let ret_type: i64 = native_ret_type(name);
        let perm: i64 = native_perm(name);
        let mut fp: i64 = cg_abi_fingerprint(param_types, argc, ret_type, perm);
        // The host marks coroutine_start's first i64-shaped parameter as a
        // function handle (ABI code 6), even though source-level checking uses
        // i64 slots. Match that registered fingerprint exactly.
        if (name == string_from_slice("coroutine_start")) {
            let codes: i64 = cg_fp_codes_get(); array_set_i64(codes, 0, 6); array_set_i64(codes, 1, 1);
            fp = cg_abi_fingerprint_codes(codes, 2, 1, 0);
        }
        cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym_idx, fp);
        cg_call_reg(RAX);  // call rax (FF D0)
        cg_add_reg_imm32(RSP, call_frame);
        // result convention: float -> xmm0; int/handle/u8 -> rax (normalize
        // narrow ints); void -> 0. Annotate the call's type on slot c.
        set_c(e, ret_type);
        if (ty_is_float(ret_type) == 1) { return 0; }
        if (ty_is_void(ret_type) == 1) { cg_mov_reg_imm64(RAX, 0); return 0; }
        cg_normalize_rax(ret_type);
        return 0;
    }

    // ---- SCRIPT call path (Phase 4: word-slot-aware for struct args) ----
    // Each operand occupies cg_words_for_type(pt) consecutive 8-byte words:
    // 1 for a scalar/float/handle, 2 for a slice, ceil(size/8) for a struct.
    // A struct arg is copied via cg_stash_struct_arg (a bare Ident copies from
    // its frame slot; a StructLit / struct-returning CallExpr materializes into
    // a fresh temp first). Words 0-3 -> rcx/rdx/r8/r9; words 4+ stay at
    // [rsp+w*8] (callee reads at [rbp+48+(w-4)*8] = caller [rsp+w*8]).
    let mut total_words: i64 = 0;
    {
        let mut i0: i64 = 0;
        while (i0 < argc) { total_words = total_words + cg_words_for_type(fn_param_type(fn_row, i0)); i0 = i0 + 1; }
    }
    let mut call_frame: i64 = total_words * 8 + 32;
    if (call_frame < 32) { call_frame = 32; }
    call_frame = cg_round16(call_frame);
    cg_sub_reg_imm32(RSP, call_frame);

    // stash each arg operand to its cumulative word slot(s). next_slot is the
    // running word index. A struct arg is copied via cg_stash_struct_arg (a
    // bare Ident from its frame slot; a StructLit / struct-returning CallExpr
    // materialized into a fresh temp via cg_alloc_struct_temp); a slice arg
    // stores rax+rdx (2 words); a scalar/float arg evals + stores 1 word.
    let mut next_slot: i64 = 0;
    {
        let mut a: i64 = nk_a(e);
        let mut i2: i64 = 0;
        while (a >= 0) {
            let pt: i64 = fn_param_type(fn_row, i2);
            let off: i64 = next_slot * 8;
            if (cg_ty_is_struct(pt) == 1) {
                cg_stash_struct_arg(a, pt, off);
                if (cg_err != 0) { return 0; }
                next_slot = next_slot + cg_words_for_type(pt);
            } else if (nk_f(pt) == 1 || nk_f(pt) == 2) {
                // slice/closure arg: {rax=word0, rdx=word1} (2 words)
                cg_eval(a); if (cg_err != 0) { return 0; }
                cg_store_reg_mem(RSP, off, RAX);
                cg_store_reg_mem(RSP, off + 8, RDX);
                next_slot = next_slot + 2;
            } else if (ty_is_float(pt) == 1) {
                cg_eval(a); if (cg_err != 0) { return 0; }
                cg_store_float(off, XMM0, cg_float_is64_type(pt));
                next_slot = next_slot + 1;
            } else {
                cg_eval(a); if (cg_err != 0) { return 0; }
                cg_normalize_rax(pt);
                cg_store_reg_mem(RSP, off, RAX);
                next_slot = next_slot + 1;
            }
            a = nk_next(a);
            i2 = i2 + 1;
        }
    }

    // place words 0..3 into the Win64 int registers (struct words are always
    // integer at the word level — a struct's float field lives inside the
    // copied byte blob, not in an xmm arg slot).
    if (total_words >= 1) { cg_load_reg_mem(RCX, RSP, 0); }
    if (total_words >= 2) { cg_load_reg_mem(RDX, RSP, 8); }
    if (total_words >= 3) { cg_load_reg_mem(R8, RSP, 16); }
    if (total_words >= 4) { cg_load_reg_mem(R9, RSP, 24); }

    // SCRIPT call: a direct call rel32 to the callee's entry label.
    // cg_fn_labels maps the callee's name to a label bound at its prologue
    // offset; the rel32 fixup is patched after all fns are compiled.
    let callee_label: i64 = cg_callee_label(e, is_ns_call, mod_tok);
    if (cg_err != 0) { return 0; }
    cg_call_rel32(callee_label);

    // add rsp, call_frame (restore the stack)
    cg_add_reg_imm32(RSP, call_frame);

    // result is in rax; normalize narrow int returns at the call boundary.
    let sret: i64 = nk_c(e);
    cg_normalize_rax(sret);
    return 0;
}

// -----------------------------------------------------------------------------
// Phase 4: struct by-value call ABI helpers.
// -----------------------------------------------------------------------------

// resolve a CallExpr's callee entry label (direct + namespace-qualified +
// intra-namespace bare call). Returns the label id or -1 (sets cg_err).
fn cg_callee_label(e: i64, is_ns_call: i64, mod_tok: i64) -> i64 {
    let name: string = nk_name(e);
    let mut lab: i64 = -1;
    if (is_ns_call == 1) {
        let mod_name: string = tok_text_at(mod_tok);
        lab = cg_lookup_fn_label_qualified(name, mod_name);
    } else {
        lab = cg_lookup_fn_label(name);
        if (lab < 0 && cg_cur_ns >= 0) {
            let qlab: i64 = cg_lookup_fn_label_qualified(name, tok_name(cg_cur_ns));
            if (qlab >= 0) { lab = qlab; }
        }
    }
    if (lab < 0) {
        if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: no entry label for function '") + name + string_from_slice("'"); }
    }
    return lab;
}

// Stash a struct-by-value call argument into the call's arg-stash region at
// [rsp+off]. Mirrors src/codegen.cpp's stash_struct_arg. sema's
// check_struct_arg_shape permits three shapes: a bare local Ident (copy from
// its frame slot), a StructLit of the matching struct (materialize into a
// fresh temp, then copy), or a struct-returning CallExpr of the matching
// struct (lea the temp's address into rax, eval_struct_returning_call writes
// through it into the temp, then copy). A non-Ident arg gets its OWN fresh
// temp via cg_alloc_struct_temp (distinct per call site). Returns 0.
fn cg_stash_struct_arg(arg_e: i64, t: i64, off: i64) -> i64 {
    let k: i64 = nk_kind(arg_e);
    let row: i64 = find_struct(ty_struct_name(t));
    if (row < 0) { if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: struct arg of unknown struct"); } return 0; }
    let nb: i64 = cg_struct_value_bytes(row);
    if (k == (NK::Ident as i64)) {
        let src_off: i64 = cg_lookup_local(nk_tok(arg_e));
        if (src_off == 0) { if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: struct arg local not found"); } return 0; }
        cg_copy_bytes(RSP, off, RBP, src_off, nb);
        return 0;
    }
    if (k == (NK::StructLit as i64)) {
        let temp_off: i64 = cg_alloc_struct_temp(nb);
        cg_store_struct_lit(arg_e, t, temp_off);
        if (cg_err != 0) { return 0; }
        cg_copy_bytes(RSP, off, RBP, temp_off, nb);
        return 0;
    }
    if (k == (NK::CallExpr as i64)) {
        let temp_off: i64 = cg_alloc_struct_temp(nb);
        // lea rax, [rbp+temp_off] (the hidden dest pointer), then the callee
        // writes the struct directly into the temp.
        cg_lea_rax_rbp(temp_off);
        let saved: i64 = cg_struct_ret_dest_ready; cg_struct_ret_dest_ready = 1;
        cg_eval_struct_returning_call(arg_e);
        cg_struct_ret_dest_ready = saved;
        if (cg_err != 0) { return 0; }
        cg_copy_bytes(RSP, off, RBP, temp_off, nb);
        return 0;
    }
    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: struct-by-value arg is not a local/literal/call"); }
    return 0;
}

// Evaluate a struct-returning CallExpr, forwarding the dest pointer (already
// loaded into rax by the caller — a local's frame address via lea for a
// let-init/assignment, a temp's address for a struct arg, or this fn's own
// incoming hidden return pointer for a `return f(...)` forward) as the hidden
// word-0 argument. Mirrors src/codegen.cpp's eval_struct_returning_call: real
// args start at word 1, the dest occupies word 0. The callee writes the struct
// through the dest — no register result is propagated. Returns 0 on success.
fn cg_eval_struct_returning_call(e: i64) -> i64 {
    let name: string = nk_name(e);
    // resolve script fn row + callee label (the subset has no native that
    // returns a struct; a struct-returning call is always a script fn).
    let mut fn_row: i64 = -1;
    let mut is_ns_call: i64 = 0;
    let mod_tok: i64 = nk_e(e);
    if (mod_tok >= 0) {
        let mod_name: string = tok_text_at(mod_tok);
        if (is_namespace_name(mod_name) == 1) { is_ns_call = 1; fn_row = find_fn_qualified(name, mod_name); }
    }
    if (is_ns_call == 0) {
        fn_row = find_fn(name);
        if (fn_row < 0 && cg_cur_ns >= 0) {
            let qrow: i64 = find_fn_qualified(name, tok_name(cg_cur_ns));
            if (qrow >= 0) { fn_row = qrow; }
        }
    }
    if (fn_row < 0) { if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: struct-returning call to unknown function '") + name + string_from_slice("'"); } return 0; }

    // Build the operand list with cumulative word slots. Word 0 is reserved
    // for the hidden dest pointer (already in rax); real args start at word 1.
    // The subset has no native struct-returning calls + no receiver, so the
    // operand list is just the user args. We compute the per-arg word count +
    // slot0 on the fly, mirroring the native add_operand/next_slot scheme.
    let nargs: i64 = fn_param_count(fn_row);
    // total words = 1 (dest) + sum of words_for_type over the params
    let mut total_words: i64 = 1;
    let mut ai0: i64 = 0;
    while (ai0 < nargs) { total_words = total_words + cg_words_for_type(fn_param_type(fn_row, ai0)); ai0 = ai0 + 1; }
    let stash_size: i64 = total_words * 8;
    // Frame = round16(stash_size + 32). Words 0..total_words-1 live at
    // [rsp+w*8] (word 0 = dest ptr); the +32 is the safety margin matching the
    // regular script-call frame (round16(total_words*8 + 32)). Words 4+ stay
    // at [rsp+w*8] = caller [rsp+32+(w-4)*8], where the callee reads them.
    let total: i64 = cg_round16(stash_size + 32);
    cg_sub_reg_imm32(RSP, total);

    // word 0: the hidden dest pointer (already in rax)
    cg_store_reg_mem(RSP, 0, RAX);

    // stash each arg operand to its cumulative word slot(s). next_slot starts
    // at 1 (word 0 = dest). A struct arg is copied via cg_stash_struct_arg
    // (with a fresh temp per non-Ident struct arg); a slice arg stores rax+rdx
    // (2 words); a scalar/float arg evals + stores 1 word.
    let mut next_slot: i64 = 1;
    let mut a: i64 = nk_a(e);
    let mut i: i64 = 0;
    while (a >= 0) {
        let pt: i64 = fn_param_type(fn_row, i);
        let off: i64 = next_slot * 8;
        if (cg_ty_is_struct(pt) == 1) {
            cg_stash_struct_arg(a, pt, off);
            if (cg_err != 0) { return 0; }
            next_slot = next_slot + cg_words_for_type(pt);
        } else if (nk_f(pt) == 1 || nk_f(pt) == 2) {
            // slice/closure arg: cg_eval yields two words in rax/rdx
            cg_eval(a); if (cg_err != 0) { return 0; }
            cg_store_reg_mem(RSP, off, RAX);
            cg_store_reg_mem(RSP, off + 8, RDX);
            next_slot = next_slot + 2;
        } else if (ty_is_float(pt) == 1) {
            cg_eval(a); if (cg_err != 0) { return 0; }
            cg_store_float(off, XMM0, cg_float_is64_type(pt));
            next_slot = next_slot + 1;
        } else {
            cg_eval(a); if (cg_err != 0) { return 0; }
            cg_store_reg_mem(RSP, off, RAX);
            next_slot = next_slot + 1;
        }
        a = nk_next(a);
        i = i + 1;
    }

    // place words 0..3 into rcx/rdx/r8/r9 (word 0 = dest ptr -> rcx). The
    // subset's struct words are always integer (no float struct fields are
    // passed in xmm at the word level — a struct's float field lives inside
    // the copied byte blob), so no per-word float dispatch is needed.
    if (total_words >= 1) { cg_load_reg_mem(RCX, RSP, 0); }
    if (total_words >= 2) { cg_load_reg_mem(RDX, RSP, 8); }
    if (total_words >= 3) { cg_load_reg_mem(R8, RSP, 16); }
    if (total_words >= 4) { cg_load_reg_mem(R9, RSP, 24); }
    // words 4+ stay at [rsp+w*8] (= caller [rsp+32+(w-4)*8]); the callee reads
    // them at [rbp+48+(w-4)*8] = caller [rsp+32+(w-4)*8]. No move needed (the
    // stash loop already placed each word at [rsp+next_slot*8] = [rsp+w*8]).

    let callee_label: i64 = cg_callee_label(e, is_ns_call, mod_tok);
    if (cg_err != 0) { return 0; }
    cg_call_rel32(callee_label);

    cg_add_reg_imm32(RSP, total);
    // no register result to propagate — the callee wrote the struct through
    // the dest pointer. Leave rax as-is (the caller will reload/read the dest).
    return 0;
}

// max(0, n)
fn cg_max0(n: i64) -> i64 { if (n < 0) { return 0; } return n; }

// Spill a single integer arg word `w` (a global word index, 0-based including
// the hidden return ptr at word 0) to [rbp+off]. Words 0-3 come from
// rcx/rdx/r8/r9 (arg_regs); words 4+ come from the caller's outgoing stack
// area at [rbp + 48 + (w-4)*8] (the caller stores words at [rsp+w*8]; words
// 4+ stay there = caller [rsp+32+(w-4)*8] = callee [rbp+48+(w-4)*8]). Used
// by the slice param spill
// (two consecutive words). `arg_regs` is the 4-entry Win64 int-arg-reg array.
fn cg_spill_word(w: i64, off: i64, arg_regs: i64, total_words: i64) -> i64 {
    if (w < 4) {
        let reg: i64 = array_get_i64(arg_regs, w);
        cg_store_reg_mem(RBP, off, reg);
    } else {
        let src_off: i64 = 48 + (w - 4) * 8;
        cg_load_reg_mem(RAX, RBP, src_off);
        cg_store_reg_mem(RBP, off, RAX);
    }
    return 0;
}

// =============================================================================
// statement compilation.
// =============================================================================

fn cg_compile_stmt(s: i64) -> i64 {
    if (s < 0) { return 0; }
    let k: i64 = nk_kind(s);

    if (k == (NK::LetStmt as i64)) {
        let name_tok: i64 = nk_tok(s);
        let init: i64 = nk_b(s);
        let mut t: i64 = nk_a(s); if (t < 0 && init >= 0) { t = cg_expr_type(init); } else if (t >= 0) { t = resolve_type(t); }
        // size the local's stack slots from the type's packed extent (struct:
        // ceil(value_bytes/8); fixed array: ceil(N*elem/8); slice: 2; scalar: 1).
        let mut slots: i64 = 1;
        if (t >= 0) { slots = cg_local_slots(t); }
        let off: i64 = cg_alloc_local_t(name_tok, t, slots);
        if (init >= 0 && nk_kind(init) == (NK::StructLit as i64)) { cg_store_struct_lit(init, t, off); return 0; }
        if (init >= 0 && nk_kind(init) == (NK::ArrayLit as i64)) { return cg_store_arraylit_let(init, t, off); }
        if (init >= 0 && nk_kind(init) == (NK::CallExpr as i64) && cg_ty_is_struct(t) == 1) {
            // Phase 4: struct-returning call init. The local's frame slot is
            // the concrete destination for the callee's hidden return pointer:
            // lea rax, [rbp+off], then the callee writes the struct directly
            // into the local (no register result, no rax store).
            cg_lea_rax_rbp(off);
            let saved: i64 = cg_struct_ret_dest_ready; cg_struct_ret_dest_ready = 1;
            cg_eval_struct_returning_call(init);
            cg_struct_ret_dest_ready = saved;
            return 0;
        }
        if (init >= 0) {
            // slice-typed init (a ViewExpr, a slice Ident, etc.): cg_eval
            // yields the 2-word slice ABI {rax=ptr, rdx=len}; store both words
            // into the 16-byte local (ptr at off, len at off+8).
            let mut is_sl_init: i64 = 0;
            if (t >= 0 && nk_kind(t) == (NK::Type as i64)) { is_sl_init = nk_f(t); }
            if (is_sl_init == 1 || is_sl_init == 2) {
                cg_eval(init); if (cg_err != 0) { return 0; }
                cg_store_reg_mem(RBP, off, RAX);
                cg_store_reg_mem(RBP, off + 8, RDX);
            } else {
                cg_eval(init); if (cg_err != 0) { return 0; }
                if (ty_is_float(t) == 1) {
                    // implicit f32->f64 widening when the init is f32 and the
                    // target is f64 (a same-type or same-width store is a no-op).
                    cg_convert_float(cg_expr_type(init), t);
                    cg_store_float(off, XMM0, cg_float_is64_type(t));
                } else { cg_normalize_rax(t); cg_store_reg_mem(RBP, off, RAX); }
            }
        } else {
            // no initializer: zero-fill an aggregate's whole extent (a fixed
            // array / struct local later populated via indexed / field assigns),
            // mirroring src/codegen.cpp's LetStmt no-init path. Scalars leave
            // their slot as whatever (the value is always written before read).
            if (t >= 0 && cg_local_width_bytes(t) > 8) { cg_zero_fill(off, cg_local_width_bytes(t)); }
        }
        return 0;
    }
    if (k == (NK::ExprStmt as i64)) {
        if (nk_a(s) >= 0) { cg_eval(nk_a(s)); }
        return 0;
    }
    if (k == (NK::ReturnStmt as i64)) {
        let val: i64 = nk_a(s);
        // Phase 4: struct-by-value return (hidden-pointer sret ABI). The fn's
        // incoming hidden return pointer (spilled to cg_struct_ret_ptr_off in
        // the prologue) is the destination; the struct value is copied there.
        // sema guarantees val is a bare Ident, a struct-returning CallExpr, or
        // a struct literal of the return type. There is no register result to
        // stash across defers (the struct is written through the dest ptr),
        // but the dest ptr must be reloaded into rax at the end (the sret ABI
        // requires the dest ptr to be returned in rax).
        if (cg_ty_is_struct(cg_cur_ret) == 1) {
            let rptr: i64 = cg_struct_ret_ptr_off;
            let ret_row: i64 = find_struct(ty_struct_name(cg_cur_ret));
            let ret_bytes: i64 = (ret_row >= 0) ? cg_struct_value_bytes(ret_row) : (cg_words_for_type(cg_cur_ret) * 8);
            if (val >= 0) {
                let vk: i64 = nk_kind(val);
                if (vk == (NK::Ident as i64)) {
                    // copy the local's bytes to [rptr] (via r11 = rptr).
                    let src_off: i64 = cg_lookup_local(nk_tok(val));
                    if (src_off == 0) { if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: return struct local not found"); } return 0; }
                    cg_load_reg_mem(R11, RBP, rptr);
                    cg_copy_bytes(R11, 0, RBP, src_off, ret_bytes);
                } else if (vk == (NK::CallExpr as i64)) {
                    // forward: rax = rptr, the callee writes through it.
                    cg_load_reg_mem(RAX, RBP, rptr);
                    let saved: i64 = cg_struct_ret_dest_ready; cg_struct_ret_dest_ready = 1;
                    cg_eval_struct_returning_call(val);
                    cg_struct_ret_dest_ready = saved;
                    if (cg_err != 0) { return 0; }
                } else if (vk == (NK::StructLit as i64)) {
                    // materialize the literal into a temp, copy to [rptr].
                    let temp_off: i64 = cg_alloc_struct_temp(ret_bytes);
                    cg_store_struct_lit(val, cg_cur_ret, temp_off);
                    if (cg_err != 0) { return 0; }
                    cg_load_reg_mem(R11, RBP, rptr);
                    cg_copy_bytes(R11, 0, RBP, temp_off, ret_bytes);
                } else {
                    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unsupported struct return value shape"); }
                    return 0;
                }
            }
            // emit pending defers (LIFO). No register result to stash (the
            // struct is already at the dest); defers may clobber rax/r11.
            cg_defer_emit_all_nostash();
            if (cg_err != 0) { return 0; }
            // the sret ABI requires the dest pointer to be returned in rax.
            cg_load_reg_mem(RAX, RBP, rptr);
            cg_jmp(cg_epilogue_label);
            return 0;
        }
        // eval the value -> rax (or xmm0 for float, {rax,rdx} for slice)
        if (val >= 0) {
            cg_eval(val);
            if (cg_err != 0) { return 0; }
        } else {
            cg_mov_reg_imm64(RAX, 0);  // void return -> rax = 0
        }
        // Phase 3b: emit all pending defers (LIFO) before exiting, stashing
        // the return value across them (a defer may clobber rax/xmm0/rdx).
        // Mirrors src/codegen.cpp's ReturnStmt emit_cleanups_to(0) + stash.
        cg_defer_emit_all_and_stash();
        if (cg_err != 0) { return 0; }
        // jmp to the function's epilogue label
        cg_jmp(cg_epilogue_label);
        return 0;
    }
    if (k == (NK::IfStmt as i64)) {
        return cg_compile_if(s);
    }
    if (k == (NK::WhileStmt as i64)) {
        return cg_compile_while(s);
    }
    if (k == (NK::BlockStmt as i64)) {
        return cg_compile_block(s);
    }
    if (k == (NK::BreakStmt as i64)) {
        // Phase 3b: clean up defers from scopes opened inside the current
        // loop/switch (down to the saved defer-mark depth), then jmp to the
        // break target. Mirrors src/codegen.cpp's break emit_cleanups_to.
        if (cg_loop_depth > 0) {
            cg_defer_emit_to(cg_loop_defer_mark);
            if (cg_err != 0) { return 0; }
            cg_jmp(cg_loop_break);
        }
        return 0;
    }
    if (k == (NK::ContinueStmt as i64)) {
        // jmp to the current loop's continue label (after cleaning up the
        // scopes opened inside the loop, mirroring src/codegen.cpp's continue).
        if (cg_loop_depth > 0) {
            cg_defer_emit_to(cg_loop_defer_mark);
            if (cg_err != 0) { return 0; }
            cg_jmp(cg_loop_continue);
        }
        return 0;
    }
    if (k == (NK::ForStmt as i64)) { return cg_compile_for(s); }
    if (k == (NK::ForEachStmt as i64)) { return cg_compile_foreach(s); }
    if (k == (NK::DoWhileStmt as i64)) { return cg_compile_dowhile(s); }
    if (k == (NK::SwitchStmt as i64)) { return cg_compile_switch(s); }
    if (k == (NK::MatchStmt as i64)) { return cg_compile_match(s); }
    // Phase 3b: defer. Do NOT emit the expr inline; record it on the defer
    // stack for the current scope so it runs (LIFO) at scope exit. Mirrors
    // src/codegen.cpp's DeferStmt (which sets a per-site activation flag).
    if (k == (NK::DeferStmt as i64)) { return cg_compile_defer(s); }
    // Phase 2 Step 6: static_assert produces NO codegen (sema resolved it:
    // true -> elided, false/non-const -> compile error that never reaches
    // codegen). Skip it before any dispatch, mirroring src/codegen.cpp.
    if (k == (NK::StaticAssertStmt as i64)) { return 0; }

    if (k == (NK::TryCatchStmt as i64)) { return cg_compile_trycatch(s); }
    if (k == (NK::ThrowStmt as i64)) { return cg_compile_throw(s); }
    if (k == (NK::YieldStmt as i64)) {
        if (nk_a(s) >= 0) { cg_eval(nk_a(s)); } else { cg_mov_reg_imm64(RAX, 0); }
        let frame: i64 = 32; cg_sub_reg_imm32(RSP, frame); cg_mov_reg_reg(RCX, RAX);
        let sym: i64 = cg_sym_index(string_from_slice("__ember_coro_yield"));
        let pts: i64 = cg_fp_types_get(); array_set_i64(pts, 0, TY_I64);
        cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, sym, cg_abi_fingerprint(pts, 1, TY_I64, 0)); cg_call_reg(RAX);
        cg_add_reg_imm32(RSP, frame); return 0;
    }
    // unsupported statement kind in v1
    if (cg_err == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: statement kind unsupported in v1"); }
    return 0;
}

fn cg_struct_field_count(row: i64) -> i64 { let mut n: i64 = 0; let mut f: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1); while (f >= 0) { n = n + 1; f = nk_next(f); } if (n < 1) { return 1; } return n; }

// store a struct literal's fields at packed offsets [off + field_offset].
// Mirrors src/codegen.cpp's LetStmt StructLit init path: eval each field
// expression, store it at base + the field's packed offset with the field's
// width. sema guarantees every field is present + types match.
fn cg_store_struct_lit(lit: i64, t: i64, off: i64) -> i64 {
    let row: i64 = find_struct(ty_struct_name(t));
    if (row < 0) { return 0; }
    let mut f: i64 = array_get_i64(g_structs, row * STRUCT_STRIDE + 1);
    let mut idx: i64 = 0;
    while (f >= 0) {
        // find the matching FieldInit by name (sema already verified it exists)
        let mut init: i64 = nk_a(lit);
        while (init >= 0 && (nk_name(init) == nk_name(f)) == false) { init = nk_next(init); }
        if (init >= 0) {
            let ft: i64 = resolve_type(nk_a(f));
            let foff: i64 = cg_struct_field_offset(row, idx);
            cg_eval(nk_a(init)); if (cg_err != 0) { return 0; }
            if (ty_is_float(ft) == 1) {
                cg_store_float(off + foff, XMM0, cg_float_is64_type(ft));
            } else {
                cg_normalize_rax(ft);
                cg_store_typed(RBP, off + foff, ft);
            }
        }
        idx = idx + 1;
        f = nk_next(f);
    }
    return 0;
}

// (Phase 3 Step 2/3 placeholders — implemented below. Forward declarations
// so the LetStmt dispatch compiles before the bodies are filled in.)
fn cg_store_arraylit_let(lit: i64, t: i64, off: i64) -> i64 { return cg_store_arraylit_let_impl(lit, t, off); }
// store an array literal as a let initializer at `off` (the local's base).
// Mirrors src/codegen.cpp's LetStmt ArrayLit init path. Two shapes:
//   (a) fixed array T[N]: elements go directly into the local's inline slot,
//       each at base + i*elem_size via cg_store_typed (handles widths + floats).
//   (b) slice T[]: the local is the 16-byte {ptr,len} pair; the elements go
//       into a separate backing region in cg_data, then ptr=addend (ABS64_DATA)
//       + len=count are stored into the slice slot. (STEP 3.)
fn cg_store_arraylit_let_impl(lit: i64, t: i64, off: i64) -> i64 {
    let mut is_sl: i64 = 0;
    if (t >= 0 && nk_kind(t) == (NK::Type as i64)) { is_sl = nk_f(t); }
    let mut elem_ty: i64 = -1;
    if (t >= 0) { elem_ty = resolve_type(nk_a(t)); }
    if (cg_err != 0) { return 0; }
    let elem_sz: i64 = cg_value_bytes(elem_ty);
    if (is_sl == 1) { return cg_store_slice_arraylit(lit, t, off, elem_ty, elem_sz); }
    // fixed array T[N]: elements inline at base + i*elem_sz
    let mut el: i64 = nk_a(lit);
    let mut i: i64 = 0;
    while (el >= 0) {
        cg_eval(el); if (cg_err != 0) { return 0; }
        if (ty_is_float(elem_ty) == 1) {
            cg_store_float(off + i * elem_sz, XMM0, cg_float_is64_type(elem_ty));
        } else {
            cg_normalize_rax(elem_ty);
            cg_store_typed(RBP, off + i * elem_sz, elem_ty);
        }
        i = i + 1;
        el = nk_next(el);
    }
    return 0;
}

// (STEP 3 slice-array-literal backing.) Materialize the elements into a
// fresh backing region in cg_data, then store the slice {ptr=addend, len=count}
// into the 16-byte local at `off` (ptr at off, len at off+8). The ptr is
// patched at load time via an ABS64_DATA reloc (the data section's base + the
// backing addend). Mirrors src/codegen.cpp's slice-ArrayLit LetStmt path
// (which uses a frame temp; the self-hosted compiler uses the data section as
// the backing region since it has no frame-temp allocator and the literals
// are immutable).
fn cg_store_slice_arraylit(lit: i64, t: i64, off: i64, elem_ty: i64, elem_sz: i64) -> i64 {
    // count elements
    let mut count: i64 = 0;
    let mut el: i64 = nk_a(lit);
    while (el >= 0) { count = count + 1; el = nk_next(el); }
    // allocate count*elem_sz bytes in cg_data + write each element's LE bytes
    let back: i64 = cg_data_alloc(count * elem_sz);
    el = nk_a(lit);
    let mut i: i64 = 0;
    while (el >= 0) {
        // eval the element -> rax (int) or xmm0 (float), then write its LE
        // bytes into cg_data at back + i*elem_sz. We must AVOID emitting
        // runtime stores to cg_data (it's a host-owned byte array built at
        // compile time); instead, fold the element to a compile-time constant
        // + write the bytes directly. v1 slice literals only carry constant
        // integer elements (sema-checked); a non-constant element is rejected.
        let ev: i64 = cg_eval_const_i64(el);
        if (cg_err != 0) { return 0; }
        let mut b: i64 = 0;
        while (b < elem_sz) {
            array_set_u8(cg_data, back + i * elem_sz + b, (ev >> (b * 8)) & 0xFF);
            b = b + 1;
        }
        i = i + 1;
        el = nk_next(el);
    }
    // store ptr = <data_base + back> into [rbp+off] via an ABS64_DATA reloc.
    // mov rax, <data_base+back>; mov [rbp+off], rax
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_DATA, 0, back);
    cg_store_reg_mem(RBP, off, RAX);
    // store len = count into [rbp+off+8]
    cg_mov_reg_imm64(RAX, count);
    cg_store_reg_mem(RBP, off + 8, RAX);
    return 0;
}

// the current function's epilogue label (set in cg_compile_func)
global cg_epilogue_label : i64 = 0;

// loop context for break/continue (v1: single-level, no nesting stack)
global cg_loop_depth   : i64 = 0;
global cg_loop_break   : i64 = 0;
global cg_loop_continue: i64 = 0;

// Phase 3b: lexical defer cleanup. A defer stack (g_defers) holds deferred
// expr node indices in declaration order; a parallel mark stack
// (g_defer_marks) records the g_defers length at each block entry, so a
// block exit can emit + truncate exactly its own defers. break/continue/return
// emit pending defers from the inner scopes outward (LIFO) before jumping,
// mirroring src/codegen.cpp's cleanup-scope emission. cg_loop_defer_mark
// records the defer-mark depth at the current loop/switch entry so break /
// continue clean up only the scopes opened inside that loop/switch.
global g_defers        : i64 = 0;   // array of deferred expr node indices
global g_defer_marks   : i64 = 0;   // array of mark depths (g_defers length)
global g_defer_mark_len: i64 = 0;   // live mark-stack depth
global cg_cur_ret      : i64 = 0;   // current fn's resolved return type (-1 none)
// Tier 1 namespaces: the namespace name token of the fn currently being
// compiled (-1 = top-level). Set in cg_compile_func so a bare call inside a
// namespaced fn resolves to the sibling Ns::fn label (mirrors sema's s_cur_ns).
global cg_cur_ns : i64 = -1;
// per-loop/switch saved defer-mark depth, so break/continue clean up only the
// scopes opened inside the current loop/switch (mirrors src/codegen.cpp's
// cleanup_scopes.size() captured in the LoopFrame).
global cg_loop_defer_mark: i64 = 0;

// push a defer-scope mark: record the current g_defers length as the cleanup
// boundary for the block about to be compiled.
fn cg_defer_push_mark() -> i64 {
    if (array_length(g_defer_marks) < g_defer_mark_len + 1) {
        array_resize(g_defer_marks, g_defer_mark_len + 1);
    }
    array_set_i64(g_defer_marks, g_defer_mark_len, array_length(g_defers));
    g_defer_mark_len = g_defer_mark_len + 1;
    return 0;
}

// pop a defer-scope mark (after the block's defers have been emitted + the
// stack truncated to the mark).
fn cg_defer_pop_mark() -> i64 {
    if (g_defer_mark_len > 0) { g_defer_mark_len = g_defer_mark_len - 1; }
    return 0;
}

// record a deferred expr (the DeferStmt's expr) on the current scope's defer
// stack. Emits NO code inline; the expr is emitted at scope exit. Mirrors
// src/codegen.cpp's DeferStmt (which sets a per-site activation flag instead;
// this stack form is semantically equivalent for the subset).
fn cg_compile_defer(s: i64) -> i64 {
    let expr: i64 = nk_a(s);
    if (expr >= 0) {
        array_push_i64(g_defers, expr);
    }
    return 0;
}

// emit the deferred exprs in the range [lo, hi) in REVERSE order (LIFO). Each
// defer's expr is evaluated for its side effect (result discarded). Mirrors
// src/codegen.cpp's emit_cleanup_scope (rbegin -> rend).
fn cg_emit_defer_range(lo: i64, hi: i64) -> i64 {
    let mut i: i64 = hi - 1;
    while (i >= lo) {
        cg_eval(array_get_i64(g_defers, i));
        if (cg_err != 0) { return 0; }
        i = i - 1;
    }
    return 0;
}

// emit + truncate the current scope's defers (from its mark to the end of the
// defer stack), then pop the mark. Used at a block's normal fallthrough exit.
fn cg_defer_emit_scope() -> i64 {
    if (g_defer_mark_len == 0) { return 0; }
    let mark: i64 = array_get_i64(g_defer_marks, g_defer_mark_len - 1);
    let end: i64 = array_length(g_defers);
    cg_emit_defer_range(mark, end);
    // truncate the defer stack back to the mark (this scope's defers are spent)
    array_resize(g_defers, mark);
    g_defer_mark_len = g_defer_mark_len - 1;
    return 0;
}

// emit all pending defers (the whole stack) in reverse with NO register
// result to stash — used at a struct-by-value return (the struct is already
// written through the hidden dest pointer; there is no rax/xmm0/rdx result
// to preserve). The dest pointer is reloaded into rax by the caller AFTER
// this. A defer's expr may clobber rax/r11/xmm, but none of those hold a
// live struct-return value at this point. Mirrors the struct-return branch
// of src/codegen.cpp's ReturnStmt (which calls emit_cleanups_to(0) with no
// stash, then reloads the dest ptr into rax).
fn cg_defer_emit_all_nostash() -> i64 {
    if (array_length(g_defers) == 0) { return 0; }
    cg_emit_defer_range(0, array_length(g_defers));
    return 0;
}

// emit all pending defers (the whole stack) in reverse — used at a function
// return. Mirrors src/codegen.cpp's emit_cleanups_to(0). The return value(s)
// are already in rax (and rdx for a two-word / xmm0 for a float return); they
// are stashed across the defer exprs (a defer may clobber rax/xmm0/rdx) and
// restored after, matching the C++ stash/restore around emit_cleanups_to(0).
fn cg_defer_emit_all_and_stash() -> i64 {
    if (array_length(g_defers) == 0) { return 0; }
    // stash the return value across the defers. i64 return -> rax; a float
    // return -> xmm0; a slice/two-word return -> {rax, rdx}. Reserve a
    // 16-byte temp on the stack (keeps rsp 16-aligned for any calls the
    // defers make), matching the C++ sub rsp,16 stash.
    let ret_ty: i64 = cg_cur_ret;
    let mut is_float: i64 = 0;
    let mut is_two_word: i64 = 0;
    if (ret_ty >= 0) {
        if (ty_is_float(ret_ty) == 1) { is_float = 1; }
        if (nk_kind(ret_ty) == (NK::Type as i64) && nk_f(ret_ty) == 1) { is_two_word = 1; }
    }
    cg_sub_reg_imm32(RSP, 16);
    if (is_float == 1) {
        cg_store_float(0, XMM0, cg_float_is64_type(ret_ty));
    } else {
        cg_store_reg_mem(RSP, 0, RAX);
        if (is_two_word == 1) { cg_store_reg_mem(RSP, 8, RDX); }
    }
    // emit the whole defer stack in reverse (LIFO), leaving it intact (a
    // return exits the function; the stack is discarded with the frame).
    cg_emit_defer_range(0, array_length(g_defers));
    if (cg_err != 0) { return 0; }
    // restore the return value(s)
    if (is_float == 1) {
        cg_load_float(XMM0, 0, cg_float_is64_type(ret_ty));
    } else {
        cg_load_reg_mem(RAX, RSP, 0);
        if (is_two_word == 1) { cg_load_reg_mem(RDX, RSP, 8); }
    }
    cg_add_reg_imm32(RSP, 16);
    return 0;
}

// emit defers from the current inner scopes down to (but not including) the
// scope at `retain_mark_len`, truncating the stack as each scope's defers run.
// Used by break/continue to clean up the scopes opened inside a loop/switch
// before jumping to the loop's break/continue target. Mirrors src/codegen.cpp's
// emit_cleanups_to(retained_depth).
fn cg_defer_emit_to(retain_mark_len: i64) -> i64 {
    while (g_defer_mark_len > retain_mark_len) {
        let mark: i64 = array_get_i64(g_defer_marks, g_defer_mark_len - 1);
        let end: i64 = array_length(g_defers);
        cg_emit_defer_range(mark, end);
        if (cg_err != 0) { return 0; }
        array_resize(g_defers, mark);
        g_defer_mark_len = g_defer_mark_len - 1;
    }
    return 0;
}

// compile a try/catch/throw statement. Uses raw JIT bytes on context_t::catch_bufs
// via r14 (the context pointer, callee-saved + preserved across call_raw).
// Mirrors src/codegen.cpp / thin_emit.cpp's TryCatch + Throw emission.
//
// catch_bufs[depth] layout (64 bytes): [0]rbx [8]rbp [16]r12 [24]r13 [32]r14
// [40]r15 [48]rsp [56]catch-entry-rip. catch_saved_call_depths[depth] snapshots
// call_depth at try-entry so a cross-frame throw restores the catching frame's
// depth. catch_depth is the 0-based index (incremented AFTER saving).
fn cg_compile_trycatch(s: i64) -> i64 {
    let try_b: i64 = nk_a(s);     // try body (BlockStmt)
    let catch_b: i64 = nk_b(s);   // catch body (BlockStmt)
    let cnametok: i64 = nk_tok(s); // catch variable name token

    // context offsets (compile-time constants from host natives)
    let cd_off: i64 = context_off_catch_depth();
    let cb_off: i64 = context_off_catch_bufs();
    let csd_off: i64 = context_off_catch_saved_depths();

    cg_push_scope();
    let catch_off: i64 = cg_alloc_local_t(cnametok, TY_I64, 1);

    let catch_label: i64 = cg_alloc_label();
    let end_label: i64 = cg_alloc_label();

    // ===== SETJMP: save state into catch_bufs[catch_depth] =====
    // 1. load catch_depth (32-bit, zero-extended) -> rax
    cg_load_elem_to_rax(R14, cd_off, 4, 0);
    // save catch_depth in r10 (for snapshot + increment later)
    cg_mov_reg_reg(R10, RAX);
    // 2. compute catch_bufs[catch_depth] address -> r9
    //    r9 = r14 + cb_off + catch_depth * 64
    cg_shift_left_imm8(RAX, 6);   // rax = catch_depth * 64
    cg_mov_reg_reg(R9, R14);
    cg_add_reg_imm32(R9, cb_off);
    cg_add_reg_reg(R9, RAX);      // r9 = &catch_bufs[catch_depth]
    // 3. save 6 callee-saved regs + rsp
    cg_store_reg_mem(R9, 0, RBX);
    cg_store_reg_mem(R9, 8, RBP);
    cg_store_reg_mem(R9, 16, R12);
    cg_store_reg_mem(R9, 24, R13);
    cg_store_reg_mem(R9, 32, R14);
    cg_store_reg_mem(R9, 40, R15);
    cg_store_reg_mem(R9, 48, RSP);
    // 4. save catch-entry rip (PC-relative lea to catch_label)
    cg_lea_reg_rip(RAX, catch_label);
    cg_store_reg_mem(R9, 56, RAX);
    // 5. save call_depth snapshot into catch_saved_call_depths[catch_depth]
    //    r10 still has catch_depth; r11 = catch_depth * 4
    cg_mov_reg_reg(R11, R10);
    cg_shift_left_imm8(R11, 2);   // r11 = catch_depth * 4
    cg_mov_reg_reg(R8, R14);
    cg_add_reg_imm32(R8, csd_off);
    cg_add_reg_reg(R8, R11);      // r8 = &saved_depths[catch_depth]
    // call_depth is at offset 8 in context_t (catch_depth at offset 20, diff=12)
    let call_depth_off: i64 = cd_off - 12;
    cg_load_elem_to_rax(R14, call_depth_off, 4, 0);
    cg_store_rax_elem(R8, 0, 4);
    // 6. catch_depth++
    cg_add_reg_imm32(R10, 1);
    cg_mov_reg_reg(RAX, R10);
    cg_store_rax_elem(R14, cd_off, 4);

    // ===== TRY BODY =====
    cg_compile_block(try_b);
    if (cg_err != 0) { cg_pop_scope(); return 0; }

    // ===== CATCH CLEANUP: on normal try completion, catch_depth-- =====
    cg_load_elem_to_rax(R14, cd_off, 4, 0);
    cg_sub_reg_imm32(RAX, 1);
    cg_store_rax_elem(R14, cd_off, 4);

    // jump past the catch block
    cg_jmp(end_label);

    // ===== CATCH BLOCK =====
    cg_bind(catch_label);
    // load thrown_value -> rax, store to catch variable frame slot
    let tv_off: i64 = context_off_thrown_value();
    cg_load_reg_mem(RAX, R14, tv_off);
    cg_store_reg_mem(RBP, catch_off, RAX);
    // compile catch body
    cg_compile_block(catch_b);
    if (cg_err != 0) { cg_pop_scope(); return 0; }

    cg_bind(end_label);
    cg_pop_scope();
    return 0;
}

// compile a throw statement: store the thrown value into context_t::thrown_value,
// then longjmp to the most recent catch handler by restoring callee-saved regs
// + rsp from catch_bufs[catch_depth-1] and jumping to the saved catch-entry rip.
fn cg_compile_throw(s: i64) -> i64 {
    // 1. evaluate throw expression -> rax (the thrown value)
    cg_eval(nk_a(s));
    if (cg_err != 0) { return 0; }
    // 2. store thrown value into context_t::thrown_value
    let tv_off: i64 = context_off_thrown_value();
    cg_store_reg_mem(R14, tv_off, RAX);
    // 3. load catch_depth (32-bit) -> rax
    let cd_off: i64 = context_off_catch_depth();
    cg_load_elem_to_rax(R14, cd_off, 4, 0);
    // 4. if catch_depth == 0 -> unhandled throw (trap via ud2)
    cg_cmp_reg_imm32(RAX, 0);
    let no_handler: i64 = cg_alloc_label();
    cg_jcc(COND_E, no_handler);
    // 5. catch_depth-- : rax = catch_depth - 1
    cg_sub_reg_imm32(RAX, 1);
    cg_mov_reg_reg(R10, RAX);   // r10 = catch_depth - 1 (saved for buf ptr)
    // store decremented catch_depth (32-bit)
    cg_store_rax_elem(R14, cd_off, 4);
    // 6. compute catch_bufs[catch_depth-1] address -> r9
    let cb_off: i64 = context_off_catch_bufs();
    cg_shift_left_imm8(RAX, 6);  // rax = (catch_depth-1) * 64
    cg_mov_reg_reg(R9, R14);
    cg_add_reg_imm32(R9, cb_off);
    cg_add_reg_reg(R9, RAX);     // r9 = &catch_bufs[catch_depth-1]
    // 7. load catch-entry rip from [r9+56] -> rax (BEFORE restoring regs)
    cg_load_reg_mem(RAX, R9, 56);
    // 8. restore 6 callee-saved regs + rsp from catch_bufs
    cg_load_reg_mem(RBX, R9, 0);
    cg_load_reg_mem(RBP, R9, 8);
    cg_load_reg_mem(R12, R9, 16);
    cg_load_reg_mem(R13, R9, 24);
    cg_load_reg_mem(R14, R9, 32);
    cg_load_reg_mem(R15, R9, 40);
    cg_load_reg_mem(RSP, R9, 48);  // restore rsp last
    // 9. jmp to catch-entry rip
    cg_jmp_reg(RAX);
    // 10. no handler: ud2 (unhandled throw trap)
    cg_bind(no_handler);
    cg_byte(0x0F); cg_byte(0x0B);  // ud2
    return 0;
}

// compile a block: push scope, compile each stmt, pop scope.
fn cg_compile_block(b: i64) -> i64 {
    if (b < 0) { return 0; }
    cg_push_scope();
    // Phase 3b: this lexical Block owns one defer cleanup scope. Push a mark
    // so defers declared inside run (LIFO) at the block's normal fallthrough
    // exit, mirroring src/codegen.cpp's exec_block cleanup-scope push/pop.
    cg_defer_push_mark();
    let mut s: i64 = nk_a(b);
    while (s >= 0) {
        cg_compile_stmt(s);
        if (cg_err != 0) { cg_defer_pop_mark(); cg_pop_scope(); return 0; }
        s = nk_next(s);
    }
    // normal fallthrough: emit this scope's defers (LIFO) + truncate the stack
    // to the mark, BEFORE popping the local scope (the defer exprs may
    // reference locals whose frame slots are still live at runtime).
    cg_defer_emit_scope();
    cg_pop_scope();
    return 0;
}

// Phase 3b: compile a bare linked list of stmts (a switch case body, which
// the parser stores as nk_b(case) = first stmt, NOT a BlockStmt). Same
// scope + defer-cleanup handling as cg_compile_block.
fn cg_compile_stmtlist(first_stmt: i64) -> i64 {
    cg_push_scope();
    cg_defer_push_mark();
    let mut s: i64 = first_stmt;
    while (s >= 0) {
        cg_compile_stmt(s);
        if (cg_err != 0) { cg_defer_pop_mark(); cg_pop_scope(); return 0; }
        s = nk_next(s);
    }
    cg_defer_emit_scope();
    cg_pop_scope();
    return 0;
}

// compile an if statement:
//   eval cond -> rax; cmp rax, 0; je else_l; <then>; jmp end_l; else_l: <else>; end_l:
fn cg_compile_if(s: i64) -> i64 {
    let cond: i64 = nk_a(s);
    let then_b: i64 = nk_b(s);
    let else_b: i64 = nk_c(s);   // -1 if no else

    cg_eval(cond);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);

    let else_l: i64 = cg_alloc_label();
    let end_l: i64 = cg_alloc_label();
    cg_jcc(COND_E, else_l);       // cond == 0 -> else

    cg_compile_block(then_b);
    if (cg_err != 0) { return 0; }

    if (else_b >= 0) {
        cg_jmp(end_l);
        cg_bind(else_l);
        cg_compile_block(else_b);
        if (cg_err != 0) { return 0; }
        cg_bind(end_l);
    } else {
        cg_bind(else_l);
    }
    return 0;
}

// compile a while statement:
//   top: eval cond -> rax; cmp rax, 0; je end; <body>; jmp top; end:
fn cg_compile_while(s: i64) -> i64 {
    let cond: i64 = nk_a(s);
    let body: i64 = nk_b(s);

    let top: i64 = cg_alloc_label();
    let end: i64 = cg_alloc_label();

    cg_bind(top);
    cg_eval(cond);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    cg_jcc(COND_E, end);          // cond == 0 -> exit loop

    // set up break/continue targets
    let saved_depth: i64 = cg_loop_depth;
    let saved_break: i64 = cg_loop_break;
    let saved_cont: i64 = cg_loop_continue;
    let saved_dmark: i64 = cg_loop_defer_mark;
    cg_loop_depth = 1;
    cg_loop_break = end;
    cg_loop_continue = top;
    cg_loop_defer_mark = g_defer_mark_len;   // break/continue clean up only inner scopes

    cg_compile_block(body);

    // restore loop context
    cg_loop_depth = saved_depth;
    cg_loop_break = saved_break;
    cg_loop_continue = saved_cont;
    cg_loop_defer_mark = saved_dmark;
    if (cg_err != 0) { return 0; }

    cg_jmp(top);                   // back-edge
    cg_bind(end);
    return 0;
}

// compile a for statement (C-style):
//   <init>; top: <cond>; je end; <body>; cont: <step>; jmp top; end:
fn cg_compile_for(s: i64) -> i64 {
    let init: i64 = nk_a(s);    // LetStmt or -1
    let cond: i64 = nk_b(s);    // expr or -1
    let step: i64 = nk_c(s);    // expr or -1
    let body: i64 = nk_e(s);    // BlockStmt

    cg_push_scope();
    // init
    if (init >= 0) {
        cg_compile_stmt(init);
        if (cg_err != 0) { cg_pop_scope(); return 0; }
    }

    let top: i64 = cg_alloc_label();
    let cont: i64 = cg_alloc_label();
    let end: i64 = cg_alloc_label();

    cg_bind(top);
    // cond
    if (cond >= 0) {
        cg_eval(cond);
        if (cg_err != 0) { cg_pop_scope(); return 0; }
        cg_cmp_reg_imm32(RAX, 0);
        cg_jcc(COND_E, end);     // cond == 0 -> exit
    }

    // set up break/continue targets
    let saved_depth: i64 = cg_loop_depth;
    let saved_break: i64 = cg_loop_break;
    let saved_cont: i64 = cg_loop_continue;
    let saved_dmark: i64 = cg_loop_defer_mark;
    cg_loop_depth = 1;
    cg_loop_break = end;
    cg_loop_continue = cont;
    cg_loop_defer_mark = g_defer_mark_len;   // break/continue clean up only inner scopes

    cg_compile_block(body);

    cg_loop_depth = saved_depth;
    cg_loop_break = saved_break;
    cg_loop_continue = saved_cont;
    cg_loop_defer_mark = saved_dmark;
    if (cg_err != 0) { cg_pop_scope(); return 0; }

    cg_bind(cont);
    // step
    if (step >= 0) {
        cg_eval(step);
        if (cg_err != 0) { cg_pop_scope(); return 0; }
    }
    cg_jmp(top);                   // back-edge
    cg_bind(end);
    cg_pop_scope();
    return 0;
}

// compile a for-each statement: for (x in iter) { body }. Two iterable kinds
// (the iterable() hook, mirroring src/codegen.cpp's ForEachStmt):
//   - array<T> handle (sema stored the inferred elem type in slot c)
//     -> len = array_length(h); while i<len { x = array_get_*(h,i); body; i++ }
//   - slice T[] (slot c is -1, the unchanged shipped path)
//        -> eval iter -> {rax=ptr, rdx=len}; stash ptr,len,idx; loop i=0..len,
//           load elem [ptr + i*esz] into the loop var, run the body, i++.
// break -> end, continue -> latch (the i++ step) for both paths.
fn cg_compile_foreach(s: i64) -> i64 {
    let vtok: i64 = nk_tok(s);     // loop var name token
    let iter: i64 = nk_a(s);       // iterable expr
    let body: i64 = nk_b(s);       // body block
    let arr_elem: i64 = nk_c(s);   // inferred array elem type (-1 = slice path)

    if (arr_elem >= 0) {
        return cg_compile_foreach_array(s, vtok, iter, body, arr_elem);
    }
    return cg_compile_foreach_slice(s, vtok, iter, body);
}

// array-handle for-each: len = array_length(h); i = 0;
// while (i < len) { x = array_get_*(h, i); body; i = i + 1; }
// Mirrors src/codegen.cpp's ForEachStmt array branch. The handle is an i64
// opaque value (from array_new); array_length + array_get_* are host natives
// emitted via ABS64_NATIVE. Win64: rcx = handle, rdx = index, 32-byte shadow.
fn cg_compile_foreach_array(s: i64, vtok: i64, iter: i64, body: i64, elem_ty: i64) -> i64 {
    // dispatch the typed get native from the inferred element type
    // (1 -> u8/array_get_u8, 4 -> f32/array_get_f32, 8 -> i64/array_get_i64).
    let mut get_name: string = string_from_slice("array_get_i64");
    if (ty_is_uint(elem_ty) == 1 && cg_value_bytes(elem_ty) == 1) {
        get_name = string_from_slice("array_get_u8");
    } else if (ty_is_float(elem_ty) == 1 && cg_float_is64_type(elem_ty) == 0) {
        get_name = string_from_slice("array_get_f32");
    }

    // hidden frame slots: handle, len, idx (each 8 bytes) + the loop var (1 slot).
    let h_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
    let len_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
    let idx_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
    let var_off: i64 = cg_alloc_local_t(vtok, elem_ty, 1);

    // eval the iterable -> rax = the i64 array handle; stash it.
    cg_eval(iter); if (cg_err != 0) { return 0; }
    cg_store_reg_mem(RBP, h_off, RAX);

    // len = array_length(h).  Win64: rcx = handle, 32-byte shadow, result in rax.
    cg_sub_reg_imm32(RSP, 32);
    cg_load_reg_mem(RCX, RBP, h_off);
    let len_sym: i64 = cg_sym_index(string_from_slice("array_length"));
    let len_pt: i64 = cg_fp_types_get();
    array_set_i64(len_pt, 0, native_param_type(string_from_slice("array_length"), 0));
    let len_fp: i64 = cg_abi_fingerprint(len_pt, 1, native_ret_type(string_from_slice("array_length")), native_perm(string_from_slice("array_length")));
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, len_sym, len_fp);
    cg_call_reg(RAX);
    cg_add_reg_imm32(RSP, 32);
    cg_store_reg_mem(RBP, len_off, RAX);

    // i = 0.
    cg_mov_reg_imm64(RAX, 0);
    cg_store_reg_mem(RBP, idx_off, RAX);

    let top: i64 = cg_alloc_label();
    let latch: i64 = cg_alloc_label();
    let end: i64 = cg_alloc_label();
    cg_bind(top);
    // if (idx >= len) goto end
    cg_load_reg_mem(RAX, RBP, idx_off);
    cg_load_reg_mem(RDX, RBP, len_off);
    cg_cmp_reg_reg(RAX, RDX);
    cg_jcc(COND_GE, end);

    // x = array_get_*(h, i).  rcx = handle, rdx = index, 32-byte shadow.
    // result: rax (u8/i64) or xmm0 (f32).
    cg_sub_reg_imm32(RSP, 32);
    cg_load_reg_mem(RCX, RBP, h_off);
    cg_load_reg_mem(RDX, RBP, idx_off);
    let get_sym: i64 = cg_sym_index(get_name);
    let get_pt: i64 = cg_fp_types_get();
    array_set_i64(get_pt, 0, native_param_type(get_name, 0));
    array_set_i64(get_pt, 1, native_param_type(get_name, 1));
    let get_fp: i64 = cg_abi_fingerprint(get_pt, 2, native_ret_type(get_name), native_perm(get_name));
    cg_emit_abs64_reloc_reg(RAX, CG_RELOC_NATIVE, get_sym, get_fp);
    cg_call_reg(RAX);
    cg_add_reg_imm32(RSP, 32);
    // store the element into the loop var slot (int via rax, f32 via xmm0).
    if (ty_is_float(elem_ty) == 1) {
        cg_store_float(var_off, XMM0, cg_float_is64_type(elem_ty));
    } else {
        cg_normalize_rax(elem_ty);
        cg_store_reg_mem(RBP, var_off, RAX);
    }

    // set up break/continue targets + run the body.
    let saved_depth: i64 = cg_loop_depth;
    let saved_break: i64 = cg_loop_break;
    let saved_cont: i64 = cg_loop_continue;
    let saved_dmark: i64 = cg_loop_defer_mark;
    cg_loop_depth = 1;
    cg_loop_break = end;
    cg_loop_continue = latch;
    cg_loop_defer_mark = g_defer_mark_len;
    cg_push_scope();
    cg_compile_block(body);
    cg_pop_scope();
    cg_loop_depth = saved_depth;
    cg_loop_break = saved_break;
    cg_loop_continue = saved_cont;
    cg_loop_defer_mark = saved_dmark;
    if (cg_err != 0) { return 0; }

    // latch: idx = idx + 1; jmp top
    cg_bind(latch);
    cg_load_reg_mem(RAX, RBP, idx_off);
    cg_add_reg_imm32(RAX, 1);
    cg_store_reg_mem(RBP, idx_off, RAX);
    cg_jmp(top);
    cg_bind(end);
    return 0;
}

// slice for-each: eval iter -> {rax=ptr, rdx=len}; stash ptr, len, idx into
// hidden frame slots; loop i=0..len, load elem [ptr + i*esz] into the loop
// var, run the body, i++. break -> end, continue -> latch (the i++ step).
// Mirrors src/codegen.cpp's ForEachStmt slice path (unchanged shipped path).
fn cg_compile_foreach_slice(s: i64, vtok: i64, iter: i64, body: i64) -> i64 {

    // element type + stride from the iter's type (a slice)
    let it: i64 = cg_expr_type(iter);
    let mut elem_ty: i64 = -1;
    if (it >= 0) { elem_ty = resolve_type(nk_a(it)); }
    if (cg_err != 0) { return 0; }
    let esz: i64 = cg_value_bytes(elem_ty);
    let mut esz_use: i64 = esz;
    if (esz_use <= 0) { esz_use = 8; }

    // alloc hidden frame slots: ptr, len, idx (each 8 bytes) + the loop var.
    // The loop var is 1 slot (v1 for-each element is a scalar; aggregate
    // elements are a future enhancement, mirroring the C++ codegen note).
    let ptr_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
    let len_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
    let idx_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
    let var_off: i64 = cg_alloc_local_t(vtok, elem_ty, 1);

    // eval the iterable -> {rax=ptr, rdx=len} (the slice ABI from cg_eval_viewexpr
    // / a slice local load). Stash ptr + len into their slots.
    cg_eval(iter); if (cg_err != 0) { return 0; }
    cg_store_reg_mem(RBP, ptr_off, RAX);
    cg_mov_reg_reg(RAX, RDX);          // rdx (len) -> rax for the store
    cg_store_reg_mem(RBP, len_off, RAX);
    cg_mov_reg_imm64(RAX, 0);
    cg_store_reg_mem(RBP, idx_off, RAX);   // i = 0

    let top: i64 = cg_alloc_label();
    let latch: i64 = cg_alloc_label();
    let end: i64 = cg_alloc_label();

    cg_bind(top);
    // if (idx >= len) goto end
    cg_load_reg_mem(RAX, RBP, idx_off);
    cg_load_reg_mem(RDX, RBP, len_off);
    cg_cmp_reg_reg(RAX, RDX);
    cg_jcc(COND_GE, end);              // idx >= len -> exit

    // load element at [ptr + idx*esz] into the loop var slot.
    cg_load_reg_mem(RAX, RBP, ptr_off);    // rax = ptr
    cg_load_reg_mem(RCX, RBP, idx_off);    // rcx = idx
    if (esz_use == 1 || esz_use == 2 || esz_use == 4 || esz_use == 8) {
        let mut sc: i64 = 0;
        if (esz_use == 2) { sc = 1; }
        else if (esz_use == 4) { sc = 2; }
        else if (esz_use == 8) { sc = 3; }
        cg_lea_rax_rax_rcx_scale(sc);   // rax = ptr + idx*scale
    } else {
        cg_mov_reg_imm64(R11, esz_use);
        cg_imul_reg_reg(RCX, R11);          // rcx = idx*esz
        cg_add_reg_reg(RAX, RCX);           // rax = ptr + idx*esz
    }
    // load the element from [rax] with its width into the var slot.
    let mut is_signed: i64 = 0;
    if (cg_type_is_int(elem_ty) == 1 && cg_type_is_uint(elem_ty) == 0) { is_signed = 1; }
    if (ty_is_float(elem_ty) == 1) {
        cg_load_float_reg(XMM0, RAX, 0, cg_float_is64_type(elem_ty));
        cg_store_float(var_off, XMM0, cg_float_is64_type(elem_ty));
    } else if (esz_use >= 8) {
        cg_load_reg_mem(RAX, RAX, 0);
        cg_normalize_rax(elem_ty);
        cg_store_reg_mem(RBP, var_off, RAX);
    } else {
        cg_load_elem_to_rax(RAX, 0, esz_use, is_signed);
        cg_normalize_rax(elem_ty);
        cg_store_reg_mem(RBP, var_off, RAX);
    }

    // set up break/continue targets + run the body.
    let saved_depth: i64 = cg_loop_depth;
    let saved_break: i64 = cg_loop_break;
    let saved_cont: i64 = cg_loop_continue;
    let saved_dmark: i64 = cg_loop_defer_mark;
    cg_loop_depth = 1;
    cg_loop_break = end;
    cg_loop_continue = latch;
    cg_loop_defer_mark = g_defer_mark_len;   // break/continue clean up only inner scopes
    cg_push_scope();
    cg_compile_block(body);
    cg_pop_scope();
    cg_loop_depth = saved_depth;
    cg_loop_break = saved_break;
    cg_loop_continue = saved_cont;
    cg_loop_defer_mark = saved_dmark;
    if (cg_err != 0) { return 0; }

    // latch: idx = idx + 1; jmp top
    cg_bind(latch);
    cg_load_reg_mem(RAX, RBP, idx_off);
    cg_add_reg_imm32(RAX, 1);
    cg_store_reg_mem(RBP, idx_off, RAX);
    cg_jmp(top);
    cg_bind(end);
    return 0;
}

// lea rax, [rax + rcx*scale] (scale: 0->1, 1->2, 2->4, 3->8). Used by for-each
// to compute the element address with a power-of-2 stride.
fn cg_lea_rax_rax_rcx_scale(scale: i64) -> i64 {
    // lea rax, [rax + rcz*2^scale] -> REX.W 8D /r SIB(scale, rcx, rax)
    // mod=00 (no disp), reg=rax, rm=4 (SIB); SIB = scale<<6 | rcx<<3 | rax
    cg_byte(cg_rex(1, 0, 0, 0));            // REX.W (rax/rcx are not extended)
    cg_byte(0x8D);
    cg_byte(cg_modrm(0, RAX, 4));           // mod=00, reg=rax, rm=4 (SIB)
    cg_byte(((scale & 3) << 6) | (1 << 3) | (0 & 7));   // SIB: scale, index=rcx(1), base=rax(0)
    return 0;
}

fn cg_compile_match(s: i64) -> i64 {
    let subject: i64 = nk_a(s);
    // Recompute from the live codegen local table. Sema runs again at codegen
    // entry, so storing canonical type-node indices on the AST would leave
    // stale indices after the second s_init appends a fresh canonical set.
    let subject_ty: i64 = cg_expr_type(subject);
    let is_struct: i64 = ty_is_struct(subject_ty);
    let mut subject_off: i64 = 0;
    if (is_struct == 1) {
        // Aggregate subjects need an address; supported struct values are
        // frame locals/params and therefore have a stable rbp offset.
        if (nk_kind(subject) != (NK::Ident as i64)) {
            cg_err = 1; cg_errmsg = string_from_slice("codegen: struct match subject must be a local"); return 0;
        }
        subject_off = cg_lookup_local(nk_tok(subject));
        if (subject_off == 0) { cg_err = 1; cg_errmsg = string_from_slice("codegen: unknown struct match subject"); return 0; }
    } else {
        cg_eval(subject); cg_push(RAX);
    }

    let end: i64 = cg_alloc_label(); let mut arm: i64 = nk_b(s);
    while (arm >= 0) {
        let next: i64 = cg_alloc_label();
        cg_push_scope();
        if (nk_f(arm) == 1) {
            let row: i64 = find_struct(tok_name(nk_tok(arm)));
            let mut fld: i64 = nk_c(arm);
            while (fld >= 0) {
                let idx: i64 = cg_struct_field_index(subject_ty, nk_name(fld));
                let ft: i64 = cg_struct_field_type_at(row, idx);
                let foff: i64 = cg_struct_field_offset(row, idx);
                cg_load_typed(RAX, RBP, subject_off + foff, ft);
                if (nk_a(fld) < 0) {
                    let cap_off: i64 = cg_alloc_local_t(nk_tok(fld), ft, 1);
                    if (ty_is_float(ft) == 1) { cg_store_float(cap_off, XMM0, cg_float_is64_type(ft)); }
                    else { cg_store_typed(RBP, cap_off, ft); }
                } else {
                    // Constant sub-pattern: compare the extracted field value.
                    cg_push(RAX);
                    cg_eval(nk_a(fld));
                    cg_mov_reg_reg(RCX, RAX);
                    cg_pop(RAX);
                    cg_cmp_reg_reg(RAX, RCX);
                    cg_jcc(COND_NE, next);
                }
                fld = nk_next(fld);
            }
        } else if (nk_d(arm) == 0) {
            cg_eval(nk_a(arm)); cg_mov_reg_reg(RCX, RAX); cg_load_reg_mem(RAX, RSP, 0); cg_cmp_reg_reg(RAX, RCX); cg_jcc(COND_NE, next);
        }
        if (nk_e(arm) >= 0) { cg_eval(nk_e(arm)); cg_cmp_reg_imm32(RAX, 0); cg_jcc(COND_E, next); }
        cg_compile_block(nk_b(arm)); cg_jmp(end);
        cg_bind(next);
        cg_pop_scope();
        arm = nk_next(arm);
    }
    cg_bind(end); if (is_struct == 0) { cg_pop(RCX); } return 0;
}

// Phase 3b: compile a do-while loop. Body runs first, then the cond is
// tested; if nonzero, jump back to the body. break -> end, continue -> cond
// (the condition is the latch, mirroring src/codegen.cpp's DoWhileStmt which
// sets the continue target to `cond`). Mirrors src/codegen.cpp exactly:
//   body: <body>; cond: eval cond; cmp rax,0; je end; jmp body; end:
fn cg_compile_dowhile(s: i64) -> i64 {
    let body: i64 = nk_a(s);
    let cond: i64 = nk_b(s);

    let body_l: i64 = cg_alloc_label();
    let cond_l: i64 = cg_alloc_label();
    let end: i64 = cg_alloc_label();

    cg_bind(body_l);
    // set up break/continue targets (continue -> cond label, break -> end)
    let saved_depth: i64 = cg_loop_depth;
    let saved_break: i64 = cg_loop_break;
    let saved_cont: i64 = cg_loop_continue;
    let saved_dmark: i64 = cg_loop_defer_mark;
    cg_loop_depth = 1;
    cg_loop_break = end;
    cg_loop_continue = cond_l;
    cg_loop_defer_mark = g_defer_mark_len;   // break/continue clean up only inner scopes

    cg_compile_block(body);

    cg_loop_depth = saved_depth;
    cg_loop_break = saved_break;
    cg_loop_continue = saved_cont;
    cg_loop_defer_mark = saved_dmark;
    if (cg_err != 0) { return 0; }

    cg_bind(cond_l);
    cg_eval(cond);
    if (cg_err != 0) { return 0; }
    cg_cmp_reg_imm32(RAX, 0);
    cg_jcc(COND_E, end);          // cond == 0 -> exit
    cg_jmp(body_l);               // back-edge
    cg_bind(end);
    return 0;
}

// Phase 3b: compile a switch. Dispatch prologue: eval the subject into rax,
// hold it in a temp stack slot, compare against each non-default case value,
// je to that case's body label. After all compares, jmp to the default's label
// (or past everything). Case bodies are emitted back-to-back; each nonempty
// case ends with break/return/continue (sema enforces no fallthrough), so an
// implicit break-to-end is NOT inserted — the explicit terminator jumps. break
// inside a case jumps to `end` (switch scopes break like a loop). continue
// inside a case continues the ENCLOSING loop (switch does not override
// cg_loop_continue), mirroring src/codegen.cpp's switch loop-frame
// {continue=Label{0}, break=end}. Mirrors src/codegen.cpp's SwitchStmt.
fn cg_compile_switch(s: i64) -> i64 {
    let subj: i64 = nk_a(s);

    // eval subject -> rax; stash in a temp stack slot across the compare chain
    // (case value evals are immediate loads and don't clobber the slot, but a
    // temp slot is robust + matches the C++ r10-volatile approach in spirit).
    cg_eval(subj);
    if (cg_err != 0) { return 0; }
    cg_push(RAX);

    // pre-allocate a body label per case + an end label. The label is stashed
    // on each Case node's `e` slot (unused by parse/sema) instead of a fresh
    // `case_labels` array — the previous array leaked a slot per switch and
    // was read after `cg_eval(case_value)` which can recurse, so a reused
    // global was unsafe. Stashing on the node is re-entrancy-safe (each case
    // owns its label) and allocation-free.
    let end: i64 = cg_alloc_label();
    let mut c: i64 = nk_b(s);
    while (c >= 0) {
        let lab: i64 = cg_alloc_label();
        set_e(c, lab);
        c = nk_next(c);
    }

    // compare chain: for each non-default case, eval the value, cmp with the
    // stashed subject, je to that case's label. Track the default index.
    let mut default_idx: i64 = -1;
    c = nk_b(s);
    let mut ci: i64 = 0;
    while (c >= 0) {
        if (nk_d(c) == 1) {
            default_idx = ci;
        } else {
            cg_eval(nk_a(c));
            if (cg_err != 0) { return 0; }
            cg_mov_reg_reg(RCX, RAX);          // RCX = case value
            cg_load_reg_mem(RAX, RSP, 0);       // RAX = stashed subject
            cg_cmp_reg_reg(RAX, RCX);
            cg_jcc(COND_E, nk_e(c));
        }
        ci = ci + 1;
        c = nk_next(c);
    }
    // no case matched: jump to default (if any) or past the switch
    if (default_idx >= 0) {
        // find the default case's stashed label
        let mut dc: i64 = nk_b(s);
        let mut di: i64 = 0;
        while (dc >= 0) {
            if (di == default_idx) { cg_jmp(nk_e(dc)); break; }
            di = di + 1;
            dc = nk_next(dc);
        }
    } else {
        cg_jmp(end);
    }

    // emit case bodies. Each case gets its own scope (cg_compile_block pushes
    // one). break inside a case jumps to `end`; continue keeps the enclosing
    // loop's continue target (we only set cg_loop_break, not continue).
    c = nk_b(s);
    ci = 0;
    let saved_depth: i64 = cg_loop_depth;
    let saved_break: i64 = cg_loop_break;
    let saved_dmark: i64 = cg_loop_defer_mark;
    cg_loop_depth = 1;
    cg_loop_break = end;
    cg_loop_defer_mark = g_defer_mark_len;   // break cleans up only inner scopes
    while (c >= 0) {
        cg_bind(nk_e(c));
        // The parser stores a case body as a bare linked list of stmts
        // (nk_b(c) = first stmt), NOT a BlockStmt. Compile it as its own
        // scope + defer cleanup scope, mirroring cg_compile_block.
        cg_compile_stmtlist(nk_b(c));
        if (cg_err != 0) { cg_loop_depth = saved_depth; cg_loop_break = saved_break; cg_loop_defer_mark = saved_dmark; return 0; }
        ci = ci + 1;
        c = nk_next(c);
    }
    cg_loop_depth = saved_depth;
    cg_loop_break = saved_break;
    cg_loop_defer_mark = saved_dmark;

    cg_bind(end);
    // pop the stashed subject (restore rsp; discard into RCX)
    cg_pop(RCX);
    return 0;
}

// =============================================================================
// function compilation.
// =============================================================================

fn cg_count_extra_struct_slots(b: i64) -> i64 {
    let mut extra: i64 = 0; if (b < 0) { return 0; } let mut s: i64 = nk_a(b);
    while (s >= 0) { if (nk_kind(s) == (NK::LetStmt as i64) && nk_a(s) >= 0) { let t: i64 = resolve_type(nk_a(s)); let row: i64 = find_struct(ty_struct_name(t)); if (row >= 0) { extra = extra + cg_struct_field_count(row) - 1; } } if (nk_kind(s) == (NK::IfStmt as i64)) { extra = extra + cg_count_extra_struct_slots(nk_b(s)); if (nk_c(s) >= 0) { extra = extra + cg_count_extra_struct_slots(nk_c(s)); } } if (nk_kind(s) == (NK::WhileStmt as i64)) { extra = extra + cg_count_extra_struct_slots(nk_b(s)); } if (nk_kind(s) == (NK::ForStmt as i64)) { extra = extra + cg_count_extra_struct_slots(nk_e(s)); } s = nk_next(s); }
    return extra;
}

// compile a single function: prologue, param spill, body, epilogue, fixups.
fn cg_compile_func(fd: i64, ns_tok: i64) -> i64 {
    cg_cur_ns = ns_tok;
    let is_lambda_fn: i64 = (nk_kind(fd) == (NK::LambdaExpr as i64)) ? 1 : 0;
    // init the local table for this function
    cg_locals_init();
    // Phase 3b: reset the defer cleanup stack for this function (defers are
    // function-scoped) + record the resolved return type so a return can
    // stash the right value across deferred exprs.
    array_resize(g_defers, 0);
    array_resize(g_defer_marks, 0);
    g_defer_mark_len = 0;
    cg_loop_defer_mark = 0;
    let ret_ty_node: i64 = nk_b(fd);
    if (ret_ty_node >= 0) { cg_cur_ret = resolve_type(ret_ty_node); } else { cg_cur_ret = TY_VOID; }
    // Phase 4: a fn whose return type is a registered struct uses the
    // hidden-pointer sret ABI (word 0 = dest ptr, arrives in rcx). Reset the
    // caller-side dest-ready flag for this fn's body.
    let ret_is_struct: i64 = cg_ty_is_struct(cg_cur_ret);
    cg_struct_ret_dest_ready = 0;
    cg_struct_ret_ptr_off = 0;
    cg_current_lambda = -1;
    cg_lambda_env_off = 0;
    if (is_lambda_fn == 1) { cg_current_lambda = fd; }

    // count params (and accumulate each param's word count for the spill map)
    let mut param_count: i64 = 0;
    let mut p: i64 = nk_a(fd);
    while (p >= 0) {
        param_count = param_count + 1;
        p = nk_next(p);
    }
    // total incoming words = (1 if struct return else 0) + sum(words_for_type
    // over params). Used for the stack-arg source offset of words >= 4.
    let mut total_words: i64 = 0;
    if (ret_is_struct == 1) { total_words = 1; }
    if (is_lambda_fn == 1) { total_words = total_words + 1; }
    {
        let mut pp: i64 = nk_a(fd);
        while (pp >= 0) {
            total_words = total_words + cg_words_for_type(resolve_type(nk_a(pp)));
            pp = nk_next(pp);
        }
    }

    // Count scalar locals, then add aggregate expansion words. The ordinary
    // count remains a conservative baseline for nested control-flow locals.
    let body: i64 = nk_c(fd);
    // cg_count_locals_block now counts each let's actual stack slots
    // (ceil(value_bytes/8) for aggregates, 1 for scalars), so the frame is
    // sized to hold every byte of every local. No separate struct-extra pass.
    let local_count: i64 = cg_count_locals_block(body, 0);
    // Phase 4: add compiler-hidden struct temp slots (struct-literal returns +
    // struct-by-value StructLit/CallExpr args) + the hidden return-pointer slot.
    let struct_temp_slots: i64 = cg_count_struct_temps_block(body, 0, ret_is_struct);
    let hidden_ptr_slots: i64 = ((ret_is_struct == 1) ? 1 : 0) + is_lambda_fn;

    // frame size = (params + locals + struct temps + hidden ptr) * 8, rounded
    // to 16, +8 for the return-address alignment (push rbp makes it 16-aligned).
    let frame: i64 = cg_round16((param_count + local_count + struct_temp_slots + hidden_ptr_slots) * 8 + 8);
    cg_frame_size = frame;

    // epilogue label for this function
    cg_epilogue_label = cg_alloc_label();

    // prologue
    cg_emit_prologue(frame);

    // spill the hidden return pointer (word 0, rcx) to a dedicated frame slot
    // BEFORE the real params (which shift to start at word 1). It is not a
    // script-visible variable, so allocate it with a synthesized token (-1)
    // and record its offset in cg_struct_ret_ptr_off for the ReturnStmt path.
    let mut param_word: i64 = 0;
    if (ret_is_struct == 1) {
        let rptr_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
        cg_struct_ret_ptr_off = rptr_off;
        // word 0 arrives in rcx (the first Win64 int arg reg)
        cg_store_reg_mem(RBP, rptr_off, RCX);
        param_word = 1;
    }
    if (is_lambda_fn == 1) {
        let env_off: i64 = cg_alloc_local_t(-1, TY_I64, 1);
        cg_lambda_env_off = env_off;
        if (param_word == 0) { cg_store_reg_mem(RBP, env_off, RCX); }
        else { cg_store_reg_mem(RBP, env_off, RDX); }
        param_word = param_word + 1;
    }

    // spill params to frame slots. Each param occupies cg_words_for_type(pt)
    // consecutive words; a struct param's bytes are spilled word-by-word into
    // the param local's frame region (the last word may be partial — store only
    // its real remaining bytes so a non-multiple-of-8 struct does not overrun
    // into the next slot / the saved rbp). Mirrors src/codegen.cpp's prologue.
    let mut arg_regs: i64 = cg_arg_regs_get();
    array_set_i64(arg_regs, 0, RCX);
    array_set_i64(arg_regs, 1, RDX);
    array_set_i64(arg_regs, 2, R8);
    array_set_i64(arg_regs, 3, R9);

    let mut pi: i64 = 0;
    p = nk_a(fd);
    while (p >= 0) {
        let pt: i64 = resolve_type(nk_a(p));
        if (cg_ty_is_struct(pt) == 1) {
            let row: i64 = find_struct(ty_struct_name(pt));
            let struct_bytes: i64 = (row >= 0) ? cg_struct_value_bytes(row) : (cg_words_for_type(pt) * 8);
            let wcount: i64 = cg_words_for_type(pt);
            let off: i64 = cg_alloc_local_t(nk_tok(p), pt, wcount);
            let mut byte_pos: i64 = 0;
            let mut w: i64 = 0;
            while (w < wcount) {
                let word_bytes: i64 = (8 < struct_bytes - byte_pos) ? 8 : (struct_bytes - byte_pos);
                let w_global: i64 = param_word + w;
                if (word_bytes >= 8) {
                    // full word: spill the arg reg (w_global < 4) or load from
                    // the caller's outgoing stack area into the local slot.
                    if (w_global < 4) {
                        let reg: i64 = array_get_i64(arg_regs, w_global);
                        cg_store_reg_mem(RBP, off + byte_pos, reg);
                    } else {
                        let src_off: i64 = 48 + (w_global - 4) * 8;
                        cg_load_reg_mem(RAX, RBP, src_off);
                        cg_store_reg_mem(RBP, off + byte_pos, RAX);
                    }
                } else {
                    // partial last word: get the word's value into rax, then
                    // store only its low `word_bytes` bytes.
                    if (w_global < 4) {
                        cg_mov_reg_reg(RAX, array_get_i64(arg_regs, w_global));
                    } else {
                        let src_off: i64 = 48 + (w_global - 4) * 8;
                        cg_load_reg_mem(RAX, RBP, src_off);
                    }
                    cg_store_rax_bytes(RBP, off + byte_pos, word_bytes);
                }
                byte_pos = byte_pos + word_bytes;
                w = w + 1;
            }
        } else if (nk_f(pt) == 1 || nk_f(pt) == 2) {
            // slice/closure param: 2 consecutive integer words -> the local's 16-byte
            // {ptr,len} slot (word 0 -> off, word 1 -> off+8).
            let off: i64 = cg_alloc_local_t(nk_tok(p), pt, 2);
            cg_spill_word(param_word, off, arg_regs, total_words);
            cg_spill_word(param_word + 1, off + 8, arg_regs, total_words);
        } else if (ty_is_float(pt) == 1) {
            let off: i64 = cg_alloc_local_t(nk_tok(p), pt, 1);
            if (param_word < 4) {
                // float args arrive in xmm0..xmm3 (flt_arg_regs[param_word])
                cg_store_float(off, param_word, cg_float_is64_type(pt));
            } else {
                let src_off: i64 = 48 + (param_word - 4) * 8;
                cg_load_reg_mem(RAX, RBP, src_off);
                cg_store_reg_mem(RBP, off, RAX);
            }
        } else {
            let off: i64 = cg_alloc_local_t(nk_tok(p), pt, 1);
            if (param_word < 4) {
                let reg: i64 = array_get_i64(arg_regs, param_word);
                cg_store_reg_mem(RBP, off, reg);
            } else {
                let src_off: i64 = 48 + (param_word - 4) * 8;
                cg_load_reg_mem(RAX, RBP, src_off);
                cg_store_reg_mem(RBP, off, RAX);
            }
        }
        param_word = param_word + cg_words_for_type(pt);
        pi = pi + 1;
        p = nk_next(p);
    }

    // body
    cg_compile_block(body);
    if (cg_err != 0) { return 0; }

    // implicit void return: rax = 0 (only reached by fallthrough — a fn
    // that falls off the end without an explicit return gets rax = 0).
    // This MUST come before the epilogue label bind: every ReturnStmt evals
    // its value into rax then jumps to cg_epilogue_label, so the label must
    // land at the epilogue itself (mov rsp, rbp; pop rbp; ret) — NOT here —
    // or the implicit zeroing would overwrite the return value. (The C++
    // reference codegen emits emit_epilogue() inline at each return instead
    // of jumping to a shared label; this codegen uses the shared-label form,
    // which is equivalent only if the implicit zero is fallthrough-only.)
    // Phase 4: a struct-returning fn's fallthrough has no struct to return;
    // rax = 0 is harmless (the caller's dest was never written, but sema
    // guarantees a struct-returning fn always has an explicit return).
    cg_mov_reg_imm64(RAX, 0);
    // bind the epilogue label + emit the epilogue (returns jump here, with
    // rax already holding their value)
    cg_bind(cg_epilogue_label);
    cg_emit_epilogue();

    // NOTE: label fixups are NOT resolved here — inter-function call rel32
    // fixups reference other fns' entry labels, which are only bound after
    // every fn is compiled. cg_resolve_fixups() is called once at the end of
    // codegen() after all fns are compiled + all entry labels bound.
    return 0;
}

// =============================================================================
// top-level codegen: find the program node, compile each function.
// =============================================================================

// find the program node in g_nodes by scanning for NK::Program.
// (sema() calls parse() internally + doesn't expose the program node index;
//  the Program node is the one with kind == NK::Program, which is unique.)
fn cg_find_program() -> i64 {
    let n: i64 = array_length(g_nodes) / PARSE_STRIDE;
    let mut i: i64 = 0;
    while (i < n) {
        if (nk_kind(i) == (NK::Program as i64)) { return i; }
        i = i + 1;
    }
    return -1;
}

// codegen(source): lex + parse + sema + emit x64 bytes for every fn.
// Returns the array<u8> handle (the code buffer) on success, or 0 on error.
// cg_failed() / cg_err_msg() expose the error state.
fn codegen(source: string) -> i64 {
    // run sema (which parses + type-checks + builds g_fns / g_globals)
    let r: i64 = sema(source);
    if (r != 0) {
        cg_err = 1;
        if (r == 2) {
            cg_errmsg = string_from_slice("codegen: parse error: ") + parse_err_msg();
        } else {
            cg_errmsg = string_from_slice("codegen: sema error: ") + sema_err_msg();
        }
        return 0;
    }

    // init the emitter
    cg_init();

    // find the program node
    let prog: i64 = cg_find_program();
    if (prog < 0) {
        cg_err = 1;
        cg_errmsg = string_from_slice("codegen: no program node found");
        return 0;
    }

    // Allocate the data-section slots for constant-initialized i64 globals
    // AND string globals (zero-filled slots, handles materialized at runtime)
    // BEFORE compiling functions, so global references in fn bodies resolve
    // to their data addend. Each global gets 8 bytes in cg_data + a
    // (name -> addend) entry in cg_globals (§5). String globals are also
    // recorded in cg_str_globals for the init function below.
    cg_compile_globals(prog);

    // Emit the synthetic __globals_init function (materializes each string
    // global's literal + stores the handle into its data slot) BEFORE the user
    // functions so it lands at offset 0 when present (the pipeline's prologue
    // check still sees 0x55 = push rbp at byte 0). No-op (no fn emitted, label
    // stays -1) when the program declares no string globals. Must run before
    // cg_resolve_fixups so its entry label is bound.
    cg_emit_globals_init();

    // Allocate an entry label for every function up front, so a call to a fn
    // declared later (forward reference) gets a fixup for a label that will be
    // bound when that fn is compiled. Stored in cg_fn_labels stride 3
    // (name_tok, label, ns_tok). Descends into NamespaceDecl members.
    let mut d: i64 = nk_a(prog);
    while (d >= 0) {
        if (nk_kind(d) == (NK::NamespaceDecl as i64)) {
            let ns_tok: i64 = nk_tok(d);
            let mut m: i64 = nk_a(d);
            while (m >= 0) {
                if (nk_kind(m) == (NK::FnDecl as i64)) {
                    let lab: i64 = cg_alloc_label();
                    array_push_i64(cg_fn_labels, nk_tok(m));
                    array_push_i64(cg_fn_labels, lab);
                    array_push_i64(cg_fn_labels, ns_tok);
                }
                m = nk_next(m);
            }
        } else if (nk_kind(d) == (NK::FnDecl as i64)) {
            let lab: i64 = cg_alloc_label();
            array_push_i64(cg_fn_labels, nk_tok(d));
            array_push_i64(cg_fn_labels, lab);
            array_push_i64(cg_fn_labels, -1);
        }
        d = nk_next(d);
    }
    // Synthetic lambdas follow user functions in creation order. This makes
    // sema's baked slot (user-fn count + lambda index) match this table.
    let mut lalloc: i64 = 0;
    while (lalloc < array_length(g_lambdas)) {
        let le: i64 = array_get_i64(g_lambdas, lalloc);
        let lab: i64 = cg_alloc_label();
        array_push_i64(cg_fn_labels, -1); array_push_i64(cg_fn_labels, lab); array_push_i64(cg_fn_labels, -1);
        lalloc = lalloc + 1;
    }

    // compile each function declaration in the program, binding its entry
    // label at its prologue offset (the current code position) first so any
    // call to it — including a self-recursive call inside its own body —
    // resolves to the right entry offset. Namespaced fns bind via the
    // qualified label lookup. A namespace is a sema/scope concern, not a
    // codegen concern: fns have entry labels regardless of namespace.
    d = nk_a(prog);
    while (d >= 0) {
        if (nk_kind(d) == (NK::NamespaceDecl as i64)) {
            let ns_tok: i64 = nk_tok(d);
            let mut m: i64 = nk_a(d);
            while (m >= 0) {
                if (nk_kind(m) == (NK::FnDecl as i64)) {
                    let mut ns_name: string = string_from_slice("");
                    if (ns_tok >= 0) { ns_name = tok_name(ns_tok); }
                    let lab: i64 = cg_lookup_fn_label_qualified(nk_name(m), ns_name);
                    if (lab >= 0) { cg_bind(lab); }   // entry = current code offset
                    cg_compile_func(m, ns_tok);
                    if (cg_err != 0) { return 0; }
                }
                m = nk_next(m);
            }
        } else if (nk_kind(d) == (NK::FnDecl as i64)) {
            let lab: i64 = cg_lookup_fn_label(nk_name(d));
            if (lab >= 0) { cg_bind(lab); }   // entry = current code offset
            cg_compile_func(d, -1);
            if (cg_err != 0) { return 0; }
        }
        d = nk_next(d);
    }

    // Compile synthetic lambda bodies after ordinary functions. Their labels
    // were allocated after user functions, so their indices are dispatch slots.
    let mut li: i64 = 0;
    while (li < array_length(g_lambdas)) {
        let le: i64 = array_get_i64(g_lambdas, li);
        let slot: i64 = (array_length(cg_fn_labels) / 3) - array_length(g_lambdas) + li;
        let llab: i64 = array_get_i64(cg_fn_labels, slot * 3 + 1);
        cg_bind(llab); cg_compile_func(le, -1); if (cg_err != 0) { return 0; }
        li = li + 1;
    }

    // resolve ALL label fixups now that every fn's entry label (and every
    // intra-fn if/while label) is bound. This patches inter-function call
    // rel32 fixups to the callee's real entry offset within the buffer.
    cg_resolve_fixups();
    if (cg_err != 0) { return 0; }

    return cg_code;  // the array<u8> handle
}

// whether the codegen flagged an error.
fn codegen_failed() -> i64 { return cg_err; }
fn codegen_err_msg() -> string { return cg_errmsg; }

// =============================================================================
// convenience: get the length of the code buffer (byte count).
// =============================================================================
fn codegen_byte_count() -> i64 {
    return array_length(cg_code);
}

// read a byte from the code buffer at offset i (for verification).
fn codegen_byte_at(i: i64) -> i64 {
    if (i < 0 || i >= array_length(cg_code)) { return -1; }
    return array_get_u8(cg_code, i) as i64;
}

// the code offset of a named function's entry (prologue) within the buffer.
// Returns -1 if the fn is not in cg_fn_labels or its label was never bound.
// Used by the end-to-end pipeline to call `main` specifically (the codegen
// lays fns out in declaration order, so `main` may not be at offset 0 when
// the program declares helper fns first); call_raw(page_ptr + entry_offset)
// invokes it.
fn codegen_fn_entry_offset(name: string) -> i64 {
    let lab: i64 = cg_lookup_fn_label(name);
    if (lab < 0) { return -1; }
    return cg_label_offset(lab);
}
