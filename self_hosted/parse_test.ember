// self_hosted/parse_test.ember — tests for the self-hosted ember parser.
//
// TDD: every grammar production implemented is exercised. The test lexes +
// parses known ember snippets and verifies the AST's structure (node kinds,
// child links, operator encodings, names, literal values). main() returns 0
// on full success, or a nonzero code identifying the first failing check (so
// a failure is harness-observable, not a silent 0).
//
// Run: ./buildt/ember_cli.exe run self_hosted/parse_test.ember --fn main
// (exit 0 == all tests pass).

import "parse.ember";

// ---------------------------------------------------------------------------
// assertion helpers — same protocol as lex_test.ember: ck/cks return 0 to
// continue or a nonzero code to bail; the driver returns immediately on the
// first failure.
// ---------------------------------------------------------------------------

global g_pass : i64 = 0;

fn ck(got: i64, want: i64, code: i64) -> i64 {
    if (got == want) { g_pass = g_pass + 1; return 0; }
    return code;
}

fn cks(got: string, want: string, code: i64) -> i64 {
    if (got == want) { g_pass = g_pass + 1; return 0; }
    return code;
}

// ---------------------------------------------------------------------------
// Test 1 — the canonical program:
//   fn main() -> i64 { return 42; }
// Verifies: Program has one FnDecl named "main", ret type is i64, body is a
// block with one ReturnStmt whose value is an IntLit = 42.
// ---------------------------------------------------------------------------
fn test_canonical() -> i64 {
    let prog: i64 = parse("fn main() -> i64 { return 42; }");
    if (parse_failed() != 0) { return 1001; }
    let mut r: i64 = 0;

    // Program node
    r = ck(nk_kind(prog), NK::Program as i64, 1010); if (r != 0) { return r; }

    // first decl = FnDecl
    let fn1: i64 = nk_a(prog);
    r = ck(nk_kind(fn1), NK::FnDecl as i64, 1011); if (r != 0) { return r; }
    r = cks(nk_name(fn1), string_from_slice("main"), 1012); if (r != 0) { return r; }

    // no params (a = -1), ret type = i64, body = block
    r = ck(nk_a(fn1), -1, 1013); if (r != 0) { return r; }   // no params
    let ret: i64 = nk_b(fn1);
    r = ck(nk_kind(ret), NK::Type as i64, 1014); if (r != 0) { return r; }
    r = ck(type_prim(ret), Prim::I64 as i64, 1015); if (r != 0) { return r; }

    let body: i64 = nk_c(fn1);
    r = ck(nk_kind(body), NK::BlockStmt as i64, 1016); if (r != 0) { return r; }

    // body has one stmt: ReturnStmt -> IntLit 42
    let s1: i64 = nk_a(body);
    r = ck(nk_kind(s1), NK::ReturnStmt as i64, 1021); if (r != 0) { return r; }
    let val: i64 = nk_a(s1);
    r = ck(nk_kind(val), NK::IntLit as i64, 1022); if (r != 0) { return r; }
    r = ck(nk_d(val), 42, 1023); if (r != 0) { return r; }
    r = ck(nk_next(s1), -1, 1024); if (r != 0) { return r; }   // no next stmt
    return 0;
}

// ---------------------------------------------------------------------------
// Test 2 — let with a binary expression exercising precedence:
//   fn f() -> i64 { let x: i64 = 1 + 2 * 3; return x; }
// Verifies: 1 + (2 * 3) — the * binds tighter than +, so the top-level BinExpr
// is Add with lhs=IntLit(1) and rhs=BinExpr(Mul, 2, 3).
// ---------------------------------------------------------------------------
fn test_let_precedence() -> i64 {
    let prog: i64 = parse("fn f() -> i64 { let x: i64 = 1 + 2 * 3; return x; }");
    if (parse_failed() != 0) { return 2001; }
    let mut r: i64 = 0;

    let fn1: i64 = nk_a(prog);
    r = ck(nk_kind(fn1), NK::FnDecl as i64, 2010); if (r != 0) { return r; }
    r = cks(nk_name(fn1), string_from_slice("f"), 2011); if (r != 0) { return r; }
    let body: i64 = nk_c(fn1);
    let s1: i64 = nk_a(body);

    // first stmt = LetStmt named "x"
    r = ck(nk_kind(s1), NK::LetStmt as i64, 2020); if (r != 0) { return r; }
    r = cks(nk_name(s1), string_from_slice("x"), 2021); if (r != 0) { return r; }

    // type = i64
    let ty: i64 = nk_a(s1);
    r = ck(type_prim(ty), Prim::I64 as i64, 2022); if (r != 0) { return r; }

    // init = 1 + (2 * 3)
    let init: i64 = nk_b(s1);
    r = ck(nk_kind(init), NK::BinExpr as i64, 2030); if (r != 0) { return r; }
    r = ck(nk_d(init), BinOp::Add as i64, 2031); if (r != 0) { return r; }
    let lhs: i64 = nk_a(init);
    r = ck(nk_kind(lhs), NK::IntLit as i64, 2032); if (r != 0) { return r; }
    r = ck(nk_d(lhs), 1, 2033); if (r != 0) { return r; }
    let rhs: i64 = nk_b(init);
    r = ck(nk_kind(rhs), NK::BinExpr as i64, 2034); if (r != 0) { return r; }
    r = ck(nk_d(rhs), BinOp::Mul as i64, 2035); if (r != 0) { return r; }
    r = ck(nk_d(nk_a(rhs)), 2, 2036); if (r != 0) { return r; }
    r = ck(nk_d(nk_b(rhs)), 3, 2037); if (r != 0) { return r; }

    // second stmt = return x
    let s2: i64 = nk_next(s1);
    r = ck(nk_kind(s2), NK::ReturnStmt as i64, 2040); if (r != 0) { return r; }
    let rv: i64 = nk_a(s2);
    r = ck(nk_kind(rv), NK::Ident as i64, 2041); if (r != 0) { return r; }
    r = cks(nk_name(rv), string_from_slice("x"), 2042); if (r != 0) { return r; }
    return 0;
}

// ---------------------------------------------------------------------------
// Test 3 — if/else with a condition + nested calls:
//   fn g(x: i64) -> i64 { if (x > 0) { return foo(x); } else { return bar(x, 1); } }
// Verifies: IfStmt cond is a BinExpr(Gt), then-block has a ReturnStmt wrapping
// a CallExpr "foo" with one arg, else-block has a ReturnStmt wrapping a
// CallExpr "bar" with two args.
// ---------------------------------------------------------------------------
fn test_if_else_calls() -> i64 {
    let prog: i64 = parse("fn g(x: i64) -> i64 { if (x > 0) { return foo(x); } else { return bar(x, 1); } }");
    if (parse_failed() != 0) { return 3001; }
    let mut r: i64 = 0;

    let fn1: i64 = nk_a(prog);
    r = cks(nk_name(fn1), string_from_slice("g"), 3010); if (r != 0) { return r; }

    // one param named "x" of type i64
    let p1: i64 = nk_a(fn1);
    r = ck(nk_kind(p1), NK::Param as i64, 3011); if (r != 0) { return r; }
    r = cks(nk_name(p1), string_from_slice("x"), 3012); if (r != 0) { return r; }
    r = ck(type_prim(nk_a(p1)), Prim::I64 as i64, 3013); if (r != 0) { return r; }
    r = ck(nk_next(p1), -1, 3014); if (r != 0) { return r; }   // no next param

    let body: i64 = nk_c(fn1);
    let ifs: i64 = nk_a(body);
    r = ck(nk_kind(ifs), NK::IfStmt as i64, 3020); if (r != 0) { return r; }

    // cond = x > 0
    let cond: i64 = nk_a(ifs);
    r = ck(nk_kind(cond), NK::BinExpr as i64, 3021); if (r != 0) { return r; }
    r = ck(nk_d(cond), BinOp::Gt as i64, 3022); if (r != 0) { return r; }
    r = cks(nk_name(nk_a(cond)), string_from_slice("x"), 3023); if (r != 0) { return r; }

    // then-block: return foo(x)
    let then_b: i64 = nk_b(ifs);
    r = ck(nk_kind(then_b), NK::BlockStmt as i64, 3030); if (r != 0) { return r; }
    let tret: i64 = nk_a(then_b);
    r = ck(nk_kind(tret), NK::ReturnStmt as i64, 3031); if (r != 0) { return r; }
    let call1: i64 = nk_a(tret);
    r = ck(nk_kind(call1), NK::CallExpr as i64, 3032); if (r != 0) { return r; }
    r = cks(nk_name(call1), string_from_slice("foo"), 3033); if (r != 0) { return r; }
    // one arg: x
    let arg1: i64 = nk_a(call1);
    r = ck(nk_kind(arg1), NK::Ident as i64, 3034); if (r != 0) { return r; }
    r = cks(nk_name(arg1), string_from_slice("x"), 3035); if (r != 0) { return r; }
    r = ck(nk_next(arg1), -1, 3036); if (r != 0) { return r; }   // no next arg

    // else-block: return bar(x, 1)
    let else_b: i64 = nk_c(ifs);
    r = ck(nk_kind(else_b), NK::BlockStmt as i64, 3040); if (r != 0) { return r; }
    let eret: i64 = nk_a(else_b);
    r = ck(nk_kind(eret), NK::ReturnStmt as i64, 3041); if (r != 0) { return r; }
    let call2: i64 = nk_a(eret);
    r = ck(nk_kind(call2), NK::CallExpr as i64, 3042); if (r != 0) { return r; }
    r = cks(nk_name(call2), string_from_slice("bar"), 3043); if (r != 0) { return r; }
    // first arg: x; second arg: 1
    let a1: i64 = nk_a(call2);
    r = cks(nk_name(a1), string_from_slice("x"), 3044); if (r != 0) { return r; }
    let a2: i64 = nk_next(a1);
    r = ck(nk_kind(a2), NK::IntLit as i64, 3045); if (r != 0) { return r; }
    r = ck(nk_d(a2), 1, 3046); if (r != 0) { return r; }
    r = ck(nk_next(a2), -1, 3047); if (r != 0) { return r; }
    return 0;
}

// ---------------------------------------------------------------------------
// Test 4 — while loop + assignment + unary:
//   fn w(n: i64) -> i64 { while (n > 0) { n = n - 1; } return -n; }
// Verifies: WhileStmt, body has an ExprStmt wrapping an AssignExpr (plain '='),
// and a ReturnStmt wrapping a UnaryExpr(Neg).
// ---------------------------------------------------------------------------
fn test_while_assign_unary() -> i64 {
    let prog: i64 = parse("fn w(n: i64) -> i64 { while (n > 0) { n = n - 1; } return -n; }");
    if (parse_failed() != 0) { return 4001; }
    let mut r: i64 = 0;

    let fn1: i64 = nk_a(prog);
    let body: i64 = nk_c(fn1);
    let ws: i64 = nk_a(body);
    r = ck(nk_kind(ws), NK::WhileStmt as i64, 4010); if (r != 0) { return r; }
    r = ck(nk_d(nk_a(ws)), BinOp::Gt as i64, 4011); if (r != 0) { return r; }

    // body: n = n - 1
    let wbody: i64 = nk_b(ws);
    let es: i64 = nk_a(wbody);
    r = ck(nk_kind(es), NK::ExprStmt as i64, 4020); if (r != 0) { return r; }
    let asgn: i64 = nk_a(es);
    r = ck(nk_kind(asgn), NK::AssignExpr as i64, 4021); if (r != 0) { return r; }
    r = ck(nk_d(asgn), -1, 4022); if (r != 0) { return r; }   // plain '=' (no compound op)
    r = cks(nk_name(nk_a(asgn)), string_from_slice("n"), 4023); if (r != 0) { return r; }
    // value = n - 1
    let val: i64 = nk_b(asgn);
    r = ck(nk_kind(val), NK::BinExpr as i64, 4024); if (r != 0) { return r; }
    r = ck(nk_d(val), BinOp::Sub as i64, 4025); if (r != 0) { return r; }

    // second stmt: return -n (next sibling of the while stmt in the body)
    let s2: i64 = nk_next(ws);
    r = ck(nk_kind(s2), NK::ReturnStmt as i64, 4030); if (r != 0) { return r; }
    let neg: i64 = nk_a(s2);
    r = ck(nk_kind(neg), NK::UnaryExpr as i64, 4031); if (r != 0) { return r; }
    r = ck(nk_d(neg), UnOp::Neg as i64, 4032); if (r != 0) { return r; }
    r = cks(nk_name(nk_a(neg)), string_from_slice("n"), 4033); if (r != 0) { return r; }
    return 0;
}

// ---------------------------------------------------------------------------
// Test 5 — struct declaration + field access + indexing:
//   struct Point { x: i64; y: i64; }
//   fn h(p: Point) -> i64 { return p.x + arr[0]; }
// Verifies: StructDecl "Point" with two fields, then a FnDecl whose return is
// a BinExpr(Add) of a FieldExpr and an IndexExpr.
// (arr is an unresolved ident — the parser doesn't do name resolution, that's
// sema's job. We only check structure.)
// ---------------------------------------------------------------------------
fn test_struct_field_index() -> i64 {
    let prog: i64 = parse("struct Point { x: i64; y: i64; } fn h(p: Point) -> i64 { return p.x + arr[0]; }");
    if (parse_failed() != 0) { return 5001; }
    let mut r: i64 = 0;

    // first decl = StructDecl
    let sd: i64 = nk_a(prog);
    r = ck(nk_kind(sd), NK::StructDecl as i64, 5010); if (r != 0) { return r; }
    r = cks(nk_name(sd), string_from_slice("Point"), 5011); if (r != 0) { return r; }
    // two fields
    let f1: i64 = nk_a(sd);
    r = cks(nk_name(f1), string_from_slice("x"), 5012); if (r != 0) { return r; }
    r = ck(type_prim(nk_a(f1)), Prim::I64 as i64, 5013); if (r != 0) { return r; }
    let f2: i64 = nk_next(f1);
    r = cks(nk_name(f2), string_from_slice("y"), 5014); if (r != 0) { return r; }
    r = ck(nk_next(f2), -1, 5015); if (r != 0) { return r; }   // no third field

    // second decl = FnDecl h
    let fn1: i64 = nk_next(sd);
    r = ck(nk_kind(fn1), NK::FnDecl as i64, 5020); if (r != 0) { return r; }
    r = cks(nk_name(fn1), string_from_slice("h"), 5021); if (r != 0) { return r; }
    // param p: Point (named struct type — prim=Void, name="Point")
    let pp: i64 = nk_a(fn1);
    r = cks(nk_name(pp), string_from_slice("p"), 5022); if (r != 0) { return r; }
    let pty: i64 = nk_a(pp);
    r = ck(type_prim(pty), Prim::Void as i64, 5023); if (r != 0) { return r; }
    r = cks(type_name(pty), string_from_slice("Point"), 5024); if (r != 0) { return r; }

    // body: return p.x + arr[0]
    let body: i64 = nk_c(fn1);
    let ret: i64 = nk_a(body);
    r = ck(nk_kind(ret), NK::ReturnStmt as i64, 5030); if (r != 0) { return r; }
    let add: i64 = nk_a(ret);
    r = ck(nk_kind(add), NK::BinExpr as i64, 5031); if (r != 0) { return r; }
    r = ck(nk_d(add), BinOp::Add as i64, 5032); if (r != 0) { return r; }

    // lhs = p.x (FieldExpr, base=Ident "p", field="x")
    let fe: i64 = nk_a(add);
    r = ck(nk_kind(fe), NK::FieldExpr as i64, 5033); if (r != 0) { return r; }
    r = cks(nk_name(fe), string_from_slice("x"), 5034); if (r != 0) { return r; }
    r = cks(nk_name(nk_a(fe)), string_from_slice("p"), 5035); if (r != 0) { return r; }

    // rhs = arr[0] (IndexExpr, base=Ident "arr", index=IntLit 0)
    let ie: i64 = nk_b(add);
    r = ck(nk_kind(ie), NK::IndexExpr as i64, 5036); if (r != 0) { return r; }
    r = cks(nk_name(nk_a(ie)), string_from_slice("arr"), 5037); if (r != 0) { return r; }
    r = ck(nk_d(nk_b(ie)), 0, 5038); if (r != 0) { return r; }
    return 0;
}

// ---------------------------------------------------------------------------
// Test 6 — multiple decls + bool literals + parenthesized expr:
//   fn a() -> bool { return (1 == 1) && true; }
//   fn b() -> void { }
// Verifies: two fn decls linked via c=next, boolean literals, logical-and, the
// eq operator, a parenthesized sub-expression, and a void return type + empty
// body.
// ---------------------------------------------------------------------------
fn test_bools_parens_multi() -> i64 {
    let prog: i64 = parse("fn a() -> bool { return (1 == 1) && true; } fn b() -> void { }");
    if (parse_failed() != 0) { return 6001; }
    let mut r: i64 = 0;

    let fn1: i64 = nk_a(prog);
    r = cks(nk_name(fn1), string_from_slice("a"), 6010); if (r != 0) { return r; }
    r = ck(type_prim(nk_b(fn1)), Prim::Bool as i64, 6011); if (r != 0) { return r; }

    // return (1 == 1) && true  — the parens are transparent (return the inner expr)
    let body: i64 = nk_c(fn1);
    let ret: i64 = nk_a(body);
    let ande: i64 = nk_a(ret);
    r = ck(nk_kind(ande), NK::BinExpr as i64, 6020); if (r != 0) { return r; }
    r = ck(nk_d(ande), BinOp::LAnd as i64, 6021); if (r != 0) { return r; }
    // lhs = 1 == 1
    let eqe: i64 = nk_a(ande);
    r = ck(nk_d(eqe), BinOp::Eq as i64, 6022); if (r != 0) { return r; }
    r = ck(nk_d(nk_a(eqe)), 1, 6023); if (r != 0) { return r; }
    r = ck(nk_d(nk_b(eqe)), 1, 6024); if (r != 0) { return r; }
    // rhs = true
    let tval: i64 = nk_b(ande);
    r = ck(nk_kind(tval), NK::BoolLit as i64, 6025); if (r != 0) { return r; }
    r = ck(nk_d(tval), 1, 6026); if (r != 0) { return r; }

    // second decl = fn b, void return, empty body
    let fn2: i64 = nk_next(fn1);
    r = cks(nk_name(fn2), string_from_slice("b"), 6030); if (r != 0) { return r; }
    r = ck(type_prim(nk_b(fn2)), Prim::Void as i64, 6031); if (r != 0) { return r; }
    let body2: i64 = nk_c(fn2);
    r = ck(nk_kind(body2), NK::BlockStmt as i64, 6032); if (r != 0) { return r; }
    r = ck(nk_a(body2), -1, 6033); if (r != 0) { return r; }   // empty body (no first stmt)
    r = ck(nk_next(fn2), -1, 6034); if (r != 0) { return r; }     // no third decl
    return 0;
}

// ---------------------------------------------------------------------------
// Test 7 — for loop (C-style) + compound assign + break/continue:
//   fn fl() -> i64 { for (let i: i64 = 0; i < 10; i = i + 1) { if (i == 3) { continue; } if (i == 7) { break; } } return 0; }
// Verifies: ForStmt with init=LetStmt, cond=BinExpr(Lt), step=AssignExpr,
// body block with two IfStmts (continue + break).
// ---------------------------------------------------------------------------
fn test_for_break_continue() -> i64 {
    let prog: i64 = parse("fn fl() -> i64 { for (let i: i64 = 0; i < 10; i = i + 1) { if (i == 3) { continue; } if (i == 7) { break; } } return 0; }");
    if (parse_failed() != 0) { return 7001; }
    let mut r: i64 = 0;

    let fn1: i64 = nk_a(prog);
    let body: i64 = nk_c(fn1);
    let fs: i64 = nk_a(body);
    r = ck(nk_kind(fs), NK::ForStmt as i64, 7010); if (r != 0) { return r; }

    // init = let i: i64 = 0
    let init: i64 = nk_a(fs);
    r = ck(nk_kind(init), NK::LetStmt as i64, 7011); if (r != 0) { return r; }
    r = cks(nk_name(init), string_from_slice("i"), 7012); if (r != 0) { return r; }
    r = ck(nk_d(nk_b(init)), 0, 7013); if (r != 0) { return r; }   // init expr = IntLit 0

    // cond = i < 10
    let cond: i64 = nk_b(fs);
    r = ck(nk_d(cond), BinOp::Lt as i64, 7014); if (r != 0) { return r; }

    // step = i = i + 1
    let step: i64 = nk_c(fs);
    r = ck(nk_kind(step), NK::AssignExpr as i64, 7015); if (r != 0) { return r; }

    // body = block with two if stmts
    let fbody: i64 = nk_e(fs);
    r = ck(nk_kind(fbody), NK::BlockStmt as i64, 7020); if (r != 0) { return r; }
    let if1: i64 = nk_a(fbody);
    r = ck(nk_kind(if1), NK::IfStmt as i64, 7021); if (r != 0) { return r; }
    // then-block of if1: continue
    let if1_body: i64 = nk_b(if1);
    let cont: i64 = nk_a(if1_body);
    r = ck(nk_kind(cont), NK::ContinueStmt as i64, 7022); if (r != 0) { return r; }
    // second if: break
    let if2: i64 = nk_next(if1);
    r = ck(nk_kind(if2), NK::IfStmt as i64, 7023); if (r != 0) { return r; }
    let if2_body: i64 = nk_b(if2);
    let brk: i64 = nk_a(if2_body);
    r = ck(nk_kind(brk), NK::BreakStmt as i64, 7024); if (r != 0) { return r; }
    r = ck(nk_next(if2), -1, 7025); if (r != 0) { return r; }   // no next stmt

    // after the for: return 0 (next sibling of the for stmt in the body)
    let s2: i64 = nk_next(fs);
    r = ck(nk_kind(s2), NK::ReturnStmt as i64, 7030); if (r != 0) { return r; }
    r = ck(nk_d(nk_a(s2)), 0, 7031); if (r != 0) { return r; }
    return 0;
}

// ---------------------------------------------------------------------------
// Test 8 — error recovery: a malformed program must set parse_failed().
//   fn main( -> i64 { }
// (missing ')' after the param list — a structural error.)
// ---------------------------------------------------------------------------
fn test_error() -> i64 {
    let prog: i64 = parse("fn main( -> i64 { }");
    // this MUST fail — the '(' is not closed.
    if (parse_failed() == 0) { return 8001; }
    // and parse() must have returned -1
    if (prog != -1) { return 8002; }
    g_pass = g_pass + 1;
    return 0;
}

// ---------------------------------------------------------------------------
// Test 9 — global + enum + link declarations at top level:
//   global COUNTER: i64 = 0;
//   enum Color { Red, Green = 2, Blue }
//   link "math.em" as math;
// Verifies: GlobalDecl, EnumDecl with three variants (one with explicit
// value), and a LinkDecl.
// ---------------------------------------------------------------------------
fn test_globals_enum_link() -> i64 {
    let prog: i64 = parse("global COUNTER: i64 = 0; enum Color { Red, Green = 2, Blue } link \"math.em\" as math;");
    if (parse_failed() != 0) { return 9001; }
    let mut r: i64 = 0;

    // first decl: global COUNTER: i64 = 0
    let g1: i64 = nk_a(prog);
    r = ck(nk_kind(g1), NK::GlobalDecl as i64, 9010); if (r != 0) { return r; }
    r = cks(nk_name(g1), string_from_slice("COUNTER"), 9011); if (r != 0) { return r; }
    r = ck(type_prim(nk_a(g1)), Prim::I64 as i64, 9012); if (r != 0) { return r; }
    r = ck(nk_d(nk_b(g1)), 0, 9013); if (r != 0) { return r; }   // init = 0
    r = ck(nk_d(g1), 0, 9014); if (r != 0) { return r; }         // not const

    // second decl: enum Color { Red, Green = 2, Blue }
    let ed: i64 = nk_next(g1);
    r = ck(nk_kind(ed), NK::EnumDecl as i64, 9020); if (r != 0) { return r; }
    r = cks(nk_name(ed), string_from_slice("Color"), 9021); if (r != 0) { return r; }
    let v1: i64 = nk_b(ed);
    r = cks(nk_name(v1), string_from_slice("Red"), 9022); if (r != 0) { return r; }
    r = ck(nk_a(v1), -1, 9023); if (r != 0) { return r; }    // no explicit value
    let v2: i64 = nk_next(v1);
    r = cks(nk_name(v2), string_from_slice("Green"), 9024); if (r != 0) { return r; }
    r = ck(nk_d(nk_a(v2)), 2, 9025); if (r != 0) { return r; }  // = 2
    let v3: i64 = nk_next(v2);
    r = cks(nk_name(v3), string_from_slice("Blue"), 9026); if (r != 0) { return r; }
    r = ck(nk_next(v3), -1, 9027); if (r != 0) { return r; }

    // third decl: link "math.em" as math
    let ld: i64 = nk_next(ed);
    r = ck(nk_kind(ld), NK::LinkDecl as i64, 9030); if (r != 0) { return r; }
    r = cks(nk_string_body(ld), string_from_slice("math.em"), 9031); if (r != 0) { return r; }
    r = cks(tok_text_at(nk_a(ld)), string_from_slice("math"), 9032); if (r != 0) { return r; }
    r = ck(nk_next(ld), -1, 9033); if (r != 0) { return r; }   // no fourth decl
    return 0;
}

// ---------------------------------------------------------------------------
// Test 10 — types: slice, fixed array, fn type, and a cast expression:
//   fn t(arr: i64[], buf: i64[16], cb: fn(i64) -> i64) -> i64 { return (x as i32); }
// Verifies: slice type (is_slice), fixed array (array_len=16), fn type with one
// param + ret, and a CastExpr.
// ---------------------------------------------------------------------------
fn test_types_cast() -> i64 {
    let prog: i64 = parse("fn t(arr: i64[], buf: i64[16], cb: fn(i64) -> i64) -> i64 { return (x as i32); }");
    if (parse_failed() != 0) { return 10001; }
    let mut r: i64 = 0;

    let fn1: i64 = nk_a(prog);
    r = cks(nk_name(fn1), string_from_slice("t"), 10010); if (r != 0) { return r; }

    // param 1: arr: i64[]  (slice)
    let p1: i64 = nk_a(fn1);
    r = cks(nk_name(p1), string_from_slice("arr"), 10011); if (r != 0) { return r; }
    let t1: i64 = nk_a(p1);
    r = ck(type_is_slice(t1), 1, 10012); if (r != 0) { return r; }
    r = ck(type_prim(type_elem(t1)), Prim::I64 as i64, 10013); if (r != 0) { return r; }

    // param 2: buf: i64[16]  (fixed array)
    let p2: i64 = nk_next(p1);
    r = cks(nk_name(p2), string_from_slice("buf"), 10014); if (r != 0) { return r; }
    let t2: i64 = nk_a(p2);
    r = ck(type_array_len(t2), 16, 10015); if (r != 0) { return r; }
    r = ck(type_prim(type_elem(t2)), Prim::I64 as i64, 10016); if (r != 0) { return r; }

    // param 3: cb: fn(i64) -> i64  (fn type)
    let p3: i64 = nk_next(p2);
    r = cks(nk_name(p3), string_from_slice("cb"), 10017); if (r != 0) { return r; }
    let t3: i64 = nk_a(p3);
    r = ck(type_prim(t3), Prim::I64 as i64, 10018); if (r != 0) { return r; }   // fn handle = i64
    // one param type (i64) in the recorded sig — stored as first-child in `a`
    let sig_p: i64 = nk_a(t3);
    r = ck(type_prim(sig_p), Prim::I64 as i64, 10019); if (r != 0) { return r; }
    // ret type in `b`
    r = ck(type_prim(type_ret(t3)), Prim::I64 as i64, 10020); if (r != 0) { return r; }
    r = ck(nk_next(p3), -1, 10021); if (r != 0) { return r; }   // no 4th param

    // body: return (x as i32)  — the parens are transparent; result is a CastExpr
    let body: i64 = nk_c(fn1);
    let ret: i64 = nk_a(body);
    let cast: i64 = nk_a(ret);
    r = ck(nk_kind(cast), NK::CastExpr as i64, 10030); if (r != 0) { return r; }
    // operand = Ident "x"
    r = cks(nk_name(nk_a(cast)), string_from_slice("x"), 10031); if (r != 0) { return r; }
    // to type = i32
    r = ck(type_prim(nk_b(cast)), Prim::I32 as i64, 10032); if (r != 0) { return r; }
    return 0;
}

// ---------------------------------------------------------------------------
// Test 11 — switch/case/default:
//   fn sw(x: i64) -> i64 { switch (x) { case 1: { return 10; } case 2: { return 20; } default: { return 0; } } }
// Verifies: SwitchStmt with subject + three cases (two with values, one default).
// ---------------------------------------------------------------------------
fn test_switch() -> i64 {
    let prog: i64 = parse("fn sw(x: i64) -> i64 { switch (x) { case 1: { return 10; } case 2: { return 20; } default: { return 0; } } }");
    if (parse_failed() != 0) { return 11001; }
    let mut r: i64 = 0;

    let fn1: i64 = nk_a(prog);
    let body: i64 = nk_c(fn1);
    let ss: i64 = nk_a(body);
    r = ck(nk_kind(ss), NK::SwitchStmt as i64, 11010); if (r != 0) { return r; }
    // subject = Ident "x"
    r = cks(nk_name(nk_a(ss)), string_from_slice("x"), 11011); if (r != 0) { return r; }

    // first case: case 1
    let c1: i64 = nk_b(ss);
    r = ck(nk_kind(c1), NK::Case as i64, 11020); if (r != 0) { return r; }
    r = ck(nk_d(c1), 0, 11021); if (r != 0) { return r; }       // not default
    r = ck(nk_d(nk_a(c1)), 1, 11022); if (r != 0) { return r; } // value = 1

    // second case: case 2
    let c2: i64 = nk_next(c1);
    r = ck(nk_d(nk_a(c2)), 2, 11023); if (r != 0) { return r; }

    // third case: default
    let c3: i64 = nk_next(c2);
    r = ck(nk_d(c3), 1, 11024); if (r != 0) { return r; }       // is_default
    r = ck(nk_a(c3), -1, 11025); if (r != 0) { return r; }      // no value
    r = ck(nk_next(c3), -1, 11026); if (r != 0) { return r; }      // no next case
    return 0;
}

// ---------------------------------------------------------------------------
// Test 12 — ternary + struct literal + array literal:
//   fn q(f: bool) -> i64 { let p: Point = Point { x: 1, y: 2 }; let a: i64[2] = [10, 20]; return f ? a[0] : a[1]; }
// Verifies: StructLit with two field inits, ArrayLit with two elements, and a
// TernaryExpr.
// ---------------------------------------------------------------------------
fn test_ternary_struct_array_lit() -> i64 {
    let prog: i64 = parse("fn q(f: bool) -> i64 { let p: Point = Point { x: 1, y: 2 }; let a: i64[2] = [10, 20]; return f ? a[0] : a[1]; }");
    if (parse_failed() != 0) { return 12001; }
    let mut r: i64 = 0;

    let fn1: i64 = nk_a(prog);
    let body: i64 = nk_c(fn1);

    // first stmt: let p: Point = Point { x: 1, y: 2 }
    let s1: i64 = nk_a(body);
    r = ck(nk_kind(s1), NK::LetStmt as i64, 12010); if (r != 0) { return r; }
    r = cks(nk_name(s1), string_from_slice("p"), 12011); if (r != 0) { return r; }
    let sl: i64 = nk_b(s1);
    r = ck(nk_kind(sl), NK::StructLit as i64, 12012); if (r != 0) { return r; }
    r = cks(nk_name(sl), string_from_slice("Point"), 12013); if (r != 0) { return r; }
    // two field inits
    let fi1: i64 = nk_a(sl);
    r = cks(nk_name(fi1), string_from_slice("x"), 12014); if (r != 0) { return r; }
    r = ck(nk_d(nk_a(fi1)), 1, 12015); if (r != 0) { return r; }
    let fi2: i64 = nk_next(fi1);
    r = cks(nk_name(fi2), string_from_slice("y"), 12016); if (r != 0) { return r; }
    r = ck(nk_d(nk_a(fi2)), 2, 12017); if (r != 0) { return r; }

    // second stmt: let a: i64[2] = [10, 20]
    let s2: i64 = nk_next(s1);
    r = cks(nk_name(s2), string_from_slice("a"), 12020); if (r != 0) { return r; }
    let al: i64 = nk_b(s2);
    r = ck(nk_kind(al), NK::ArrayLit as i64, 12021); if (r != 0) { return r; }
    let e1: i64 = nk_a(al);
    r = ck(nk_d(e1), 10, 12022); if (r != 0) { return r; }
    let e2: i64 = nk_next(e1);
    r = ck(nk_d(e2), 20, 12023); if (r != 0) { return r; }

    // third stmt: return f ? a[0] : a[1]
    let s3: i64 = nk_next(s2);
    r = ck(nk_kind(s3), NK::ReturnStmt as i64, 12030); if (r != 0) { return r; }
    let tern: i64 = nk_a(s3);
    r = ck(nk_kind(tern), NK::TernaryExpr as i64, 12031); if (r != 0) { return r; }
    // cond = f
    r = cks(nk_name(nk_a(tern)), string_from_slice("f"), 12032); if (r != 0) { return r; }
    // then = a[0]
    let then_e: i64 = nk_b(tern);
    r = ck(nk_kind(then_e), NK::IndexExpr as i64, 12033); if (r != 0) { return r; }
    r = ck(nk_d(nk_b(then_e)), 0, 12034); if (r != 0) { return r; }
    // else = a[1]
    let else_e: i64 = nk_c(tern);
    r = ck(nk_kind(else_e), NK::IndexExpr as i64, 12035); if (r != 0) { return r; }
    r = ck(nk_d(nk_b(else_e)), 1, 12036); if (r != 0) { return r; }
    return 0;
}

// ---------------------------------------------------------------------------
// Test 13 — do-while + defer + yield:
//   fn dw() -> i64 { defer cleanup(); do { yield 1; } while (true); return 0; }
// Verifies: DeferStmt wrapping a CallExpr, DoWhileStmt with a YieldStmt body.
// ---------------------------------------------------------------------------
fn test_do_defer_yield() -> i64 {
    let prog: i64 = parse("fn dw() -> i64 { defer cleanup(); do { yield 1; } while (true); return 0; }");
    if (parse_failed() != 0) { return 13001; }
    let mut r: i64 = 0;

    let fn1: i64 = nk_a(prog);
    let body: i64 = nk_c(fn1);

    // first stmt: defer cleanup()
    let s1: i64 = nk_a(body);
    r = ck(nk_kind(s1), NK::DeferStmt as i64, 13010); if (r != 0) { return r; }
    let call: i64 = nk_a(s1);
    r = ck(nk_kind(call), NK::CallExpr as i64, 13011); if (r != 0) { return r; }
    r = cks(nk_name(call), string_from_slice("cleanup"), 13012); if (r != 0) { return r; }
    r = ck(nk_a(call), -1, 13013); if (r != 0) { return r; }   // no args

    // second stmt: do { yield 1; } while (true);
    let s2: i64 = nk_next(s1);
    r = ck(nk_kind(s2), NK::DoWhileStmt as i64, 13020); if (r != 0) { return r; }
    let dbody: i64 = nk_a(s2);
    let ys: i64 = nk_a(dbody);
    r = ck(nk_kind(ys), NK::YieldStmt as i64, 13021); if (r != 0) { return r; }
    r = ck(nk_d(nk_a(ys)), 1, 13022); if (r != 0) { return r; }   // yield value = 1
    // cond = true
    let dcond: i64 = nk_b(s2);
    r = ck(nk_kind(dcond), NK::BoolLit as i64, 13023); if (r != 0) { return r; }
    r = ck(nk_d(dcond), 1, 13024); if (r != 0) { return r; }

    // third stmt: return 0
    let s3: i64 = nk_next(s2);
    r = ck(nk_kind(s3), NK::ReturnStmt as i64, 13030); if (r != 0) { return r; }
    r = ck(nk_d(nk_a(s3)), 0, 13031); if (r != 0) { return r; }
    return 0;
}

// ---------------------------------------------------------------------------
// Test 14 — match + function handle (&fn):
//   fn mh(x: i64) -> i64 { match (x) { 0 => { return 1; } _ => { return 2; } } return 0; }
//   fn fh() -> fn { let h: fn = &id; return 0; }
// Verifies: MatchStmt with two arms (literal pattern + wildcard), and a
// FnHandleExpr.
// (Two separate programs so each construct is isolated.)
// ---------------------------------------------------------------------------
fn test_match() -> i64 {
    let prog: i64 = parse("fn mh(x: i64) -> i64 { match (x) { 0 => { return 1; } _ => { return 2; } } return 0; }");
    if (parse_failed() != 0) { return 14001; }
    let mut r: i64 = 0;

    let fn1: i64 = nk_a(prog);
    let body: i64 = nk_c(fn1);
    let ms: i64 = nk_a(body);
    r = ck(nk_kind(ms), NK::MatchStmt as i64, 14010); if (r != 0) { return r; }
    r = cks(nk_name(nk_a(ms)), string_from_slice("x"), 14011); if (r != 0) { return r; }

    // first arm: 0 => { return 1; }
    let a1: i64 = nk_b(ms);
    r = ck(nk_kind(a1), NK::MatchArm as i64, 14020); if (r != 0) { return r; }
    r = ck(nk_d(a1), 0, 14021); if (r != 0) { return r; }       // not wildcard
    r = ck(nk_d(nk_a(a1)), 0, 14022); if (r != 0) { return r; } // pattern = 0

    // second arm: _ => { return 2; }
    let a2: i64 = nk_next(a1);
    r = ck(nk_d(a2), 1, 14023); if (r != 0) { return r; }       // is_wildcard
    r = ck(nk_a(a2), -1, 14024); if (r != 0) { return r; }      // no pattern expr
    // body: return 2  (a2b = BlockStmt -> ReturnStmt -> IntLit)
    let a2b: i64 = nk_b(a2);
    r = ck(nk_d(nk_a(nk_a(a2b))), 2, 14025); if (r != 0) { return r; }
    r = ck(nk_next(a2), -1, 14026); if (r != 0) { return r; }      // no next arm
    return 0;
}

fn test_fn_handle() -> i64 {
    let prog: i64 = parse("fn fh() -> fn { let h: fn = &id; return 0; }");
    if (parse_failed() != 0) { return 14101; }
    let mut r: i64 = 0;

    let fn1: i64 = nk_a(prog);
    // ret type = fn (bare fn handle, prim=I64, no recorded sig)
    r = ck(type_prim(nk_b(fn1)), Prim::I64 as i64, 14110); if (r != 0) { return r; }
    let body: i64 = nk_c(fn1);
    let s1: i64 = nk_a(body);
    r = ck(nk_kind(s1), NK::LetStmt as i64, 14111); if (r != 0) { return r; }
    r = cks(nk_name(s1), string_from_slice("h"), 14112); if (r != 0) { return r; }
    // init = &id  (FnHandleExpr)
    let fh: i64 = nk_b(s1);
    r = ck(nk_kind(fh), NK::FnHandleExpr as i64, 14113); if (r != 0) { return r; }
    r = cks(nk_name(fh), string_from_slice("id"), 14114); if (r != 0) { return r; }
    // operand = Ident "id"
    r = cks(nk_name(nk_a(fh)), string_from_slice("id"), 14115); if (r != 0) { return r; }
    r = ck(nk_e(fh), -1, 14116); if (r != 0) { return r; }   // not cross-module
    return 0;
}

fn test_expanded_literals() -> i64 {
    let prog: i64 = parse("fn f() -> f64 { let s: string = f\"value={42}\"; return 1.5; }");
    if (parse_failed() != 0) { return 15001; }
    let fd: i64 = nk_a(prog);
    if (type_prim(nk_b(fd)) != (Prim::F64 as i64)) { return 15002; }
    let first: i64 = nk_a(nk_c(fd));
    if (nk_kind(nk_b(first)) != (NK::StringLit as i64) || nk_d(nk_b(first)) != 1) { return 15003; }
    let ret: i64 = nk_next(first);
    if (nk_kind(nk_a(ret)) != (NK::FloatLit as i64)) { return 15004; }
    return 0;
}

// ---------------------------------------------------------------------------
// main — run every test in order; bail on the first nonzero return.
// ---------------------------------------------------------------------------
fn main() -> i64 {
    let mut r: i64 = 0;

    r = test_canonical();             if (r != 0) { return r; }
    r = test_let_precedence();        if (r != 0) { return r; }
    r = test_if_else_calls();         if (r != 0) { return r; }
    r = test_while_assign_unary();    if (r != 0) { return r; }
    r = test_struct_field_index();    if (r != 0) { return r; }
    r = test_bools_parens_multi();    if (r != 0) { return r; }
    r = test_for_break_continue();    if (r != 0) { return r; }
    r = test_error();                 if (r != 0) { return r; }
    r = test_globals_enum_link();     if (r != 0) { return r; }
    r = test_types_cast();            if (r != 0) { return r; }
    r = test_switch();                if (r != 0) { return r; }
    r = test_ternary_struct_array_lit(); if (r != 0) { return r; }
    r = test_do_defer_yield();        if (r != 0) { return r; }
    r = test_match();                 if (r != 0) { return r; }
    r = test_fn_handle();             if (r != 0) { return r; }
    r = test_expanded_literals();     if (r != 0) { return r; }

    // every check passed
    return 0;
}
